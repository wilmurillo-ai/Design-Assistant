{
  "name": "蓝色简约",
  "description": "干净专业的蓝色主题，适合大多数公众号文章",
  "accent_color": "#2b7df0",
  "templateId": "blue_clean",
  "templateName": "蓝色简约",
  "editableStyles": [
    {"key": "h2-font-size", "type": "fontSize", "group": "一级标题", "label": "字号", "default": "18px"},
    {"key": "h2-color", "type": "color", "group": "一级标题", "label": "字体颜色", "default": "#1a1a1a"},
    {"key": "h2-text-align", "type": "textAlign", "group": "一级标题", "label": "对齐", "default": "center"},
    {"key": "h3-font-size", "type": "fontSize", "group": "二级标题", "label": "字号", "default": "16px"},
    {"key": "h3-color", "type": "color", "group": "二级标题", "label": "字体颜色", "default": "#1a1a1a"},
    {"key": "h3-text-align", "type": "textAlign", "group": "二级标题", "label": "对齐", "default": "left"},
    {"key": "p-font-size", "type": "fontSize", "group": "正文", "label": "字号", "default": "15px"},
    {"key": "p-color", "type": "color", "group": "正文", "label": "字体颜色", "default": "#3a3a3a"},
    {"key": "p-text-align", "type": "textAlign", "group": "正文", "label": "对齐", "default": "justify"},
    {"key": "blockquote-font-size", "type": "fontSize", "group": "引用", "label": "字号", "default": "15px"},
    {"key": "blockquote-color", "type": "color", "group": "引用", "label": "字体颜色", "default": "#666666"},
    {"key": "blockquote-text-align", "type": "textAlign", "group": "引用", "label": "对齐", "default": "left"}
  ],
  "fragments": {
    "body_wrapper": "<section style=\"max-width:680px;margin:0 auto;padding:20px 0;background:#fff;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Helvetica Neue','PingFang SC','Microsoft YaHei',sans-serif;\">",
    "body_wrapper_end": "</section>",
    "header_image": "",
    "top_decoration": "<section style=\"width:32px;height:4px;background-color:#2b7df0;border-radius:2px;margin:24px 20px 16px;\"></section>",
    "hero": "<section style=\"margin:0 20px 24px;padding:24px 20px;background-color:#f5f5f5;border-radius:4px;\"><p style=\"font-size:15px;color:#3a3a3a;line-height:1.9;text-align:justify;margin:0;\">{TEXT}</p></section>",
    "blockquote": "<section style=\"margin:16px 20px;padding:14px 16px;border-radius:6px;background-color:#f9f9f9;border-left:3px solid #ddd;\"><p style=\"font-size:15px;color:#666666;line-height:1.8;font-style:italic;text-align:left;margin:0;\">{TEXT}</p></section>",
    "section_title": "<section style=\"text-align:center;margin:28px 20px 18px;\"><section style=\"display:inline-block;position:relative;padding:8px 16px 8px 8px;background-color:#f4f4f5;border-radius:12px;\"><span style=\"display:inline-block;min-width:36px;height:32px;padding:0 10px;border-radius:8px;background-color:#2b7df0;color:#ffffff;font-size:14px;font-weight:700;line-height:32px;text-align:center;vertical-align:middle;\">{NUM}</span><span style=\"font-size:18px;font-weight:700;color:#1a1a1a;letter-spacing:0.5px;vertical-align:middle;margin-left:10px;\">{TEXT}</span><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#2b7df0\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"position:absolute;right:-14px;top:-10px;width:20px;height:20px;\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/></svg></section></section>",
    "highlight": "<section style=\"display:flex;align-items:center;margin:24px 20px 14px;gap:10px;\"><section style=\"display:flex;align-items:center;flex-shrink:0;\"><span style=\"display:inline-block;width:9px;height:9px;border-radius:50%;background-color:#1a1a1a;\"></span><span style=\"display:inline-block;width:9px;height:9px;border-radius:50%;background-color:#ffffff;border:1px solid #1a1a1a;margin-left:-4px;\"></span></section><span style=\"font-size:16px;font-weight:700;color:#1a1a1a;letter-spacing:0.3px;\">{TEXT}</span></section>",
    "paragraph": "<section style=\"padding:0 20px;\"><p style=\"font-size:15px;color:#3a3a3a;line-height:1.85;margin-bottom:16px;text-align:justify;\">{TEXT}</p></section>",
    "list_ordered": "<ol style=\"padding:0 20px 0 44px;margin-bottom:16px;\">{ITEMS}</ol>",
    "list_unordered": "<ul style=\"padding:0 20px 0 44px;margin-bottom:16px;\">{ITEMS}</ul>",
    "list_item": "<li style=\"font-size:15px;color:#3a3a3a;line-height:1.85;margin-bottom:6px;\">{TEXT}</li>",
    "image": "<section style=\"padding:0 20px;margin-bottom:16px;text-align:center;\"><img src=\"{SRC}\" alt=\"{ALT}\" style=\"max-width:100%;border-radius:4px;\" /></section>",
    "image_placeholder": "<section style=\"padding:0 20px;margin-bottom:16px;text-align:center;\"><img src=\"{SRC}\" alt=\"{ALT}\" style=\"max-width:100%;border-radius:4px;\" /><p style=\"font-size:13px;color:#999;margin:8px 0 0 0;\">{ALT}</p></section>"
  }
}
