// ============================================================================
// OpenClaw Agent Configuration: Observer Agent Template (HTTP Mode)
// ============================================================================
//
// Observer agents review Player Agent actions to ensure persona compliance.
// They use cyber_jianghu_review tool to approve/reject intents.
//
// Architecture:
//   Player Agent submits intent -> Observer Agent reviews via HTTP API
//
// Review Workflow:
//   1. Observer polls for pending reviews (cron: */10 * * * * *)
//   2. For each pending intent, Observer decides: approve or reject
//   3. Observer submits decision with reason and optional narrative
// ============================================================================

{
  // Agent 基本信息
  name: "{AGENT_NAME}",
  description: "Observer Agent - reviews player intents for persona compliance",

  // 工作区配置
  agents: {
    defaults: {
      workspace: "~/.openclaw/cyber-jianghu-openclaw-agents/{AGENT_NAME}",

      // Observer 使用 cyber-jianghu-openclaw skill（包含 cyber_jianghu_review 工具）
      skills: ["cyber-jianghu-openclaw"],

      cron: [
        {
          name: "review-pending-intents",
          expression: "*/10 * * * * *",  // 每 10 秒检查一次待审查意图
          prompt: `检查并审查待处理的玩家意图。

**CRITICAL**: 你必须使用 cyber_jianghu_review 工具来审查玩家的动作意图。

审查流程:
1. 调用 getPendingReviews() 获取待审查列表
2. 对每个意图，根据武侠世界观和人设要求判断是否符合
3. 调用 submitReview() 提交审查决定

审查标准:
- 动作是否符合武侠世界观
- 行为是否符合人设描述
- 是否有违反江湖道义的情况

如果没有待审查意图，可以跳过本次决策。`,
          session: "main",
          enabled: true
        }
      ],

      heartbeat: {
        every: "0m",
        enabled: false
      },

      model: "claude/claude-sonnet-4-20250514",
      timeoutSeconds: 60,  // Observer 可以有更长超时
    }
  },

  // Hook 配置 - 使用现有的 bootstrap hook
  hooks: {
    "agent:bootstrap": "hooks/cyber-jianghu-openclaw-bootstrap"
  },

  // 工具配置 - Observer 使用 cyber_jianghu_review 而不是 cyber_jianghu_act
  tools: {
    required: ["cyber_jianghu_review"],
    allow: ["cyber_jianghu_review", "read", "write"],
    deny: ["cyber_jianghu_act", "exec", "system"]
  },

  // 沙箱配置 - Observer 默认启用沙箱
  sandbox: {
    enabled: true,
    workspaceRoot: "~/.openclaw/sandboxes",
    privilegeMode: "restricted"
  }
}
