{
  "openapi": "3.1.0",
  "info": {
    "title": "OTPLY API",
    "description": "Email OTP Service - Simple, Fast, Reliable",
    "version": "1.0.0"
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Root",
        "description": "API root endpoint",
        "operationId": "root__get",
        "responses": {
