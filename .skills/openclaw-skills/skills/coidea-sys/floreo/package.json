{
  "name": "floreo",
  "version": "0.2.0",
  "description": "Life flourishing system with privacy tiers and export screening",
  "main": "SKILL.md",
  "keywords": [
    "openclaw-skill",
    "productivity",
    "tracking",
    "privacy",
    "journal",
    "life-logging",
    "wellness"
  ],
  "author": "OpenClaw",
  "license": "MIT",
  "homepage": "https://github.com/openclaw/floreo",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/floreo.git"
  },
  "bugs": {
    "url": "https://github.com/openclaw/floreo/issues"
  },
  "engines": {
    "openclaw": ">=0.5.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "icon": "🌸",
  "categories": [
    "productivity",
    "utilities"
  ],
  "commands": [
    {
      "name": "work",
      "description": "Track professional work",
      "example": "/floreo work 'Shipped v0.6.8' --metric commits=5"
    },
    {
      "name": "health",
      "description": "Track health and fitness",
      "example": "/floreo health 'Ran 5k' --metric energy=8 --privacy private"
    },
    {
      "name": "learn",
      "description": "Track learning and growth",
      "example": "/floreo learn 'Read Rust book' --privacy public"
    },
    {
      "name": "privacy",
      "description": "Manage privacy settings and export screening",
      "example": "/floreo privacy --report"
    },
    {
      "name": "export",
      "description": "Export entries with privacy screening",
      "example": "/floreo export --domain work --ruleset client-safe"
    },
    {
      "name": "fork",
      "description": "Cross-system export to external platforms",
      "example": "/floreo fork work --to notion --ruleset team-sync"
    }
  ]
}