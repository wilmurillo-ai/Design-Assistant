{
  "name": "literature-report",
  "version": "1.0.4",
  "description": "自动科研文献汇报系统，每天自动检索顶级期刊最新论文，AI辅助筛选，生成双语摘要，推送到飞书",
  "keywords": [
    "literature",
    "research",
    "papers",
    "AI",
    "automation",
    "RSS",
    "PubMed"
  ],
  "author": "ClawHub Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawhub-community/literature-report"
  },
  "credentials": {
    "required": [
      {
        "name": "LLM_API_KEY",
        "description": "LLM API Key for semantic understanding and content generation",
        "how_to_get": "https://platform.openai.com or https://cloud.siliconflow.cn",
        "stored_in": "config.yaml (api.api_key)"
      }
    ],
    "optional": [
      {
        "name": "FEISHU_USER_ID",
        "description": "Feishu user ID for push notifications",
        "how_to_get": "Open Feishu profile, view 'User ID'",
        "stored_in": "config.yaml (feishu.target)"
      }
    ]
  },
  "python": {
    "dependencies": [
      "feedparser>=6.0.0",
      "requests>=2.25.0",
      "pyyaml>=5.4.0",
      "markdown>=3.3.0",
      "weasyprint>=52.0"
    ]
  },
  "files": [
    "SKILL.md",
    "README.md",
    "GUIDE.md",
    "install.sh",
    "config.yaml.example",
    "scripts/*.py"
  ]
}