{
  "name": "shuttle-qc-ai-chatbot",
  "version": "2.1.0",
  "description": "Shuttle QC AI Chatbot 聊天機器人操作技能 - 自動化輸入查詢、等待回應、批次執行",
  "main": "index.js",
  "bin": {
    "shuttle-qc-ai-chatbot": "./index.js"
  },
  "keywords": [
    "openclaw",
    "skill",
    "shuttle",
    "qc",
    "ai",
    "chatbot",
    "automation"
  ],
  "author": "Shuttle AI",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "skill": {
    "id": "shuttle-qc-ai-chatbot",
    "name": "Shuttle QC AI Chatbot",
    "description": "自動化查詢 Shuttle 產品規格，使用瀏覽器操作內部 QC AI 客服系統。支援單次查詢、批次執行、產品比較（如 DL30N vs DL40N）",
    "tags": ["qc", "shuttle", "product", "spec", "automation", "comparison"],
    "inputs": [
      {
        "name": "query",
        "type": "string",
        "description": "查詢文字（如產品型號、比較指令）"
      },
      {
        "name": "batch",
        "type": "file",
        "description": "批次查詢檔案（每行一筆）"
      },
      {
        "name": "url",
        "type": "string",
        "description": "目標網頁 URL",
        "default": "http://192.168.100.98:8888/v1"
      }
    ],
    "outputs": [
      {
        "name": "response",
        "type": "string",
        "description": "AI 回應內容"
      },
      {
        "name": "elapsed",
        "type": "string",
        "description": "耗時（秒）"
      },
      {
        "name": "timestamp",
        "type": "string",
        "description": "時間戳"
      }
    ],
    "commands": [
      "query",
      "batch"
    ],
    "options": {
      "timeout": {
        "type": "number",
        "default": 30,
        "description": "等待回應超時秒數"
      },
      "output": {
        "type": "string",
        "default": "json",
        "enum": ["json", "text"],
        "description": "輸出格式"
      }
    }
  }
}