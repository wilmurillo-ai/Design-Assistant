{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["index.ts", "cli.ts", "src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "src/qmd"]
}
