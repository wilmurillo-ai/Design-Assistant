{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/signal.schema.json",
  "title": "Weekly User Signal",
  "type": "object",
  "required": [
    "title",
    "description",
    "evidence",
    "confidence",
    "confidence_reason",
    "recommended_experiment",
    "tags",
    "impacted_stage",
    "change_over_time"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 5
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "participant_code",
          "timestamp",
          "snippet"
        ],
        "properties": {
          "participant_code": {
            "type": "string",
            "pattern": "^P[0-9]{1,4}$"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "snippet": {
            "type": "string",
            "minLength": 5
          },
          "source": {
            "type": "string",
            "enum": [
              "diary",
              "debrief",
              "mixed"
            ],
            "default": "diary"
          },
          "entry_id": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "confidence": {
      "type": "string",
      "enum": [
        "Low",
        "Med",
        "High"
      ]
    },
    "confidence_reason": {
      "type": "string",
      "minLength": 10
    },
    "recommended_experiment": {
      "type": "object",
      "required": [
        "hypothesis",
        "method",
        "primary_metric",
        "decision_rule",
        "owner",
        "timebox"
      ],
      "properties": {
        "hypothesis": {
          "type": "string",
          "minLength": 10
        },
        "method": {
          "type": "string",
          "minLength": 10
        },
        "primary_metric": {
          "type": "string",
          "minLength": 3
        },
        "decision_rule": {
          "type": "string",
          "minLength": 5
        },
        "owner": {
          "type": "string",
          "minLength": 2
        },
        "timebox": {
          "type": "string",
          "minLength": 2
        }
      },
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "impacted_stage": {
      "type": "string",
      "minLength": 2
    },
    "change_over_time": {
      "type": "string",
      "minLength": 5
    }
  },
  "additionalProperties": false
}
