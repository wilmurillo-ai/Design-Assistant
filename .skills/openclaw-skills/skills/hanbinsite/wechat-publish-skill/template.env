# 微信公众号配置模板
# 复制此文件为 .env 并填写实际值

# 微信公众号 AppID
WECHAT_APP_ID=

# 微信公众号 AppSecret
WECHAT_APP_SECRET=

# 公众号名称（用于作者署名）
WECHAT_ACCOUNT_NAME=

# AI 图片生成配置
# API 基础地址（默认 OpenAI）
AI_IMAGE_BASE_URL=https://api.openai.com/v1

# API 密钥
AI_IMAGE_API_KEY=

# 模型名称（如 dall-e-3, dall-e-2 等）
AI_IMAGE_MODEL=dall-e-3
