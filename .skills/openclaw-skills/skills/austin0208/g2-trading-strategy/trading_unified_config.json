    },
    "决策简化": "每次交易前问：这次会踩到伤疤吗？"
  },
  "core_principles": [
    {
      "序号": 1,
      "原则": "只买低位+放量",
      "说明": "高位放量=主力出货，远离"
    },
    {
      "序号": 2,
      "原则": "严格止损",
      "说明": "触及-2%直接卖，不问"
    },
    {
      "序号": 3,
      "原则": "尾盘买入",
      "说明": "14:30-15:00"
    },
    {
      "序号": 4,
      "原则": "收盘价判断",
      "说明": "止损止盈都用收盘价，不用盘中触及"
    },
    {
      "序号": 5,
      "原则": "分散持仓",
      "说明": "最多3只，单只≤25%"
    },
    {
      "序号": 6,
      "原则": "执行合一",
      "说明": "触及条件立即执行，不犹豫"
    },
    {
      "序号": 7,
      "原则": "量能背离监控",
