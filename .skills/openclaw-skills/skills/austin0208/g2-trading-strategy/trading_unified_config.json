    },
    {
      "序号": 8,
      "原则": "伤疤决策",
      "说明": "每次决策问会踩伤疤吗"
    },
    {
      "序号": 9,
      "原则": "只做大概率",
      "说明": "不确定性高时放弃"
    }
  ],
  "position_management": {
    "max_positions": 3,
    "single_position_pct": 25
  },
  "trading_rules": {
    "stop_loss_pct": 2.0,
