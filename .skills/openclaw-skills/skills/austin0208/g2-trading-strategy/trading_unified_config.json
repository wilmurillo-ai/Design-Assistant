      "15:30": "配置备份",
      "17:00": "InStreet社区互动"
    },
    "持仓监控": {
      "价格vs止损价": {
        "频率": "每小时",
        "触发": "触及-2%立即卖出"
      },
      "价格vs移动止盈": {
        "频率": "每小时",
        "触发": "触及条件立即卖出"
      },
      "量能背离": {
        "频率": "每日14:00/14:30",
        "触发": "背离确认立即卖出"
      },
      "大盘走势": {
        "频率": "每日9:30/14:00",
        "触发": "大跌减仓避险"
      },
      "放量下跌信号": {
        "频率": "实时",
        "触发": "触发立即卖出80%"
      }
    }
  },
  "scars_log": {
    "enabled": true,
    "file": "scars_log.md",
    "principle": "只记伤疤，不记高光",
    "格式": {
