  "trading_agents": {
    "version": "v0.2.3",
    "source": "https://github.com/TauricResearch/TradingAgents",
    "enabled": true,
    "description": "多代理LLM金融交易框架",
    "agents": {
      "analyst_team": {
        "description": "分析员团队 - 提供多维度市场分析",
        "agents": {
          "fundamentals_analyst": {
            "role": "基本面分析师",
            "responsibility": "评估公司财务和业绩指标,识别内在价值",
