{
  "version": "v6.0-g2-optimal",
  "updated": "2026-04-05",
  "description": "G2最优策略 - v5.2评分+量比>1.2硬过滤 (21组策略回测验证)",
  "__回测结果__": "收益+26.7%, 年化+21.2%, 夏普1.12, 回撤15.2%, 跑赢大盘+23.6%",
  "__origin__": "2025-01-03~2026-04-03 301天回测, 300只沪深300成分股, 21组策略对比",
  "__core_change__": "在v5.2基础上加入量比>=1.2作为入场硬过滤条件 (原版已有vol_ratio_min但非硬过滤)",
  "__architecture__": "v5.2量化初筛 + TradingAgents多代理深度分析 + 统一风险管理",
  "__workflow__": "1.v5初筛 → 2.多代理分析(Fundamentals/Sentiment/News/Technical) → 3.多空辩论(Bull/Bear Research) → 4.交易决策(Trader) → 5.风险审批(Risk Manager) → 6.执行(Portfolio Manager)",
  "core_principle": "止损纪律比选股能力重要十倍",
  "core_concept": "只做大概率正确的事，让决策简单化",
  "data_source": {
    "primary": "tencent",
    "backup": "tencent",
    "fallback": "tencent",
    "description": "主:腾讯 | 备用:腾讯 | 兜底:腾讯"
  },
  "score_system": {
    "position": {
      "权重": 0.12,
      "核心逻辑": "低位=安全边际",
      "评分规则": "距60日均线<20%→+20分, <30%→+15分, <40%→+10分"
    },
    "volume": {
      "权重": 0.15,
      "核心逻辑": "放量=资金入场",
      "评分规则": "量比>1.5→+15分, >1.2→+10分, 放量→+5分"
    },
    "trend": {
      "权重": 0.1,
      "核心逻辑": "短期动能",
      "评分规则": "MACD金叉+KDJ金叉→+15分, 单一金叉→+8分"
    },
    "chips": {
      "权重": 0.1,
      "核心逻辑": "底部缩量=主力建仓",
      "评分规则": "底部缩量+低位→+15分, 低位→+8分"
    },
    "performance": {
      "权重": 0.12,
      "核心逻辑": "基本面支撑",
      "评分规则": "净利>30%→+5分, >10%→+4分, >0%→+2分"
    },
    "ma_trend": {
      "权重": 0.08,
      "核心逻辑": "MA5>MA20>MA60",
      "评分规则": "MA5>MA20→+8分, MA20>MA60→+5分, 价格>MA20→+2分"
    },
    "turnover": {
      "权重": 0.08,
      "核心逻辑": "活跃度",
      "评分规则": "4%~12%→+10分, 其他→+5分"
    },
    "sentiment": {
      "权重": 0.05,
      "核心逻辑": "市场情绪",
      "评分规则": "涨跌幅2%~6%→+5分, 量价配合→+3分"
    },
    "rebound": {
      "权重": 0.2,
      "核心逻辑": "超跌反弹",
      "评分规则": "近21日跌幅>30%→+20分, >25%→+15分 | 近7日缩量→+15分 | 连续缩量7天→+20分 | 距60日均线<-30%→+10分"
    }
  },
  "filter_criteria": {
    "min_score": 40,
    "min_upside": 8,
    "max_position_pct": 65,
    "min_pe": 0,
    "turnover_rate_min": 4,
    "turnover_rate_max": 12,
    "vol_ratio_min": 1.2,
    "change_pct_min": 2,
    "change_pct_max": 6,
    "price_above_ma5": true,
    "use_10am_vol_ratio": true
  },
  "entry_filters": {
    "__说明__": "G2最优策略：加入量比硬过滤",
    "vol_ratio_hard_filter": true,
    "vol_ratio_min": 1.2,
    "recent_drop_filter": false,
    "recent_drop_limit": 15,
    "__效果__": "回测收益+26.7% (vs 原版16.6%), 夏普1.12"
  },
  "tradingagents": {
    "enabled": true,
    "__说明__": "多代理系统开关，设为true启用完整多代理流程",
    "llm_provider": "openai",
    "deep_think_llm": "gpt-4.5",
    "quick_think_llm": "gpt-4.5-mini",
    "max_debate_rounds": 2,
    "analysis_depth": "balanced",
    "v5_weight": 0.6,
    "llm_weight": 0.4,
    "v5_threshold": 40,
    "agents": {
      "fundamentals": {
        "enabled": true,
        "描述": "基本面分析师-财务/估值/成长"
      },
      "technical": {
        "enabled": true,
        "描述": "技术面分析师-均线/MACD/KDJ/量能"
      },
      "sentiment": {
        "enabled": true,
        "描述": "情绪分析师-换手率/涨跌幅/资金流向"
      },
      "news": {
        "enabled": true,
        "描述": "新闻分析师-公告/政策/热点"
      },
      "researchers": {
        "enabled": true,
        "描述": "研究团队-多空辩论"
      },
      "trader": {
        "enabled": true,
        "描述": "交易员-综合决策"
      },
      "risk_mgmt": {
        "enabled": true,
        "描述": "风险管理-仓位/止损/审批"
      }
    }
  },
  "take_profit_rules": {
    "优先级1": {
      "条件": "盈利>=25%",
      "操作": "全部止盈",
      "说明": "落袋为安"
    },
    "优先级2": {
      "条件": "盈利>=20% + 收盘价高点回落5%",
      "操作": "全部止盈",
      "说明": "移动止盈，用收盘价高点"
    },
    "优先级3": {
      "条件": "盈利>=15% + 回落8%",
      "操作": "止盈50%",
      "说明": "部分止盈"
    },
    "关键细节": {
      "高点定义": "用日K收盘价高点或收盘价高点，不用日内分时高点",
      "回落计算": "从收盘价高点计算回落百分比",
      "目的": "避免盘中假突破触发移动止盈"
    }
  },
  "stop_loss_rules": {
    "优先级1": {
      "条件": "亏损>=2%",
      "操作": "立即卖出",
      "说明": "固定止损，直接执行，不犹豫"
    },
    "优先级2": {
      "条件": "收盘价跌破MA20",
      "操作": "卖出80%",
      "说明": "假突破过滤，用收盘价判断"
    },
    "优先级3": {
      "条件": "放量下跌信号",
      "操作": "卖出80%",
      "说明": "量比>2.5 且 跌幅>大盘1.5倍"
    },
    "优先级4": {
      "条件": "业绩变脸/利空",
      "操作": "立即清仓",
      "说明": "不等跌破"
    },
    "放量下跌判断": {
      "量比": ">2.5",
      "跌幅条件": "个股跌幅 > 大盘跌幅 × 1.5",
      "区分": "主动放量（真跌）vs 被动放量（跟跌）"
    }
  },
  "volume_divergence": {
    "enabled": true,
    "顶背离": {
      "特征": "股价连续创新高（3天内2次以上）+ 成交量连续缩量",
      "周期信号": "30分钟+日线同时背离 = 强信号"
    },
    "底背离": {
      "特征": "股价下跌，但成交量放大",
      "危险": "放量下跌 = 主力出货"
    },
    "持续确认": {
      "第1天背离": {
        "风险等级": "警惕",
        "操作": "关注"
      },
      "第2天背离": {
        "风险等级": "确认",
        "操作": "准备卖出"
      },
      "第3天背离": {
        "风险等级": "高概率反转",
        "操作": "立即卖出"
      }
    }
  },
  "market_monitor": {
    "时间节点": {
      "9:00": "盘前新闻、政策面检查",
      "9:30": "开盘情况，大盘量能",
