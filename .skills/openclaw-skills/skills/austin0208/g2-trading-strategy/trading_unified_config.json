        "description": "研究员团队 - 多空辩论平衡风险收益",
        "agents": {
          "bullish_researcher": {
            "role": "多头研究员",
            "responsibility": "积极评估,发现潜在上涨机会",
            "focus": "寻找买入理由,上行空间,催化剂"
          },
          "bearish_researcher": {
            "role": "空头研究员",
            "responsibility": "审慎评估,识别潜在风险和陷阱",
            "focus": "寻找卖出理由,下行风险,警示信号"
          }
        },
        "debate_rounds": 2,
        "synthesize_insights": true
      },
      "trader": {
        "role": "交易员",
