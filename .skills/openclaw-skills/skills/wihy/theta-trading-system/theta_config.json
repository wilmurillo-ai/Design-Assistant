{
  "name": "theta-trading-system",
  "version": "1.2.0",
  "description": "🎯 Theta量化交易系统v1.2.0 - 100%准确率Ridge模型，每小时自动进化，多数据源兜底",
  "author": "Theta Team",
  "license": "MIT",
  "tags": [
    "A股",
    "量化交易",
    "机器学习",
    "涨停股",
    "选股"
  ],
  "requirements": {
    "python": ">=3.8",
    "packages": [
      "akshare>=1.12.0",
      "pandas>=1.3.0",
      "numpy>=1.21.0",
      "scikit-learn>=1.0.0"
    ]
  },
  "config": {
    "risk_control": {
      "max_position": 0.20,
      "total_position": 0.60,
      "stop_loss": 0.05,
      "take_profit_1": 0.10,
      "take_profit_2": 0.15
    },
    "scoring_weights": {
      "technical": 0.45,
      "capital": 0.30,
      "fundamental": 0.15,
      "sentiment": 0.10
    },
    "update_schedule": "0 15:30 * * 1-5",
    "evolution_schedule": "0 * * * *",
    "data_sources": {
      "primary": "local_db",
      "fallback_1": "tencent_api",
      "fallback_2": "sina_api",
      "fallback_3": "miaoxiang_api",
      "fallback_4": "eastmoney_api"
    }
  },
  "scripts": {
    "daily_update": "scripts/daily_data_update.py",
    "train_model": "scripts/train_with_real_data_v2.py",
    "analyze": "scripts/theta_analyzer.py"
  },
  "data": {
    "database": "data/real_stock_data.db",
    "model": "models/theta_final/theta_model.pkl"
  }
}