{
  "name": "Unlock PDF",
  "description": "Remove password protection from encrypted PDFs via the PDFAPIHub cloud API. Your PDF and password are sent to pdfapihub.com for decryption.",
  "method": "POST",
  "endpoint": "/v1/unlockPdf",
  "base_url": "https://pdfapihub.com/api",
  "auth": { "type": "apiKey", "header": "CLIENT-API-KEY", "required": true },
  "parameters": {
    "body": {
      "content_type": "application/json",
      "fields": [
        { "name": "url", "type": "string", "required": false, "description": "URL to the encrypted PDF" },
        { "name": "base64_pdf", "type": "string", "required": false, "description": "Base64-encoded encrypted PDF" },
        { "name": "password", "type": "string", "required": true, "description": "Password to unlock the PDF" },
        { "name": "output", "type": "string", "required": false, "default": "file", "enum": ["file", "url", "base64"], "description": "Output mode" },
        { "name": "output_name", "type": "string", "required": false, "description": "Custom output filename" }
      ],
      "also_accepts": "multipart/form-data with 'file' field"
    }
  }
}
