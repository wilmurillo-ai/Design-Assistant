{
  "name": "Document to PDF",
  "description": "Convert office documents (DOCX, DOC, PPT, PPTX, XLS, XLSX, CSV, TXT, ODT, RTF) to PDF via the PDFAPIHub cloud API. Documents are uploaded to pdfapihub.com for conversion.",
  "method": "POST",
  "endpoint": "/v1/convert/docx/pdf",
  "base_url": "https://pdfapihub.com/api",
  "auth": { "type": "apiKey", "header": "CLIENT-API-KEY", "required": true },
  "parameters": {
    "body": {
      "content_type": "application/json",
      "fields": [
        { "name": "url", "type": "string", "required": false, "description": "Public URL to the document" },
        { "name": "file", "type": "string", "required": false, "description": "Base64-encoded document" },
        { "name": "input_format", "type": "string", "required": false, "enum": ["doc", "docx", "odt", "rtf", "txt", "ppt", "pptx", "odp", "xls", "xlsx", "ods", "csv"], "description": "Input format (required for base64)" },
        { "name": "output", "type": "string", "required": false, "default": "url", "enum": ["url", "base64", "both", "file"], "description": "Output mode" },
        { "name": "output_filename", "type": "string", "required": false, "description": "Custom output filename" }
      ],
      "also_accepts": "multipart/form-data with 'file' field",
      "aliases": ["/v1/convert/document/pdf"]
    }
  }
}
