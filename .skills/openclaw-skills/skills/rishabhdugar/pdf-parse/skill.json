{
  "name": "PDF Parse",
  "description": "Parse a PDF into structured JSON: text, layout-aware blocks with bounding boxes, tables, and image metadata.",
  "method": "POST",
  "endpoint": "/v1/pdf/parse",
  "base_url": "https://pdfapihub.com/api",
  "auth": { "type": "apiKey", "header": "CLIENT-API-KEY", "required": true },
  "parameters": {
    "body": {
      "content_type": "application/json",
      "fields": [
        { "name": "url", "type": "string", "required": false, "description": "Public URL to a PDF" },
        { "name": "mode", "type": "string", "required": false, "default": "full", "enum": ["text", "layout", "tables", "full"], "description": "Parsing mode" },
        { "name": "pages", "type": "string", "required": false, "default": "all", "description": "Page selection (e.g. '1-3', 'all')" }
      ],
      "also_accepts": "multipart/form-data with 'file' field"
    }
  }
}
