{
  "request": {
    "method": "POST",
    "url": "https://pdfapihub.com/api/v1/convert/pdf/txt",
    "headers": { "CLIENT-API-KEY": "your_api_key", "Content-Type": "application/json" },
    "body": { "url": "https://pdfapihub.com/sample-pdfapi-intro.pdf", "pages": "1-3", "output": "file", "output_filename": "chapter1.txt" }
  },
  "response": {
    "status": 200,
    "body": { "success": true, "input_format": "pdf", "output_format": "txt", "file_size_bytes": 8192, "txt_url": "https://cdn.pdfapihub.com/txt/converted.txt" }
  }
}
