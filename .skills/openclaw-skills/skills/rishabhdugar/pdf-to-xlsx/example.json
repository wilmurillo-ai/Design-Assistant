{
  "request": {
    "method": "POST",
    "url": "https://pdfapihub.com/api/v1/convert/pdf/xlsx",
    "headers": { "CLIENT-API-KEY": "your_api_key", "Content-Type": "application/json" },
    "body": { "url": "https://pdfapihub.com/sample-pdfinvoice-with-image.pdf", "pages": "2-4", "output": "url" }
