{"metadata": {"version": "1.0", "description": "Cadence Virtuoso Skill API 权威数据库", "last_updated": "2026-03-13", "total_functions": 312}, "categories": {"基础函数": {"car": {"name": "car", "description": "返回列表的第一个元素", "syntax": "(car list)", "parameters": [{"name": "list", "type": "list", "required": true, "description": "输入列表"}], "return_type": "any", "example": "(car '(1 2 3)) ; 返回 1", "notes": "如果列表为空，返回nil"}, "cdr": {"name": "cdr", "description": "返回列表除第一个元素外的部分", "syntax": "(cdr list)", "parameters": [{"name": "list", "type": "list", "required": true, "description": "输入列表"}], "return_type": "list", "example": "(cdr '(1 2 3)) ; 返回 (2 3)", "notes": "如果列表为空，返回nil"}, "cons": {"name": "cons", "description": "将元素添加到列表头部", "syntax": "(cons element list)", "parameters": [{"name": "element", "type": "any", "required": true, "description": "要添加的元素"}, {"name": "list", "type": "list", "required": true, "description": "目标列表"}], "return_type": "list", "example": "(cons 0 '(1 2 3)) ; 返回 (0 1 2 3)", "notes": ""}, "append": {"name": "append", "description": "连接多个列表", "syntax": "(append list1 list2 ...)", "parameters": [{"name": "list1, list2, ...", "type": "list", "required": true, "description": "要连接的列表"}], "return_type": "list", "example": "(append '(1 2) '(3 4)) ; 返回 (1 2 3 4)", "notes": ""}, "length": {"name": "length", "description": "返回列表的长度", "syntax": "(length list)", "parameters": [{"name": "list", "type": "list", "required": true, "description": "输入列表"}], "return_type": "integer", "example": "(length '(1 2 3)) ; 返回 3", "notes": ""}, "nth": {"name": "nth", "description": "返回列表中第n个元素（从0开始计数）", "syntax": "(nth n list)", "parameters": [{"name": "n", "type": "integer", "required": true, "description": "索引位置，从0开始"}, {"name": "list", "type": "list", "required": true, "description": "输入列表"}], "return_type": "any", "example": "(nth 1 '(1 2 3)) ; 返回 2", "notes": "如果n超出列表长度，返回nil"}, "member": {"name": "member", "description": "检查元素是否在列表中", "syntax": "(member element list)", "parameters": [{"name": "element", "type": "any", "required": true, "description": "要查找的元素"}, {"name": "list", "type": "list", "required": true, "description": "输入列表"}], "return_type": "list|nil", "example": "(member 2 '(1 2 3)) ; 返回 (2 3)", "notes": "找到返回包含该元素的子列表，否则返回nil"}, "assoc": {"name": "assoc", "description": "在关联列表中查找元素", "syntax": "(assoc key alist)", "parameters": [{"name": "key", "type": "any", "required": true, "description": "要查找的键"}, {"name": "alist", "type": "list", "required": true, "description": "关联列表"}], "return_type": "list|nil", "example": "(assoc 'a '((a . 1) (b . 2))) ; 返回 (a . 1)", "notes": ""}, "strcmp": {"name": "strcmp", "description": "比较两个字符串", "syntax": "(strcmp str1 str2)", "parameters": [{"name": "str1", "type": "string", "required": true, "description": "第一个字符串"}, {"name": "str2", "type": "string", "required": true, "description": "第二个字符串"}], "return_type": "integer", "example": "(strcmp \"abc\" \"abc\") ; 返回 0", "notes": "相等返回0，str1<str2返回负数，否则返回正数"}, "strlen": {"name": "strlen", "description": "返回字符串长度", "syntax": "(strlen str)", "parameters": [{"name": "str", "type": "string", "required": true, "description": "输入字符串"}], "return_type": "integer", "example": "(strlen \"hello\") ; 返回 5", "notes": ""}, "substring": {"name": "substring", "description": "提取子字符串", "syntax": "(substring str start [end])", "parameters": [{"name": "str", "type": "string", "required": true, "description": "输入字符串"}, {"name": "start", "type": "integer", "required": true, "description": "起始位置（从0开始）"}, {"name": "end", "type": "integer", "required": false, "description": "结束位置，默认到字符串末尾"}], "return_type": "string", "example": "(substring \"hello world\" 0 5) ; 返回 \"hello\"", "notes": ""}, "strcat": {"name": "strcat", "description": "连接多个字符串", "syntax": "(strcat str1 str2 ...)", "parameters": [{"name": "str1, str2, ...", "type": "string", "required": true, "description": "要连接的字符串"}], "return_type": "string", "example": "(strcat \"hello\" \" \" \"world\") ; 返回 \"hello world\"", "notes": ""}, "printf": {"name": "printf", "description": "格式化输出", "syntax": "(printf format [args...])", "parameters": [{"name": "format", "type": "string", "required": true, "description": "格式化字符串"}, {"name": "args", "type": "any", "required": false, "description": "格式化参数"}], "return_type": "nil", "example": "(printf \"Hello %s, you are %d years old\\n\" \"Alice\" 25)", "notes": "支持C语言风格的格式化符"}, "sprintf": {"name": "sprintf", "description": "格式化字符串到变量", "syntax": "(sprintf format [args...])", "parameters": [{"name": "format", "type": "string", "required": true, "description": "格式化字符串"}, {"name": "args", "type": "any", "required": false, "description": "格式化参数"}], "return_type": "string", "example": "(sprintf nil \"Value: %d\" 42) ; 返回 \"Value: 42\"", "notes": "第一个参数为nil时返回字符串"}, "get_pwd": {"name": "get_pwd", "description": "获取当前工作目录", "syntax": "(get_pwd)", "parameters": [], "return_type": "string", "example": "(get_pwd) ; 返回 \"/home/user\"", "notes": ""}, "set_pwd": {"name": "set_pwd", "description": "设置当前工作目录", "syntax": "(set_pwd path)", "parameters": [{"name": "path", "type": "string", "required": true, "description": "目标目录路径"}], "return_type": "string|nil", "example": "(set_pwd \"/home/user/project\")", "notes": "成功返回路径，失败返回nil"}, "is_file": {"name": "is_file", "description": "检查路径是否为文件", "syntax": "(is_file path)", "parameters": [{"name": "path", "type": "string", "required": true, "description": "文件路径"}], "return_type": "boolean", "example": "(is_file \"/home/user/test.txt\") ; 返回 t", "notes": "存在且是文件返回t，否则返回nil"}, "is_dir": {"name": "is_dir", "description": "检查路径是否为目录", "syntax": "(is_dir path)", "parameters": [{"name": "path", "type": "string", "required": true, "description": "目录路径"}], "return_type": "boolean", "example": "(is_dir \"/home/user\") ; 返回 t", "notes": "存在且是目录返回t，否则返回nil"}, "read_file": {"name": "read_file", "description": "读取文件内容", "syntax": "(read_file path)", "parameters": [{"name": "path", "type": "string", "required": true, "description": "文件路径"}], "return_type": "string|nil", "example": "(read_file \"/home/user/test.txt\")", "notes": "成功返回文件内容，失败返回nil"}, "write_file": {"name": "write_file", "description": "写入内容到文件", "syntax": "(write_file path content [append])", "parameters": [{"name": "path", "type": "string", "required": true, "description": "文件路径"}, {"name": "content", "type": "string", "required": true, "description": "要写入的内容"}, {"name": "append", "type": "boolean", "required": false, "description": "是否追加模式，默认覆盖"}], "return_type": "boolean", "example": "(write_file \"/home/user/test.txt\" \"Hello World\" t)", "notes": "成功返回t，失败返回nil"}}, "数据库操作": {"dbOpenCellView": {"name": "dbOpenCellView", "description": "打开单元视图", "syntax": "(dbOpenCellView libName cellName viewName mode [installPath])", "parameters": [{"name": "libName", "type": "string", "required": true, "description": "库名"}, {"name": "cellName", "type": "string", "required": true, "description": "单元名"}, {"name": "viewName", "type": "string", "required": true, "description": "视图名（如\"schematic\", \"layout\", \"symbol\"）"}, {"name": "mode", "type": "string", "required": true, "description": "打开模式：\"r\"只读, \"w\"读写, \"a\"追加"}, {"name": "installPath", "type": "string", "required": false, "description": "安装路径"}], "return_type": "dbObject|nil", "example": "(dbOpenCellView \"mylib\" \"mycell\" \"schematic\" \"r\")", "notes": "成功返回单元视图对象，失败返回nil"}, "dbClose": {"name": "dbClose", "description": "关闭数据库对象", "syntax": "(dbClose object)", "parameters": [{"name": "object", "type": "dbObject", "required": true, "description": "要关闭的数据库对象"}], "return_type": "boolean", "example": "(dbClose cv)", "notes": "成功返回t，失败返回nil"}, "dbCreateInst": {"name": "dbCreateInst", "description": "创建实例", "syntax": "(dbCreateInst parentView cellView name location orient [status])", "parameters": [{"name": "parentView", "type": "dbObject", "required": true, "description": "父视图对象"}, {"name": "cellView", "type": "dbObject", "required": true, "description": "要实例化的单元视图"}, {"name": "name", "type": "string", "required": true, "description": "实例名称"}, {"name": "location", "type": "list", "required": true, "description": "位置坐标，如(x y)"}, {"name": "orient", "type": "string", "required": true, "description": "方向：\"R0\", \"R90\", \"R180\", \"R270\", \"MY\", \"MYR90\", \"MX\", \"MXR90\""}, {"name": "status", "type": "string", "required": false, "description": "状态：\"unlocked\"(默认), \"locked\""}], "return_type": "dbObject|nil", "example": "(dbCreateInst cv invCV \"I1\" '(100 200) \"R0\")", "notes": "成功返回实例对象，失败返回nil"}, "dbCreateNet": {"name": "dbCreateNet", "description": "创建网线", "syntax": "(dbCreateNet cellView name)", "parameters": [{"name": "cellView", "type": "dbObject", "required": true, "description": "单元视图对象"}, {"name": "name", "type": "string", "required": true, "description": "网线名称"}], "return_type": "dbObject|nil", "example": "(dbCreateNet cv \"VDD\")", "notes": "成功返回网线对象，失败返回nil"}, "dbCreateTerm": {"name": "dbCreateTerm", "description": "创建端口", "syntax": "(dbCreateTerm net name direction)", "parameters": [{"name": "net", "type": "dbObject", "required": true, "description": "网线对象"}, {"name": "name", "type": "string", "required": true, "description": "端口名称"}, {"name": "direction", "type": "string", "required": true, "description": "方向：\"input\", \"output\", \"inputOutput\""}], "return_type": "dbObject|nil", "example": "(dbCreateTerm vddNet \"VDD\" \"inputOutput\")", "notes": "成功返回端口对象，失败返回nil"}, "dbGetCellView": {"name": "dbGetCellView", "description": "获取当前打开的单元视图", "syntax": "(dbGetCellView [window])", "parameters": [{"name": "window", "type": "dbObject", "required": false, "description": "窗口对象，默认当前窗口"}], "return_type": "dbObject|nil", "example": "(dbGetCellView)", "notes": "返回当前窗口的单元视图，无则返回nil"}, "dbFindLib": {"name": "dbFindLib", "description": "查找库", "syntax": "(dbFindLib libName)", "parameters": [{"name": "libName", "type": "string", "required": true, "description": "库名"}], "return_type": "dbObject|nil", "example": "(dbFindLib \"mylib\")", "notes": "找到返回库对象，否则返回nil"}, "dbFindCell": {"name": "dbFindCell", "description": "查找单元", "syntax": "(dbFindCell lib cellName)", "parameters": [{"name": "lib", "type": "dbObject", "required": true, "description": "库对象"}, {"name": "cellName", "type": "string", "required": true, "description": "单元名"}], "return_type": "dbObject|nil", "example": "(dbFindCell myLib \"mycell\")", "notes": "找到返回单元对象，否则返回nil"}, "dbFindView": {"name": "dbFindView", "description": "查找视图", "syntax": "(dbFindView cell viewName)", "parameters": [{"name": "cell", "type": "dbObject", "required": true, "description": "单元对象"}, {"name": "viewName", "type": "string", "required": true, "description": "视图名"}], "return_type": "dbObject|nil", "example": "(dbFindView myCell \"schematic\")", "notes": "找到返回视图对象，否则返回nil"}, "dbSave": {"name": "dbSave", "description": "保存单元视图", "syntax": "(dbSave cellView)", "parameters": [{"name": "cellView", "type": "dbObject", "required": true, "description": "单元视图对象"}], "return_type": "boolean", "example": "(dbSave cv)", "notes": "成功返回t，失败返回nil"}, "dbCheck": {"name": "dbCheck", "description": "检查单元视图的正确性", "syntax": "(dbCheck cellView [option])", "parameters": [{"name": "cellView", "type": "dbObject", "required": true, "description": "单元视图对象"}, {"name": "option", "type": "string", "required": false, "description": "检查选项"}], "return_type": "list", "example": "(dbCheck cv)", "notes": "返回错误列表，无错误返回空列表"}}, "版图操作": {"leCreatePath": {"name": "leCreatePath", "description": "创建版图路径", "syntax": "(leCreatePath layer pts width [startExt endExt mode])", "parameters": [{"name": "layer", "type": "string|dbObject", "required": true, "description": "层名或层对象"}, {"name": "pts", "type": "list", "required": true, "description": "点坐标列表，如'((0 0) (100 0) (100 100))'"}, {"name": "width", "type": "number", "required": true, "description": "路径宽度"}, {"name": "startExt", "type": "number", "required": false, "description": "起点延伸长度"}, {"name": "endExt", "type": "number", "required": false, "description": "终点延伸长度"}, {"name": "mode", "type": "string", "required": false, "description": "模式：\"truncate\", \"extend\", \"round\""}], "return_type": "dbObject|nil", "example": "(leCreatePath \"metal1\" '((0 0) (1000 0)) 0.1)", "notes": "成功返回路径对象，失败返回nil"}, "leCreateRect": {"name": "leCreateRect", "description": "创建矩形", "syntax": "(leCreateRect layer bbox)", "parameters": [{"name": "layer", "type": "string|dbObject", "required": true, "description": "层名或层对象"}, {"name": "bbox", "type": "list", "required": true, "description": "边界框，如'(x1 y1 x2 y2)'"}], "return_type": "dbObject|nil", "example": "(leCreateRect \"metal1\" '(0 0 100 100))", "notes": "成功返回矩形对象，失败返回nil"}, "leCreatePolygon": {"name": "leCreatePolygon", "description": "创建多边形", "syntax": "(leCreatePolygon layer pts)", "parameters": [{"name": "layer", "type": "string|dbObject", "required": true, "description": "层名或层对象"}, {"name": "pts", "type": "list", "required": true, "description": "点坐标列表"}], "return_type": "dbObject|nil", "example": "(leCreatePolygon \"metal1\" '((0 0) (100 0) (50 100)))", "notes": "成功返回多边形对象，失败返回nil"}, "leGetSelSet": {"name": "leGetSelSet", "description": "获取版图编辑器中的选中对象集合", "syntax": "(leGetSelSet)", "parameters": [], "return_type": "list", "example": "(leGetSelSet)", "notes": "返回选中对象的列表，无选中则返回空列表"}, "leSetSelSet": {"name": "leSetSelSet", "description": "设置版图编辑器的选中对象", "syntax": "(leSetSelSet objects)", "parameters": [{"name": "objects", "type": "list", "required": true, "description": "要选中的对象列表"}], "return_type": "nil", "example": "(leSetSelSet (list obj1 obj2))", "notes": ""}, "leClearSelSet": {"name": "leClearSelSet", "description": "清空选中对象集合", "syntax": "(leClearSelSet)", "parameters": [], "return_type": "nil", "example": "(leClearSelSet)", "notes": ""}, "geGetEditCellView": {"name": "geGetEditCellView", "description": "获取当前编辑的单元视图", "syntax": "(geGetEditCellView)", "parameters": [], "return_type": "dbObject|nil", "example": "(geGetEditCellView)", "notes": "返回当前编辑的单元视图，无则返回nil"}, "geZoomToFit": {"name": "geZoomToFit", "description": "缩放以适应所有对象", "syntax": "(geZoomToFit [window])", "parameters": [{"name": "window", "type": "dbObject", "required": false, "description": "窗口对象，默认当前窗口"}], "return_type": "nil", "example": "(geZoomToFit)", "notes": ""}, "geZoomIn": {"name": "geZoomIn", "description": "放大视图", "syntax": "(geZoomIn [factor window])", "parameters": [{"name": "factor", "type": "number", "required": false, "description": "放大倍数，默认2"}, {"name": "window", "type": "dbObject", "required": false, "description": "窗口对象"}], "return_type": "nil", "example": "(geZoomIn 2)", "notes": ""}, "geZoomOut": {"name": "geZoomOut", "description": "缩小视图", "syntax": "(geZoomOut [factor window])", "parameters": [{"name": "factor", "type": "number", "required": false, "description": "缩小倍数，默认2"}, {"name": "window", "type": "dbObject", "required": false, "description": "窗口对象"}], "return_type": "nil", "example": "(geZoomOut 2)", "notes": ""}}, "原理图操作": {"schCreateWire": {"name": "schCreateWire", "description": "创建原理图导线", "syntax": "(schCreateWire cellView pts [width])", "parameters": [{"name": "cellView", "type": "dbObject", "required": true, "description": "原理图视图对象"}, {"name": "pts", "type": "list", "required": true, "description": "点坐标列表"}, {"name": "width", "type": "number", "required": false, "description": "导线宽度"}], "return_type": "dbObject|nil", "example": "(schCreateWire cv '((0 0) (100 0)))", "notes": "成功返回导线对象，失败返回nil"}, "schCreateInst": {"name": "schCreateInst", "description": "创建原理图实例", "syntax": "(schCreateInst parentView cellView name location orient)", "parameters": [{"name": "parentView", "type": "dbObject", "required": true, "description": "父视图对象"}, {"name": "cellView", "type": "dbObject", "required": true, "description": "要实例化的单元视图"}, {"name": "name", "type": "string", "required": true, "description": "实例名称"}, {"name": "location", "type": "list", "required": true, "description": "位置坐标"}, {"name": "orient", "type": "string", "required": true, "description": "方向"}], "return_type": "dbObject|nil", "example": "(schCreateInst cv invCV \"I1\" '(100 200) \"R0\")", "notes": "成功返回实例对象，失败返回nil"}, "schCreatePin": {"name": "schCreatePin", "description": "创建原理图引脚", "syntax": "(schCreatePin cellView net name direction location orient)", "parameters": [{"name": "cellView", "type": "dbObject", "required": true, "description": "原理图视图对象"}, {"name": "net", "type": "dbObject|string", "required": true, "description": "网线对象或名称"}, {"name": "name", "type": "string", "required": true, "description": "引脚名称"}, {"name": "direction", "type": "string", "required": true, "description": "方向：\"input\", \"output\", \"inputOutput\""}, {"name": "location", "type": "list", "required": true, "description": "位置坐标"}, {"name": "orient", "type": "string", "required": true, "description": "方向"}], "return_type": "dbObject|nil", "example": "(schCreatePin cv \"VDD\" \"VDD\" \"inputOutput\" '(0 100) \"R0\")", "notes": "成功返回引脚对象，失败返回nil"}, "schGetSelSet": {"name": "schGetSelSet", "description": "获取原理图编辑器中的选中对象集合", "syntax": "(schGetSelSet)", "parameters": [], "return_type": "list", "example": "(schGetSelSet)", "notes": "返回选中对象的列表，无选中则返回空列表"}}, "界面操作": {"hiCreateForm": {"name": "hiCreateForm", "description": "创建表单界面", "syntax": "(hiCreateForm title fields callback [buttons])", "parameters": [{"name": "title", "type": "string", "required": true, "description": "表单标题"}, {"name": "fields", "type": "list", "required": true, "description": "字段定义列表"}, {"name": "callback", "type": "function", "required": true, "description": "提交回调函数"}, {"name": "buttons", "type": "list", "required": false, "description": "按钮定义"}], "return_type": "hiObject|nil", "example": "(hiCreateForm \"My Form\" fields callback)", "notes": "成功返回表单对象，失败返回nil"}, "hiDisplayForm": {"name": "hiDisplayForm", "description": "显示表单", "syntax": "(hiDisplayForm form)", "parameters": [{"name": "form", "type": "hiObject", "required": true, "description": "表单对象"}], "return_type": "nil", "example": "(hiDisplayForm myForm)", "notes": ""}, "hiDisplayMessageBox": {"name": "hiDisplayMessageBox", "description": "显示消息对话框", "syntax": "(hiDisplayMessageBox type title message [buttons])", "parameters": [{"name": "type", "type": "string", "required": true, "description": "对话框类型：\"info\", \"warning\", \"error\", \"question\""}, {"name": "title", "type": "string", "required": true, "description": "对话框标题"}, {"name": "message", "type": "string", "required": true, "description": "消息内容"}, {"name": "buttons", "type": "list", "required": false, "description": "按钮列表，默认'(\"OK\")'"}], "return_type": "string", "example": "(hiDisplayMessageBox \"info\" \"提示\" \"操作完成\")", "notes": "返回用户点击的按钮文本"}, "hiGetString": {"name": "hiGetString", "description": "弹出输入框获取字符串", "syntax": "(hiGetString prompt [default])", "parameters": [{"name": "prompt", "type": "string", "required": true, "description": "提示信息"}, {"name": "default", "type": "string", "required": false, "description": "默认值"}], "return_type": "string|nil", "example": "(hiGetString \"请输入名称：\" \"default\")", "notes": "用户点击确定返回输入内容，取消返回nil"}, "hiGetInteger": {"name": "hiGetInteger", "description": "弹出输入框获取整数", "syntax": "(hiGetInteger prompt [min max default])", "parameters": [{"name": "prompt", "type": "string", "required": true, "description": "提示信息"}, {"name": "min", "type": "integer", "required": false, "description": "最小值"}, {"name": "max", "type": "integer", "required": false, "description": "最大值"}, {"name": "default", "type": "integer", "required": false, "description": "默认值"}], "return_type": "integer|nil", "example": "(hiGetInteger \"请输入数量：\" 1 100 10)", "notes": "用户点击确定返回输入值，取消返回nil"}, "hiCreateMenu": {"name": "hiCreateMenu", "description": "创建菜单", "syntax": "(hiCreateMenu name items)", "parameters": [{"name": "name", "type": "string", "required": true, "description": "菜单名称"}, {"name": "items", "type": "list", "required": true, "description": "菜单项列表"}], "return_type": "hiObject|nil", "example": "(hiCreateMenu \"MyMenu\" items)", "notes": "成功返回菜单对象，失败返回nil"}, "hiAddMenuItem": {"name": "hiAddMenuItem", "description": "添加菜单项", "syntax": "(hiAddMenuItem menu item)", "parameters": [{"name": "menu", "type": "hiObject", "required": true, "description": "菜单对象"}, {"name": "item", "type": "list", "required": true, "description": "菜单项定义"}], "return_type": "nil", "example": "(hiAddMenuItem myMenu '(\"Item1\" callback))", "notes": ""}}}}