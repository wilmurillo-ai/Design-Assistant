{
  "version": "2.0.0",
  "kind": "Node",
  "spec": {
    "nodes": [
      {
        "name": "step1",
        "id": "step1",
        "recurrence": "Normal",
        "timeout": 1,
        "timeoutUnit": "HOURS",
        "instanceMode": "T+1",
        "rerunMode": "Allowed",
        "rerunTimes": 0,
        "rerunInterval": 180000,
        "script": {
          "path": "step1",
          "language": "shell",
          "runtime": {
            "command": "DIDE_SHELL"
          },
          "content": ""
        },
        "trigger": {
          "type": "Manual"
        },
        "runtimeResource": {
          "resourceGroup": "${spec.runtimeResource.resourceGroup}"
        },
        "outputs": {
          "nodeOutputs": [
            {
              "data": "${projectIdentifier}.step1",
              "artifactType": "NodeOutput"
            }
          ]
        },
        "inputs": {
          "nodeOutputs": [
            {
              "data": "${projectIdentifier}_root",
              "artifactType": "NodeOutput"
            }
          ]
        }
      }
    ],
    "dependencies": [
      {
        "nodeId": "step1",
        "depends": [
          {
            "type": "Normal",
            "output": "${projectIdentifier}_root"
          }
        ]
      }
    ]
  }
}
