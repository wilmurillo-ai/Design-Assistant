  "tags": [
    "ai-agent",
    "knowledge-graph",
    "memory-system",
    "visualization"
  ],
  "license": "MIT",
  "main": "SKILL.md",
  "engines": {
    "openclaw": ">=1.0.0"
  },
  "files": [
    "SKILL.md",
    "core/",
    "data/"
  ],
