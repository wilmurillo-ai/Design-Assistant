      },
      {
        "name": "OPENAI_API_KEY",
        "description": "OpenAI API密钥（可选）",
        "sensitive": true
      }
    ]
  },
  "clawhub": {
    "displayName": "荞麦饼 Skills",
    "summary": "智能体增强工具：记忆管理、知识图谱、报告生成、类案检索",
    "icon": "🌾",
    "category": "platform-tools",
    "pricing": "free"
  }
}