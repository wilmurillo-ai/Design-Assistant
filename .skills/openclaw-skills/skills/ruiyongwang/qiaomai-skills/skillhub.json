  "entryPoint": "SKILL.md",
  "platforms": ["openclaw", "skillhub"],
  "requirements": {
    "minOpenClawVersion": "1.0.0",
    "dependencies": [],
    "config": {
      "path": "~/.qiaomai/config.yaml",
      "template": "config/config.template.yaml",
      "envPrefix": "QIAOMAI_",
      "description": "配置文件路径，支持 YAML 格式配置"
    },
    "env": {
      "required": [],
      "optional": [
        {
          "name": "QIAOMAI_MEMORY_BACKEND",
          "description": "记忆后端类型",
          "options": ["faiss", "chroma", "pinecone"],
          "default": "faiss"
        },
        {
          "name": "QIAOMAI_KG_BACKEND",
          "description": "知识图谱后端",
          "options": ["networkx", "neo4j"],
          "default": "networkx"
        },
        {
          "name": "QIAOMAI_DB_BACKEND",
          "description": "数据库后端",
          "options": ["sqlite", "postgresql"],
          "default": "sqlite"
        },
        {
          "name": "QIAOMAI_CACHE_BACKEND",
          "description": "缓存后端",
          "options": ["memory", "redis"],
          "default": "memory"
        },
        {
          "name": "QIAOMAI_LOG_LEVEL",
          "description": "日志级别",
          "options": ["debug", "info", "warning", "error"],
          "default": "info"
        },
        {
          "name": "OPENAI_API_KEY",
          "description": "OpenAI API 密钥（可选，用于增强功能）",
          "sensitive": true
        },
        {
          "name": "PERPLEXITY_API_KEY",
          "description": "Perplexity API 密钥（可选，用于搜索增强）",
          "sensitive": true
        },
        {
          "name": "GROK_API_KEY",
          "description": "Grok API 密钥（可选，用于代码生成）",
          "sensitive": true
        }
      ]
    }
  },
