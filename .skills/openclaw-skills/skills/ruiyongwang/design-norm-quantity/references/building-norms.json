{
  "version": "1.0",
  "title": "房屋建筑设计规范要点速查",
  "description": "与工程量配比相关的设计规范关键参数",
  "norms": {
    "GB50010": {
      "name": "混凝土结构设计规范",
      "version": "GB50010-2010(2015年版)",
      "key_points": [
        {
          "topic": "混凝土强度等级",
          "content": "钢筋混凝土结构的混凝土强度等级不应低于C20；当采用HRB400及以上钢筋时，不应低于C25"
        },
        {
          "topic": "钢筋配筋率",
          "content": "梁端受拉钢筋配筋率不宜大于2.5%；柱纵向钢筋配筋率不宜大于5%"
        },
        {
          "topic": "抗震设计",
          "content": "抗震等级一、二、三级框架梁配筋率不应小于0.6%、0.4%、0.4%"
        },
        {
          "topic": "钢筋锚固长度",
          "content": "HPB300钢筋锚固长度30d，HRB400钢筋35d（受拉）；搭接长度1.2-1.6倍锚固长度"
        }
      ]
    },
    "GB50011": {
      "name": "建筑抗震设计规范",
      "version": "GB50011-2010(2016年版)",
      "key_points": [
        {
          "topic": "抗震设防分类",
          "content": "甲类：重大建筑工程；乙类：人员密集公共建筑；丙类：一般工业与民用建筑；丁类：次要建筑"
        },
        {
          "topic": "抗震等级划分",
          "content": "按设防类别、结构类型、烈度和高度分为一、二、三、四级"
        },
        {
          "topic": "剪力墙最小厚度",
          "content": "一级抗震：不宜小于160mm；二级：不宜小于140mm；底部加强部位不应小于层高1/16"
        }
      ]
    },
    "GB50003": {
      "name": "砌体结构设计规范",
      "version": "GB50003-2011",
      "key_points": [
        {
          "topic": "砌体强度等级",
          "content": "烧结普通砖、烧结多孔砖不低于MU10；蒸压粉煤灰砖不低于MU15；砌块不低于MU5"
        },
        {
          "topic": "砂浆强度等级",
          "content": "不宜低于Mb5，用于外墙时应不低于M7.5"
        },
        {
          "topic": "砌体容重",
          "content": "普通砖18kN/m³；多孔砖14kN/m³；加气混凝土砌块5-8kN/m³"
        }
      ]
    },
    "GB50367": {
      "name": "混凝土结构加固设计规范",
      "key_points": [
        {
          "topic": "加固用混凝土",
          "content": "不低于原构件强度等级，且不低于C25"
        }
      ]
    },
    "JGJ3": {
      "name": "高层建筑混凝土结构技术规程",
      "version": "JGJ3-2010",
      "key_points": [
        {
          "topic": "高层建筑定义",
          "content": "10层及10层以上或房屋高度大于28m的住宅建筑和建筑高度大于24m的其他民用建筑"
        },
        {
          "topic": "高宽比限值",
          "content": "A级高度框架-剪力墙6；剪力墙6；框架-核心筒5；筒中筒7"
        },
        {
          "topic": "位移角限值",
          "content": "风荷载作用下层间位移角：框架1/550；剪力墙1/1000；框架-核心筒1/800"
        }
      ]
    }
  },
  "typical_values": {
    "floor_height": {
      "住宅": {"standard": 2.8, "range": [2.6, 3.3]},
      "办公": {"standard": 3.6, "range": [3.0, 4.5]},
      "商业": {"standard": 4.5, "range": [4.2, 6.0]},
      "学校": {"standard": 3.6, "range": [3.3, 4.2]},
      "医院": {"standard": 3.9, "range": [3.6, 4.8]}
    },
    "basement_depth": {
      "普通": {"depth": 3.6, "floor_height": 3.0},
      "机械停车": {"depth": 4.5, "floor_height": 3.6},
      "人防": {"depth": 3.6, "floor_height": 3.0}
    }
  }
}
