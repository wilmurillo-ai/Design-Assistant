      ["M6", "结构型钢(H型钢/钢管)", "3%~8%", "±12%", "0.8×", "★★☆☆☆", "我的钢铁网"]
    ],

    "key_insight": {
      "title": "关键发现",
      "finding1": "M1+M2+M3三大因子累计贡献度达70%~85%",
      "finding2": "M3(铜)是价格波动最大的因子，但可通过期货对冲",
      "finding3": "M2(混凝土)价格受政策影响显著，区域差异大",
      "finding4": "M4+M5组合决定外立面成本，约占总造价8%~15%"
    }
  },

  "uncertainty_propagation_model": {
    "title": "材料价格不确定性传播模型",
    "principle": "材料价格波动通过材料用量传递到工程造价",

    "formula": "ΔP_project / P_project = Σ(αᵢ × ΔPᵢ / Pᵢ)",

    "variables": {
      "ΔP_project / P_project": "项目总造价变动率",
      "αᵢ": "第i种材料的成本权重 (α₁+α₂+...+α₆ ≈ 0.55~0.70)",
      "ΔPᵢ / Pᵢ": "第i种材料的单价变动率"
    },

    "material_weights": {
      "M1_钢筋": {"typical_value": 0.15, "range": [0.12, 0.18]},
      "M2_混凝土": {"typical_value": 0.12, "range": [0.08, 0.15]},
      "M3_铜缆": {"typical_value": 0.08, "range": [0.04, 0.12]},
      "M4_铝合金": {"typical_value": 0.07, "range": [0.05, 0.12]},
      "M5_玻璃": {"typical_value": 0.05, "range": [0.04, 0.10]},
      "M6_结构型钢": {"typical_value": 0.04, "range": [0.02, 0.08]},
      "其他材料": {"typical_value": 0.49, "range": [0.30, 0.55]}
    },

    "monte_carlo_simulation": {
      "description": "对6大因子进行蒙特卡洛模拟，计算项目总造价的不确定性分布",

      "input_distribution": {
        "M1_钢筋": "N(0, 0.15²) - 正态分布，年波动率15%",
        "M2_混凝土": "N(0, 0.10²) - 正态分布，年波动率10%",
        "M3_铜缆": "LN(μ, 0.20²) - 对数正态分布，右偏",
        "M4_铝合金": "N(0, 0.15²) - 正态分布",
        "M5_玻璃": "N(0, 0.15²) - 正态分布",
        "M6_结构型钢": "N(0, 0.12²) - 正态分布"
      },

      "correlation_matrix": {
        "M1-M6(结构钢)": 0.85,
        "M1-M2(混凝土)": 0.30,
        "M3-M4(有色金属)": 0.65,
        "M4-M5(立面材料)": 0.40,
        "M1-M3": 0.20,
        "M2-M3": 0.15
      },

      "output": {
        "distribution_type": "近似正态分布",
        "P50(中值)": "50%概率总造价",
        "P80区间": "80%置信区间 (低P10 ~ 高P90)",
        "P95区间": "95%置信区间 (低P2.5 ~ 高P97.5)"
      }
    }
  },

  "practical_application": {
    "title": "实战应用指南",

    "scenario_1_price_lookup": {
      "title": "场景一：查询当前材料价格",
      "trigger": "用户输入'查一下现在钢筋价格'",
      "action": "返回M1~M6六大因子的当前市场价格区间",
      "output": "含数据来源、时间戳、价格趋势图"
    },

    "scenario_2_cost_impact": {
      "title": "场景二：评估材料涨价对项目成本的影响",
      "trigger": "用户输入'铜价涨了20%，对项目影响多大'",
      "action": "基于铜缆占比(8%~15%)，计算对项目总造价的影响",
      "formula": "Δ总造价 ≈ 项目造价 × 铜缆占比 × 20%",
      "example": "10亿项目，铜缆占比10%，铜价涨20% → 影响约200万"
    },

    "scenario_3_budget_estimate": {
