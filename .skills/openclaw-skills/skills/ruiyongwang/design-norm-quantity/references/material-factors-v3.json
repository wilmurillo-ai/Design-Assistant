{
  "version": "3.0",
  "title": "关键材料因子体系 - '测不准'造价波动引擎",
  "date": "2026-04-03",
  "author": "度量衡智库",

  "philosophy": {
    "core_insight": "工程造价的不确定性，70%以上来自材料价格的波动。从上千种材料中遴选出6个关键因子，就能量化并预测整体造价的波动范围。",
    "methodology": "帕累托法则(Pareto Principle) + 主成分分析(PCA) + 专家判断"
  },

  "material_selection": {
    "selection_criteria": {
      "value_contribution": "单项材料占建安造价比例 ≥ 3%",
      "price_volatility": "年价格波动率 ≥ 8%",
      "representativeness": "能代表某一类材料的价格趋势",
      "data_availability": "有公开、权威的价格发布渠道"
    },
    "selection_process": {
      "step1": "梳理房屋建筑工程材料清单（约2000+种）",
      "step2": "按专业分类：结构/建筑/机电/装饰",
      "step3": "计算各类材料在典型项目中的价值占比",
      "step4": "筛选出累计贡献度 > 70% 的关键因子",
      "step5": "专家评审调整，确定6大关键因子"
    }
  },

  "six_key_material_factors": {

    "M1_steel_rebar": {
      "name": "材料因子M1 - 钢筋（螺纹钢/线材）",
      "code": "M1",
      "category": "结构材料 - 黑色金属",
      "hs_code": "7214/7215",

      "engineering_significance": {
        "cost_share": "占建安造价比例: 12%~18%",
        "sensitivity_rank": "#1 (最高)",
        "description": "钢筋是混凝土结构的骨架，几乎所有钢筋混凝土构件都依赖钢筋承力"
      },

      "price_composition": {
        "raw_material": "铁矿石 (占比约40%)",
        "processing": "炼钢+轧制 (占比约25%)",
        "transport": "物流运输 (占比约10%)",
        "trading_margin": "贸易商利润 (占比约10%)",
        "other": "其他/税费 (占比约15%)"
      },

      "price_indicators": [
        {"name": "HRB400 螺纹钢", "unit": "元/吨", "typical_range": [3800, 4800], "fluctuation": "±15%/年"},
        {"name": "HPB300 光圆钢筋", "unit": "元/吨", "typical_range": [3900, 4900], "fluctuation": "±14%/年"},
        {"name": "HRB500 高强钢筋", "unit": "元/吨", "typical_range": [4200, 5200], "fluctuation": "±13%/年"}
      ],

      "price_influence_factors": {
        "upstream": ["铁矿石期货(CFE)", "焦炭价格", "废钢价格"],
        "policy": ["环保限产", "去产能政策", "出口关税"],
        "demand": ["房地产开工率", "基建投资", "制造业需求"]
      },

      "market_data_sources": [
        "我的钢铁网(mysteel.com)",
        "兰格钢铁网",
        "西本新干线",
        "中国钢铁工业协会"
      ],

      "correlation_with_project_cost": {
        "reinforced_concrete_ratio": "140 kg/m³ (典型框架-剪力墙)",
        "concrete_structure": "钢筋成本 = V_concrete × 140kg/m³ × P_steel",
        "influence_coefficient": 1.0,
        "price_elasticity": "钢筋价格每上涨10%，整体建安造价上涨1.2%~1.8%"
      },

      "price_forecast": {
        "method": "蒙特卡洛模拟 + 历史价格分布",
        "distribution": "对数正态分布",
        "confidence_interval_1y": "±12% (80%置信度)",
        "confidence_interval_3y": "±25% (80%置信度)"
      }
    },

