      "output": "点预测 + 置信区间 + 情景分析(乐观/基准/悲观)"
    },

    "scenario_5_risk_hedge": {
      "title": "场景五：价格风险对冲建议",
      "trigger": "用户输入'怎么对冲材料涨价风险'",
      "action": "提供锁价策略、期货对冲、集采策略、保险方案",
      "output": "定制化风险管控方案"
    }
  },

