{
  "name": "openclaw-skill-hitpaw-enhancer",
  "version": "1.0.1",
  "description": "HitPaw Image & Video Enhancement Skill for OpenClaw",
  "main": "dist/cli.js",
  "type": "module",
  "bin": {
    "enhance-image": "./dist/cli.js",
    "enhance-video": "./dist/video-cli.js"
  },
  "scripts": {
