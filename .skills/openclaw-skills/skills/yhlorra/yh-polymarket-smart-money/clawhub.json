{
  "emoji": "🐋",
  "requires": {
    "pip": ["simmer-sdk", "python-dotenv"],
    "env": ["SIMMER_API_KEY"]
  },
  "cron": null,
  "autostart": false,
  "automaton": {
    "managed": true,
    "entrypoint": "smartmoney_trader.py"
  },
  "tunables": [
    {
      "env": "SIMMER_SMARTMONEY_MIN_SCORE",
      "type": "number",
      "default": 7,
      "range": [5, 10],
      "step": 0.5,
      "label": "Minimum signal score"
    },
    {
      "env": "SIMMER_SMARTMONEY_MAX_POSITION",
      "type": "number",
      "default": 10,
      "range": [1, 50],
      "step": 1,
      "label": "Max position size (USD)"
    }
  ]
}
