    "x402",
    "payment-required",
    "web3",
    "bun",
    "base",
    "usdc"
  ],
  "author": "PayNode Labs",
  "license": "MIT",
  "homepage": "https://github.com/PayNodeLabs/paynode-ai-skills",
  "repository": {
    "type": "git",
    "url": "https://github.com/PayNodeLabs/paynode-ai-skills.git"
  },
  "dependencies": {
    "@paynodelabs/sdk-js": "^2.2.3",
    "cac": "7.0.0"
  },
  "devDependencies": {
    "bun-types": "^1.0.0"
  },
  "required_env_vars": [
