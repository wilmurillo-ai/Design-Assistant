            {"id": "RS-004", "pattern": "python.*socket.*connect.*(?:subprocess|os\\.(?:dup2|system))", "pattern_type": "regex", "name": "Python reverse shell", "description": "Python reverse shell pattern"},
            {"id": "RS-005", "pattern": "socket\\.socket.*\\.connect\\s*\\(.*\\d+\\.\\d+\\.\\d+\\.\\d+.*\\d{4,5}", "pattern_type": "regex", "name": "Socket connect to IP:port", "description": "Raw socket connection to IP address with high port"},
            {"id": "RS-006", "pattern": "13338", "pattern_type": "literal", "name": "Port 13338 (ClawHavoc)", "description": "Port 13338 — used in documented ClawHavoc reverse shells"},
            {"id": "RS-007", "pattern": "mkfifo\\s+/tmp/", "pattern_type": "regex", "name": "Named pipe reverse shell", "description": "Creates named pipe for reverse shell"},
            {"id": "RS-008", "pattern": "socat\\s+.*EXEC:", "pattern_type": "regex", "name": "Socat reverse shell", "description": "Socat-based reverse shell"},
            {"id": "RS-009", "pattern": "(?:perl|ruby|php)\\s+.*-e\\s+.*socket.*connect", "pattern_type": "regex", "name": "Scripting reverse shell", "description": "Reverse shell via scripting language"},
            {"id": "RS-010", "pattern": "telnet\\s+\\d+\\.\\d+\\.\\d+\\.\\d+\\s+\\d+\\s*\\|", "pattern_type": "regex", "name": "Telnet pipe shell", "description": "Telnet-based reverse shell with pipe"},
            {"id": "RS-011", "pattern": "pty\\.spawn\\s*\\(\\s*['\"](?:/bin/(?:ba)?sh|cmd)", "pattern_type": "regex", "name": "PTY spawn shell", "description": "Python PTY spawn for interactive shell"},
            {"id": "RS-012", "pattern": "os\\.dup2\\s*\\(\\s*s\\.fileno", "pattern_type": "regex", "name": "Socket FD duplication", "description": "Duplicates socket file descriptor (reverse shell setup)"},
            {"id": "RS-013", "pattern": "subprocess\\.call\\s*\\(\\s*\\[.*(?:/bin/(?:ba)?sh|cmd)", "pattern_type": "regex", "name": "Subprocess shell call", "description": "Spawns shell via subprocess"},
            {"id": "RS-014", "pattern": "msfvenom|meterpreter|metasploit", "pattern_type": "regex", "name": "Metasploit reference", "description": "References Metasploit framework payloads"},
            {"id": "RS-015", "pattern": "\\bssh\\s+.*-R\\s+\\d+:", "pattern_type": "regex", "name": "SSH reverse tunnel", "description": "Establishes SSH reverse tunnel"}
          ]
