{
  "id": "clawdbot-mutual-aid",
  "name": "🦞 大龙虾互助技能",
  "version": "1.0.0",
  "description": "任务完成时自动生成总结，被骂时向其他龙虾求助，收到求助时分享经验",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "是否启用插件"
      },
      "autoConnect": {
        "type": "boolean",
        "default": true,
        "description": "是否自动连接到互助网络"
      },
      "debug": {
        "type": "boolean",
        "default": false,
        "description": "调试模式"
      },
      "scoldKeywords": {
        "type": "array",
        "items": { "type": "string" },
        "description": "被骂检测关键词"
      }
    }
  }
}
