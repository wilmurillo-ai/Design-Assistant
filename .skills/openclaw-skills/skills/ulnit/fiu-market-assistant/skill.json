{
  "name": "fiu-market-assistant",
  "version": "1.0.7",
  "description": "FIU MCP Market Data and Trading Assistant",
  "homepage": "https://github.com/fiu-ai/openclaw-skills",
  "source": "https://github.com/fiu-ai/openclaw-skills",
  "author": "@ulnit",
  "license": "MIT-0",
  "requiredEnvVars": [
    {
      "name": "FIU_MCP_TOKEN",
      "description": "JWT token for FIU MCP Server authentication. Get your token from https://ai.szfiu.com/auth/login",
      "required": true,
      "sensitive": true
    }
  ],
  "requiredBinaries": [
    "curl",
    "jq",
    "date",
    "bash"
  ],
  "primaryCredential": "FIU_MCP_TOKEN",
  "capabilities": [
    "market_data_query",
    "trading"
  ],
  "trading": {
    "mode": "both",
    "defaultMode": "SIMULATE",
    "requiresConfirmation": true
  },
  "user-invocable": true,
  "allowed-tools": [
    "Read",
    "Write",
    "Bash"
  ]
}