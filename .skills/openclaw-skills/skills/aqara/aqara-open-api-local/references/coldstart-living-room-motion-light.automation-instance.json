{
  "metadata": {
    "name": "coldstart-living-room-motion-light-automation-pack",
    "description": "Living room: turn on the main light whenever occupancy is detected throughout the day, and turn it off after 5 minutes of no occupancy. Study: lighting only; at night from 18:00 to 06:00, turn on the main light when occupancy is detected, and turn it off after 5 minutes of no occupancy.",
    "scope": [
      {
        "name": "livingRoomMotion",
        "type": "device.property",
        "deviceId": "dev.living_room.motion",
        "endpointId": 1,
        "functionCode": "OccupancySensing",
        "traitCode": "Occupancy"
      },
      {
        "name": "studyMotion",
        "type": "device.property",
        "deviceId": "dev.study.motion",
        "endpointId": 1,
        "functionCode": "OccupancySensing",
        "traitCode": "Occupancy"
      }
    ]
  },
  "automations": [
    {
      "name": "Living Room Occupied Lights On",
      "starters": [
        {
          "type": "property.event",
          "source": {
            "type": "data.ref",
            "from": "/metadata/scope",
            "select": {
              "by": "name",
              "value": "livingRoomMotion"
            }
          },
          "is": true,
          "for": "5sec",
          "suppressFor": "30sec"
        }
      ],
      "condition": {
        "type": "property.state",
        "source": {
          "type": "device.property",
          "deviceId": "dev.living_room.light",
          "endpointId": 1,
          "functionCode": "Output",
          "traitCode": "OnOff"
        },
        "is": false
      },
      "actions": [
        {
          "type": "device.trait.write",
          "functionCode": "Output",
          "traitCode": "OnOff",
          "targets": [
            {
              "deviceId": "dev.living_room.light",
              "endpointIds": [1]
            }
          ],
          "value": true
        }
      ]
    },
    {
      "name": "Living Room Vacant Lights Off",
      "starters": [
        {
          "type": "property.event",
          "source": {
            "type": "data.ref",
            "from": "/metadata/scope",
            "select": {
              "by": "name",
              "value": "livingRoomMotion"
            }
          },
          "is": false,
          "for": "5min",
          "suppressFor": "30sec"
        }
      ],
      "condition": {
        "type": "property.state",
        "source": {
          "type": "device.property",
          "deviceId": "dev.living_room.light",
          "endpointId": 1,
          "functionCode": "Output",
          "traitCode": "OnOff"
        },
        "is": true
      },
      "actions": [
        {
          "type": "device.trait.write",
          "functionCode": "Output",
          "traitCode": "OnOff",
          "targets": [
            {
              "deviceId": "dev.living_room.light",
              "endpointIds": [1]
            }
          ],
          "value": false
        }
      ]
    },
    {
      "name": "Study Occupied At Night Lights On",
      "starters": [
        {
          "type": "property.event",
          "source": {
            "type": "data.ref",
            "from": "/metadata/scope",
            "select": {
              "by": "name",
              "value": "studyMotion"
            }
          },
          "is": true,
          "for": "5sec",
          "suppressFor": "30sec"
        }
      ],
      "condition": {
        "type": "and",
        "conditions": [
          {
            "type": "time.between",
            "after": "18:00",
            "before": "06:00"
          },
          {
            "type": "property.state",
            "source": {
              "type": "device.property",
              "deviceId": "dev.study.light",
              "endpointId": 1,
              "functionCode": "Output",
              "traitCode": "OnOff"
            },
            "is": false
          }
        ]
      },
      "actions": [
        {
          "type": "device.trait.write",
          "functionCode": "Output",
          "traitCode": "OnOff",
          "targets": [
            {
              "deviceId": "dev.study.light",
              "endpointIds": [1]
            }
          ],
          "value": true
        }
      ]
    },
    {
      "name": "Study Vacant Lights Off",
      "starters": [
        {
          "type": "property.event",
          "source": {
            "type": "data.ref",
            "from": "/metadata/scope",
            "select": {
              "by": "name",
              "value": "studyMotion"
            }
          },
          "is": false,
          "for": "5min",
          "suppressFor": "30sec"
        }
      ],
      "condition": {
        "type": "property.state",
        "source": {
          "type": "device.property",
          "deviceId": "dev.study.light",
          "endpointId": 1,
          "functionCode": "Output",
          "traitCode": "OnOff"
        },
        "is": true
      },
      "actions": [
        {
          "type": "device.trait.write",
          "functionCode": "Output",
          "traitCode": "OnOff",
          "targets": [
            {
              "deviceId": "dev.study.light",
              "endpointIds": [1]
            }
          ],
          "value": false
        }
      ]
    }
  ]
}
