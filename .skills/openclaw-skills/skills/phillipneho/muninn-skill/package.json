{
  "name": "@openclaw/muninn-skill",
  "version": "2.0.0",
  "description": "Production memory for AI agents. 99.1% LOCOMO accuracy. Cloudflare-native with knowledge graph, temporal reasoning, multi-hop retrieval.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "mcp": "tsx src/mcp/server.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:router": "npm run build && node dist/tests/router.test.js",
    "test:entities": "npm run build && node dist/tests/entities.test.js",
    "test:evolution": "npm run build && node dist/procedures/evolution.test.js",
    "test:integration": "npm run build && node dist/tests/integration.test.js",
    "test:filter": "npm run build && node dist/tests/filter.test.js",
    "test:hybrid": "npm run build && node dist/tests/hybrid.test.js",
    "test:normalize": "npm run build && node dist/tests/normalize.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/luxon": "^3.7.1",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.0.0",
    "luxon": "^3.7.2",
    "ollama": "^0.5.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "AGPL-3.0"
}
