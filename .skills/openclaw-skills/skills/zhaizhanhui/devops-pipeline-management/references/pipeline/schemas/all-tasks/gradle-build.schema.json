{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gradle-build.schema.json",
  "title": "GradleBuild Task",
  "description": "Gradle构建任务配置，用于Java/Android项目的Gradle构建",
  "type": "object",
  "required": ["taskCategory", "jobType", "name"],
  "properties": {
    "taskCategory": {
      "type": "string",
      "const": "Build",
      "description": "任务类别，固定为Build"
    },
    "jobType": {
      "type": "string",
      "const": "GradleBuild",
      "description": "任务类型，固定为GradleBuild"
    },
    "name": {
      "type": "string",
      "maxLength": 100,
      "description": "任务名称",
      "examples": ["Gradle构建"]
    },
    "workPath": {
      "type": "string",
      "description": "工作目录，流水线源文件将被下载到此目录，当配置多个源时可以选择具体的工作目录"
    },
    "sourceId": {
      "type": "string",
      "description": "代码源ID，关联流水线源配置中的sourceId"
    },
    "buildImageModel": {
      "type": "string",
      "enum": ["default", "custom"],
      "default": "default",
      "description": "构建环境模式，default为默认环境，custom为自定义镜像"
    },
    "executeImageId": {
      "type": "string",
      "description": "执行镜像ID，当buildImageModel为custom时需要指定"
    },
    "jdkVersion": {
      "type": "string",
      "description": "JDK版本，从系统预设版本列表中选择",
      "default": "JDK17",
      "examples": ["JDK1.8", "JDK11", "JDK17", "JDK21"]
    },
    "gradleVersion": {
      "type": "string",
      "description": "Gradle版本，从系统预设版本列表中选择",
      "default": "Gradle7.6.3",
      "examples": ["Gradle5.6.4", "Gradle6.9.4", "Gradle7.6.3", "Gradle8.x"]
    },
    "script": {
      "type": "string",
      "description": "Shell命令，支持bash、cmd语法输入命令",
      "default": "gradle build -x test"
    },
    "uploadArtifact": {
      "type": "boolean",
      "default": true,
      "description": "是否上传构建物"
    },
    "artifactPath": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["build/libs/"],
      "description": "制品路径，起始位置为项目文件夹的相对路径"
    },
    "artifactSuffix": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["jar"],
      "description": "制品类型，指定需上传的制品类型；若不指定，将默认上传制品路径下的所有文件",
      "examples": ["jar", "war", "zip", "tar"]
    },
    "artifactCompress": {
      "type": "boolean",
      "default": true,
      "description": "是否压缩制品"
    },
    "compressType": {
      "type": "string",
      "enum": ["TAR(.tgz)", "TAR(.tar.gz)", "ZIP"],
      "default": "TAR(.tgz)",
      "description": "压缩格式"
    },
    "packagedName": {
      "type": "string",
      "maxLength": 200,
      "default": "Artifacts_${PIPELINE_LOG_ID}",
      "description": "压缩包名称，支持固定值例如Artifacts或者动态参数${PIPELINE_LOG_ID}"
    },
    "idInTemplate": {
      "type": "string",
      "description": "模板中的任务ID，用于从模板创建流水线时保持任务引用"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "依赖的任务ID列表"
    }
  }
}
