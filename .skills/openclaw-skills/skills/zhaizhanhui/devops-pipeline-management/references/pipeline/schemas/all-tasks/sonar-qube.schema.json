{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sonar-qube.schema.json",
  "title": "SonarQube Task",
  "description": "SonarQube代码扫描任务配置",
  "type": "object",
  "required": ["taskCategory", "jobType", "name"],
  "properties": {
    "taskCategory": {
      "type": "string",
      "const": "CodeScanner"
    },
    "jobType": {
      "type": "string",
      "const": "SonarQube"
    },
    "name": {
      "type": "string",
      "maxLength": 100,
      "description": "任务名称"
    },
    "workPath": {
      "type": "string",
      "description": "工作目录"
    },
    "sourceId": {
      "type": "string",
      "description": "代码源ID"
    },
    "buildImageModel": {
      "type": "string",
      "enum": ["default", "custom"],
      "default": "default"
    },
    "executeImageId": {
      "type": "string"
    },
    "sonarProjectKey": {
      "type": "string",
      "description": "SonarQube项目Key"
    },
    "sonarProjectName": {
      "type": "string",
      "description": "SonarQube项目名称"
    },
    "script": {
      "type": "string",
      "description": "自定义扫描命令"
    },
    "qualityGate": {
      "type": "boolean",
      "default": false,
      "description": "质量门禁检查"
    },
    "idInTemplate": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  }
}
