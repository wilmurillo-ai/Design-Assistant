{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "python-build.schema.json",
  "title": "PythonBuild Task",
  "description": "Python构建任务配置，用于Python项目的构建和打包",
  "type": "object",
  "required": ["taskCategory", "jobType", "name"],
  "properties": {
    "taskCategory": {
      "type": "string",
      "const": "Build",
      "description": "任务类别，固定为Build"
    },
    "jobType": {
      "type": "string",
      "const": "PythonBuild",
      "description": "任务类型，固定为PythonBuild"
    },
    "name": {
      "type": "string",
      "maxLength": 100,
      "description": "任务名称",
      "examples": ["Python构建"]
    },
    "workPath": {
      "type": "string",
      "description": "工作目录，流水线源文件将被下载到此目录，当配置多个源时可以选择具体的工作目录"
    },
    "sourceId": {
      "type": "string",
      "description": "代码源ID，关联流水线源配置中的sourceId"
    },
    "buildImageModel": {
      "type": "string",
      "enum": ["default", "custom"],
      "default": "default",
      "description": "构建环境模式，default为默认环境，custom为自定义镜像"
    },
    "executeImageId": {
      "type": "string",
      "description": "执行镜像ID，当buildImageModel为custom时需要指定"
    },
    "pythonVersion": {
      "type": "string",
      "description": "Python版本，从系统预设版本列表中选择",
      "default": "Python3.10",
      "examples": ["Python3.8", "Python3.9", "Python3.10", "Python3.11", "Python3.12"]
    },
    "script": {
      "type": "string",
      "description": "Shell命令，支持bash、cmd语法输入命令",
      "default": "pip install -r requirements.txt\npython setup.py build"
    },
    "uploadArtifact": {
      "type": "boolean",
      "default": true,
      "description": "是否上传构建物"
    },
    "artifactPath": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["dist/"],
      "description": "制品路径，起始位置为项目文件夹的相对路径"
    },
    "artifactSuffix": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "制品类型，指定需上传的制品类型；若不指定，将默认上传制品路径下的所有文件"
    },
    "artifactCompress": {
      "type": "boolean",
      "default": true,
      "description": "是否压缩制品"
    },
    "compressType": {
      "type": "string",
      "enum": ["TAR(.tgz)", "TAR(.tar.gz)", "ZIP"],
      "default": "TAR(.tgz)",
      "description": "压缩格式"
    },
    "packagedName": {
      "type": "string",
      "maxLength": 200,
      "default": "Artifacts_${PIPELINE_LOG_ID}",
      "description": "压缩包名称，支持固定值例如Artifacts或者动态参数${PIPELINE_LOG_ID}"
    },
    "idInTemplate": {
      "type": "string",
      "description": "模板中的任务ID，用于从模板创建流水线时保持任务引用"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "依赖的任务ID列表"
    }
  }
}
