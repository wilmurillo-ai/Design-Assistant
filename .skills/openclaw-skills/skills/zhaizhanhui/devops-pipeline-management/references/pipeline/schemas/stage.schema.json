{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "stage.schema.json",
  "title": "Stage",
  "description": "阶段数据结构",
  "type": "object",
  "required": ["id", "name", "nodeType", "steps"],
  "properties": {
    "id": {
      "type": "string",
      "description": "阶段唯一标识"
    },
    "name": {
      "type": "string",
      "description": "阶段名称"
    },
    "nodeType": {
      "type": "string",
      "const": "custom-stage-node",
      "description": "节点类型"
    },
    "bizType": {
      "type": "string",
      "description": "业务类型"
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "step.schema.json"
      },
      "description": "步骤列表"
    }
  }
}
