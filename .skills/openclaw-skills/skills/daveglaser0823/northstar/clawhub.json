{
  "name": "northstar",
  "version": "2.10.0",
  "description": "Daily business briefing for founders running OpenClaw. Pulls Stripe, Shopify, Lemon Squeezy, and Gumroad metrics. Delivers a clean morning briefing via iMessage, Slack, Telegram, or Email.",
  "author": "Dave Glaser via steve-glaser-ops",
  "license": "MIT-0",
  "tags": [
    "business",
    "briefing",
    "stripe",
    "shopify",
    "daily",
    "metrics",
    "revenue",
    "dashboard",
    "founder",
    "saas",
    "ecommerce",
    "gumroad",
    "lemon-squeezy",
    "morning-briefing",
    "iMessage",
    "slack",
    "telegram"
  ],
  "category": "business-intelligence",
  "pricing": {
    "model": "tiered",
    "tiers": [
      {
        "name": "lite",
        "price": 0,
        "period": null,
        "description": "Stripe only, terminal output, manual run"
      },
      {
        "name": "standard",
        "price": 19,
        "period": "month",
        "description": "Stripe + Shopify, all delivery channels, scheduled runs"
      },
      {
        "name": "pro",
        "price": 49,
        "period": "month",
        "description": "Multi-channel delivery, custom metrics, weekly digest"
      }
    ]
  },
  "requirements": {
    "python": ">=3.9",
    "packages": [
      "stripe",
      "requests"
    ],
    "openclaw": ">=1.0.0"
  },
  "commands": {
    "run": "northstar run",
    "test": "northstar test",
    "status": "northstar status"
  },
  "install": {
    "script": "scripts/install.sh"
  },
  "config": {
    "template": "config/northstar.json.example",
    "destination": "~/.clawd/skills/northstar/config/northstar.json"
  },
  "links": {
    "github": "https://github.com/Daveglaser0823/northstar-skill",
    "docs": "https://github.com/Daveglaser0823/northstar-skill/blob/main/SKILL.md",
    "listing": "https://clawhub.ai/Daveglaser0823/northstar"
  },
  "pro_features": [
    "weekly_digest",
    "multi_channel_delivery",
    "custom_metrics",
    "7day_trend_sparkline",
    "monthly_pacing_projection"
  ]
}
