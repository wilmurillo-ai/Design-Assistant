{
  "name": "beep-announcement",
  "version": "2.1.0-dev",
  "description": "Real-time voice announcements for OpenClaw actions. | 实时语音播报AI的一举一动。",
  "display_name": "Beep · 小喇叭",
  "author": "miaoweilin (wililam)",
  "license": "MIT",
  "homepage": "https://github.com/wililam/beep-skills",
  "repository": {
    "type": "git",
    "url": "https://github.com/wililam/beep-skills.git"
  },
  "dependencies": {
    "python": ">=3.9",
    "edge-tts": ">=7.2.8",
    "pygame": ">=2.6.1 (required for Windows, recommended for all platforms)"
  },
  "platforms": {
    "windows": {
      "status": "stable",
      "script": "scripts/announce_pygame.py",
      "dependencies": [
        "edge-tts",
        "pygame"
      ],
      "notes": "必须安装 pygame（Windows 无降级方案）"
    },
    "macos": {
      "status": "stable",
      "recommended": true,
      "script": "scripts/announce.sh",
      "dependencies": [
        "edge-tts",
        "pygame (recommended) or afplay"
      ],
      "notes": "优先安装 pygame，否则使用系统 afplay"
    },
    "linux": {
      "status": "stable",
      "recommended": true,
      "script": "scripts/announce.sh",
      "dependencies": [
        "edge-tts",
        "pygame (recommended) or mpg123"
      ],
      "notes": "优先安装 pygame，否则使用系统 mpg123"
    }
  },
  "supportedLanguages": [
    "zh",
    "en",
    "ja",
    "ko",
    "es",
    "fr",
    "de",
    "ru",
    "pt"
  ],
  "entryPoints": {
    "cli": "beep",
    "compat": "audio-announce",
    "unified": "scripts/announce.py"
  },
  "commands": {
    "beep": {
      "test": "测试所有类型播报",
      "config": "查看/设置配置",
      "verify-integration": "一键集成验证（播放测试音+完整报告）",
      "stats": "查看统计信息",
      "enable": "启用播报",
      "disable": "禁用播报",
      "check": "运行环境自检"
    }
  },
  "capabilities": [
    "text-to-speech",
    "real-time-announcement",
    "queue-system",
    "multi-language",
    "cross-platform",
    "windows-11-support",
    "anti-forgetting",
    "configurable",
    "async-playback",
    "pypi-package",
    "session-start-check",
    "heartbeat-monitoring",
    "local-playback",
    "unified-script",
    "volume-control",
    "one-click-verification",
    "hot-reload-config",
    "lru-cache",
    "structured-logging",
    "retry-mechanism",
    "graceful-degradation"
  ],
  "tags": [
    "tts",
    "audio",
    "announcement",
    "beep",
    "小喇叭",
    "voice",
    "speech",
    "transparency",
    "windows",
    "pygame",
    "anti-forgetting",
    "pypi",
    "session-hook",
    "local-playback",
    "one-click-verify"
  ],
  "minimumOpenClawVersion": "1.0.0",
  "brand": {
    "english_name": "Beep",
    "chinese_name": "小喇叭",
    "full_name": "Beep · 小喇叭",
    "slogan": "让电脑会说话",
    "slogan_en": "Make your computer talk",
    "pronunciation": {
      "en": "/biːp/",
      "zh": "/xiǎo lǎ ba/"
    }
  },
  "changelog": {
    "2.1.0-dev": [
      "新增：一键集成验证命令 beep verify-integration",
      "稳定性增强：重试机制（3次指数退避）、播放降级",
      "配置热重载：`beep config reload` 无需重启",
      "LRU 缓存优化：自动清理旧文件",
      "结构化日志：时间戳+级别+消息",
      "运行时统计：缓存大小、成功率",
      "修复：配置读取bug、方法缺失、函数名错误",
      "品牌升级：Beep · 小喇叭"
    ],
    "2.0.8": [
      "播报本地化",
      "统一包装脚本",
      "默认音量优化",
      "CLI 工具修复",
      "文档全面升级"
    ],
    "2.0.7": [
      "PyPI 支持",
      "配置文件系统",
      "异步默认化",
      "CLI 工具"
    ],
    "2.0.6": [
      "防遗忘机制",
      "快速集成指南",
      "强制规则模板"
    ]
  }
}
