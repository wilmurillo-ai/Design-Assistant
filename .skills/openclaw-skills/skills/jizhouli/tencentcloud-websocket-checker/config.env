# ============================================================
# WebSocket 连接延迟检测工具 - 配置文件
# 功能：定义可自定义的检测参数和性能阈值
# 用法：将此文件放在 ws_check.sh 同级目录下，脚本会自动加载
# ============================================================

# -------------------- 基础配置 --------------------

# 默认测试轮数（1-10）
DEFAULT_ROUNDS=3

# curl 请求超时时间（秒）
CURL_TIMEOUT=15

# 测试轮次间隔时间（秒，支持小数）
ROUND_INTERVAL=0.5

# -------------------- 性能阈值（毫秒） --------------------
# 用于性能评级：
#   ≤ GOOD  → 优秀（绿色）
#   ≤ WARN  → 正常（黄色）
#   >  WARN → 偏慢（红色）

# DNS 解析阈值
DNS_THRESHOLD_GOOD=50
DNS_THRESHOLD_WARN=200

# TCP 连接建立阈值
TCP_THRESHOLD_GOOD=100
TCP_THRESHOLD_WARN=300

# TLS 握手阈值（仅 wss 协议）
TLS_THRESHOLD_GOOD=200
TLS_THRESHOLD_WARN=500

# WebSocket Upgrade 握手阈值
WS_THRESHOLD_GOOD=200
WS_THRESHOLD_WARN=500

# 总体连接建立阈值
TOTAL_THRESHOLD_GOOD=500
TOTAL_THRESHOLD_WARN=1000

# -------------------- 自定义 WebSocket 请求头 --------------------
# 如需添加自定义请求头，可在此处配置
# 格式：CUSTOM_HEADERS=("-H" "Authorization: Bearer your-token" "-H" "X-Custom: value")
# 默认为空
CUSTOM_HEADERS=()

# -------------------- 输出配置 --------------------

# 是否启用彩色输出（true/false）
ENABLE_COLOR=true

# 条形图最大宽度（字符数）
BAR_MAX_WIDTH=30

# -------------------- DNS 配置 --------------------

# 自定义 DNS 服务器（留空则使用系统默认）
# 示例：CUSTOM_DNS_SERVER="8.8.8.8"
CUSTOM_DNS_SERVER=""
