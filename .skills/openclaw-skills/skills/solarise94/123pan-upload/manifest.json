{
  "name": "123pan-upload",
  "version": "1.1.0",
  "description": "Upload files to 123pan and generate shareable links with privacy-friendly short links",
  "entry": "scripts/upload.py",
  "config": {
    "env": [
      "PAN123_ACCESS_TOKEN",
      "PAN123_DIRECT_FOLDER_ID"
    ]
  },
  "inputs": {
    "file": {
      "type": "string",
      "description": "Path to the file to upload",
      "required": true
    },
    "folder": {
      "type": "number",
      "description": "Target folder ID (overrides PAN123_DIRECT_FOLDER_ID)",
      "required": false
    },
    "short-link": {
      "type": "boolean",
      "description": "Return short share link instead of direct link (default: true)",
      "required": false,
      "default": true
    }
  },
  "outputs": {
    "success": {
      "type": "boolean",
      "description": "Whether the upload was successful"
    },
    "file_id": {
      "type": "number",
      "description": "The file ID in 123pan"
    },
    "filename": {
      "type": "string",
      "description": "The uploaded filename"
    },
    "size": {
      "type": "number",
      "description": "File size in bytes"
    },
    "link": {
      "type": "string",
      "description": "The shareable link (short or direct based on options)"
    },
    "link_type": {
      "type": "string",
      "description": "Type of link: 'short_link' or 'direct_link'"
    }
  }
}