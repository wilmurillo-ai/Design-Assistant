    "schemamap": "https://vocab.voyage/schemamap.xml",
    "cliRoadmap": "https://vocab.voyage/cli.md"
  },
  "authentication": {
    "publicApi": "No authentication required for public endpoints.",
    "mcp": "Anonymous tools are available; optional vv_mcp personal tokens support scoped authenticated access.",
    "scopes": ["mcp.read", "mcp.tools", "profile.read", "progress.read"],
    "tokenIssuance": "https://vocab.voyage/mcp",
    "reference": "https://vocab.voyage/developers/auth",
    "oauthProtectedResource": "https://vocab.voyage/.well-known/oauth-protected-resource"
  },
  "nlweb": {
    "ask": "https://gponcrussdahcdyrlhcr.supabase.co/functions/v1/nlweb-ask",
    "method": "POST",
    "body": { "query": "string", "prefer": { "streaming": "boolean" } },
    "responseMeta": { "response_type": "vocab-voyage.nlweb.answer", "version": "1.0.0" },
    "streaming": "Send Accept: text/event-stream OR prefer.streaming=true. Events: start, result, complete."
