# SQL Server connection credentials
# Copy this file to ~/.openclaw/credentials/mssql.env and fill in your values.
# Override this path with the MSSQL_ENV_FILE environment variable if needed.

MSSQL_HOST=your-server.database.windows.net
MSSQL_DB=your_database
MSSQL_USER=your_user
MSSQL_PASSWORD=change_me

# Optional
# MSSQL_PORT=1433
# MSSQL_ENCRYPT=yes
# MSSQL_TRUST_CERT=yes
# SQLCMD_BIN=/opt/mssql-tools18/bin/sqlcmd
