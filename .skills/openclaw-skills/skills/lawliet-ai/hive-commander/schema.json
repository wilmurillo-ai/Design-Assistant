{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "tasks": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "system_prompt": { "type": "string" },
          "user_query": { "type": "string" },
          "api_key": { "type": "string" },
          "base_url": { "type": "string" },
          "model": { "type": "string" }
        },
        "required": ["name", "system_prompt", "user_query", "api_key", "base_url", "model"]
      }
    }
  },
  "required": ["tasks"]
}