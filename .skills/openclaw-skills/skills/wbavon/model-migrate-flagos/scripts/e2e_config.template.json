{
  "_comment": "E2E correctness verification config. Copy to e2e_config.json and fill in actual values.",
  "gt_machine": {
    "host": "<GT_HOST_IP>",
    "ssh_user": "root",
    "ssh_port": 22,
    "ssh_key": "~/.ssh/id_ed25519",
    "docker_container": "<CONTAINER_NAME>",
    "conda_env": "<CONDA_ENV>",
    "vllm_port": 8122,
    "env_vars": {
      "VLLM_FL_PREFER_ENABLED": "false",
      "VLLM_USE_DEEP_GEMM": "0"
    },
    "gpu_ids": "0,1,2,3,4,5,6,7",
    "tensor_parallel_size": 8,
    "extra_serve_args": "--trust-remote-code --load-format fastsafetensors"
  },
  "local": {
    "vllm_port": 8122
  },
  "shared_storage": {
    "models_dir": "/models",
    "results_dir": "./results"
  },
  "eval": {
    "max_tokens": 256,
    "token_match_count": 32,
    "temperature": 0.0,
    "top_p": 1.0,
    "seed": 42
  }
}
