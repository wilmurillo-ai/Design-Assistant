{
  "name": "winforms-to-qt-mapper-enhanced",
  "version": "2.0.0",
  "description": "Enhanced WinForms to Qt migration tool with intelligent mapping and deep code analysis",
  "main": "src/cli/index.js",
  "bin": {
    "winforms-qt-migrate": "src/cli/index.js"
  },
  "scripts": {
    "start": "node src/cli/index.js",
    "analyze": "node src/cli/index.js analyze",
    "migrate": "node src/cli/index.js migrate",
    "validate": "node src/cli/index.js validate",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "benchmark": "node tools/benchmark/index.js",
    "profile": "node tools/profiler/index.js",
    "build": "webpack --config webpack.config.js",
    "docs": "jsdoc -c jsdoc.json"
  },
  "keywords": [
    "winforms",
    "qt",
    "migration",
    "code-conversion",
    "ui-migration",
    "csharp-to-cpp",
    "roslyn",
    "ast-transformation",
    "intelligent-mapping"
  ],
  "author": "RaySense Qt Migration Team",
  "license": "MIT",
  "dependencies": {
    "@microsoft/codeanalysis-csharp": "^4.0.0",
    "@microsoft/codeanalysis-workspaces-msbuild": "^4.0.0",
    "@tensorflow/tfjs": "^4.0.0",
    "brain.js": "^2.0.0",
    "commander": "^11.0.0",
    "inquirer": "^9.0.0",
    "chalk": "^5.0.0",
    "lodash": "^4.17.0",
    "moment": "^2.29.0",
    "yaml": "^2.0.0",
    "xml2js": "^0.6.0",
    "ejs": "^3.1.0",
    "prettier": "^3.0.0",
    "winston": "^3.0.0",
    "pino": "^8.0.0",
    "pino-pretty": "^10.0.0",
    "node-cache": "^5.0.0",
    "axios": "^1.0.0",
    "ws": "^8.0.0",
    "express": "^4.18.0",
    "cors": "^2.8.0",
    "helmet": "^7.0.0",
    "compression": "^1.7.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "supertest": "^6.0.0",
    "puppeteer": "^20.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "babel-loader": "^9.0.0",
    "@babel/core": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "jsdoc": "^4.0.0",
    "nodemon": "^3.0.0",
    "concurrently": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/raysense/winforms-to-qt-mapper.git"
  },
  "bugs": {
    "url": "https://github.com/raysense/winforms-to-qt-mapper/issues"
  },
  "homepage": "https://github.com/raysense/winforms-to-qt-mapper#readme",
  "files": [
    "src/",
    "config/",
    "examples/",
    "docs/",
    "tools/"
  ]
}