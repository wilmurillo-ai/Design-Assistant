{
  "name": "council-of-llms",
  "version": "1.0.0",
  "description": "Multi-model deliberation for high-stakes decisions. Don't take one model's word for it.",
  "author": "Wahaj Ahmed",
  "license": "MIT",
  "category": "productivity",
  "keywords": [
    "council",
    "multi-model",
    "deliberation",
    "debate",
    "decision-making",
    "security",
    "architecture"
  ],
  "requirements": {
    "openclaw": ">=0.5.0",
    "tools": ["sessions_spawn"],
    "optional": ["memory_search"]
  },
  "runtime": {
    "type": "instruction",
    "entry": "SKILL.md"
  },
  "config": {
    "env": {
      "COUNCIL_TIMEOUT": {
        "default": "120",
        "description": "Per-model timeout in seconds"
      },
      "COUNCIL_MAX_TOKENS": {
        "default": "8192",
        "description": "Max tokens per model response"
      },
      "COUNCIL_COST_WARNING": {
        "default": "25000",
        "description": "Token threshold for cost warning"
      }
    },
    "files": [
      "~/.openclaw/council-config.json"
    ]
  },
  "links": {
    "homepage": "https://github.com/wahajahmed010/council-of-llms",
    "repository": "https://github.com/wahajahmed010/council-of-llms",
    "issues": "https://github.com/wahajahmed010/council-of-llms/issues"
  }
}