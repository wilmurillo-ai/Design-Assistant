{
  "name": "lk-order-mcp",
  "version": "1.0.0",
  "description": "瑞幸咖啡订单 MCP 服务，支持一键下单、门店查询、订单管理、支付二维码等功能",
  "author": "LinZaiLong",
  "license": "MIT",
  "tags": [
    "瑞幸",
    "luckin",
    "咖啡",
    "下单",
    "订单",
    "门店",
    "支付",
    "餐饮"
  ],
  "category": "productivity",
  "repository": "https://github.com/your-repo/lk-order-mcp",
  "homepage": "https://clawhub.com/skills/lk-order-mcp",
  "keywords": [
    "瑞幸咖啡",
    "luckin coffee",
    "一键下单",
    "门店查询",
    "订单管理",
    "支付二维码",
    "轻食",
    "饮品"
  ],
  "features": [
    "一键下单 - 说出想喝的，自动完成全流程",
    "门店查询 - 根据经纬度获取附近瑞幸门店",
    "商品浏览 - 获取门店菜单、商品详情",
    "购物车管理 - 添加商品、结算购物车",
    "订单管理 - 查看订单列表、订单详情、取消订单",
    "优惠券管理 - 获取可用优惠券、咖啡钱包",
    "地址管理 - 添加/修改/删除收货地址",
    "支付二维码 - 自动生成支付宝/微信二维码图片"
  ],
  "requirements": {
    "openclaw": ">=2026.3.7",
    "nodejs": ">=14.0.0"
  },
  "configuration": {
    "mcpServer": {
      "name": "lk-order",
      "url": "https://inpre.lkcoffee.com/app/proxymcp",
      "transportType": "streamable-http"
    },
    "token": {
      "required": true,
      "source": "environment|openclaw.json",
      "envName": "LK_ORDER_TOKEN",
      "configPath": "mcpServers.lk-order.headers.Authorization"
    }
  },
  "scripts": {
    "install": "bash install.sh",
    "init": "/home/node/.openclaw/scripts/lkorder-mcp.sh init",
    "quickOrder": "/home/node/.openclaw/scripts/lkorder-mcp.sh call quick_order '{\"keyword\":\"美式\"}'"
  },
  "examples": [
    {
      "name": "一键下单",
      "command": "/home/node/.openclaw/scripts/lkorder-mcp.sh call quick_order '{\"keyword\":\"美式\"}'",
      "description": "快速下单美式咖啡"
    },
    {
      "name": "指定规格下单",
      "command": "/home/node/.openclaw/scripts/lkorder-mcp.sh call quick_order '{\"keyword\":\"拿铁\",\"temperature\":\"热\",\"cup\":\"大杯\"}'",
      "description": "下单热拿铁，大杯"
    },
    {
      "name": "查询附近门店",
      "command": "/home/node/.openclaw/scripts/lkorder-mcp.sh call get_nearby_shops '{\"latitude\":24.5086,\"longitude\":118.1932}'",
      "description": "查询海西金谷广场附近门店"
    },
    {
      "name": "查看订单列表",
      "command": "/home/node/.openclaw/scripts/lkorder-mcp.sh call get_order_list '{\"pageNo\":1}'",
      "description": "查看我的订单列表"
    }
  ],
  "changelog": {
    "1.0.0": [
      "初始版本",
      "支持一键下单、门店查询、订单管理",
      "支持支付二维码图片输出（Markdown 格式）",
      "修复 Token 硬编码安全问题",
      "添加安全配置说明文档"
    ]
  },
  "screenshots": [
    "https://clawhub.com/screenshots/lk-order-mcp/order-success.png",
    "https://clawhub.com/screenshots/lk-order-mcp/payment-qr.png"
  ],
  "relatedSkills": [
    "wecom-schedule",
    "feishu-task"
  ]
}
