    "index.js",
    "plugin.js",
    "openclaw.plugin.json",
    "README.md",
    "README_ZH.md",
    "SECURITY.md",
    "PRIVACY.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./index.js"
    ]
  },
