# VAIBot Guard (user service) environment

# Required for service auth (recommended)
# VAIBOT_GUARD_TOKEN=

# Policy file
# VAIBOT_POLICY_PATH=references/policy.default.json

# Service bind
# VAIBOT_GUARD_HOST=127.0.0.1
# VAIBOT_GUARD_PORT=39111

# Workspace + logs
# VAIBOT_WORKSPACE=
# VAIBOT_GUARD_LOG_DIR=

# VAIBot anchoring
# VAIBOT_API_URL=https://www.vaibot.io/api
# VAIBOT_API_KEY=
# VAIBOT_PROVE_MODEL=vaibot-guard
# VAIBOT_PROVE_MODE=best-effort

# Checkpoint cadence
# VAIBOT_MERKLE_CHECKPOINT_EVERY=50
# VAIBOT_MERKLE_CHECKPOINT_EVERY_MS=600000
