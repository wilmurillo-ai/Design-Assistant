{
  "version": "0.1",
  "denyTokens": [
    "systemctl",
    "service",
    "launchctl",
    "crontab",
    "cron",
    "ssh",
    "scp",
    "rsync",
    "apt",
    "apt-get",
    "dnf",
    "yum",
    "brew",
    "pacman"
  ],
  "approveTokens": ["curl", "wget"],
  "allowlistedDomains": ["example.com"],
  "allowlistedDomainsNotes": "Exact-match only. Use '*.example.com' to allow subdomains.",
  "denyPaths": ["~/.ssh", "/etc", "/var/lib"],
  "redactPatterns": [
    "(?i)bearer\\s+[A-Za-z0-9._-]+",
    "(?i)api[_-]?key\\s*[:=]\\s*[^\\s]+",
    "(?i)token\\s*[:=]\\s*[^\\s]+",
    "(?i)secret\\s*[:=]\\s*[^\\s]+",
    "(?i)password\\s*[:=]\\s*[^\\s]+"
  ],
  "redactEnvKeyPatterns": ["(?i)key", "(?i)token", "(?i)secret", "(?i)pass"],
  "fileMutationOutsideWorkspaceAction": "deny",
  "fileMutationDeniedPathAction": "deny"
}
