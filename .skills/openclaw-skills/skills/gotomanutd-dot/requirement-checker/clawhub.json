    "directory": "skills/requirement-checker"
  },
  "keywords": [
    "需求文档",
    "规范检查",
    "AI 检查",
    "GWT 验收",
    "系统对接",
    "金融需求",
    "温柔话术",
    "建议分级",
    "openclaw-skill"
  ],
  "engines": {
    "openclaw": ">=2026.2.26"
  },
  "dependencies": {
    "python": ">=3.7"
  },
  "files": [
    "SKILL.md",
    "README.md",
    "install.json",
    "_meta.json",
    "requirements.txt",
    "scripts/",
    "references/"
  ],
  "scripts": {
    "test": "bash scripts/test.sh",
    "verify": "test -f SKILL.md && echo '✅ 技能文件验证通过'",
    "postinstall": "node scripts/postinstall.js"
  },
  "publishConfig": {
