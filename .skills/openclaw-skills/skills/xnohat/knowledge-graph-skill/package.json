{
  "name": "knowledge-graph",
  "version": "1.1.1",
  "description": "Embedded knowledge graph skill for AI agents. JSON storage, hybrid search (trigram + BM25), KGML summary format, script-driven article extraction, interactive visualization, encrypted vault. Zero external dependencies.",
  "type": "module",
  "license": "MIT",
  "author": "Annie & xnohat <xnohat@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/knowledge-graph"
  },
  "keywords": [
    "knowledge-graph",
    "agent-skill",
    "openclaw",
    "claude",
    "gemini",
    "rag",
    "kg",
    "agentic"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "install-skill": "node scripts/install.mjs",
    "summarize": "node scripts/summarize.mjs",
    "consolidate": "node scripts/consolidate.mjs",
    "visualize": "node scripts/visualize.mjs",
    "test": "node scripts/test-retrieval.mjs",
    "test:verbose": "node scripts/test-retrieval.mjs --verbose"
  }
}
