{
    "_comment": "PDF style configuration. Edit this file if you want to customize the report appearance.",
    "_version": "1.0",
    
    "page": {
        "size": "A4",
        "margin_top": 2.0,
        "margin_bottom": 2.0,
        "margin_left": 2.5,
        "margin_right": 2.5,
        "unit": "cm"
    },
    
    "colors": {
        "primary": "#2E86AB",
        "secondary": "#F6F6F6",
        "accent": "#E94F37",
        "text_main": "#000000",
        "text_light": "#666666",
        "success": "#28A745",
        "warning": "#FFC107",
        "danger": "#DC3545",
        "table_header_bg": "#F8F9FA",
        "table_border": "#DEE2E6"
    },
    
    "fonts": {
        "main": "NotoSansSC-Regular",
        "main_bold": "NotoSansSC-Bold",
        "main_italic": "NotoSansSC-Italic",
        "size_title": 18,
        "size_heading": 14,
        "size_body": 10,
        "size_small": 8
    },
    
    "logo": {
        "enabled": false,
        "path": "logo.png",
        "width": 3.0,
        "height": 1.0,
        "position": "top-right",
        "unit": "cm"
    },
    
    "header": {
        "show_date": true,
        "show_user_name": true,
        "background_color": "#F8F9FA",
        "height": 2.0,
        "unit": "cm"
    },
    
    "footer": {
        "show_page_number": true,
        "show_generated_time": true,
        "text": "Generated by OpenClaw Health Report Skill",
        "height": 1.5,
        "unit": "cm"
    },
    
    "sections": {
        "summary": {
            "show": true,
            "background_color": "#E3F2FD",
            "border_radius": 5
        },
        "scores": {
            "show_stars": true,
            "show_comments": true,
            "table_style": "striped"
        },
        "analysis": {
            "show_good": true,
            "show_improve": true,
            "use_icons": true
        },
        "nutrition": {
            "show_table": true,
            "show_chart": false
        },
        "recommendations": {
            "show": true,
            "max_items": 5
        }
    },
    
    "charts": {
        "enabled": false,
        "type": "bar",
        "colors": ["#2E86AB", "#F6F6F6", "#E94F37", "#28A745"],
        "show_values": true,
        "width": 15.0,
        "height": 8.0,
        "unit": "cm"
    }
}
