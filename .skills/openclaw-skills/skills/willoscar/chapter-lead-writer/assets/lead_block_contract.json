{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/chapter-lead-writer/lead-block-contract.schema.json",
  "title": "Chapter Lead Block Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "section_id",
    "section_title",
    "output_path",
    "body_only",
    "max_paragraphs",
    "must_not_have_headings",
    "may_add_new_facts",
    "citation_scope",
    "compatibility_mode"
  ],
  "properties": {
    "section_id": {
      "type": "string",
      "minLength": 1
    },
    "section_title": {
      "type": "string",
      "minLength": 1
    },
    "output_path": {
      "type": "string",
      "pattern": "^sections/S[^/]+_lead\\.md$"
    },
    "body_only": {
      "type": "boolean",
      "const": true
    },
    "max_paragraphs": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "must_not_have_headings": {
      "type": "boolean",
      "const": true
    },
    "may_add_new_facts": {
      "type": "boolean",
      "const": false
    },
    "citation_scope": {
      "type": "string",
      "enum": [
        "chapter-only",
        "chapter-or-selected-crosscutting"
      ]
    },
    "compatibility_mode": {
      "type": "boolean"
    }
  }
}
