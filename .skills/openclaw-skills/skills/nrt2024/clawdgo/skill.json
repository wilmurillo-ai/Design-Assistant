  "sideEffects": {
    "fileWrites": [],
    "autonomousModes": [
      {
        "mode": "B self-train",
        "description": "先选择前台/后台形态；前台默认配置 cron 自动逐场推送，后台批次训练后汇总。"
      },
      {
        "mode": "F arena",
        "description": "5 轮连续红蓝对抗，可由用户发送暂停/退出中断。"
      },
      {
        "mode": "H internal-test",
        "description": "联网斗虾处于内测提示阶段，不执行任何 duel 子命令。"
      }
    ],
    "cronNote": "B/H 模式包含 cron 示例；执行失败必须返回真实错误，不得伪造成功。"
  },
