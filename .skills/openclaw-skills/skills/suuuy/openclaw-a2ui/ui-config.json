{
  "version": 1,
  "description": "A2UI rich card rendering for OpenClaw webchat",
  "dompurify": {
    "allowedTags": [
      "div", "span", "section", "article", "header", "footer",
      "h1", "h2", "h3", "h4", "h5", "h6",
      "p", "ul", "ol", "li",
      "strong", "em", "b", "i", "code", "pre",
      "a", "img", "figure", "figcaption",
      "table", "thead", "tbody", "tr", "th", "td",
      "details", "summary",
      "hr", "br",
      "button", "label",
      "svg", "path", "circle", "rect", "polyline", "polygon", "line"
    ],
    "allowedAttrs": [
      "class", "style", "id",
      "href", "target", "rel",
      "src", "alt", "width", "height",
      "data-card", "data-type", "data-action", "data-value",
      "open", "title",
      "viewBox", "fill", "stroke", "stroke-width", "stroke-linecap", "stroke-linejoin",
      "d", "cx", "cy", "r", "x", "y", "x1", "y1", "x2", "y2", "points",
      "xmlns"
    ]
  },
  "markdown": {
    "allowRawHTML": true
  },
  "customCSS": ""
}
