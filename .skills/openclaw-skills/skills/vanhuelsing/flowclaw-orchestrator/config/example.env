# FlowClaw Configuration
# Copy this file to .env and fill in your values.
#
# SECURITY: Never commit your .env file to version control.
# Add ".env" to your .gitignore.
#
# NOTE: FlowClaw only reads credentials from environment variables and .env files
# by default. Set FLOWCLAW_LOAD_OPENCLAW_CONFIG=true to also load from
# ~/.openclaw/openclaw.json (see Credential Isolation section below).

# ── Core (Required) ──────────────────────────────────
# Required: API key for authenticating ALL requests to FlowClaw.
# Generate a strong random value: openssl rand -hex 32
WORKFLOW_EXECUTOR_API_KEY=your-secret-api-key-here

# Required: Notion integration token (starts with "secret_...")
NOTION_API_KEY=your-notion-api-key

# Required for /notion/create-subtask endpoint: Notion database ID (UUID)
# Find it in the Notion page URL: notion.so/your-workspace/<DATABASE_ID>?v=...
NOTION_TASKS_DATABASE_ID=your-notion-database-id-here

# Server port (default: 8765)
PORT=8765

# Bind address
# 127.0.0.1 = local only (recommended for production)
# 0.0.0.0   = all interfaces (only if running behind a reverse proxy with auth)
HOST=127.0.0.1

# ── Credential Isolation ─────────────────────────────
# By default, FlowClaw only reads credentials from environment variables
# and .env files. Set this to "true" to also load missing credentials
# from ~/.openclaw/openclaw.json. Only enable this if you understand
# that ALL credentials in your OpenClaw config become accessible to FlowClaw.
FLOWCLAW_LOAD_OPENCLAW_CONFIG=false

# ── Discord (Optional) ───────────────────────────────
# Discord bot token for notifications (requires Send Messages permission)
DISCORD_BOT_TOKEN=your-discord-bot-token

# Discord channel IDs — must match exactly what's in your Discord server.
# Copy the channel ID from Discord: right-click channel → Copy ID
# (Requires Developer Mode enabled in Discord settings)
# Channels left empty ("") will be treated as disabled — notifications are skipped.
DISCORD_CHANNEL_PROJECT_UPDATES=
DISCORD_CHANNEL_PROJECT_CALLS=
DISCORD_CHANNEL_CHATTERIA=

# ── Other Integrations (Optional) ────────────────────
# n8n API key — used if FlowClaw needs to call n8n webhooks
N8N_API_KEY=your-n8n-api-key

# OpenClaw gateway URL — for agent dispatch via sessions_spawn
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# OpenClaw gateway token — required for authenticated gateway connections.
# Optional: only needed when your OpenClaw gateway requires authentication
# (i.e. FLOWCLAW_LOAD_OPENCLAW_CONFIG=false and the gateway has auth enabled).
# If FLOWCLAW_LOAD_OPENCLAW_CONFIG=true, FlowClaw will auto-read this token from
# ~/.openclaw/openclaw.json. Leave empty ("") to disable token auth.
OPENCLAW_GATEWAY_TOKEN=

# ── Performance ──────────────────────────────────────
# Gunicorn worker count (recommended: 2× CPU cores)
MAX_WORKERS=4
