{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FlowClaw Workflow",
  "description": "Schema for FlowClaw Workflow Executor YAML workflow files",
  "type": "object",
  "required": ["name", "version", "steps"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable workflow name"
    },
    "description": {
      "type": "string",
      "description": "Optional description of what this workflow does"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g. 1.0.0)"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of step definitions",
      "items": {
        "type": "object",
        "minProperties": 1,
        "maxProperties": 1,
        "additionalProperties": {
          "oneOf": [
            {"type": "object"},
            {"type": "null"}
          ]
        }
      }
    }
  },
  "additionalProperties": false
}
