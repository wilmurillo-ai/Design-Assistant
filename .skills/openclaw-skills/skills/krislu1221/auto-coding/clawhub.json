{
  "name": "auto-coding",
  "version": "3.2.0",
  "description": "自主完善的编程系统 - 多模型交叉验证、自动测试、能力补充",
  "author": "Claw Soft Team",
  "license": "MIT",
  "keywords": [
    "auto-coding",
    "multi-model",
    "cross-validation",
    "autonomous",
    "testing",
    "openclaw"
  ],
  "engines": {
    "openclaw": ">=2025.1.0"
  },
  "files": [
    "SKILL.md",
    "skill.py",
    "auto_coding_worker.py",
    "cross_model_validator.py",
    "task_decomposer.py",
    "security.py",
    "task_manager.py",
    "agent_controller.py",
    "self_reflection.py",
    "__init__.py",
    "prompts/",
    "tests/"
  ],
  "main": "skill.py",
  "config": {
    "triggers": ["/auto-coding", "/autonomous-coding"],
    "userInvocable": true,
    "envVars": {
      "AUTO_CODING_ALLOWED_PATHS": {
        "description": "允许的基础路径（逗号分隔）",
        "default": "~/.enhance-claw,/tmp/auto-coding-projects"
      },
      "AUTO_CODING_MAX_INPUT_LENGTH": {
        "description": "最大输入长度",
        "default": "10000"
      },
      "AUTO_CODING_PROJECTS_DIR": {
        "description": "项目目录",
        "default": "/tmp/auto-coding-projects"
      },
      "MAX_ITERATIONS": {
        "description": "最大迭代次数",
        "default": "50"
      },
      "AUTO_CODING_MODEL_IMPLEMENTER": {
        "description": "实现代码的模型ID",
        "default": "default-implementer"
      },
      "AUTO_CODING_MODEL_REVIEWER": {
        "description": "审查代码的模型ID",
        "default": "default-reviewer"
      },
      "AUTO_CODING_MODEL_TESTER": {
        "description": "设计测试的模型ID",
        "default": "default-tester"
      },
      "AUTO_CODING_MODEL_FIXER": {
        "description": "修复问题的模型ID",
        "default": "default-fixer"
      },
      "AUTO_CODING_MODELS_CONFIG": {
        "description": "模型配置文件路径（可选）",
        "default": ""
      }
    }
  }
}