{
  "id": "Arshis-Game-Design-Pro",
  "name": "Arshis Game Design Pro",
  "description": "商业级游戏策划专业工具 - 完整策划案生成/评审/世界观管理",
  "version": "1.0.0",
  "author": "Arshis",
  "main": "index.js",
  "type": "module",
  "engines": {
    "openclaw": ">=2026.4.0"
  },
  "tools": [
    {
      "name": "generate_design",
      "description": "生成完整游戏策划案（世界观/系统/数值/关卡/剧情）",
      "inputSchema": {
        "type": "object",
        "properties": {
          "doc_type": {
            "type": "string",
            "enum": ["worldview", "system", "numeric", "level", "story"],
            "description": "文档类型"
          },
          "topic": {
            "type": "string",
            "description": "策划案主题"
          },
          "details": {
            "type": "string",
            "description": "详细要求"
          },
          "word_count": {
            "type": "number",
            "default": 5000,
            "description": "目标字数"
          }
        },
        "required": ["doc_type", "topic"]
      }
    },
    {
      "name": "modify_design_section",
      "description": "修改策划案的特定章节（带版本管理）",
      "inputSchema": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string",
            "default": "v1.0",
            "description": "当前版本号"
          },
          "section": {
            "type": "string",
            "description": "章节名（如'数值设计'、'战斗系统'）"
          },
          "content": {
            "type": "string",
            "description": "新章节内容"
          },
          "change_log": {
            "type": "string",
            "description": "修改日志"
          }
        },
        "required": ["section", "content"]
      }
    },
    {
      "name": "save_version",
      "description": "保存策划案版本",
      "inputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "策划案内容"
          },
          "version": {
            "type": "string",
            "description": "版本号（如 v1.0, v1.1）"
          },
          "change_log": {
            "type": "string",
            "description": "修改日志"
          },
          "project": {
            "type": "string",
            "default": "default",
            "description": "项目名称"
          }
        },
        "required": ["content", "version"]
      }
    },
    {
      "name": "compare_versions",
      "description": "对比两个版本的差异",
      "inputSchema": {
        "type": "object",
        "properties": {
          "version1": {
            "type": "string",
            "description": "版本号 1"
          },
          "version2": {
            "type": "string",
            "description": "版本号 2"
          },
          "project": {
            "type": "string",
            "default": "default",
            "description": "项目名称"
          }
        },
        "required": ["version1", "version2"]
      }
    },
    {
      "name": "list_versions",
      "description": "列出所有版本",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project": {
            "type": "string",
            "default": "default",
            "description": "项目名称"
          }
        }
      }
    },
    {
      "name": "list_templates",
      "description": "列出所有可用策划案模板（新角色/新活动/新系统等）",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "get_template",
      "description": "获取指定类型的策划案模板",
      "inputSchema": {
        "type": "object",
        "properties": {
          "template_type": {
            "type": "string",
            "enum": ["new_character", "new_activity", "new_system", "version_update", "numeric_adjustment"],
            "description": "模板类型"
          }
        },
        "required": ["template_type"]
      }
    },
    {
      "name": "generate_from_template",
      "description": "从模板生成策划案（支持填充数据）",
      "inputSchema": {
        "type": "object",
        "properties": {
          "template_type": {
            "type": "string",
            "enum": ["new_character", "new_activity", "new_system", "version_update", "numeric_adjustment"],
            "description": "模板类型"
          },
          "fill_data": {
            "type": "object",
            "description": "填充数据（键值对）"
          }
        },
        "required": ["template_type"]
      }
    },
    {
      "name": "check_consistency",
      "description": "检查新内容的一致性（世界观/数值/技能冲突检测）",
      "inputSchema": {
        "type": "object",
        "properties": {
          "content_type": {
            "type": "string",
            "enum": ["character", "activity", "system"],
            "description": "内容类型"
          },
          "content_data": {
            "type": "object",
            "description": "内容数据"
          }
        },
        "required": ["content_type", "content_data"]
      }
    }
    {
      "name": "review_design",
      "description": "评审游戏策划案，提供完整性检查、风险识别、优化建议",
      "inputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "策划案内容"
          },
          "doc_type": {
            "type": "string",
            "default": "system",
            "description": "文档类型"
          }
        },
        "required": ["content"]
      }
    },
    {
      "name": "store_worldview",
      "description": "存储世界观设定到记忆系统（永久保存）",
      "inputSchema": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": ["worldview", "character", "faction", "location", "history"],
            "description": "设定分类"
          },
          "content": {
            "type": "string",
            "description": "设定内容"
          },
          "importance": {
            "type": "number",
            "default": 0.9,
            "description": "重要性（世界观默认 0.9，永久保存）"
          }
        },
        "required": ["category", "content"]
      }
    },
    {
      "name": "query_worldview",
      "description": "查询世界观设定",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "查询关键词"
          },
          "limit": {
            "type": "number",
            "default": 10,
            "description": "返回数量"
          }
        },
        "required": ["query"]
      }
    },
    {
      "name": "check_consistency",
      "description": "检查新世界观设定与现有设定的一致性",
      "inputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "新设定内容"
          }
        },
        "required": ["content"]
      }
    }
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "autoSaveWorldview": {
        "type": "boolean",
        "default": true,
        "description": "自动生成世界观时自动保存"
      },
      "defaultWordCount": {
        "type": "number",
        "default": 5000,
        "description": "默认生成字数"
      }
    }
  }
}
