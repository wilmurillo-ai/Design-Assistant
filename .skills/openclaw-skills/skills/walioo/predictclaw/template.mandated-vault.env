# Internal / compatibility vault bootstrap template.
# This is NOT a standalone user-facing mode.
# Use it only when you intentionally need the internal mandated-vault bootstrap subflow
# that creates or prepares a vault for the user-facing `predict-account + vault` route.

PREDICT_STORAGE_DIR=~/.openclaw/predict
PREDICT_ENV=mainnet
PREDICT_API_BASE_URL=https://api.predict.fun
PREDICT_WALLET_MODE=mandated-vault
PREDICT_API_KEY=YOUR_PREDICT_API_KEY
PREDICT_EOA_PRIVATE_KEY=0xYOUR_EOA_PRIVATE_KEY

ERC_MANDATED_MCP_COMMAND=erc-mandated-mcp
ERC_MANDATED_CHAIN_ID=56
ERC_MANDATED_FUNDING_MAX_AMOUNT_PER_TX=
ERC_MANDATED_FUNDING_MAX_AMOUNT_PER_WINDOW=
ERC_MANDATED_FUNDING_WINDOW_SECONDS=
ERC_MANDATED_BOOTSTRAP_PRIVATE_KEY=
ERC_MANDATED_ENABLE_BROADCAST=

# If the runtime is missing, run:
# uv run python scripts/predictclaw.py setup mandated-mcp --install --write-env
# Product default factory: 0x6eFC613Ece5D95e4a7b69B4EddD332CeeCbb61c6
# Preview without broadcasting:
#   uv run python scripts/predictclaw.py wallet bootstrap-vault --json
# Confirm and broadcast:
#   uv run python scripts/predictclaw.py wallet bootstrap-vault --confirm --json
# `--confirm` auto-enables the MCP broadcast gate and bridges the bootstrap signer key.
# Only set ERC_MANDATED_BOOTSTRAP_PRIVATE_KEY / ERC_MANDATED_ENABLE_BROADCAST to override that behavior.
# Inspect the resulting vault permission model:
#   uv run python scripts/predictclaw.py wallet status --json
# Preview vault-share redeemability before any real exit path:
#   uv run python scripts/predictclaw.py wallet redeem-vault --share-token <vault_share_token> --holder <holder> --all --preview --json
# After success PredictClaw backfills ERC_MANDATED_VAULT_ADDRESS and resolved values into .env.
# Advanced/manual escape hatches for explicit vault address or full derivation tuple remain documented in README.md / SKILL.md.
