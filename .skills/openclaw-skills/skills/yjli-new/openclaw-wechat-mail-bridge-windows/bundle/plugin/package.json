{
  "name": "openclaw-wechat-mail-bridge-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw plugin-first WeChat to mail bridge",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
