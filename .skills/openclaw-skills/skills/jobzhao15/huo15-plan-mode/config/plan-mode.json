{
  "version": "1.0",
  "mode": "normal",
  "autoConfirmLowRisk": true,
  "notifyOnCancel": true,
  "dangerousOperations": {
    "high": [
      "rm -rf",
      "rm -r",
      "trash",
      "unlink",
      "kill",
      "pkill",
      "git push --force",
      "git push -f",
      "shutdown",
      "reboot",
      ">~/.zshrc",
      ">~/.bashrc",
      "chmod 777",
      "chown root"
    ],
    "medium": [
      "curl",
      "wget",
      "npm install",
      "pip install",
      "apt install",
      "yum install",
      "docker rm",
      "docker rmi",
      "git push",
      "git commit",
      "ssh",
      "scp"
    ],
    "low": [
      "cat",
      "ls",
      "pwd",
      "git status",
      "find",
      "grep",
      "head",
      "tail"
    ]
  },
  "confirmMessages": {
    "high": "⚠️ 高危操作！此操作可能导致数据永久丢失。确认执行？",
    "medium": "⚠️ 中危操作。此操作可能影响系统状态。确认执行？",
    "low": "低危操作，是否确认？"
  }
}
