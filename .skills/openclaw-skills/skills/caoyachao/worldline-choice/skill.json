{
  "name": "worldline-choice",
  "version": "4.4.1",
  "description": "AI驱动互动叙事游戏引擎 v4.4.1 - 强制自动保存版。在v4.4.0基础上增加每回合强制自动保存机制，引擎层强制执行，LLM只需读取保存状态。禁止保存相关幻觉行为。",
  "author": "Worldline Team",
  "entry": "worldline_skill.py",
  "runtime": "python3",
  "tools": [
    {
      "name": "start_game",
      "description": "开始一个新的Worldline Choice游戏会话",
      "parameters": {
        "type": "object",
        "properties": {
          "world_setting": {
            "type": "string",
            "description": "游戏世界观设定，例如：武侠、赛博朋克、克苏鲁、现代都市等"
          },
          "player_role": {
            "type": "string",
            "description": "玩家角色类型，例如：剑客、黑客、侦探、法师等"
          },
          "player_name": {
            "type": "string",
            "description": "玩家角色姓名"
          },
          "world_description": {
            "type": "string",
            "description": "可选的世界观详细描述"
          }
        },
        "required": ["world_setting", "player_role", "player_name"]
      }
    },
    {
      "name": "process_turn",
      "description": "处理玩家的一个游戏回合。分析意图、执行d20检定、生成叙事。支持外部战术加成修正DC和应用优势/劣势",
      "parameters": {
        "type": "object",
        "properties": {
          "player_input": {
            "type": "string",
            "description": "玩家的自然语言行动描述"
          },
          "dc_modifier": {
            "type": "integer",
            "description": "外部DC修正值（例如来自前置准备或环境互动的加成），默认0"
          },
          "advantage": {
            "type": "boolean",
            "description": "是否拥有优势（如NPC协助成功或环境互动激活），默认false"
          },
          "disadvantage": {
            "type": "boolean",
            "description": "是否处于劣势，默认false"
          }
        },
        "required": ["player_input"]
      }
    },
    {
      "name": "analyze_action",
      "description": "分析玩家行动的意图、难度和可能后果（不执行检定）",
      "parameters": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "description": "玩家行动描述"
          }
        },
        "required": ["action"]
      }
    },
    {
      "name": "execute_check",
      "description": "执行d20检定（客观判定，不涉及LLM）",
      "parameters": {
        "type": "object",
        "properties": {
          "attribute": {
            "type": "string",
            "enum": ["FORCE", "MIND", "INFLUENCE", "REFLEX", "RESILIENCE", "LUCK"],
            "description": "检定时使用的属性"
          },
          "dc": {
            "type": "integer",
            "description": "难度等级（5-25）"
          },
          "advantage": {
            "type": "boolean",
            "description": "是否有优势"
          },
          "disadvantage": {
            "type": "boolean",
            "description": "是否有劣势"
          }
        },
        "required": ["attribute", "dc"]
      }
    },
    {
      "name": "generate_narrative",
      "description": "基于骰子结果生成叙事描述",
      "parameters": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "description": "原始行动描述"
          },
          "intention": {
            "type": "string",
            "description": "行动意图"
          },
          "check_result": {
            "type": "object",
            "description": "d20检定结果"
          },
          "world_setting": {
            "type": "string",
            "description": "世界观"
          }
        },
        "required": ["action", "intention", "check_result", "world_setting"]
      }
    },
    {
      "name": "generate_turn_options",
      "description": "生成本回合的ABCD预定义选项和E自由选项",
      "parameters": {
        "type": "object",
        "properties": {
          "previous_result": {
            "type": "object",
            "description": "上一回合的结果（可选）"
          }
        }
      }
    },
    {
      "name": "process_option",
      "description": "处理玩家选择的选项（A/B/C/D/E）",
      "parameters": {
        "type": "object",
        "properties": {
          "choice": {
            "type": "string",
            "enum": ["A", "B", "C", "D", "E"],
            "description": "玩家选择的选项"
          },
          "free_text": {
            "type": "string",
            "description": "如果选E，玩家的自由输入文本"
          }
        },
        "required": ["choice"]
      }
    },
    {
      "name": "save_game",
      "description": "保存当前游戏状态",
      "parameters": {
        "type": "object",
        "properties": {
          "save_id": {
            "type": "string",
            "description": "存档标识"
          }
        },
        "required": ["save_id"]
      }
    },
    {
      "name": "load_game",
      "description": "加载游戏存档",
      "parameters": {
        "type": "object",
        "properties": {
          "save_id": {
            "type": "string",
            "description": "存档标识"
          }
        },
        "required": ["save_id"]
      }
    },
    {
      "name": "get_game_state",
      "description": "获取当前游戏状态摘要",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "set_scene_objects",
      "description": "设置当前场景中的可互动物体（环境互动系统）",
      "parameters": {
        "type": "object",
        "properties": {
          "objects": {
            "type": "array",
            "description": "场景物体列表，每个元素包含 id, name, description, interaction_hint, benefit"
          }
        },
        "required": ["objects"]
      }
    },
    {
      "name": "interact_with_scene_object",
      "description": "玩家与场景中的指定物体互动。成功后该物体对应的 benefit 会自动加入 active_benefits",
      "parameters": {
        "type": "object",
        "properties": {
          "object_id": {
            "type": "string",
            "description": "物体ID"
          },
          "player_input": {
            "type": "string",
            "description": "玩家的互动行动描述"
          }
        },
        "required": ["object_id", "player_input"]
      }
    },
    {
      "name": "execute_npc_check",
      "description": "执行NPC的协助检定。成功后自动为玩家添加一个 active_benefit",
      "parameters": {
        "type": "object",
        "properties": {
          "npc_name": {
            "type": "string",
            "description": "NPC名称"
          },
          "action": {
            "type": "string",
            "description": "NPC执行的行动描述"
          },
          "attribute": {
            "type": "string",
            "enum": ["FORCE", "MIND", "INFLUENCE", "REFLEX", "RESILIENCE", "LUCK"],
            "description": "检定时使用的属性"
          },
          "dc": {
            "type": "integer",
            "description": "难度等级"
          }
        },
        "required": ["npc_name", "action", "attribute", "dc"]
      }
    },
    {
      "name": "add_active_benefit",
      "description": "手动添加一个战术加成（通常用于记录玩家的前置准备成功）",
      "parameters": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "加成名称"
          },
          "description": {
            "type": "string",
            "description": "加成描述"
          },
          "dc_modifier": {
            "type": "integer",
            "description": "DC修正值，例如-3表示降低3点DC"
          },
          "advantage": {
            "type": "boolean",
            "description": "是否提供优势"
          },
          "applies_to": {
            "type": "array",
            "items": { "type": "string" },
            "description": "适用属性列表，空数组表示适用所有属性"
          },
          "remaining_uses": {
            "type": "integer",
            "description": "可使用次数，默认1"
          }
        },
        "required": ["name", "description"]
      }
    },
    {
      "name": "consume_active_benefit",
      "description": "按名称消耗一个 active_benefit",
      "parameters": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "要消耗的加成名称"
          }
        },
        "required": ["name"]
      }
    },
    {
      "name": "get_active_benefits",
      "description": "获取当前所有可用的战术加成，可按属性过滤",
      "parameters": {
        "type": "object",
        "properties": {
          "filter_attribute": {
            "type": "string",
            "description": "可选，过滤适用某属性的加成"
          }
        }
      }
    },
    {
      "name": "calculate_effective_dc",
      "description": "计算经过所有可用加成后的最终 DC 和 advantage 状态",
      "parameters": {
        "type": "object",
        "properties": {
          "base_dc": {
            "type": "integer",
            "description": "基础DC"
          },
          "attribute": {
            "type": "string",
            "description": "本次行动使用的属性"
          }
        },
        "required": ["base_dc", "attribute"]
      }
    }
  ]
}
