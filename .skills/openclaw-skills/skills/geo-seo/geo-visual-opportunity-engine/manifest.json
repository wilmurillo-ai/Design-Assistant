{
  "name": "ecommerce-automator",
  "version": "3.0.5",
  "display_name": "电商 Automator (E-commerce Automator)",
  "display_name_en": "E-commerce Automator",
  "description": "AI-powered commerce workflow that generates product images using Nano Banana 2 and prepares export-ready assets for Shopify and WooCommerce/WordPress, with direct export only when explicitly enabled.",
  "author": {
    "name": "Tim",
    "email": "sales@dageno.ai",
    "website": "https://dageno.ai/"
  },
  "tags": [
    "ecommerce",
    "automation",
    "shopify",
    "woocommerce",
    "wordpress",
    "ai-images",
    "nano-banana-2",
    "product-listing",
    "dropshipping"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GEO-SEO/geo-visual-opportunity-engine"
  },
  "entry_point": "src/main.py",
  "model_config": {
    "temperature": 0.7,
    "top_p": 0.9,
    "presence_penalty": 0.3,
    "max_tokens": 8000
  },
  "platforms": [
    "shopify",
    "woocommerce",
    "wordpress",
    "python"
  ],
  "languages_supported": [
    "en",
    "zh",
    "ja",
    "es",
    "fr",
    "de",
    "ko",
    "pt",
    "it",
    "ru"
  ],
  "integrations": {
    "image_generation": {
      "provider": "nano-banana-2",
      "model": "gemini-2.5-flash-image",
      "api_env_var": "GOOGLE_API_KEY",
      "supported_styles": [
        "white_info",
        "lifestyle",
        "hero"
      ]
    },
    "shopify_export": {
      "api_env_vars": [
        "SHOPIFY_STORE_URL",
        "SHOPIFY_ACCESS_TOKEN"
      ]
    },
    "woocommerce_export": {
      "api_env_vars": [
        "WOOCOMMERCE_STORE_URL",
        "WOOCOMMERCE_CONSUMER_KEY",
        "WOOCOMMERCE_CONSUMER_SECRET"
      ]
    }
  },
  "created_at": "2025-03-10",
  "updated_at": "2026-02-28",
  "metadata": {
    "schema_version": "3.0",
    "skill_type": "ecommerce-automation",
    "output_format": "application/json",
    "network_access": "required for image generation and optional for commerce publishing",
    "minimum_permissions": "image generation requires GOOGLE_API_KEY; direct platform export requires only the credentials for the enabled target",
    "data_access_policy": "Analysis, asset generation, and export packaging can run without store credentials. Direct platform export is opt-in only and should not be assumed by default."
  }
}
