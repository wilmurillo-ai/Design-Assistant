{
  "name": "substreams-search-mcp",
  "version": "1.3.0",
  "description": "MCP server to search and inspect Substreams packages — browse the registry and introspect .spkg module graphs, protobuf types, and DAG dependencies",
  "type": "module",
  "bin": {
    "substreams-search-mcp": "build/index.js"
  },
  "main": "./build/index.js",
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "start": "node build/index.js",
    "start:http": "node build/index.js --http",
    "start:http-only": "node build/index.js --http-only",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "substreams",
    "substreams-dev",
    "spkg",
    "blockchain",
    "blockchain-data",
    "streaming",
    "indexer",
    "the-graph",
    "streamingfast",
    "ethereum",
    "solana",
    "polygon",
    "arbitrum",
    "base",
    "defi",
    "web3",
    "ai",
    "claude",
    "cursor",
    "ai-agent",
    "protobuf",
    "module-graph",
    "sink",
    "sql-sink",
    "data-pipeline",
    "openclaw",
    "sse"
  ],
  "author": "PaulieB14",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PaulieB14/substreams-search-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@substreams/core": "^0.17.0",
    "express": "^4.21.0",
    "node-html-parser": "^7.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
