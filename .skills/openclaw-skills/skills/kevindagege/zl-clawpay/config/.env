# ZLPay Skill Environment Variables Configuration Template
# Copy this file to .env and fill in actual values

# ==================== API Configuration ====================

# API URL (optional, default https://gateway.zqpay.com)
#ZLPAY_API_URL=https://gatewaytest.zqpay.com:8443/zl-core-payacc/
ZLPAY_API_URL=https://gatewaytest.zqpay.com/zl-core-payacc-uat/
#ZLPAY_API_URL=http://10.4.178.167:3012/zl-core-payacc/

# App ID (application identifier, required for GM strategy)
# dev
#ZLPAY_APP_ID=30ca371b4a5868c9347db5ce2e938a8d 
# uat
ZLPAY_APP_ID=F41975C498B44D6EE053376010ACB761

# API Key (optional, managed by Memory system)
# Note: This config is no longer required, system will auto-read from Memory
# ZLPAY_API_KEY=your_api_key_here

# ==================== Security Strategy Configuration ====================

# Security strategy: gm (GM SM2/SM4, default) or hmac (HMAC-SHA256)
# ZLPAY_SECURITY_STRATEGY=gm

# GM encryption switch (true/false, default true)
# When disabled: no secret/sign, data in plaintext
ZLPAY_GM_ENABLE_ENCRYPTION=false

# GM SM2 client private key (hex string)
# Used for: signing requests, decrypting server responses
ZLPAY_GM_CLIENT_PRIVATE_KEY=90294f49196dfc2c4448dbb3f2f773b6e1e1746b3bfa805f8cbf17835bd38bd2

# GM SM2 server public key (hex string)
# Used for: encrypting request keys, verifying server signatures
ZLPAY_GM_SERVER_PUBLIC_KEY=04565fe65a0e0be7860877858a1bd05ef07d4b782a56cc9db1b8cbe866a9825935486df8251c18ea8e88a7ee37e07175dd710e4047ee4c26ee2e0df283fef91399

# Read keys from file (alternative to direct config, more secure)
# ZLPAY_GM_CLIENT_PRIVATE_KEY_PATH=/path/to/client_private_key.pem
# ZLPAY_GM_SERVER_PUBLIC_KEY_PATH=/path/to/server_public_key.pem

# ==================== Logging Configuration ====================

# Log level (DEBUG, INFO, WARNING, ERROR)
ZLPAY_LOG_LEVEL=DEBUG

# Log directory (optional, default logs/)
# ZLPAY_LOG_DIR=logs

# ==================== Other Configuration ====================

# Request timeout (seconds, default 30)
# ZLPAY_REQUEST_TIMEOUT=30

# State file retention days (default 90)
# ZLPAY_REQUEST_TIMEOUT=30

# 状态文件保留天数（默认 90）
# ZLPAY_STATE_RETENTION_DAYS=90
