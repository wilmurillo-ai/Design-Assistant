{
  "workflow_name": "auto-quotation-openclaw",
  "version": "1.0.1",
  "nodes": [
    {
      "name": "input_router",
      "inputs": {
        "input_type": "markdown|text|docx|image",
        "input_uri": "string",
        "project_name": "string?",
        "vendor_name": "string?",
        "quote_date": "string?",
        "tax_note": "string?",
        "work_dir": "string?",
        "docx_renderer_mode": "auto|native|html?"
      },
      "outputs": {
        "normalized_input_task": {
          "route": "vision|markdown",
          "input_uri": "string"
        }
      }
    },
    {
      "name": "vision_normalize",
      "inputs": {
        "image_uri": "string",
        "project_name": "string?"
      },
      "outputs": {
        "requirement_markdown": "string",
        "vision_notes": ["string"]
      }
    },
    {
      "name": "markdown_normalize",
      "inputs": {
        "text_uri": "string"
      },
      "outputs": {
        "requirement_markdown": "string"
      }
    },
    {
      "name": "requirement_parser",
      "inputs": {
        "requirement_markdown": "string"
      },
      "outputs": {
        "requirement_json": {
          "project_name": "string",
          "features": ["string"],
          "project_domains": ["string"],
          "delivery_channels": ["string"],
          "assumptions": ["string"]
        }
      }
    },
    {
      "name": "historical_retrieval",
      "inputs": {
        "requirement_json": "object",
        "corpus_index_uri": "string"
      },
      "outputs": {
        "similar_documents": [
          {
            "title": "string",
            "file_path": "string",
            "score": "number",
            "domains": ["string"]
          }
        ]
      }
    },
    {
      "name": "estimate_engine",
      "inputs": {
        "requirement_json": "object",
        "similar_documents": "array",
        "sample_library_uri": "string",
        "profiles_uri": "string",
        "rate_cards_uri": "string",
        "vendor_name": "string?",
        "quote_date": "string?",
        "tax_note": "string?",
        "work_dir": "string?",
        "docx_renderer_mode": "auto|native|html?"
      },
      "outputs": {
        "quote_json": {
          "project_name": "string",
          "vendor_name": "string?",
          "quote_date": "string?",
          "tax_note": "string?",
          "project_domains": ["string"],
          "matched_rate_cards": "array",
          "line_items": "array",
          "roles": "array",
          "payment_schedule": "array",
          "similar_documents": "array",
          "day_rate": "number",
          "total_price": "number"
        }
      }
    },
    {
      "name": "markdown_renderer",
      "inputs": {
        "quote_json": "object"
      },
      "outputs": {
        "quote_markdown": "string"
      }
    },
    {
      "name": "docx_renderer",
      "inputs": {
        "quote_json": "object",
        "docx_renderer_mode": "auto|native|html?",
        "work_dir": "string?"
      },
      "outputs": {
        "quote_docx_uri": "string",
        "quote_html_uri": "string?"
      }
    }
  ]
}
