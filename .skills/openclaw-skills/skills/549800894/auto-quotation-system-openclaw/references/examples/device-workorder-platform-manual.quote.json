  "requirement_groups": [
    {
      "module": "基础档案、绑定关系与权限基础",
      "items": [
        "点位、园区、设备、供应商档案，点位绑定设备、设备绑定供应商，以及场地方/供应商/管理员基础权限控制。"
      ]
    },
    {
      "module": "场地方小程序报修与验收闭环",
      "items": [
        "场地方首页、快捷报修、自动识别点位、设备选择、故障类型、图片上传、工单进度、验收确认、评价与催单。"
      ]
    },
    {
      "module": "供应商小程序接单与处理闭环",
      "items": [
        "供应商待处理工单、接单、指派维修人员、维修记录、图片上传、标记完成，以及供应商侧工单处理链路。"
      ]
    },
    {
      "module": "后台工单中心与自动派单干预",
      "items": [
        "工单列表筛选、工单详情、流转记录、操作日志、自动派单、转派供应商、催单、强制关闭、人工备注。"
      ]
    },
    {
      "module": "对账结算与绩效统计",
      "items": [
        "场地方费用确认/异议、供应商结算申请/进度、已完成工单费用统计，以及处理数量、响应时长、完成率等绩效指标。"
      ]
    },
    {
      "module": "消息通知与超时提醒机制",
      "items": [
        "小程序订阅消息、站内通知、短信提醒、服务号通知、超时未接单/未完成提醒、系统公告发布。"
      ]
    }
  ],
