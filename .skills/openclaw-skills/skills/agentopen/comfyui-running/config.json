{
  // =============================================================================
  // ComfyUI Running Skill - 配置文件
  // =============================================================================
  // 
  // 【配置优先级】
  // 环境变量 > config.json > 自动检测默认值
  //
  // 【环境变量】
  // COMFYUI_ROOT       - ComfyUI 安装根目录
  // COMFYUI_PORT       - ComfyUI 端口（默认 8188）
  // CDP_PORT           - Chrome/Edge 调试端口（默认 9222）
  // COMFYUI_WORKFLOWS_DIR - 工作流目录
  // COMFYUI_OUTPUT_DIR    - 输出目录
  //
  // =============================================================================

  // ---------------------------------------------------------------------------
  // 【必填】ComfyUI 安装根目录
  // ---------------------------------------------------------------------------
  // Windows 示例:
  //   "H:/ComfyUI-aki-v3/ComfyUI"   ✅ 斜杠兼容 Windows/Linux
  //   "H:\\ComfyUI-aki-v3\\ComfyUI" ✅ 反斜杠（需双写转义）
  //   "D:/ComfyUI/ComfyUI"
  //
  // Linux/macOS 示例:
  //   "/opt/ComfyUI/ComfyUI"
  //   "/home/user/ComfyUI/ComfyUI"
  //   "~/ComfyUI/ComfyUI"
  //
  // WSL 示例:
  //   "/mnt/h/ComfyUI-aki-v3/ComfyUI"  ✅ 访问 Windows 盘符
  //
  // ⚠️ 注意: 路径必须包含 main.py 文件所在目录
  // ---------------------------------------------------------------------------
  "comfyui_root": "H:/ComfyUI-aki-v3/ComfyUI",

  // ---------------------------------------------------------------------------
  // 【可选】Python 解释器路径
  // ---------------------------------------------------------------------------
  // Windows 示例:
  //   "H:/ComfyUI-aki-v3/python/python.exe"  ✅ 整合包自带 Python
  //   "C:/Python311/python.exe"              ✅ 系统 Python
  //
  // Linux/macOS 示例:
  //   "/usr/bin/python3"
  //   "/home/user/anaconda3/envs/comfyui/bin/python"
  //
  // ⚠️ 如不填写，将自动检测以下顺序:
  //    1. conda 环境 (CONDA_DEFAULT_ENV)
  //    2. 虚拟环境 (VIRTUAL_ENV)
  //    3. 系统 Python (python3 / python.exe)
  // ---------------------------------------------------------------------------
  "python_path": "H:/ComfyUI-aki-v3/python/python.exe",

  // ---------------------------------------------------------------------------
  // 【可选】工作流 JSON 文件目录
  // ---------------------------------------------------------------------------
  // 默认: 优先使用 skill 自带的 example_workflows 目录
  // 如果需要使用自定义工作流，指定此路径
  // ---------------------------------------------------------------------------
  "workflows_dir": "C:/Users/Administrator/.openclaw/workspace/skills/comfyui-running/example_workflows",

  // ---------------------------------------------------------------------------
  // 【可选】图片输出目录
  // ---------------------------------------------------------------------------
  // Windows 示例:
  //   "H:/ComfyUI-aki-v3/ComfyUI/output"
  //
  // Linux/macOS 示例:
  //   "/opt/ComfyUI/ComfyUI/output"
  //
  // ⚠️ 如不填写，默认使用 {comfyui_root}/output
  // ---------------------------------------------------------------------------
  "output_dir": "H:/ComfyUI-aki-v3/ComfyUI/output",

  // ---------------------------------------------------------------------------
  // ComfyUI 服务端口
  // ---------------------------------------------------------------------------
  // 默认: 8188
  // 如果你修改过 ComfyUI 启动端口，请同步修改此值
  // ---------------------------------------------------------------------------
  "comfyui_port": 8188,

  // ---------------------------------------------------------------------------
  // Chrome DevTools Protocol (CDP) 端口
  // ---------------------------------------------------------------------------
  // 默认: 9222
  // 用于浏览器自动化控制（可选功能）
  // ⚠️ 仅 Edge/Chrome 浏览器支持
  // ---------------------------------------------------------------------------
  "cdp_port": 9222,

  // ---------------------------------------------------------------------------
  // UI 类型
  // ---------------------------------------------------------------------------
  // 可选值:
  //   "aki"      - 秋叶版 ComfyUI-aki-v3（默认）
  //   "official" - 官方原版 ComfyUI
  //   "auto"     - 自动检测（根据路径判断）
  //
  // 【自动检测规则】
  //   - 路径包含 "aki"、"秋叶"、"v3" → aki
  //   - 存在 extra_model_paths.yaml → aki
  //   - 其他 → official
  // ---------------------------------------------------------------------------
  "ui_type": "aki",

  // ---------------------------------------------------------------------------
  // 【可选】浏览器路径（用于 CDP 自动化，可不填自动检测）
  // ---------------------------------------------------------------------------
  // Windows Edge:
  //   "C:/Program Files (x86)/Microsoft/Edge/Application/msedge.exe"
  //   "C:/Program Files/Microsoft/Edge/Application/msedge.exe"
  //
  // Windows Chrome:
  //   "C:/Users/{用户名}/AppData/Local/Google/Chrome/Application/chrome.exe"
  //
  // Linux:
  //   "/usr/bin/google-chrome"
  //   "/usr/bin/chromium-browser"
  //   "/snap/bin/chromium"
  //
  // macOS:
  //   "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
  // ---------------------------------------------------------------------------
  "browser_path": "C:/Program Files (x86)/Microsoft/Edge/Application/msedge.exe",

  // ---------------------------------------------------------------------------
  // 【可选】浏览器类型（可不填，根据 browser_path 自动判断）
  // ---------------------------------------------------------------------------
  // 可选值: "edge", "chrome"
  // ---------------------------------------------------------------------------
  "browser_type": "edge"
}
