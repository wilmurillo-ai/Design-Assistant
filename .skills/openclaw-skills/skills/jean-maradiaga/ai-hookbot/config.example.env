# AI Hookbot - Environment Configuration
# Copy this file, fill in your values, and source it:
#   cp config.example.env ~/.hookbot.env && source ~/.hookbot.env
# Keep this file separate from your ~/.zshrc — source only this file, not your full shell config

# Path to the directory containing pipeline.py and related scripts
export HOOKBOT_SCRIPTS_DIR="$HOME/hookbot"

# Default directory to look for CTA videos
export HOOKBOT_CTA_DIR="$HOME/hookbot/cta"

# Path to yt-dlp binary (leave as-is if it's in your PATH)
export HOOKBOT_YTDLP_PATH="yt-dlp"

# Path to ffmpeg binary (leave as-is if it's in your PATH)
export HOOKBOT_FFMPEG_PATH="ffmpeg"

# YouTube Data API v3 key — only needed for --viral (sort by views)
# Get one at: https://console.cloud.google.com
# export YOUTUBE_API_KEY="your_key_here"
