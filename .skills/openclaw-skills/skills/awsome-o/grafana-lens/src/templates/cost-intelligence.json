      },
      "targets": [
        {
          "expr": "sum by (gen_ai_operation_name) (increase(gen_ai_client_operation_duration_seconds_sum[$__range]))",
          "legendFormat": "{{gen_ai_operation_name}}",
          "refId": "A",
          "instant": true
        }
