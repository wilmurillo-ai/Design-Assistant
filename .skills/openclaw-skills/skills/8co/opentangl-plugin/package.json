{
  "name": "opentangl-openclaw-plugin",
  "version": "0.1.0",
  "description": "OpenClaw plugin for OpenTangl — autonomous multi-repo development engine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "openclaw": {
    "extensions": ["./index.ts"]
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "opentangl",
    "ai-agents",
    "autonomous-development",
    "multi-repo",
    "workflow-automation"
  ],
  "license": "MIT",
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
