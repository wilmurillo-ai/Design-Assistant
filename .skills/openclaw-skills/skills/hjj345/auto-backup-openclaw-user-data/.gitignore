# Auto-Backup-Openclaw-User-Data .gitignore

# 依赖目录
node_modules/
lib/

# 日志文件
*.log
logs/

# 备份文件
backups/
*.zip

# 配置文件（包含用户个人设置）
config.json

# 操作系统文件
.DS_Store
Thumbs.db
Desktop.ini

# IDE 配置
.idea/
.vscode/
*.swp
*.swo

# git文件夹
.git/

# Claude配置文件
CLAUDE.md

# 临时文件
*.tmp
*.temp
tmp/
temp/

# 打包输出
skill_zip_output/
*.skill
*.zip

# 敏感数据
*.env
.env.*
credentials.json
secrets.json

# 测试覆盖率
coverage/
.nyc_output/

# 构建产物
dist/
build/