{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/rep/agent_heartbeat_record.json",
  "title": "Agent Heartbeat Record",
  "description": "Periodic health and status signal from an agent session",
  "type": "object",
  "required": ["artifact_type", "timestamp", "session_id", "actor", "status"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "agent_heartbeat_record",
      "description": "Must be exactly 'agent_heartbeat_record'"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the heartbeat"
    },
    "session_id": {
      "type": "string",
      "description": "Unique identifier for the session"
    },
    "actor": {
      "type": "string",
      "description": "Agent identifier (e.g., 'agent:monitor', 'agent:main')"
    },
    "status": {
      "type": "string",
      "enum": ["healthy", "degraded", "unhealthy", "stopped"],
      "description": "Current operational status"
    },
    "metrics": {
      "type": "object",
      "description": "Performance metrics at time of heartbeat",
      "properties": {
        "cpu_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "memory_mb": {
          "type": "number",
          "minimum": 0
        },
        "response_time_ms": {
          "type": "number",
          "minimum": 0
        },
        "active_tools": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "context_summary": {
      "type": "string",
      "description": "Brief summary of current context/state"
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "version": {
          "type": "string"
        },
        "environment": {
          "type": "string"
        }
      }
    }
  }
}
