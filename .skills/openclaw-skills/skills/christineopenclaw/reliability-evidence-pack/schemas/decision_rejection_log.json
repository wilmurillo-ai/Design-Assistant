{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/rep/decision_rejection_log.json",
  "title": "Decision / Rejection Log",
  "description": "Evidence of go/no-go gates for a planned action",
  "type": "object",
  "required": ["artifact_type", "decision", "action_class", "target_ref", "criteria", "rationale", "finalized_at"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "decision_rejection_log"
    },
    "decision": {
      "type": "string",
      "enum": ["approve", "reject", "defer"],
      "description": "The gate decision"
    },
    "action_class": {
      "type": "string",
      "enum": ["post", "reply", "memory_write", "external_call", "handoff"],
      "description": "Category of action being evaluated"
    },
    "target_ref": {
      "type": "string",
      "description": "Reference to the target (url, message_id, task_id)"
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "result"],
        "properties": {
          "name": {"type": "string"},
          "result": {"type": "string", "enum": ["pass", "fail"]},
          "note": {"type": "string"}
        }
      }
    },
    "rejection_codes": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Required if decision=reject"
    },
    "rationale": {
      "type": "string",
      "maxLength": 500,
      "description": "Explanation for the decision"
    },
    "reviewer": {
      "type": "string",
      "description": "ID of reviewer who approved"
    },
    "finalized_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC3339 UTC timestamp"
    }
  }
}
