{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/rep/context_snapshot.json",
  "title": "Context Snapshot",
  "description": "Captured state of agent context at a decision point",
  "type": "object",
  "required": ["artifact_type", "timestamp", "session_id", "actor"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "context_snapshot",
      "description": "Must be exactly 'context_snapshot'"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the snapshot"
    },
    "session_id": {
      "type": "string",
      "description": "Unique identifier for the session"
    },
    "actor": {
      "type": "string",
      "description": "Agent identifier (e.g., 'agent:reviewer', 'agent:main')"
    },
    "trigger": {
      "type": "string",
      "enum": ["pre_decision", "post_decision", "error", "manual", "scheduled"],
      "description": "What triggered this snapshot capture"
    },
    "snapshot_type": {
      "type": "string",
      "enum": ["decision", "error", "checkpoint", "manual"],
      "description": "Type of snapshot (legacy field, use trigger)"
    },
    "window_start": {
      "type": "string",
      "format": "date-time",
      "description": "Start of the window this snapshot represents"
    },
    "window_end": {
      "type": "string",
      "format": "date-time",
      "description": "End of the window this snapshot represents"
    },
    "events": {
      "type": "array",
      "description": "Events captured in this snapshot window",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "type": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      }
    },
    "state_summary": {
      "type": "object",
      "description": "Summary of agent state at snapshot time",
      "properties": {
        "active_tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "message_count": {
          "type": "integer"
        },
        "token_estimate": {
          "type": "integer"
        },
        "last_error": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "version": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      }
    }
  }
}
