{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/rep/claim_file.json",
  "title": "Claim File",
  "description": "Verifiable claim about agent behavior or decision",
  "type": "object",
  "required": ["artifact_type", "timestamp", "session_id", "actor", "claim_id", "claim_type", "status"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "claim_file",
      "description": "Must be exactly 'claim_file'"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the claim"
    },
    "session_id": {
      "type": "string",
      "description": "Unique identifier for the session"
    },
    "actor": {
      "type": "string",
      "description": "Agent identifier making the claim (e.g., 'agent:writer')"
    },
    "claim_id": {
      "type": "string",
      "description": "Unique identifier for this claim"
    },
    "claim_type": {
      "type": "string",
      "enum": ["behavior", "decision", "output", "safety", "performance", "compliance"],
      "description": "Category of the claim"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "verified", "rejected", "disputed"],
      "description": "Verification status of the claim"
    },
    "content_hash": {
      "type": "string",
      "description": "SHA-256 hash of the claimed content",
      "pattern": "^[a-f0-9]{64}$"
    },
    "prev_hash": {
      "type": "string",
      "description": "Hash of previous claim in chain (for blockchain-like verification)",
      "pattern": "^[a-f0-9]{64}$"
    },
    "verified_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when claim was verified"
    },
    "verifier": {
      "type": "string",
      "description": "Agent or system that verified the claim"
    },
    "evidence_refs": {
      "type": "array",
      "description": "References to evidence supporting this claim",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["heartbeat", "snapshot", "log", "metric", "external"]
          },
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "content": {
      "type": "object",
      "description": "The actual claimed content or statement",
      "properties": {
        "statement": {
          "type": "string"
        },
        "decision": {
          "type": "string"
        },
        "action": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "version": {
          "type": "string"
        },
        "chain_id": {
          "type": "string"
        }
      }
    }
  }
}
