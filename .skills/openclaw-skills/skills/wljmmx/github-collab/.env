# 环境变量配置示例
# 复制此文件为 .env 并修改相应值

# 应用配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_PATH=./src/db/github-collab.db
DB_BACKUP_PATH=./src/db/backup
DB_MAX_CONNECTIONS=10

# 缓存配置
CACHE_ENABLED=true
CACHE_MAX_SIZE=1000
CACHE_DEFAULT_TTL=3600000

# Agent 配置
AGENT_DEFAULT_TIMEOUT=300000
AGENT_MAX_RETRIES=3
AGENT_HEALTH_CHECK_INTERVAL=60000

# 任务配置
TASK_AUTO_ASSIGN=true

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10M
LOG_MAX_FILES=5

# Git 配置
GIT_COMMIT_MESSAGE_FORMAT=feat: %s
GIT_BRANCH_PREFIX=feature/
GIT_AUTO_COMMIT=true

# GitHub API 配置
GITHUB_TOKEN=your_github_token_here
GITHUB_API_VERSION=2022-11-28
GITHUB_RATE_LIMIT_MAX=5000
GITHUB_RATE_LIMIT_WINDOW=3600000

# 性能监控配置
MONITORING_ENABLED=true
MONITORING_REPORT_INTERVAL=300000

# 测试配置
TEST_COVERAGE_THRESHOLD=80
TEST_TIMEOUT=10000