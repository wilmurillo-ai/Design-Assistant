{
  "conda_env": {
    "name": "meeting-assistant",
    "python": "D:/program/codesupport/anaconda/envs/meeting-assistant/python.exe",
    "whisper": "D:/program/codesupport/anaconda/envs/meeting-assistant/Scripts/whisper.exe",
    "scripts_dir": "D:/program/codesupport/anaconda/envs/meeting-assistant/Scripts",
    "ffmpeg": "D:/program/codesupport/anaconda/envs/meeting-assistant/Library/bin/ffmpeg.exe"
  },
  "docker": {
    "exe": "C:/Program Files/Docker/Docker/resources/bin/docker.exe",
    "compose_plugin": true
  },

  "screenshot_interval": 30,
  "audio_chunk_minutes": 5,
  "whisper_model": "base",
  "whisper_language": "zh",
  "mode": "general",
