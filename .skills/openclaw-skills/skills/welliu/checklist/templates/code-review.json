    {"id": 9, "text": "HTTPS is enforced for all traffic", "required": true},
    {"id": 10, "text": "No console.log or debug statements left", "required": false},
    {"id": 11, "text": "Unit tests are included", "required": true},
    {"id": 12, "text": "Code is documented where complex", "required": false},
    {"id": 13, "text": "No performance issues identified", "required": true},
