{
  "name": "Deploy Checklist",
  "description": "Pre-deployment verification steps",
  "category": "devops",
  "items": [
    {"id": 1, "text": "Run all tests locally and verify passing", "required": true},
    {"id": 2, "text": "Review code changes in git diff", "required": true},
    {"id": 3, "text": "Check environment variables are properly set", "required": true},
    {"id": 4, "text": "Verify database migrations are backward compatible", "required": true},
    {"id": 5, "text": "Enable maintenance mode (if needed)", "required": false},
    {"id": 6, "text": "Deploy to staging/QA environment first", "required": true},
    {"id": 7, "text": "Run smoke tests on staging", "required": true},
    {"id": 8, "text": "Create database backup", "required": true},
    {"id": 9, "text": "Deploy to production", "required": true},
    {"id": 10, "text": "Verify health endpoints respond correctly", "required": true},
    {"id": 11, "text": "Check application logs for errors", "required": true},
    {"id": 12, "text": "Verify database connections working", "required": true},
    {"id": 13, "text": "Notify stakeholders of deployment", "required": false},
    {"id": 14, "text": "Disable maintenance mode", "required": false},
    {"id": 15, "text": "Monitor error rates for 30 minutes", "required": true}
  ]
}
