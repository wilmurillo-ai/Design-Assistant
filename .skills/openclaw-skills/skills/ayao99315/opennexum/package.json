{
  "name": "opennexum",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm dlx turbo run build --filter=@nexum/core --filter=@nexum/prompts --filter=@nexum/spawn --filter=@nexum/notify --filter=@nexum/cli",
