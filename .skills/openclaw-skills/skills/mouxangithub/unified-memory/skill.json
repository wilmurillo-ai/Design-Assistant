{
  "name": "unified-memory",
  "version": "1.5.1",
  "description": "Intelligent memory system + Agent collaboration system for AI Agents. Zero-dependency alternative to MetaGPT with memory, learning, and self-evolution capabilities",
  "author": "mouxangithub",
  "license": "MIT",
  "keywords": [
    "memory",
    "ai-agent",
    "vector-database",
    "knowledge-graph",
    "semantic-search",
    "hierarchical-cache",
    "auto-extraction",
    "quality-metrics",
    "proactive-injection",
    "adaptive-confidence",
    "multi-agent-sync",
    "audit-logging",
    "agent-collaboration",
    "workflow-engine",
    "code-generation",
    "llm-integration",
    "metagpt-alternative",
    "zero-dependency"
  ],
  "categories": [
    "Core",
    "Memory",
    "Agent Collaboration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mouxangithub/unified-memory"
  },
  "bugs": {
    "url": "https://github.com/mouxangithub/unified-memory/issues"
  },
  "homepage": "https://github.com/mouxangithub/unified-memory#readme",
  "engines": {
    "python": ">=3.8",
    "openclaw": ">=0.1.0"
  },
  "requirements": {
    "installation": {
      "required": true,
      "script": "scripts/install.sh",
      "description": "Creates directories, installs Python dependencies, and optionally installs dependent skills"
    },
    "dependencies": {
      "python": {
        "required": [
          "requests>=2.28.0"
        ],
        "optional": [
          "lancedb>=0.3.0"
        ]
      },
      "skills": [
        {
          "name": "memory-lancedb-pro",
          "required": true,
          "version": ">=1.1.0",
          "autoInstall": true,
          "source": "clawhub",
          "fallback": "git+https://github.com/CortexReach/memory-lancedb-pro.git",
          "description": "Provides LanceDB vector storage, hybrid retrieval, and reranking"
        }
      ]
    },
    "externalServices": [
      {
        "name": "ollama",
        "required": false,
        "type": "llm-embedding-service",
        "description": "Local LLM and embedding service for auto-extraction and vector search",
        "defaultHost": "http://localhost:11434",
        "envVars": [
          "OLLAMA_HOST",
          "OLLAMA_LLM_MODEL",
          "OLLAMA_EMBED_MODEL"
        ],
        "fallback": "Rule-based extraction without LLM features"
      }
    ]
  },
  "permissions": {
    "filesystem": {
      "read": [
        "~/.openclaw/workspace/memory/"
      ],
      "write": [
        "~/.openclaw/workspace/memory/"
      ],
      "description": "Read/write memory data, cache, knowledge blocks, archives"
    },
    "network": {
      "outbound": [
        {
          "host": "${OLLAMA_HOST:-http://localhost:11434}",
          "purpose": "LLM auto-extraction and embedding generation",
          "required": false
        }
      ],
      "description": "Optional outbound to Ollama for LLM features"
    },
    "process": {
      "execute": [
        "scripts/install.sh",
        "scripts/uninstall.sh"
      ],
      "description": "Install/uninstall scripts"
    },
    "autoInstall": {
      "skills": true,
      "description": "Auto-install dependency skill (memory-lancedb-pro)"
    }
  },
  "config": {
    "env": {
      "OLLAMA_HOST": {
        "default": "http://localhost:11434",
        "description": "Ollama server URL for embeddings and LLM",
        "required": false,
        "sensitive": false
      },
      "OLLAMA_LLM_MODEL": {
        "default": "deepseek-v3.2:cloud",
        "description": "LLM model for memory extraction",
        "required": false,
        "sensitive": false
      },
      "OLLAMA_EMBED_MODEL": {
        "default": "nomic-embed-text:latest",
        "description": "Embedding model for vector search",
        "required": false,
        "sensitive": false
      }
    },
    "parameters": {
      "L1_HOT_HOURS": {
        "default": 24,
        "type": "integer",
        "description": "L1 hot memory time window in hours",
        "min": 1,
        "max": 168
      },
      "L2_WARM_DAYS": {
        "default": 7,
        "type": "integer",
        "description": "L2 warm memory time window in days",
        "min": 1,
        "max": 30
      },
      "L1_MAX_SIZE": {
        "default": 20,
        "type": "integer",
        "description": "Maximum L1 hot memory items",
        "min": 5,
        "max": 100
      },
      "L2_MAX_SIZE": {
        "default": 100,
        "type": "integer",
        "description": "Maximum L2 warm memory items",
        "min": 10,
        "max": 500
      },
      "SIMILARITY_THRESHOLD": {
        "default": 0.85,
        "type": "float",
        "description": "Similarity threshold for knowledge merging",
        "min": 0.5,
        "max": 1
      },
      "STALE_DAYS": {
        "default": 30,
        "type": "integer",
        "description": "Days before memory is considered stale"
      },
      "FORGET_IMPORTANCE": {
        "default": 0.1,
        "type": "float",
        "description": "Importance threshold for forgetting",
        "min": 0,
        "max": 0.5
      }
    }
  },
  "scripts": {
    "main": "scripts/memory.py",
    "install": "scripts/install.sh",
    "uninstall": "scripts/uninstall.sh",
    "webui": "scripts/memory_webui.py"
  },
  "triggers": {
    "keywords": [
      "\u8bb0\u4f4f",
      "\u8bb0\u5f55",
      "\u67e5\u4e00\u4e0b",
      "\u6709\u4ec0\u4e48",
      "\u8bb0\u5fc6",
      "\u77e5\u8bc6\u5e93",
      "memory",
      "remember",
      "recall",
      "forget"
    ],
    "commands": [
      "/memory",
      "/remember",
      "/recall",
      "/forget"
    ]
  },
  "capabilities": [
    "memory:read",
    "memory:write",
    "memory:search",
    "memory:export",
    "memory:import",
    "memory:delete",
    "memory:validate",
    "memory:quality",
    "agent:workflow",
    "agent:generate",
    "agent:collaborate",
    "llm:integrate",
    "sandbox:execute"
  ],
  "compatibility": {
    "openclaw": ">=0.1.0",
    "python": ">=3.8",
    "os": [
      "linux",
      "macos",
      "windows"
    ]
  },
  "fallbacks": {
    "no_lancedb": {
      "description": "Use JSON file storage instead of vector database",
      "behavior": "Store memories in memories.json, disable vector search"
    },
    "no_ollama": {
      "description": "Use rule-based extraction only",
      "behavior": "Disable LLM-powered auto-extraction, use regex patterns"
    }
  },
  "changelog": [
    {
      "version": "1.5.1",
      "date": "2026-03-23",
      "changes": [
        "Context Tree 统一架构：记忆上下文 + 项目上下文",
        "session_start 深度集成：Context Tree + Knowledge Graph 自动加载",
        "mem ctx open/list 命令",
        "mem init --template 快捷命令",
        "Smart Summarizer 定时脚本",
        "Knowledge Graph search_context() 函数",
        "Visualizer HTML 可视化仪表盘"
      ]
    },
    {
      "version": "1.4.0",
      "date": "2026-03-23",
      "changes": [
        "Deep optimization benchmarked against QMD and MetaGPT",
        "Added OCR engine (Tesseract/PaddleOCR/Qwen VL)",
        "Added STT engine (Whisper/Aliyun)",
        "Added smart classifier with auto-tagging",
        "Added agent scheduler with load balancing",
        "Added code quality assessor with security scanning",
        "Added Web UI with user auth and WebSocket",
        "Added API docs generator (Markdown/OpenAPI)",
        "Added unified CLI for all modules",
        "Zero dependencies vs QMD 5+ and MetaGPT 70+"
      ]
    },
    {
      "version": "0.1.0",
      "date": "2026-03-18",
      "changes": [
        "Fixed metadata to accurately declare permissions and requirements",
        "Added permissions section (filesystem, network, autoInstall)",
        "Added requirements section with explicit dependencies",
        "Clarified external service dependencies (Ollama)"
      ]
    },
    {
      "version": "0.0.8",
      "date": "2026-03-18",
      "changes": [
        "Renamed memory_v7.py to memory.py",
        "Removed hardcoded user data for privacy",
        "Added hierarchical cache (L1/L2/L3)",
        "Added knowledge merging",
        "Added predictive loading",
        "Added auto extraction with sensitive filter",
        "Added quality metrics",
        "Added import/export",
        "Added agent integration hooks"
      ]
    }
  ]
}