{
  "name": "hs-ti",
  "displayName": "Hillstone Threat Intelligence",
  "version": "2.2.5",
  "description": "Hillstone Threat Intelligence Skill. Query IP addresses, domains, URLs, and file hashes in the Hillstone threat intelligence database.",
  "homepage": "https://clawhub.ai/maxjia/hs-ti",
  "main": "scripts/hs_ti_plugin.py",
  "scripts": {
    "test": "python3 tests/test_hs_ti.py"
  },
  "env": {
    "HILLSTONE_API_KEY": {
      "description": "Hillstone Threat Intelligence API key (recommended over config.json storage). If set, takes precedence over api_key in config.json.",
      "required": false,
      "sensitive": true
    }
  },
  "config": {
    "required": true,
    "file": "config.json",
    "description": "Hillstone Threat Intelligence API configuration file",
    "schema": {
      "api_key": {
        "type": "string",
        "description": "Hillstone Threat Intelligence API Key (HILLSTONE_API_KEY env var recommended)",
        "required": true,
        "sensitive": true
      },
      "api_url": {
        "type": "string",
        "description": "Hillstone Threat Intelligence API URL",
        "default": "https://ti.hillstonenet.com.cn"
      },
      "timeout": {
        "type": "integer",
        "description": "Request timeout in seconds",
        "default": 30
      },
      "max_retries": {
        "type": "integer",
        "description": "Maximum retry attempts",
        "default": 3
      },
      "retry_delay": {
        "type": "integer",
        "description": "Retry delay in seconds",
        "default": 1
      },
      "cache_enabled": {
        "type": "boolean",
        "description": "Enable caching",
        "default": true
      },
      "cache_ttl": {
        "type": "integer",
        "description": "Cache time-to-live in seconds",
        "default": 3600
      },
      "max_workers": {
        "type": "integer",
        "description": "Maximum concurrent query threads",
        "default": 5
      },
      "max_cache_size": {
        "type": "integer",
        "description": "Maximum cache entries",
        "default": 1000
      },
      "max_connections": {
        "type": "integer",
        "description": "Maximum HTTP connection pool size",
        "default": 10
      },
      "circuit_breaker_failure_threshold": {
        "type": "integer",
        "description": "Circuit breaker failure threshold",
        "default": 5
      },
      "circuit_breaker_timeout": {
        "type": "integer",
        "description": "Circuit breaker timeout in seconds",
        "default": 60
      }
    }
  },
  "keywords": [
    "hs-ti",
    "threat-intel",
    "threat-intelligence",
    "yunzhan",
    "hillstone",
    "hillstone-networks",
    "network-security",
    "ip",
    "domain",
    "url",
    "hash",
    "ioc",
    "ioc-query",
    "indicators",
    "compromise",
    "malware",
    "phishing",
    "c2",
    "apt",
    "threat-hunting",
    "threat-detection",
    "security-analysis",
    "cybersecurity",
    "threat-assessment",
    "threat-response",
    "threat-monitoring",
    "threat-intel-api",
    "ti-api",
    "threat-database",
    "malicious",
    "benign",
    "credibility",
    "threat-type",
    "caching",
    "auto-detection",
    "export",
    "logging",
    "performance",
    "optimization",
    "connection-pool",
    "circuit-breaker",
    "retry",
    "batch-query",
    "file-import",
    "progress-tracking",
    "statistics",
    "monitoring",
    "api-key",
    "api-management",
    "environment-variable",
    "security",
    "sensitive-data",
    "data-masking",
    "log-security",
    "file-security",
    "permissions",
    "audit",
    "compliance"
  ],
  "author": "maxjia",
  "publisher": "maxjia",
  "license": "MIT",
  "dependencies": {
    "python": ">=3.8"
  },
  "openclaw": {
    "type": "python-skill",
    "commands": [
      "/threat-check",
      "/hs-ti",
      "/threat"
    ],
    "aliases": [
      "hs-ti",
      "threat-intel",
      "hillstone-ti"
    ],
    "network": {
      "required": true,
      "endpoints": [
        {
          "name": "Hillstone Threat Intelligence API",
          "url": "https://ti.hillstonenet.com.cn",
          "description": "Used to query threat intelligence for IPs, domains, URLs, and file hashes"
        }
      ]
    }
  }
}
