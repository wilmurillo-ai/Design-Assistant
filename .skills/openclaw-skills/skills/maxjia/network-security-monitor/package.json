{
  "name": "openclaw-security-monitor",
  "displayName": "OpenClaw Security Monitor",
  "version": "1.1.4",
  "description": "OpenClaw network access security monitoring skill. Monitors external network access and file downloads, checks security of IPs, domains, URLs, and file hashes via threat intelligence APIs. Provides warnings or blocks access when security risks are detected.",
  "homepage": "https://clawhub.ai/maxjia/openclaw-security-monitor",
  "main": "scripts/security_monitor.py",
  "scripts": {
    "test": "python3 tests/test_security_monitor.py"
  },
  "env": {
    "SECURITY_MONITOR_API_KEY": {
      "description": "Optional: Custom threat intelligence API key for fallback when hs-ti is unavailable. Recommended over config.json storage for security. If set, takes precedence over api_key in config.json.",
      "required": false,
      "sensitive": true
    }
  },
  "config": {
    "required": false,
    "schema": {
      "threat_intel": {
        "type": "object",
        "description": "Threat intelligence configuration",
        "properties": {
          "provider": {
            "type": "string",
            "description": "Threat intelligence provider (hs-ti recommended)",
            "enum": ["hs-ti", "custom"],
            "default": "hs-ti"
          },
          "enabled": {
            "type": "boolean",
            "description": "Enable threat intelligence checks",
            "default": true
          },
          "cache_ttl": {
            "type": "integer",
            "description": "Cache TTL in seconds",
            "default": 3600
          },
          "timeout": {
            "type": "integer",
            "description": "Query timeout in milliseconds",
            "default": 5000
          },
          "fallback_to_custom": {
            "type": "boolean",
            "description": "Fallback to custom API when hs-ti is unavailable",
            "default": false
          },
          "custom_api": {
            "type": "object",
            "description": "Custom threat intelligence API configuration (only used when provider is 'custom' or fallback is enabled)",
            "properties": {
              "api_url": {
                "type": "string",
                "description": "API URL",
                "default": "https://ti.hillstonenet.com.cn"
              },
              "api_key": {
                "type": "string",
                "description": "API Key (SECURITY_MONITOR_API_KEY environment variable recommended over this field)",
                "sensitive": true
              }
            }
          }
        }
      },
      "cache": {
        "type": "object",
        "description": "Cache configuration",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable cache",
            "default": true
          },
          "max_size": {
            "type": "integer",
            "description": "Maximum cache entries",
            "default": 1000
          },
          "ttl": {
            "type": "integer",
            "description": "Cache TTL in seconds",
            "default": 3600
          }
        }
      },
      "policy": {
        "type": "object",
        "description": "Security policy configuration",
        "properties": {
          "block_critical": {
            "type": "boolean",
            "description": "Block critical threats",
            "default": true
          },
          "block_high": {
            "type": "boolean",
            "description": "Block high threats",
            "default": false
          },
          "warn_high": {
            "type": "boolean",
            "description": "Warn on high threats",
            "default": true
          },
          "warn_medium": {
            "type": "boolean",
            "description": "Warn on medium threats",
            "default": true
          },
          "log_low": {
            "type": "boolean",
            "description": "Log low threats",
            "default": true
          },
          "log_benign": {
            "type": "boolean",
            "description": "Log benign access",
            "default": false
          },
          "require_confirmation": {
            "type": "boolean",
            "description": "Require user confirmation for risky actions",
            "default": true
          }
        }
      },
      "whitelist": {
        "type": "object",
        "description": "Whitelist configuration - domains/IPs in this list will not be checked",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable whitelist",
            "default": true
          },
          "domains": {
            "type": "array",
            "description": "Domain whitelist",
            "items": {
              "type": "string"
            },
            "default": ["github.com", "openclaw.ai", "hillstonenet.com.cn"]
          },
          "ips": {
            "type": "array",
            "description": "IP whitelist",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "patterns": {
            "type": "array",
            "description": "URL pattern whitelist",
            "items": {
              "type": "string"
            },
            "default": []
          }
        }
      },
      "blacklist": {
        "type": "object",
        "description": "Blacklist configuration - domains/IPs in this list will always be blocked",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable blacklist",
            "default": true
          },
          "domains": {
            "type": "array",
            "description": "Domain blacklist",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "ips": {
            "type": "array",
            "description": "IP blacklist",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "patterns": {
            "type": "array",
            "description": "URL pattern blacklist",
            "items": {
              "type": "string"
            },
            "default": []
          }
        }
      },
      "logging": {
        "type": "object",
        "description": "Logging configuration. IMPORTANT: Logs may contain monitored URLs and file paths. Review SECURITY.md for best practices.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable logging",
            "default": true
          },
          "log_file": {
            "type": "string",
            "description": "Log file path",
            "default": "~/.openclaw/logs/security-monitor.log"
          },
          "log_blocked": {
            "type": "boolean",
            "description": "Log blocked events",
            "default": true
          },
          "log_warned": {
            "type": "boolean",
            "description": "Log warned events",
            "default": true
          },
          "log_logged": {
            "type": "boolean",
            "description": "Log logged events",
            "default": true
          },
          "log_benign": {
            "type": "boolean",
            "description": "Log benign events",
            "default": false
          },
          "max_log_size_mb": {
            "type": "integer",
            "description": "Maximum log file size in MB",
            "default": 10
          },
          "log_rotation": {
            "type": "boolean",
            "description": "Enable log rotation",
            "default": true
          }
        }
      },
      "monitoring": {
        "type": "object",
        "description": "Monitoring configuration. This skill automatically monitors specified tools via OpenClaw plugin hooks. It will inspect tool parameters and may read local files for hash calculation.",
        "properties": {
          "web_fetch": {
            "type": "boolean",
            "description": "Monitor web_fetch tool calls",
            "default": true
          },
          "web_search": {
            "type": "boolean",
            "description": "Monitor web_search tool calls",
            "default": true
          },
          "browser": {
            "type": "boolean",
            "description": "Monitor browser tool calls",
            "default": true
          },
          "file_download": {
            "type": "boolean",
            "description": "Monitor file download operations",
            "default": true
          },
          "check_file_hashes": {
            "type": "boolean",
            "description": "Calculate and check file hashes (requires reading file contents)",
            "default": true
          }
        }
      },
      "notifications": {
        "type": "object",
        "description": "Notification configuration",
        "properties": {
          "show_warnings": {
            "type": "boolean",
            "description": "Show security warnings",
            "default": true
          },
          "show_threat_details": {
            "type": "boolean",
            "description": "Show threat details in warnings",
            "default": true
          },
          "show_recommendations": {
            "type": "boolean",
            "description": "Show security recommendations",
            "default": true
          }
        }
      }
    }
  },
  "keywords": [
    "security-monitor",
    "network-security",
    "threat-intelligence",
    "web-filter",
    "url-filter",
    "ip-filter",
    "file-security",
    "threat-detection",
    "malware-detection",
    "phishing-detection",
    "network-security-monitor",
    "network-access-control",
    "download-security",
    "network-threat-protection",
    "threat-monitor",
    "sec-mon",
    "openclaw-security",
    "hs-ti-integration"
  ],
  "author": "maxjia",
  "publisher": "maxjia",
  "license": "MIT",
  "dependencies": {
    "python": ">=3.8"
  },
  "openclaw": {
    "type": "python-skill",
    "commands": [
      "/security-check",
      "/sec-check",
      "/threat-check",
      "/security-monitor",
      "/security-stats"
    ],
    "hooks": {
      "before_tool_call": "scripts/security_monitor.py:before_tool_call"
    }
  }
}
