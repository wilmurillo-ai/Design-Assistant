{
  "poems": [
    {
      "id": 1,
      "title": "静夜思",
      "author": "李白",
      "dynasty": "唐",
      "lines": ["床前明月光", "疑是地上霜", "举头望明月", "低头思故乡"]
    },
    {
      "id": 2,
      "title": "春晓",
      "author": "孟浩然",
      "dynasty": "唐",
      "lines": ["春眠不觉晓", "处处闻啼鸟", "夜来风雨声", "花落知多少"]
    },
    {
      "id": 3,
      "title": "望庐山瀑布",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "日照香炉生紫烟",
        "遥看瀑布挂前川",
        "飞流直下三千尺",
        "疑是银河落九天"
      ]
    },
    {
      "id": 4,
      "title": "赠汪伦",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "李白乘舟将欲行",
        "忽闻岸上踏歌声",
        "桃花潭水深千尺",
        "不及汪伦送我情"
      ]
    },
    {
      "id": 5,
      "title": "黄鹤楼送孟浩然之广陵",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "故人西辞黄鹤楼",
        "烟花三月下扬州",
        "孤帆远影碧空尽",
        "唯见长江天际流"
      ]
    },
    {
      "id": 6,
      "title": "早发白帝城",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "朝辞白帝彩云间",
        "千里江陵一日还",
        "两岸猿声啼不住",
        "轻舟已过万重山"
      ]
    },
    {
      "id": 7,
      "title": "望天门山",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "天门中断楚江开",
        "碧水东流至此回",
        "两岸青山相对出",
        "孤帆一片日边来"
      ]
    },
    {
      "id": 8,
      "title": "绝句",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        "两个黄鹂鸣翠柳",
        "一行白鹭上青天",
        "窗含西岭千秋雪",
        "门泊东吴万里船"
      ]
    },
    {
      "id": 9,
      "title": "春夜喜雨",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": ["好雨知时节", "当春乃发生", "随风潜入夜", "润物细无声"]
    },
    {
      "id": 10,
      "title": "望岳",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": ["岱宗夫如何", "齐鲁青未了", "造化钟神秀", "阴阳割昏晓"]
    },
    {
      "id": 11,
      "title": "登鹳雀楼",
      "author": "王之涣",
      "dynasty": "唐",
      "lines": ["白日依山尽", "黄河入海流", "欲穷千里目", "更上一层楼"]
    },
    {
      "id": 12,
      "title": "凉州词",
      "author": "王之涣",
      "dynasty": "唐",
      "lines": [
        "黄河远上白云间",
        "一片孤城万仞山",
        "羌笛何须怨杨柳",
        "春风不度玉门关"
      ]
    },
    {
      "id": 13,
      "title": "枫桥夜泊",
      "author": "张继",
      "dynasty": "唐",
      "lines": [
        "月落乌啼霜满天",
        "江枫渔火对愁眠",
        "姑苏城外寒山寺",
        "夜半钟声到客船"
      ]
    },
    {
      "id": 14,
      "title": "清明",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "清明时节雨纷纷",
        "路上行人欲断魂",
        "借问酒家何处有",
        "牧童遥指杏花村"
      ]
    },
    {
      "id": 15,
      "title": "山行",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "远上寒山石径斜",
        "白云生处有人家",
        "停车坐爱枫林晚",
        "霜叶红于二月花"
      ]
    },
    {
      "id": 16,
      "title": "泊秦淮",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "烟笼寒水月笼沙",
        "夜泊秦淮近酒家",
        "商女不知亡国恨",
        "隔江犹唱后庭花"
      ]
    },
    {
      "id": 17,
      "title": "乐游原",
      "author": "李商隐",
      "dynasty": "唐",
      "lines": ["向晚意不适", "驱车登古原", "夕阳无限好", "只是近黄昏"]
    },
    {
      "id": 18,
      "title": "夜雨寄北",
      "author": "李商隐",
      "dynasty": "唐",
      "lines": [
        "君问归期未有期",
        "巴山夜雨涨秋池",
        "何当共剪西窗烛",
        "却话巴山夜雨时"
      ]
    },
    {
      "id": 19,
      "title": "九月九日忆山东兄弟",
      "author": "王维",
      "dynasty": "唐",
      "lines": [
        "独在异乡为异客",
        "每逢佳节倍思亲",
        "遥知兄弟登高处",
        "遍插茱萸少一人"
      ]
    },
    {
      "id": 20,
      "title": "送元二使安西",
      "author": "王维",
      "dynasty": "唐",
      "lines": [
        "渭城朝雨浥轻尘",
        "客舍青青柳色新",
        "劝君更尽一杯酒",
        "西出阳关无故人"
      ]
    },
    {
      "id": 21,
      "title": "山居秋暝",
      "author": "王维",
      "dynasty": "唐",
      "lines": ["空山新雨后", "天气晚来秋", "明月松间照", "清泉石上流"]
    },
    {
      "id": 22,
      "title": "鸟鸣涧",
      "author": "王维",
      "dynasty": "唐",
      "lines": ["人闲桂花落", "夜静春山空", "月出惊山鸟", "时鸣春涧中"]
    },
    {
      "id": 23,
      "title": "使至塞上",
      "author": "王维",
      "dynasty": "唐",
      "lines": ["单车欲问边", "属国过居延", "征蓬出汉塞", "归雁入胡天"]
    },
    {
      "id": 24,
      "title": "终南别业",
      "author": "王维",
      "dynasty": "唐",
      "lines": ["中岁颇好道", "晚家南山陲", "兴来每独往", "胜事空自知"]
    },
    {
      "id": 25,
      "title": "鹿柴",
      "author": "王维",
      "dynasty": "唐",
      "lines": ["空山不见人", "但闻人语响", "返景入深林", "复照青苔上"]
    },
    {
      "id": 26,
      "title": "竹里馆",
      "author": "王维",
      "dynasty": "唐",
      "lines": ["独坐幽篁里", "弹琴复长啸", "深林人不知", "明月来相照"]
    },
    {
      "id": 27,
      "title": "相思",
      "author": "王维",
      "dynasty": "唐",
      "lines": ["红豆生南国", "春来发几枝", "愿君多采撷", "此物最相思"]
    },
    {
      "id": 28,
      "title": "黄鹤楼",
      "author": "崔颢",
      "dynasty": "唐",
      "lines": [
        "昔人已乘黄鹤去",
        "此地空余黄鹤楼",
        "黄鹤一去不复返",
        "白云千载空悠悠"
      ]
    },
    {
      "id": 29,
      "title": "望洞庭",
      "author": "刘禹锡",
      "dynasty": "唐",
      "lines": [
        "湖光秋月两相和",
        "潭面无风镜未磨",
        "遥望洞庭山水翠",
        "白银盘里一青螺"
      ]
    },
    {
      "id": 30,
      "title": "浪淘沙",
      "author": "刘禹锡",
      "dynasty": "唐",
      "lines": [
        "九曲黄河万里沙",
        "浪淘风簸自天涯",
        "如今直上银河去",
        "同到牵牛织女家"
      ]
    },
    {
      "id": 31,
      "title": "乌衣巷",
      "author": "刘禹锡",
      "dynasty": "唐",
      "lines": [
        "朱雀桥边野草花",
        "乌衣巷口夕阳斜",
        "旧时王谢堂前燕",
        "飞入寻常百姓家"
      ]
    },
    {
      "id": 32,
      "title": "石头城",
      "author": "刘禹锡",
      "dynasty": "唐",
      "lines": [
        "山围故国周遭在",
        "潮打空城寂寞回",
        "淮水东边旧时月",
        "夜深还过女墙来"
      ]
    },
    {
      "id": 33,
      "title": "秋词",
      "author": "刘禹锡",
      "dynasty": "唐",
      "lines": [
        "自古逢秋悲寂寥",
        "我言秋日胜春朝",
        "晴空一鹤排云上",
        "便引诗情到碧霄"
      ]
    },
    {
      "id": 34,
      "title": "江雪",
      "author": "柳宗元",
      "dynasty": "唐",
      "lines": ["千山鸟飞绝", "万径人踪灭", "孤舟蓑笠翁", "独钓寒江雪"]
    },
    {
      "id": 35,
      "title": "渔翁",
      "author": "柳宗元",
      "dynasty": "唐",
      "lines": [
        "渔翁夜傍西岩宿",
        "晓汲清湘燃楚竹",
        "烟销日出不见人",
        "欸乃一声山水绿"
      ]
    },
    {
      "id": 36,
      "title": "登乐游原",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "长空澹澹孤鸟没",
        "万古销沉向此中",
        "看取汉家何事业",
        "五陵无树起秋风"
      ]
    },
    {
      "id": 37,
      "title": "江南春",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "千里莺啼绿映红",
        "水村山郭酒旗风",
        "南朝四百八十寺",
        "多少楼台烟雨中"
      ]
    },
    {
      "id": 38,
      "title": "赤壁",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "折戟沉沙铁未销",
        "自将磨洗认前朝",
        "东风不与周郎便",
        "铜雀春深锁二乔"
      ]
    },
    {
      "id": 39,
      "title": "题乌江亭",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "胜败兵家事不期",
        "包羞忍耻是男儿",
        "江东子弟多才俊",
        "卷土重来未可知"
      ]
    },
    {
      "id": 40,
      "title": "金谷园",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "繁华事散逐香尘",
        "流水无情草自春",
        "日暮东风怨啼鸟",
        "落花犹似坠楼人"
      ]
    },
    {
      "id": 41,
      "title": "秋夕",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "银烛秋光冷画屏",
        "轻罗小扇扑流萤",
        "天阶夜色凉如水",
        "卧看牵牛织女星"
      ]
    },
    {
      "id": 42,
      "title": "赠别",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "娉娉袅袅十三余",
        "豆蔻梢头二月初",
        "春风十里扬州路",
        "卷上珠帘总不如"
      ]
    },
    {
      "id": 43,
      "title": "无题",
      "author": "李商隐",
      "dynasty": "唐",
      "lines": [
        "相见时难别亦难",
        "东风无力百花残",
        "春蚕到死丝方尽",
        "蜡炬成灰泪始干"
      ]
    },
    {
      "id": 44,
      "title": "锦瑟",
      "author": "李商隐",
      "dynasty": "唐",
      "lines": [
        "锦瑟无端五十弦",
        "一弦一柱思华年",
        "庄生晓梦迷蝴蝶",
        "望帝春心托杜鹃"
      ]
    },
    {
      "id": 45,
      "title": "嫦娥",
      "author": "李商隐",
      "dynasty": "唐",
      "lines": [
        "云母屏风烛影深",
        "长河渐落晓星沉",
        "嫦娥应悔偷灵药",
        "碧海青天夜夜心"
      ]
    },
    {
      "id": 46,
      "title": "贾生",
      "author": "李商隐",
      "dynasty": "唐",
      "lines": [
        "宣室求贤访逐臣",
        "贾生才调更无伦",
        "可怜夜半虚前席",
        "不问苍生问鬼神"
      ]
    },
    {
      "id": 47,
      "title": "夜雨寄北",
      "author": "李商隐",
      "dynasty": "唐",
      "lines": [
        "君问归期未有期",
        "巴山夜雨涨秋池",
        "何当共剪西窗烛",
        "却话巴山夜雨时"
      ]
    },
    {
      "id": 48,
      "title": "望岳",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": ["岱宗夫如何", "齐鲁青未了", "造化钟神秀", "阴阳割昏晓"]
    },
    {
      "id": 49,
      "title": "茅屋为秋风所破歌",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        "八月秋高风怒号",
        "卷我屋上三重茅",
        "茅飞渡江洒江郊",
        "高者挂罥长林梢"
      ]
    },
    {
      "id": 50,
      "title": "登高",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        "风急天高猿啸哀",
        "渚清沙白鸟飞回",
        "无边落木萧萧下",
        "不尽长江滚滚来"
      ]
    },
    {
      "id": 51,
      "title": "蜀相",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        "丞相祠堂何处寻",
        "锦官城外柏森森",
        "映阶碧草自春色",
        "隔叶黄鹂空好音"
      ]
    },
    {
      "id": 52,
      "title": "闻官军收河南河北",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        "剑外忽传收蓟北",
        "初闻涕泪满衣裳",
        "却看妻子愁何在",
        "漫卷诗书喜欲狂"
      ]
    },
    {
      "id": 53,
      "title": "绝句二首",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": ["迟日江山丽", "春风花草香", "泥融飞燕子", "沙暖睡鸳鸯"]
    },
    {
      "id": 54,
      "title": "江畔独步寻花",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        "黄四娘家花满蹊",
        "千朵万朵压枝低",
        "留连戏蝶时时舞",
        "自在娇莺恰恰啼"
      ]
    },
    {
      "id": 55,
      "title": "赠花卿",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        "锦城丝管日纷纷",
        "半入江风半入云",
        "此曲只应天上有",
        "人间能得几回闻"
      ]
    },
    {
      "id": 56,
      "title": "旅夜书怀",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": ["细草微风岸", "危樯独夜舟", "星垂平野阔", "月涌大江流"]
    },
    {
      "id": 57,
      "title": "登高",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        "风急天高猿啸哀",
        "渚清沙白鸟飞回",
        "无边落木萧萧下",
        "不尽长江滚滚来"
      ]
    },
    {
      "id": 58,
      "title": "望庐山瀑布",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "日照香炉生紫烟",
        "遥看瀑布挂前川",
        "飞流直下三千尺",
        "疑是银河落九天"
      ]
    },
    {
      "id": 59,
      "title": "行路难",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "金樽清酒斗十千",
        "玉盘珍羞直万钱",
        "停杯投箸不能食",
        "拔剑四顾心茫然"
      ]
    },
    {
      "id": 60,
      "title": "蜀道难",
      "author": "李白",
      "dynasty": "唐",
      "lines": ["噫吁嚱", "危乎高哉", "蜀道之难", "难于上青天"]
    },
    {
      "id": 61,
      "title": "梦游天姥吟留别",
      "author": "李白",
      "dynasty": "唐",
      "lines": ["海客谈瀛洲", "烟涛微茫信难求", "越人语天姥", "云霞明灭或可睹"]
    },
    {
      "id": 62,
      "title": "将进酒",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "君不见黄河之水天上来",
        "奔流到海不复回",
        "君不见高堂明镜悲白发",
        "朝如青丝暮成雪"
      ]
    },
    {
      "id": 63,
      "title": "望天门山",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "天门中断楚江开",
        "碧水东流至此回",
        "两岸青山相对出",
        "孤帆一片日边来"
      ]
    },
    {
      "id": 64,
      "title": "早发白帝城",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "朝辞白帝彩云间",
        "千里江陵一日还",
        "两岸猿声啼不住",
        "轻舟已过万重山"
      ]
    },
    {
      "id": 65,
      "title": "黄鹤楼送孟浩然之广陵",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "故人西辞黄鹤楼",
        "烟花三月下扬州",
        "孤帆远影碧空尽",
        "唯见长江天际流"
      ]
    },
    {
      "id": 66,
      "title": "赠汪伦",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "李白乘舟将欲行",
        "忽闻岸上踏歌声",
        "桃花潭水深千尺",
        "不及汪伦送我情"
      ]
    },
    {
      "id": 67,
      "title": "闻王昌龄左迁龙标遥有此寄",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "杨花落尽子规啼",
        "闻道龙标过五溪",
        "我寄愁心与明月",
        "随君直到夜郎西"
      ]
    },
    {
      "id": 68,
      "title": "望庐山瀑布",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "日照香炉生紫烟",
        "遥看瀑布挂前川",
        "飞流直下三千尺",
        "疑是银河落九天"
      ]
    },
    {
      "id": 69,
      "title": "夜宿山寺",
      "author": "李白",
      "dynasty": "唐",
      "lines": ["危楼高百尺", "手可摘星辰", "不敢高声语", "恐惊天上人"]
    },
    {
      "id": 70,
      "title": "独坐敬亭山",
      "author": "李白",
      "dynasty": "唐",
      "lines": ["众鸟高飞尽", "孤云独去闲", "相看两不厌", "只有敬亭山"]
    },
    {
      "id": 71,
      "title": "秋浦歌",
      "author": "李白",
      "dynasty": "唐",
      "lines": ["白发三千丈", "缘愁似个长", "不知明镜里", "何处得秋霜"]
    },
    {
      "id": 72,
      "title": "清平调",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "云想衣裳花想容",
        "春风拂槛露华浓",
        "若非群玉山头见",
        "会向瑶台月下逢"
      ]
    },
    {
      "id": 73,
      "title": "望岳",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": ["岱宗夫如何", "齐鲁青未了", "造化钟神秀", "阴阳割昏晓"]
    },
    {
      "id": 74,
      "title": "春夜喜雨",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": ["好雨知时节", "当春乃发生", "随风潜入夜", "润物细无声"]
    },
    {
      "id": 75,
      "title": "绝句",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        "两个黄鹂鸣翠柳",
        "一行白鹭上青天",
        "窗含西岭千秋雪",
        "门泊东吴万里船"
      ]
    },
    {
      "id": 76,
      "title": "江畔独步寻花",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        "黄四娘家花满蹊",
        "千朵万朵压枝低",
        "留连戏蝶时时舞",
        "自在娇莺恰恰啼"
      ]
    },
    {
      "id": 77,
      "title": "江南逢李龟年",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        "岐王宅里寻常见",
        "崔九堂前几度闻",
        "正是江南好风景",
        "落花时节又逢君"
      ]
    },
    {
      "id": 78,
      "title": "登鹳雀楼",
      "author": "王之涣",
      "dynasty": "唐",
      "lines": ["白日依山尽", "黄河入海流", "欲穷千里目", "更上一层楼"]
    },
    {
      "id": 79,
      "title": "凉州词",
      "author": "王之涣",
      "dynasty": "唐",
      "lines": [
        "黄河远上白云间",
        "一片孤城万仞山",
        "羌笛何须怨杨柳",
        "春风不度玉门关"
      ]
    },
    {
      "id": 80,
      "title": "凉州词",
      "author": "王翰",
      "dynasty": "唐",
      "lines": [
        "葡萄美酒夜光杯",
        "欲饮琵琶马上催",
        "醉卧沙场君莫笑",
        "古来征战几人回"
      ]
    },
    {
      "id": 81,
      "title": "枫桥夜泊",
      "author": "张继",
      "dynasty": "唐",
      "lines": [
        "月落乌啼霜满天",
        "江枫渔火对愁眠",
        "姑苏城外寒山寺",
        "夜半钟声到客船"
      ]
    },
    {
      "id": 82,
      "title": "寒食",
      "author": "韩翃",
      "dynasty": "唐",
      "lines": [
        "春城无处不飞花",
        "寒食东风御柳斜",
        "日暮汉宫传蜡烛",
        "轻烟散入五侯家"
      ]
    },
    {
      "id": 83,
      "title": "滁州西涧",
      "author": "韦应物",
      "dynasty": "唐",
      "lines": [
        "独怜幽草涧边生",
        "上有黄鹂深树鸣",
        "春潮带雨晚来急",
        "野渡无人舟自横"
      ]
    },
    {
      "id": 84,
      "title": "塞下曲",
      "author": "卢纶",
      "dynasty": "唐",
      "lines": ["月黑雁飞高", "单于夜遁逃", "欲将轻骑逐", "大雪满弓刀"]
    },
    {
      "id": 85,
      "title": "游子吟",
      "author": "孟郊",
      "dynasty": "唐",
      "lines": ["慈母手中线", "游子身上衣", "临行密密缝", "意恐迟迟归"]
    },
    {
      "id": 86,
      "title": "登科后",
      "author": "孟郊",
      "dynasty": "唐",
      "lines": [
        "昔日龌龊不足夸",
        "今朝放荡思无涯",
        "春风得意马蹄疾",
        "一日看尽长安花"
      ]
    },
    {
      "id": 87,
      "title": "江雪",
      "author": "柳宗元",
      "dynasty": "唐",
      "lines": ["千山鸟飞绝", "万径人踪灭", "孤舟蓑笠翁", "独钓寒江雪"]
    },
    {
      "id": 88,
      "title": "渔翁",
      "author": "柳宗元",
      "dynasty": "唐",
      "lines": [
        "渔翁夜傍西岩宿",
        "晓汲清湘燃楚竹",
        "烟销日出不见人",
        "欸乃一声山水绿"
      ]
    },
    {
      "id": 89,
      "title": "竹枝词",
      "author": "刘禹锡",
      "dynasty": "唐",
      "lines": [
        "杨柳青青江水平",
        "闻郎江上踏歌声",
        "东边日出西边雨",
        "道是无晴却有晴"
      ]
    },
    {
      "id": 90,
      "title": "浪淘沙",
      "author": "刘禹锡",
      "dynasty": "唐",
      "lines": [
        "九曲黄河万里沙",
        "浪淘风簸自天涯",
        "如今直上银河去",
        "同到牵牛织女家"
      ]
    },
    {
      "id": 91,
      "title": "望洞庭",
      "author": "刘禹锡",
      "dynasty": "唐",
      "lines": [
        "湖光秋月两相和",
        "潭面无风镜未磨",
        "遥望洞庭山水翠",
        "白银盘里一青螺"
      ]
    },
    {
      "id": 92,
      "title": "乌衣巷",
      "author": "刘禹锡",
      "dynasty": "唐",
      "lines": [
        "朱雀桥边野草花",
        "乌衣巷口夕阳斜",
        "旧时王谢堂前燕",
        "飞入寻常百姓家"
      ]
    },
    {
      "id": 93,
      "title": "石头城",
      "author": "刘禹锡",
      "dynasty": "唐",
      "lines": [
        "山围故国周遭在",
        "潮打空城寂寞回",
        "淮水东边旧时月",
        "夜深还过女墙来"
      ]
    },
    {
      "id": 94,
      "title": "秋词",
      "author": "刘禹锡",
      "dynasty": "唐",
      "lines": [
        "自古逢秋悲寂寥",
        "我言秋日胜春朝",
        "晴空一鹤排云上",
        "便引诗情到碧霄"
      ]
    },
    {
      "id": 95,
      "title": "江南春",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "千里莺啼绿映红",
        "水村山郭酒旗风",
        "南朝四百八十寺",
        "多少楼台烟雨中"
      ]
    },
    {
      "id": 96,
      "title": "山行",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "远上寒山石径斜",
        "白云生处有人家",
        "停车坐爱枫林晚",
        "霜叶红于二月花"
      ]
    },
    {
      "id": 97,
      "title": "清明",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "清明时节雨纷纷",
        "路上行人欲断魂",
        "借问酒家何处有",
        "牧童遥指杏花村"
      ]
    },
    {
      "id": 98,
      "title": "赤壁",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "折戟沉沙铁未销",
        "自将磨洗认前朝",
        "东风不与周郎便",
        "铜雀春深锁二乔"
      ]
    },
    {
      "id": 99,
      "title": "泊秦淮",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "烟笼寒水月笼沙",
        "夜泊秦淮近酒家",
        "商女不知亡国恨",
        "隔江犹唱后庭花"
      ]
    },
    {
      "id": 100,
      "title": "秋夕",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        "银烛秋光冷画屏",
        "轻罗小扇扑流萤",
        "天阶夜色凉如水",
        "卧看牵牛织女星"
      ]
    }
  ]
}
