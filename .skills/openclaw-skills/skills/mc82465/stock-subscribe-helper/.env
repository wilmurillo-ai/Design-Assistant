# stock-subscribe-helper 合规版环境变量配置
# 复制此文件为 .env 并填写实际值

# ==================== 飞书配置 ====================
# 飞书机器人Webhook（从飞书机器人设置获取）
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 飞书AccessToken（从飞书开放平台获取）
FEISHU_ACCESS_TOKEN=t-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书多维表格AppToken（从表格设置-开发者信息获取）
FEISHU_APP_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书表格ID（从表格URL获取）
FEISHU_TABLE_ID=tblxxxxxxxxxxxxxxxx

# ==================== 用户配置 ====================
# 订阅产品类型：仅新债 / 仅新股 / 新债+新股
SUBSCRIPTION_PRODUCT=新债+新股

# 关注板块：主板 / 创业板 / 科创板 / 北交所
SUBSCRIPTION_PLATE=["主板", "创业板"]

# 用户ID（用于标识操作）
USER_ID=default_user

# ==================== 运行配置 ====================
# 调试模式（true/false）
DEBUG=false

# API请求超时时间（毫秒）
REQUEST_TIMEOUT=15000