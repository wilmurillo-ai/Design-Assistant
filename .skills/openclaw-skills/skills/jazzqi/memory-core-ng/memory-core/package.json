  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/memory-core"
  },
  "bugs": {
    "url": "https://github.com/openclaw/memory-core/issues"
  },
  "homepage": "https://github.com/openclaw/memory-core#readme",
