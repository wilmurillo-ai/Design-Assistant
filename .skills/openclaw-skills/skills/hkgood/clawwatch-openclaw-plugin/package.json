{
  "name": "clawwatch-openclaw-plugin",
  "version": "1.3.11",
  "description": "OpenClaw plugin + CLI: ClawWatch node agent (setup, bind, adaptive report to ClawWatch Worker)",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "clawwatch-agent": "./src/agent.mjs"
  },
  "files": [
    "dist",
    "src",
    "openclaw.plugin.json",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hkgood/clawwatch-openclaw-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/hkgood/clawwatch-openclaw-plugin/issues"
  },
  "homepage": "https://github.com/hkgood/clawwatch-openclaw-plugin#readme",
  "author": "hkgood",
  "license": "MIT",
  "keywords": [
    "clawwatch",
    "openclaw",
    "openclaw-plugin",
    "telemetry",
    "clawhub"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.1",
      "minGatewayVersion": "2026.3.1"
    },
    "build": {
      "openclawVersion": "2026.3.1",
      "pluginSdkVersion": "2026.3.1"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.1"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
