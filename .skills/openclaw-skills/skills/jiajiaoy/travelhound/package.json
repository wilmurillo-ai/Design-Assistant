{
  "name": "travelhound",
  "version": "1.0.0",
  "description": "Flight and hotel price comparison with booking timing analysis — Google Flights, Skyscanner, Kayak, Booking.com, Agoda, Trip.com. Stacks OTA coupon codes via CouponClaw and pulls destination news via NewsToday.",
  "keywords": [
    "flights",
    "cheap flights",
    "flight comparison",
    "flight deals",
    "best time to book flights",
    "Google Flights",
    "Skyscanner",
    "Kayak",
    "hotels",
    "hotel deals",
    "cheap hotels",
    "hotel comparison",
    "Booking.com",
    "Agoda",
    "Trip.com",
    "携程",
    "travel",
    "travel planning",
    "trip planner",
    "travel deals",
    "机票",
    "酒店",
    "旅行计划",
    "机票比价",
    "酒店比价",
    "订机票",
    "订酒店",
    "旅游",
    "travel budget",
    "OTA",
    "travel coupon",
    "visa requirements",
    "exchange rate"
  ],
  "main": "scripts/trip.js",
  "scripts": {
    "flights": "node scripts/flights.js",
    "hotels": "node scripts/hotels.js",
    "trip": "node scripts/trip.js"
  },
  "openclaw": {
    "triggers": [
      "flights",
      "cheap flights",
      "hotels",
      "hotel",
      "travel",
      "trip to",
      "机票",
      "酒店",
      "旅行",
      "旅游",
      "订机票",
      "订酒店"
    ],
    "entrypoint": "scripts/trip.js"
  },
  "dependencies": {}
}
