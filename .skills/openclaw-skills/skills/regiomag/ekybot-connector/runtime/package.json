{
  "name": "ekybot-connector",
  "version": "1.0.1",
  "description": "Bridge OpenClaw agents to Ekybot remote management platform",
  "main": "src/index.js",
  "keywords": [
    "openclaw",
    "ai-agents",
    "remote-management",
    "ekybot",
    "telemetry",
    "monitoring"
  ],
  "author": "Ekybot Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/regiomag/ekybot-connector.git"
  },
  "homepage": "https://github.com/regiomag/ekybot-connector#readme",
  "bugs": {
    "url": "https://github.com/regiomag/ekybot-connector/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "dotenv": "^16.3.1",
    "inquirer": "^8.2.6",
    "node-fetch": "^2.7.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "start": "node scripts/start.js",
    "stop": "node scripts/stop.js",
    "restart": "npm run stop && npm run start",
    "register": "node scripts/register.js",
    "companion:register": "node scripts/companion-register.js",
    "companion:connect": "node scripts/companion-connect.js",
    "companion:api-check": "node scripts/companion-api-check.js",
    "companion:doctor": "node scripts/companion-doctor.js",
    "companion:disconnect": "node scripts/companion-disconnect.js",
    "companion:sync": "node scripts/companion-sync.js",
    "companion:memory-check": "node scripts/companion-memory-check.js",
    "companion:apply": "node scripts/companion-apply.js",
    "companion:reconcile": "node scripts/companion-reconcile.js",
    "companion:daemon": "node scripts/companion-daemon.js",
    "companion:install-launchd": "node scripts/companion-install-launchd.js",
    "setup": "node scripts/setup.js",
    "preview": "node scripts/preview.js",
    "enable-telemetry": "node scripts/enable-telemetry.js",
    "health": "node scripts/health.js",
    "test-connection": "node scripts/test-connection.js",
    "logs": "node scripts/logs.js",
    "install-service": "node scripts/install-service.js",
    "uninstall": "node scripts/uninstall.js",
    "test": "node --test tests/*.test.js",
    "test:verbose": "node --test --reporter=verbose tests/*.test.js",
    "lint": "eslint src/ scripts/ tests/",
    "lint:fix": "eslint --fix src/ scripts/ tests/",
    "format": "prettier --write src/ scripts/ tests/ *.md",
    "format:check": "prettier --check src/ scripts/ tests/ *.md",
    "validate": "npm run lint && npm run format:check && npm run test",
    "prepare": "npm run validate"
  },
  "files": [
    "src/",
    "scripts/",
    "README.md",
    "LICENSE",
    ".env.example"
  ]
}
