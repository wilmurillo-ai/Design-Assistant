{
  "name": "tushare-future",
  "version": "1.0.1",
  "description": "提供行情、仓单、持仓排名等14个期货数据接口。注意：本技能不内置Token，需用户自行提供。",
  "author": "真圆氦狗",
  "tags": ["期货", "行情", "tushare", "量化"],
  "license": "MIT",
  "dependencies": {
    "python": ">=3.8",
    "packages": ["tushare>=1.2.89", "pandas>=1.5.0"]
  },
  "openclaw": {
    "requires": {
      "bins": ["python3"],
      "env": ["TUSHARE_TOKEN"]
    }
  },
  "environment_variables": ["TUSHARE_TOKEN"],
  "runtime": {
    "type": "python3",
    "entrypoint": "handler"
  }
}