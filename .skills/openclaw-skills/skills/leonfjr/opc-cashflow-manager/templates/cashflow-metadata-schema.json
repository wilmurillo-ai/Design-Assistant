{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cash Flow Snapshot",
  "description": "Monthly cash flow snapshot for solo founder survival forecasting. Stores opening cash, expected inflows, committed outflows, recurring commitments, scenario assumptions, and generated alerts.",
  "type": "object",
  "required": [
    "snapshot_id",
    "period",
    "opening_cash",
    "status",
    "created_at"
  ],
  "properties": {
    "snapshot_id": {
      "type": "string",
      "description": "Unique ID in YYYY-MM format, e.g. 2026-03",
      "pattern": "^\\d{4}-\\d{2}$"
    },
    "period": {
      "type": "string",
      "description": "The month this snapshot covers, YYYY-MM format",
      "pattern": "^\\d{4}-\\d{2}$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "current", "historical"],
      "description": "draft = work in progress, current = active month, historical = archived"
    },
    "opening_cash": {
      "type": "object",
      "description": "Cash on hand at start of period",
      "required": ["amount", "as_of_date", "source"],
      "properties": {
        "amount": {
          "type": "string",
          "description": "Decimal-safe string, e.g. '15000.00'"
        },
        "as_of_date": {
          "type": "string",
          "format": "date",
          "description": "Date this balance was confirmed, YYYY-MM-DD"
        },
        "source": {
          "type": "string",
          "enum": ["manual", "bank_statement", "last_snapshot"],
          "description": "How this amount was obtained"
        },
        "notes": {
          "type": ["string", "null"],
          "default": null
        }
      }
    },
    "expected_inflows": {
      "type": "array",
      "description": "All expected income for the forecast period",
      "items": {
        "type": "object",
        "required": ["id", "source", "amount", "expected_date", "confidence", "status"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique inflow ID, e.g. inflow-001"
          },
          "source": {
            "type": "string",
            "description": "Client name or revenue source"
          },
          "amount": {
            "type": "string",
            "description": "Decimal-safe string"
          },
          "expected_date": {
            "type": "string",
            "format": "date",
            "description": "When payment is expected, YYYY-MM-DD"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "high=0.9-1.0 (signed contract, sent invoice), medium=0.5-0.7 (verbal, proposal), low=0.1-0.3 (pipeline, speculative)"
          },
          "probability_factor": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Auto-set from confidence: high=0.95, medium=0.6, low=0.2. Can be overridden."
          },
          "weighted_amount": {
            "type": "string",
            "description": "amount × probability_factor, decimal-safe string"
          },
          "invoice_ref": {
            "type": ["string", "null"],
            "description": "Link to opc-invoice-manager invoice_id, e.g. INV-2026-001_acme-corp",
            "default": null
          },
          "status": {
            "type": "string",
            "enum": ["expected", "received", "partial", "cancelled", "delayed"],
            "description": "Current tracking status of this inflow"
          },
          "received_amount": {
            "type": ["string", "null"],
            "description": "Actual amount received (if partial or received)",
            "default": null
          },
          "received_date": {
            "type": ["string", "null"],
            "format": "date",
            "default": null
          },
          "notes": {
            "type": ["string", "null"],
            "default": null
          }
        }
      }
    },
    "committed_outflows": {
      "type": "array",
      "description": "One-time or specific outflows for this period",
      "items": {
        "type": "object",
        "required": ["id", "category", "payee", "amount", "due_date", "essentiality", "status"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique outflow ID, e.g. outflow-001"
          },
          "category": {
            "type": "string",
            "description": "Expense category: rent, software, contractor, utilities, insurance, tax, marketing, equipment, professional_services, other"
          },
          "payee": {
            "type": "string",
            "description": "Who gets paid"
          },
          "amount": {
            "type": "string",
            "description": "Decimal-safe string"
          },
          "due_date": {
            "type": "string",
            "format": "date",
            "description": "When payment is due, YYYY-MM-DD"
          },
          "essentiality": {
            "type": "string",
            "enum": ["critical", "important", "optional"],
            "description": "critical=cannot defer (rent, tax, insurance), important=should pay on time (key tools, contractors), optional=can defer/cancel (subscriptions, nice-to-haves)"
          },
          "status": {
            "type": "string",
            "enum": ["upcoming", "paid", "deferred", "cancelled"],
            "description": "Payment status of this outflow"
          },
          "notes": {
            "type": ["string", "null"],
            "default": null
          }
        }
      }
    },
    "recurring_commitments": {
      "type": "array",
      "description": "Ongoing recurring expenses that generate committed_outflows each period",
      "items": {
        "type": "object",
        "required": ["id", "category", "payee", "amount", "frequency", "next_due_date", "essentiality"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique recurring ID, e.g. recurring-001"
          },
          "category": {
            "type": "string"
          },
          "payee": {
            "type": "string"
          },
          "amount": {
            "type": "string",
            "description": "Decimal-safe string per occurrence"
          },
          "frequency": {
            "type": "string",
            "enum": ["weekly", "biweekly", "monthly", "quarterly", "annual"],
            "description": "How often this recurs"
          },
          "next_due_date": {
            "type": "string",
            "format": "date",
            "description": "Next occurrence date, YYYY-MM-DD"
          },
          "essentiality": {
            "type": "string",
            "enum": ["critical", "important", "optional"]
          },
          "auto_generate": {
            "type": "boolean",
            "default": true,
            "description": "If true, auto-add to committed_outflows each period"
          },
          "notes": {
            "type": ["string", "null"],
            "default": null
          }
        }
      }
    },
    "scenarios": {
      "type": "object",
      "description": "Three-scenario model for forecasting",
      "properties": {
        "base": {
          "type": "object",
          "properties": {
            "inflow_factor": { "type": "number", "default": 1.0 },
            "outflow_factor": { "type": "number", "default": 1.0 },
            "description": { "type": "string", "default": "Expected case — weighted probabilities as-is" }
          }
        },
        "conservative": {
          "type": "object",
          "properties": {
            "inflow_factor": { "type": "number", "default": 0.7 },
            "outflow_factor": { "type": "number", "default": 1.1 },
            "description": { "type": "string", "default": "Pessimistic — 30% less income, 10% more expenses" }
          }
        },
        "aggressive": {
          "type": "object",
          "properties": {
            "inflow_factor": { "type": "number", "default": 1.3 },
            "outflow_factor": { "type": "number", "default": 0.9 },
            "description": { "type": "string", "default": "Optimistic — 30% more income, 10% less expenses" }
          }
        }
      }
    },
    "alerts": {
      "type": "array",
      "description": "System-generated alerts based on forecast analysis",
      "items": {
        "type": "object",
        "required": ["type", "severity", "message", "action_recommended", "triggered_at"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "runway_warning",
              "negative_cash",
              "collection_urgent",
              "large_outflow",
              "concentration_risk"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "warning", "info"]
          },
          "message": {
            "type": "string"
          },
          "action_recommended": {
            "type": "string"
          },
          "triggered_at": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "description": "Calculated summary fields — generated by cashflow_tracker.py",
      "properties": {
        "total_inflows_raw": {
          "type": "string",
          "description": "Sum of all expected inflow amounts (unweighted)"
        },
        "total_inflows_weighted": {
          "type": "string",
          "description": "Sum of all weighted inflow amounts (probability-adjusted)"
        },
        "total_outflows": {
          "type": "string",
          "description": "Sum of all committed outflows + recurring for period"
        },
        "projected_cash_base": {
          "type": "string",
          "description": "opening_cash + weighted_inflows - total_outflows (base scenario)"
        },
        "projected_cash_conservative": {
          "type": "string"
        },
        "projected_cash_aggressive": {
          "type": "string"
        },
        "monthly_burn_rate": {
          "type": "string",
          "description": "Total recurring + average one-time outflows per month"
        },
        "weighted_monthly_income": {
          "type": "string",
          "description": "Probability-weighted expected monthly income"
        },
        "net_monthly_burn": {
          "type": "string",
          "description": "monthly_burn_rate - weighted_monthly_income (positive = spending more than earning)"
        },
        "runway_months": {
          "type": "number",
          "description": "opening_cash / net_monthly_burn (null if cash-flow positive)"
        },
        "runway_months_conservative": {
          "type": "number"
        },
        "cash_flow_positive": {
          "type": "boolean",
          "description": "True if weighted income exceeds burn rate"
        }
      }
    },
    "invoice_import_date": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Last date invoices were auto-imported from opc-invoice-manager",
      "default": null
    },
    "contract_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Contract IDs from opc-contract-manager used for recurring inflow expectations",
      "default": []
    },
    "notes": {
      "type": ["string", "null"],
      "default": null
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null
    }
  }
}
