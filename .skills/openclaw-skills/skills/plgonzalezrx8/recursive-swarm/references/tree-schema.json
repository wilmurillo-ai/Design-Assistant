{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/skills/recursive-swarm/tree-schema.json",
  "title": "recursive-swarm run tree",
  "type": "object",
  "required": [
    "version",
    "runId",
    "task",
    "mode",
    "status",
    "rootNodeId",
    "maxDepth",
    "createdAt",
    "updatedAt",
    "defaults",
    "nodes"
  ],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "task": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": ["research", "coding", "ops", "browser", "mixed"]
    },
    "status": {
      "type": "string",
      "enum": ["planned", "running", "completed", "failed", "waiting_for_approval"]
    },
    "rootNodeId": { "type": "string", "minLength": 1 },
    "maxDepth": { "type": "integer", "minimum": 1, "maximum": 3 },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "defaults": {
      "type": "object",
      "required": ["fanout", "concurrency", "maxNodes", "workspaceMode", "allowWorktrees"],
      "properties": {
        "fanout": { "type": "integer", "minimum": 1, "maximum": 5 },
        "concurrency": { "type": "integer", "minimum": 1, "maximum": 5 },
        "maxNodes": { "type": "integer", "minimum": 1, "maximum": 15 },
        "workspaceMode": { "type": "string", "enum": ["artifacts", "worktree"] },
        "allowWorktrees": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "nodes": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/node" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": [
        "id",
        "goal",
        "type",
        "executor",
        "status",
        "depth",
        "children",
        "dependsOn",
        "confidence",
        "approvalRequired",
        "workspaceMode",
        "artifacts",
        "createdAt",
        "updatedAt",
        "summary"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "parentId": { "type": ["string", "null"] },
        "goal": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["research", "coding", "ops", "browser", "synthesis", "review"]
        },
        "executor": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["planned", "running", "completed", "failed", "waiting_for_approval", "blocked"]
        },
        "depth": { "type": "integer", "minimum": 0, "maximum": 3 },
        "children": { "type": "array", "items": { "type": "string" } },
        "dependsOn": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "string", "enum": ["unknown", "low", "medium", "high"] },
        "approvalRequired": { "type": "boolean" },
        "workspaceMode": { "type": "string", "enum": ["artifacts", "worktree"] },
        "artifacts": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "summary": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
