{
  "id": "unraidclaw",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "serverUrl": {
        "type": "string",
        "description": "URL of the UnraidClaw server (single-server mode)"
      },
      "apiKey": {
        "type": "string",
        "description": "API key for authenticating with UnraidClaw (single-server mode)"
      },
      "tlsSkipVerify": {
        "type": "boolean",
        "description": "Skip TLS certificate verification (for self-signed certs)",
        "default": false
      },
      "servers": {
        "type": "array",
        "description": "Multiple UnraidClaw servers (multi-server mode)",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Server name used to target this server in tool calls"
            },
            "serverUrl": {
              "type": "string",
              "description": "URL of the UnraidClaw server"
            },
            "apiKey": {
              "type": "string",
              "description": "API key for authenticating with this server"
            },
            "tlsSkipVerify": {
              "type": "boolean",
              "description": "Skip TLS certificate verification",
              "default": false
            },
            "default": {
              "type": "boolean",
              "description": "Use this server when no server name is specified"
            }
          },
          "required": ["name", "serverUrl", "apiKey"]
        }
      }
    }
  },
  "uiHints": {
    "serverUrl": {
      "label": "Server URL",
      "placeholder": "https://192.168.1.100:9876"
    },
    "apiKey": {
      "label": "API Key",
      "sensitive": true
    },
    "tlsSkipVerify": {
      "label": "Skip TLS Verification"
    }
  }
}
