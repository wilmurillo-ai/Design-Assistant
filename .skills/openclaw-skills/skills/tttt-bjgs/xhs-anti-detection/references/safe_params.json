{
  "version": "1.0",
  "description": "Safe parameters for Xiaohongshu anti-detection processing",
  "processing": {
    "noise_sigma": 0.3,
    "color_shift": {
      "hue_deg": 1,
      "saturation_pct": 2,
      "brightness_pct": 1
    },
    "recompression": {
      "quality": 98,
      "optimize": true,
      "progressive": false
    },
    "text_protection": {
      "sharpening_radius": 1,
      "sharpening_strength": 0.5,
      "text_detection_threshold": 0.5
    },
    "texture": {
      "grain_amount": 5,
      "grain_size": 1
    }
  },
  "metadata": {
    "fields_to_remove": [
      "Software",
      "Creator",
      "CreatorTool",
      "CreationDate",
      "DateTime",
      "DateTimeOriginal",
      "DateTimeDigitized",
      "Artist",
      "Copyright",
      "ExifVersion",
      "UserComment",
      "Make",
      "Model"
    ],
    "fake_camera_models": [
      "Canon EOS R5",
      "Sony A7M4",
      "iPhone 15 Pro",
      "Xiaomi 14 Ultra",
      "HUAWEI Pura 70 Pro"
    ],
    "preserve_fields": [
      "ImageWidth",
      "ImageHeight",
      "ColorSpace",
      "Orientation",
      "ResolutionUnit",
      "XResolution",
      "YResolution"
    ]
  },
  "verification": {
    "check_metadata_clean": true,
    "check_naturalness_score": true,
    "naturalness_threshold": 0.7,
    "generate_report": true
  },
  "strength_presets": {
    "light": {
      "noise_sigma": 0.1,
      "color_shift_hue_deg": 0.5,
      "color_shift_saturation_pct": 1,
      "grain_amount": 2
    },
    "medium": {
      "noise_sigma": 0.3,
      "color_shift_hue_deg": 1,
      "color_shift_saturation_pct": 2,
      "grain_amount": 5
    },
    "heavy": {
      "noise_sigma": 0.5,
      "color_shift_hue_deg": 2,
      "color_shift_saturation_pct": 3,
      "grain_amount": 8
    }
  }
}
