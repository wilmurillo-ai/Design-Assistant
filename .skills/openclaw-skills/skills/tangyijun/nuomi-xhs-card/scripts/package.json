{
  "name": "nuomi-xhs-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "xhs-card": "./xhs-card.cjs"
  },
  "scripts": {
    "render": "node ./xhs-card.cjs render",
    "templates": "node ./xhs-card.cjs templates list",
