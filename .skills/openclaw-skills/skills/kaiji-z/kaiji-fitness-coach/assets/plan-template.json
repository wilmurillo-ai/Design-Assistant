  "warmup": {
    "duration": "5-10分钟",
    "exercises": [
      "动态拉伸（手臂绕环、腿部摆动）",
      "轻重量预热组（正式动作的50%重量）"
    ]
  },
  
  "cooldown": {
    "duration": "5-10分钟",
    "exercises": [
      "静态拉伸目标肌群（每个动作30秒）",
      "泡沫轴放松（如果有）"
    ]
  },
  
  "progression": {
    "method": "渐进超负荷",
    "rules": [
      "连续2周完成目标次数上限 → 增加重量2.5-5%",
      "无法完成 → 保持重量，先增加次数",
      "动作变形 → 降低重量，专注技术"
    ]
  },
  
  "schedule": {
    "suggested": ["周一", "周三", "周五"],
    "restDays": ["周二", "周四", "周六", "周日"],
    "note": "训练日之间至少休息1天"
  }
