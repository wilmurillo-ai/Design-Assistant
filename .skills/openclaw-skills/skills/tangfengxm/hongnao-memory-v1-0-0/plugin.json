{
  "name": "hongnao_memory",
  "version": "1.0.0",
  "description": "弘脑记忆系统 - 为 OpenClaw 打造的长期记忆操作系统",
  "description_en": "HongNao Memory OS - Long-term Memory System for OpenClaw",
  "author": "燧弘华创",
  "author_email": "contact@hongnao.ai",
  "license": "MIT",
  "homepage": "https://github.com/hongnao/hongnao_memory",
  "repository": "https://github.com/hongnao/hongnao_memory",
  "documentation": "https://github.com/hongnao/hongnao_memory/blob/main/集成指南.md",
  
  "python_version": ">=3.8",
  "platforms": ["linux", "darwin", "windows"],
  
  "dependencies": [
    "chromadb>=0.4.0",
    "numpy>=1.20.0",
    "sentence-transformers>=2.2.0"
  ],
  "optional_dependencies": {
    "redis": ["redis>=4.5.0"],
    "flag-embedding": ["FlagEmbedding>=1.2.0"]
  },
  
  "entry_point": "memory_api.py",
  "main_class": "HongNaoMemorySystem",
  "config_file": "hongnao_memory_config.ini",
  
  "features": [
    "Session 记忆同步",
    "跨 Session 检索",
    "用户偏好学习",
    "记忆巩固与遗忘",
    "向量 + 关键词混合检索",
    "自动记忆抽取",
    "记忆场景管理"
  ],
  
  "tags": ["memory", "ai", "openclaw", "plugin", "nlp", "rag"],
  "categories": ["productivity", "ai-tools", "memory-management"],
  
  "screenshots": [
    "screenshots/demo_1.png",
    "screenshots/demo_2.png"
  ],
  
  "changelog": {
    "1.0.0": {
      "date": "2026-04-14",
      "changes": [
        "🎉 正式发布 v1.0.0",
        "完整的 4 层记忆架构",
        "OpenClaw 深度集成",
        "用户偏好自动学习",
        "Session 自动同步",
        "100% 测试覆盖 (15/15)",
        "性能超额完成 (添加 0.03ms, 检索 0.27ms)"
      ]
    },
    "0.2.0": {
      "date": "2026-04-13",
      "changes": [
        "新增 OpenClaw 集成模块",
        "新增用户偏好学习模块",
        "新增 Session 上下文集成测试",
        "新增自动安装脚本",
        "完善集成文档"
      ]
    },
    "0.1.0": {
      "date": "2026-04-05",
      "changes": [
        "初始版本",
        "核心记忆模块实现",
        "基础架构设计"
      ]
    }
  },
  
  "compatibility": {
    "openclaw": ">=0.1.0",
    "tested_with": ["openclaw-0.1.0", "openclaw-0.2.0"]
  },
  
  "performance": {
    "retrieval_latency_ms": "<100",
    "recall_accuracy": ">90%",
    "token_savings": ">40%"
  }
}
