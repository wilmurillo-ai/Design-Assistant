{
  "name": "outbound-auto-setup-hook",
  "version": "1.0.0",
  "description": "外出任务自动配置 - OpenClaw 消息处理钩子",
  "main": "hook.js",
  "type": "hook",
  "hooks": {
    "message:receive": {
      "priority": 1,
      "async": true
    }
  },
  "config": {
    "enabled": true,
    "logFile": "~/.openclaw/logs/outbound-auto-setup.log"
  },
  "dependencies": {
    "outbound-auto-setup": "file:./outbound-auto-setup"
  }
}
