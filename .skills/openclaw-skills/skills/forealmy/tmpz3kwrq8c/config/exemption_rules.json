  "classic_literature": {
    "detection_rules": {
      "avg_sentence_length": {"min": 30},
      "long_sentence_ratio": {"min": 0.4},
      "compound_indicator_density": {"min": 5}
    },
    "threshold_boosts": {
      "sentence_variance_threshold": 1.0,
      "perplexity_threshold": 0.2,
      "style_weight_reduction": 0.5
    },
    "boost_factor": 1.25
  }
