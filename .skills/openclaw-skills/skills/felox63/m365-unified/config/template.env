# M365 Unified Skill - Environment Template
# ==========================================
# Copy this file to .env and fill in your values
# NEVER commit .env with real credentials!

# === REQUIRED: Authentication ===
# Get these from Azure AD App Registration
M365_TENANT_ID="<your-tenant-id-here>"
M365_CLIENT_ID="<your-client-id-here>"
M365_CLIENT_SECRET="<your-client-secret-here>"

# === OPTIONAL: Feature Toggles ===
# Set to true/false to enable/disable modules
M365_ENABLE_EMAIL=true
M365_ENABLE_SHAREPOINT=false
M365_ENABLE_ONEDRIVE=false
M365_ENABLE_PLANNER=false
M365_ENABLE_WEBHOOKS=false

# === OPTIONAL: Email Configuration ===
# Primary mailbox (required if email enabled)
M365_MAILBOX="<user@domain.com>"

# Shared mailboxes (comma-separated, optional)
M365_SHARED_MAILBOXES="<team1@domain.com>,<team2@domain.com>"

# === OPTIONAL: SharePoint Configuration ===
# Format: <tenant>.sharepoint.com,<site-guid>,<web-guid>
M365_SHAREPOINT_SITE_ID="<tenant>.sharepoint.com,<site-guid>,<web-guid>"

# === OPTIONAL: OneDrive Configuration ===
# Usually same as M365_MAILBOX
M365_ONEDRIVE_USER="<user@domain.com>"

# === OPTIONAL: Planner Configuration ===
# M365 Group ID that contains Planner plans
M365_PLANNER_GROUP_ID="<m365-group-id-here>"

# === OPTIONAL: Webhook Configuration ===
# Your public webhook endpoint (must be reachable by Microsoft)
M365_WEBHOOK_URL="https://your-domain.com/webhook/m365"

# Secret for webhook validation (generate random string)
M365_WEBHOOK_SECRET="<generate-random-secret-here>"

# Webhook notification email (optional, for alerts)
M365_WEBHOOK_ALERT_EMAIL="<admin@domain.com>"

# === OPTIONAL: Telegram Notifications ===
# Bot Token (erstellen via @BotFather)
TELEGRAM_BOT_TOKEN="<your-bot-token-here>"

# Chat ID (Gruppe oder Channel)
TELEGRAM_CHAT_ID="<your-chat-id-here>"

# Thread/Topic ID (für Foren-Gruppen)
TELEGRAM_THREAD_ID="<your-thread-id-here>"
