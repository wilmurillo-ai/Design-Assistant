{
  "name": "@pita/nutrition-claw",
  "version": "1.0.9",
  "description": "Local-first nutrition tracking CLI for agents and humans",
  "license": "MIT",
  "author": "Peter 'Pita' Martischka <petermartischka@gmail.com>",
  "homepage": "https://github.com/Pita/nutrition-claw#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pita/nutrition-claw.git"
  },
  "bugs": {
    "url": "https://github.com/Pita/nutrition-claw/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "nutrition",
    "calories",
    "meal",
    "tracker",
    "cli",
    "agent",
    "openclaw",
    "health",
    "diet",
    "macros"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "bin": {
    "nutrition-claw": "bin/nutrition-claw.js"
  },
  "files": [
    "bin/",
    "dist/",
    "SKILL.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outfile ./dist/index.js --target node --packages external",
    "start": "bun src/index.ts",
    "prepublishOnly": "npm run build",
    "clawhub:publish": "npm run build && ./scripts/sync-skill.sh && clawhub publish ~/.openclaw/workspace/skills/nutrition-claw --version $npm_package_version"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.2",
    "@themaximalist/embeddings.js": "^0.1.3",
    "@xenova/transformers": "^2.17.2",
    "debug": "^4.4.3",
    "nanoid": "^5.1.5",
    "vectra": "^0.12.3",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.2"
  }
}
