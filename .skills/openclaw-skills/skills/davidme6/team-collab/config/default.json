      "description": "UI设计、视觉优化、交互方案",
      "enabled": true
    },
    "tester": {
      "name": "测试工程师",
      "model": "deepseek-coder",
      "type": "core",
      "description": "功能测试、Bug定位、测试报告",
      "enabled": true
    },
    "reviewer": {
      "name": "代码审查员",
      "model": "bailian/qwen-max",
      "type": "core",
      "description": "代码审查、性能优化、安全检查",
      "enabled": true
    },
    "legal_advisor": {
