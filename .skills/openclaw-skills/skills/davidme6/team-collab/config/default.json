  "presets": {
    "minimal": ["product_manager", "developer"],
    "core": ["product_manager", "developer", "designer", "tester", "reviewer"],
    "full": ["product_manager", "market_analyst", "developer", "designer", "art_expert", "legal_advisor", "tester", "reviewer"],
    "business": ["product_manager", "market_analyst", "developer", "designer", "legal_advisor", "reviewer"],
    "startup": ["product_manager", "market_analyst", "developer", "designer", "tester", "legal_advisor", "reviewer"]
