      "name": "产品经理",
      "model": "bailian/qwen-plus",
      "type": "core",
      "description": "需求分析、功能设计、优先级排序",
      "enabled": true
    },
    "developer": {
      "name": "程序员",
      "model": "bailian/glm-5",
