  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw-skills/jarvis-core"
  },
  "clawhub": {
    "type": "skill",
    "category": "productivity",
    "tags": ["proactive", "assistant", "memory", "automation"],
    "compatibility": "openclaw>=1.0.0",
    "permissions": [
      "read:workspace",
      "write:workspace",
      "read:memory",
      "write:memory",
      "exec:scripts"
    ],
    "autoActivate": true,
    "priority": "high"
  },
  "dependencies": {},
  "devDependencies": {}
