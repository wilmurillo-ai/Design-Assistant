{
  "name": "jarvis-core",
  "version": "1.0.0",
  "description": "让 AI 从被动工具进化为主动伙伴 —— 像钢铁侠的贾维斯一样思考、行动、成长",
  "main": "SKILL.md",
  "scripts": {
    "check": "python scripts/proactive_check.py",
    "memory": "python scripts/memory_manager.py",
    "test": "echo \"Jarvis Core: All systems operational\" && exit 0"
