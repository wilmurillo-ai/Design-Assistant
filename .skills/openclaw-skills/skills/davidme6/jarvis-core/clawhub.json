{
  "name": "jarvis-core",
  "displayName": "🤖 Jarvis Core - 主动智能助手",
  "version": "1.0.0",
  "description": "让 AI 从被动工具进化为主动伙伴。主动思考、主动帮助、主动学习、人格化交互。像钢铁侠的贾维斯一样成为你的真正助手。",
  "author": "Jarvis",
  "license": "MIT",
  "homepage": "https://github.com/openclaw-skills/jarvis-core",
  "repository": "https://github.com/openclaw-skills/jarvis-core",
  "bugs": "https://github.com/openclaw-skills/jarvis-core/issues",
  "category": "productivity",
  "tags": [
    "proactive",
    "assistant",
    "memory",
    "automation",
    "personality",
    "learning"
  ],
  "compatibility": {
    "openclaw": ">=1.0.0",
    "node": ">=18.0.0",
    "python": ">=3.8.0"
  },
  "permissions": {
    "scope": "workspace",
    "actions": [
      "read:files",
      "write:files",
      "read:memory",
      "write:memory",
      "execute:scripts",
      "git:status"
    ],
    "external": {
      "allowed": false,
      "requireConfirmation": true
    }
  },
  "activation": {
    "auto": true,
    "priority": "high",
    "triggers": [
      "session:start",
      "message:receive",
      "heartbeat"
    ]
  },
  "scripts": {
    "proactive_check": "scripts/proactive_check.py",
    "memory_manager": "scripts/memory_manager.py"
  },
  "files": [
    "SKILL.md",
    "README.md",
    "scripts/*.py"
  ],
  "changelog": {
    "1.0.0": {
      "date": "2026-03-16",
      "changes": [
        "初始版本发布",
        "主动思考引擎",
        "三层记忆系统",
        "决策框架",
        "人格化基础",
        "proactive_check.py 脚本",
        "memory_manager.py 脚本"
      ]
    }
  }
}
