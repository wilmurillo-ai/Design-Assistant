{
  "schema_version": "v1",
  "name": "liblib-comfyui-fusion",
  "description": "基于LiblibAI的商品图背景融合生成插件，支持本地图片、URL、飞书文本输入",
  "version": "0.1.0",

  "runtime": "nodejs",

  "entrypoint": "index.js",

  "commands": [
    {
      "name": "run",
      "description": "执行图片融合生成任务",
      "args": [
        {
          "name": "--image-url",
          "type": "string",
          "required": false,
          "description": "公网图片URL"
        },
        {
          "name": "--local-image",
          "type": "string",
          "required": false,
          "description": "本地图片路径"
        },
        {
          "name": "--feishu-text",
          "type": "string",
          "required": false,
          "description": "飞书文本（自动提取图片URL）"
        },
        {
          "name": "--guidance",
          "type": "number",
          "required": false,
          "default": 2.5
        }
      ]
    },
    {
      "name": "status",
      "description": "查询任务状态",
      "args": [
        {
          "name": "uuid",
          "type": "string",
          "required": true
        }
      ]
    }
  ]
}