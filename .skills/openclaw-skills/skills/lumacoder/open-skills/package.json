{
  "name": "open-skills",
  "version": "2.0.0",
  "description": "AI Agent Skill 分发与一键安装 CLI 工具",
  "main": "dist/cli.js",
  "bin": {
    "open-skills": "dist/cli.js"
  },
  "files": [
    "dist",
    "registry",
    "bundles",
    "README.md",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "validate-registry": "tsx scripts/validate-registry.ts",
    "test": "vitest",
    "prepublishOnly": "npm run lint && npm run build && npm run validate-registry"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumacoder/open-skills.git"
  },
  "bugs": {
    "url": "https://github.com/lumacoder/open-skills/issues"
  },
  "homepage": "https://github.com/lumacoder/open-skills#readme",
  "keywords": [
    "skills",
    "ai-agent",
    "claude-code",
    "codex",
    "opencode",
    "cli"
  ],
  "author": "lumacoder",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "fs-extra": "^11.3.0",
    "simple-git": "^3.27.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.14.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module"
}
