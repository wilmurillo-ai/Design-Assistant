    "browse":  "node scripts/browse.js",
    "trade":   "node scripts/trade.js",
    "balance": "node scripts/balance.js",
    "auto":    "node scripts/auto.js",
    "sell":    "node scripts/sell.js",
    "link":    "node scripts/link.js",
    "approve": "node scripts/approve.js"
  },
  "keywords": ["polymarket", "prediction-markets", "trading", "ai-agent", "defi", "polygon", "openclaw"],
