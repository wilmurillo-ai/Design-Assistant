# 复制为 .env 或写入 OpenClaw skills.entries（勿提交 .env）
# 非敏感项可由同目录 config.json 提供；以下为必填密钥
KEPLERJAI_OSS_ACCESS_KEY_ID=
KEPLERJAI_OSS_ACCESS_KEY_SECRET=
# 若未设环境变量，则由 config.json 的 staticOSS 填充下列项（可选）
# KEPLERJAI_OSS_ENDPOINT=oss-cn-chengdu.aliyuncs.com
# KEPLERJAI_OSS_BUCKET=static-szxg
# KEPLERJAI_OSS_HOST=https://static-szxg.oss-cn-chengdu.aliyuncs.com
# KEPLERJAI_OSS_UPLOAD_DIR=upload
# KEPLERJAI_OSS_BIND_HOST=https://static.thinkzoneai.com
# 可选：设为 1/true 时，年/月目录按 UTC；默认按本机本地时区
# KEPLERJAI_OSS_PATH_UTC=0
# 可选：自定义文件名随机字符表（与后端 base64Table 一致时可对齐）
# KEPLERJAI_OSS_NAME_ALPHABET=123QRSTUabcdVWXYZHijKLAWDCABDstEFGuvwxyzGHIJklmnopqr234560178912
# 可选：Post policy 等用毫秒；与 config.json expireTime 对齐
# KEPLERJAI_OSS_EXPIRE_TIME_MS=6000000
# KEPLERJAI_OSS_CALLBACK_URL=https://example.com/api/oss/callback
# 与 config.json objectLifecycleExpireDays 一致；用于 put_bucket_lifecycle / 上传 --sync-lifecycle
# KEPLERJAI_OSS_OBJECT_LIFECYCLE_DAYS=7
# 可选：PutBucketLifecycle 时合并覆盖的规则 ID（与 config.json lifecycleRuleId 对齐）
# KEPLERJAI_OSS_LIFECYCLE_RULE_ID=keplerjai-oss-upload-expire
# 可选：上传成功后自动 PutBucketLifecycle（需 RAM oss:PutBucketLifecycle 等权限）
# KEPLERJAI_OSS_SYNC_LIFECYCLE_ON_UPLOAD=0
