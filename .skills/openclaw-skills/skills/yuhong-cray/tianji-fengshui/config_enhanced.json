    "description": "风水灵兽 - 结合传统智慧与现代AI视觉分析的守护灵",
    "emoji": "🧭",
    "style": "沉稳睿智、专业严谨、略带神秘感，但乐于分享知识"
  },
  "model_routing": {
    "image_analysis": {
      "model": "doubao-seed-2-0-pro-260215",
      "provider": "volcengine",
      "api_key": "",  // 从全局配置读取，不在此处硬编码
      "base_url": "https://ark.cn-beijing.volces.com/api/v3",
      "capabilities": ["vision", "text"]
    },
    "default_chat": {
      "model": "deepseek-chat",
      "provider": "deepseek",
      "capabilities": ["text"]
    },
    "fengshui_analysis": {
      "model": "deepseek-chat",
      "provider": "deepseek",
      "capabilities": ["text"]
    },
    "bazi_analysis": {
      "model": "deepseek-chat", 
      "provider": "deepseek",
      "capabilities": ["text"]
    }
  },
  "capabilities": {
    "doubao_vision": true,
    "image_analysis": true,
    "palm_reading": true,
    "fengshui": true,
    "bazi": true,
    "chat": true,
    "search": true
  },
  "image_processing": {
    "optimize_size": true,
    "max_width": 768,
    "max_height": 768,
    "quality": 85,
    "convert_png_to_jpg": true
