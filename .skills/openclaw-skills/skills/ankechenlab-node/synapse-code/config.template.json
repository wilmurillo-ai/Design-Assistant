{
  "_comment": "Synapse Code 配置文件 — 复制为 config.json 并修改路径",
  "_docs": "https://github.com/synapse-skills/synapse-code#configuration",

  "pipeline": {
    "workspace": "~/pipeline-workspace",
    "enabled": true,
    "auto_log": true,
    "mode": "auto"
  },

  "gitnexus": {
    "enabled": true,
    "auto_analyze": false
  },

  "synapse": {
    "knowledge_dir": ".knowledge",
    "memory_dir": ".synapse/memory",
    "auto_log_enabled": true
  },

  "paths": {
    "pipeline_script": "~/pipeline-workspace/pipeline.py",
    "pipeline_summary": "/tmp/pipeline_summary.json"
  },

  "_mode_help": "mode 可选值：auto=自动检测，standalone=独立开发（无需 Pipeline），lite=轻量 Pipeline，full=完整 Pipeline。新手建议用 auto 或 standalone。"
}
