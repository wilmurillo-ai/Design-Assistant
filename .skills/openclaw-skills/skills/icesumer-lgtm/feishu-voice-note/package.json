  },
  "keywords": [
    "feishu",
    "voice",
    "tts",
    "audio",
    "opus",
    "语音条",
    "语音消息"
  ],
  "engines": {
    "openclaw": ">=2026.3.13"
  },
  "main": "SKILL.md",
  "scripts": {
    "test": "echo \"No tests specified\""
  },
  "config": {
    "ttsProvider": "edge",
    "ffmpegPath": "C:\\ffmpeg\\ffmpeg-8.1-essentials_build\\bin\\ffmpeg.exe",
