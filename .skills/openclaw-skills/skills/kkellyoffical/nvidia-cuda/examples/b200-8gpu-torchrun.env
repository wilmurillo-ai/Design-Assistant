# Example single-node 8-GPU training environment for B200-class systems

CUDA_DEVICE_MAX_CONNECTIONS=1
NCCL_DEBUG=INFO
TORCH_NCCL_USE_COMM_NONBLOCKING=1
TORCH_ALLOW_TF32_CUBLAS_OVERRIDE=1

# Launch shape:
# torchrun --nproc_per_node=8 train.py --config examples/h200-long-context-training.yaml

# Use this as a starting point only after verifying network, storage, and topology.
