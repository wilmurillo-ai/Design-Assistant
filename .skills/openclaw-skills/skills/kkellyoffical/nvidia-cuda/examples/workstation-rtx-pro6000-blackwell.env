# Example workstation environment for a serious single-node desk-side AI setup
# Target hardware: RTX PRO 6000 Blackwell Workstation Edition / Max-Q

CUDA_VISIBLE_DEVICES=0
TORCH_ALLOW_TF32_CUBLAS_OVERRIDE=1
TORCH_CUDNN_V8_API_LRU_CACHE_LIMIT=10000

# Keep allocator tuning minimal until you have evidence.
# Uncomment only if fragmentation shows up in practice.
# PYTORCH_ALLOC_CONF=expandable_segments:True

# Typical usage
# python scripts/cuda_env_probe.py
# python scripts/benchmark_attention.py --backend flash --dtype bf16 --seq 4096
# python train.py
