{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenClawUxEthnographySummary",
  "type": "object",
  "required": [
    "report_date",
    "window",
    "consent",
    "metrics",
    "top_intents",
    "top_insights",
    "top_pain_points",
    "recommendations",
    "open_questions",
    "next_day_plan",
    "files"
  ],
  "properties": {
    "report_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "window": {
      "type": "object",
      "required": [
        "start",
        "end",
        "timezone"
      ],
      "properties": {
        "start": {
          "type": "string"
        },
        "end": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        }
      }
    },
    "consent": {
      "type": "object",
      "required": [
        "consent_granted",
        "capture_level",
        "scope",
        "retention_days"
      ],
      "properties": {
        "consent_granted": {
          "type": "boolean"
        },
        "capture_level": {
          "enum": [
            "minimal",
            "snippets",
            "full"
          ]
        },
        "scope": {
          "enum": [
            "all_agent_sessions",
            "this_session_only"
          ]
        },
        "retention_days": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "sessions_analyzed",
        "total_turns",
        "tools_used",
        "time_to_first_useful_result",
        "error_rate",
        "retry_loop_signals"
      ],
      "properties": {
        "sessions_analyzed": {
          "type": "integer",
          "minimum": 0
        },
        "total_turns": {
          "type": "integer",
          "minimum": 0
        },
        "tools_used": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "count"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "count": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "time_to_first_useful_result": {
          "type": "object",
          "required": [
            "median_minutes",
            "method"
          ],
          "properties": {
            "median_minutes": {
              "type": "number",
              "minimum": 0
            },
            "method": {
              "type": "string"
            }
          }
        },
        "error_rate": {
          "type": "object",
          "required": [
            "value",
            "method"
          ],
          "properties": {
            "value": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "method": {
              "type": "string"
            }
          }
        },
        "retry_loop_signals": {
          "type": "object",
          "required": [
            "count",
            "method"
          ],
          "properties": {
            "count": {
              "type": "integer",
              "minimum": 0
            },
            "method": {
              "type": "string"
            }
          }
        }
      }
    },
    "top_intents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "intent",
          "count"
        ],
        "properties": {
          "intent": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "top_insights": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "title",
          "evidence_event_ids",
          "impact"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "evidence_event_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "impact": {
            "type": "string"
          }
        }
      }
    },
    "top_pain_points": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "pain_point",
          "severity",
          "frequency",
          "evidence_event_ids"
        ],
        "properties": {
          "pain_point": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "frequency": {
            "enum": [
              "rare",
              "occasional",
              "frequent",
              "persistent"
            ]
          },
          "evidence_event_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "minItems": 3,
      "maxItems": 7,
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_day_plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "files": {
      "type": "object",
      "required": [
        "raw_events",
        "sessions_index",
        "report_markdown",
        "summary_json"
      ],
      "properties": {
        "raw_events": {
          "type": "string"
        },
        "sessions_index": {
          "type": "string"
        },
        "report_markdown": {
          "type": "string"
        },
        "summary_json": {
          "type": "string"
        }
      }
    }
  }
}
