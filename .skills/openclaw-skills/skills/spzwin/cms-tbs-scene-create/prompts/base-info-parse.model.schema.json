{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://xgjk.local/schemas/cms-tbs-scene-create/base-info-parse.model.schema.json",
  "title": "BaseInfoParseModelOutput",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "businessDomainName": {
      "type": "string",
      "enum": [
        "临床推广",
        "院外零售",
        "学术合作",
        "通用能力"
      ]
    },
    "departmentName": {
      "type": "string",
      "minLength": 1
    },
    "drugName": {
      "type": "string",
      "minLength": 1
    },
    "location": {
      "type": "string",
      "minLength": 1
    },
    "doctorConcerns": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "repGoal": {
      "type": "string",
      "minLength": 1
    },
    "generationNotes": {
      "type": "string"
    }
  }
}
