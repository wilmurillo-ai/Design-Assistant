{
  "name": "web-reader-tts",
  "version": "2.0.0",
  "description": "将网页内容转换为语音，支持多种 TTS 引擎和 Whisper 语音识别",
  "author": "tech",
  "tags": ["tts", "whisper", "playwright", "语音", "朗读"],
  "dependencies": {
    "python": ">=3.8",
    "packages": [
      "playwright",
      "edge-tts",
      "openai-whisper"
    ]
  },
  "commands": {
    "full": "python web_reader_tts.py --url <url>",
    "tts-only": "python web_reader_tts.py --url <url> --tts-only",
    "stt-only": "python web_reader_tts.py --audio <audio> --stt-only"
  },
  "examples": [
    {
      "description": "完整流程",
      "command": "python web_reader_tts.py --url \"https://example.com\""
    },
    {
      "description": "使用更大的 Whisper 模型",
      "command": "python web_reader_tts.py --url \"https://example.com\" --whisper-model medium"
    },
    {
      "description": "调整语速和音量",
      "command": "python web_reader_tts.py --url \"https://example.com\" --rate \"+20%\" --volume \"+50%\""
    }
  ]
}
