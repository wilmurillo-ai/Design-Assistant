      {"id": "edit-blacklist", "name": "编辑黑名单", "description": "编辑黑名单配置文件"},
      {"id": "read-blacklist", "name": "读取黑名单", "description": "读取黑名单配置文件"},
      {"id": "modify-whitelist", "name": "修改白名单", "description": "修改白名单配置文件"},
