    "automation",
    "show-notes",
    "social-media",
    "xiaoyuzhou",
    "ximalaya",
    "bilibili"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sunnyhot/podcast-production-pipeline"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "requires": {
      "bins": ["node"]
    },
    "optionalBins": ["whisper"],
    "configPaths": ["config/settings.json"]
  }
