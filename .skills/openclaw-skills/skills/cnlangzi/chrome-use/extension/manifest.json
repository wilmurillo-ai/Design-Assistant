{
  "manifest_version": 3,
  "name": "Chrome Use",
  "version": "0.1.3",
  "description": "Browser automation for OpenClaw Skill",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "nativeMessaging",
    "debugger"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Chrome Use",
    "default_popup": "popup.html"
  }
}
