{
  "type": "function",
  "function": {
    "name": "_schedule_create_define",
    "description": "Create a new scheduled task definition.",
    "parameters": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Scheduled task name"
        },
        "type": {
          "type": "string",
          "description": "Scheduled task type. Only one of the following values can be filled: default (default periodic scheduling), cron (Cron expression scheduling, must provide cron field at the same time)."
        },
        "cron": {
          "type": "string",
          "description": "cron expression (required when type=cron)"
        },
        "invokeType": {
          "type": "string",
          "description": "Invocation type. Only one of the following values can be filled: automatic (invoke automation, must provide automaticId at the same time), script (invoke script, must provide scriptId and scriptFunc at the same time)."
        },
        "automaticId": {
          "type": "string",
          "description": "Automation ID (when invokeType=automatic)"
        },
        "scriptId": {
          "type": "string",
          "description": "Script ID (when invokeType=script)"
        },
        "scriptFunc": {
          "type": "string",
          "description": "Script function name (when invokeType=script)"
        },
        "schedulePeriod": {
          "type": "string",
          "description": "Scheduling period (used when type=default). Only one of the following values can be filled: day (every day), week (every week, with scheduleWeekList), dualweek (every two weeks, with scheduleWeekList), month (every month, with scheduleDayList), interval (by interval, with scheduleInterval)."
        },
        "scheduleWeekList": {
          "type": "array",
          "description": "Weekly scheduling list (1-7)",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 7
          }
        },
        "scheduleDayList": {
          "type": "array",
          "description": "Monthly scheduling list (1-31)",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 31
          }
        },
        "scheduleTriggeredTime": {
          "type": "string",
          "format": "date-time",
          "description": "First trigger time"
        },
        "scheduleInterval": {
          "type": "integer",
          "description": "Interval execution time (minutes)"
        },
        "retryCount": {
          "type": "integer",
          "description": "Failure retry count (maximum 10)",
          "minimum": 0,
          "maximum": 10
        },
        "misfireHandlingType": {
          "type": "string",
          "description": "Misfire handling strategy"
        },
        "misfireThreshold": {
          "type": "integer",
          "description": "Misfire threshold (seconds)"
        },
        "isEnable": {
          "type": "boolean",
          "description": "Whether to enable",
          "default": true
        },
        "serverIdList": {
          "type": "string",
          "description": "List of allowed service IDs (comma separated)"
        }
      },
      "required": [
        "name",
        "type",
        "invokeType"
      ],
      "additionalProperties": false
    }
  }
}
