{
	"type": "function",
	"function": {
		"name": "_query_app_user_list",
		"description": "Query basic account information. Including account ID, email, direct superior, department information, etc.",
		"parameters": {
			"type": "object",
			"oneOf": [
		        { "required": ["idList"] },
		        { "required": ["nameList"] }
		      ],
			"properties": {
				"idList": {
					"type": "array",
					"items": {
						"type": "string",
						"description": "Account ID"
					},
					"description": "Account ID list"
				},
				"nameList": {
					"type": "array",
					"items": {
						"type": "string",
						"description": "Account name"
					},
					"description": "Account name list"
				}
			}
		}
	}
}