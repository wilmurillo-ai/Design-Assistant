{
  "type": "function",
  "function": {
    "name": "_update_module_and_group_order",
    "description": "Update module and group order. Need to pass the complete moduleList at once.",
    "parameters": {
      "type": "object",
      "properties": {
        "moduleList": {
          "type": "array",
          "description": "Module list (including groups, tree structure, supporting multi-level nesting)",
          "items": {
            "$ref": "#/definitions/ObjectRef"
          }
        }
      },
      "required": ["moduleList"],
      "definitions": {
        "ObjectRef": {
          "type": "object",
          "description": "Module or directory node",
          "properties": {
            "id": {
              "type": "string",
              "description": "Module ID (can be empty, generated by the system)"
            },
            "children": {
              "type": "array",
              "description": "Sub-module list",
              "items": {
                "$ref": "#/definitions/ObjectRef"
              }
            }
          },
          "required": ["id"]
        }
      }
    }
  }
}
