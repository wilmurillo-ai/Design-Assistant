{
  "id": "tag-memory",
  "name": "TagMemory",
  "version": "1.0.0",
  "description": "标签化长期记忆系统 - 人类参与审核的记忆管理",
  "author": "System Guardian",
  "license": "MIT",
  "entry": "src/skill.js",
  "runtime": "node",
  "tools": [
    {
      "name": "tag_memory_store",
      "description": "存储重要记忆（带标签和时间，自动去重）",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "要记忆的原始内容"
          },
          "tags": {
            "type": "array",
            "items": {"type": "string"},
            "description": "标签列表，如 ['#偏好', '#决定']"
          },
          "time_label": {
            "type": "string",
            "description": "时间标签，格式 YYYY-MM"
          },
          "source": {
            "type": "string",
            "enum": ["dialogue", "summary", "manual"],
            "default": "dialogue"
          },
          "force": {
            "type": "boolean",
            "default": false,
            "description": "强制存储（跳过去重）"
          }
        },
        "required": ["content", "tags"]
      }
    },
    {
      "name": "tag_memory_query",
      "description": "查询记忆（BM25 搜索，返回原汁原味结果）",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "查询内容"
          },
          "tags": {
            "type": "array",
            "items": {"type": "string"},
            "description": "筛选特定标签"
          },
          "time_range": {
            "type": "object",
            "properties": {
              "start": {"type": "string"},
              "end": {"type": "string"}
            }
          },
          "limit": {
            "type": "integer",
            "default": 5
          }
        },
        "required": ["query"]
      }
    },
    {
      "name": "tag_memory_verify",
      "description": "核对记忆：确认正确、修正错误、或删除",
      "parameters": {
        "type": "object",
        "properties": {
          "memory_id": {"type": "string"},
          "action": {
            "type": "string",
            "enum": ["confirm", "correct", "delete"]
          },
          "correction": {"type": "string"}
        },
        "required": ["memory_id", "action"]
      }
    },
    {
      "name": "tag_memory_list",
      "description": "列出记忆，支持分页和标签过滤",
      "parameters": {
        "type": "object",
        "properties": {
          "tags": {"type": "array"},
          "verified_only": {"type": "boolean"},
          "page": {"type": "integer"},
          "page_size": {"type": "integer"}
        }
      }
    },
    {
      "name": "tag_memory_verify_pending",
      "description": "获取待核对的记忆列表（闲时核对）",
      "parameters": {
        "type": "object",
        "properties": {
          "max_count": {"type": "integer", "default": 3}
        }
      }
    },
    {
      "name": "tag_memory_verify_result",
      "description": "处理核对结果",
      "parameters": {
        "type": "object",
        "properties": {
          "index": {"type": "integer"},
          "action": {"type": "string", "enum": ["confirm", "correct", "delete"]},
          "correction": {"type": "string"}
        },
        "required": ["index", "action"]
      }
    },
    {
      "name": "tag_memory_summarize",
      "description": "生成阶段性总结",
      "parameters": {
        "type": "object",
        "properties": {
          "days": {"type": "integer", "default": 7}
        }
      }
    },
    {
      "name": "tag_memory_summarize_confirm",
      "description": "确认总结并存档",
      "parameters": {
        "type": "object",
        "properties": {
          "feedback": {"type": "string", "default": "confirm"}
        }
      }
    },
    {
      "name": "tag_memory_stats",
      "description": "获取记忆统计"
    }
  ],
  "hooks": {
    "before_tool_call": "src/hooks/before_tool_call.js",
    "after_agent_message": "src/hooks/after_agent_message.js"
  },
  "config": {
    "db_path": {
      "type": "string",
      "default": "~/.openclaw/workspace/skills/tag-memory/data/memory.db"
    },
    "auto_tag": {
      "type": "boolean",
      "default": true,
      "description": "自动提取标签"
    },
    "verify_after_store": {
      "type": "boolean",
      "default": true,
      "description": "存储后自动核对"
    }
  }
}
