{
  "name": "omnicast",
  "version": "1.0.8",
  "description": "A secure, multi-modal AI podcast studio supporting YouTube, PDFs, MP4s, Web URLs, and Text.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "podcast",
    "gemini",
    "ai",
    "youtube",
    "tts",
    "whisper",
    "elevenlabs"
  ],
  "author": "Kaushik Datta",
  "license": "MIT",
  "os": ["darwin", "win32", "linux"],
  "engines": {
    "node": ">=20.0.0"
  },
  "config": {
    "requiredDependencies": ["ffmpeg"],
    "requiredEnvVars": ["GEMINI_API_KEY", "OPENAI_API_KEY"]
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@google/genai": "^1.45.0",
    "archiver": "^7.0.1",
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^171.4.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.29.0",
    "pdf-parse": "^1.1.1",
    "youtube-transcript-plus": "^1.2.0"
  }
}