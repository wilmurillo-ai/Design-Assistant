{
  "name": "openclaw-plugin-grinders-farm",
  "version": "0.3.3",
  "private": false,
  "type": "module",
  "description": "OpenClaw plugin for Grinder's Farm: deterministic /farm command and grinders_farm tool.",
  "main": "dist/index.js",
