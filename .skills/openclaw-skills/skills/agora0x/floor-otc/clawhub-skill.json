    { "symbol": "USDbC", "address": "0xd9aAEc86B65D86f6A7B5B1b0c42FFA531710b6Ca", "decimals": 6 },
    { "symbol": "DAI", "address": "0x50c5725949A6F0c72E6C4a641F24049A917DB0Cb", "decimals": 18 },
    { "symbol": "WETH", "address": "0x4200000000000000000000000000000000000006", "decimals": 18 }
  ],
  "protocol_fee_bps": 25,
  "protocol_fee_note": "0.25% deducted from each side on settlement. Immutable in contract. Zero spread on quotes.",
  "skills": [
    {
      "id": "get_quote",
      "name": "Get OTC Quote",
      "description": "Get a live token swap quote at real CoinGecko market rates. Zero spread.",
      "tags": ["quote", "swap", "pricing"],
      "input": {
        "method": "REST GET or JSON-RPC",
        "rest": "GET /api/quote?from={from_token}&to={to_token}&amount={amount}",
        "jsonrpc": {
          "method": "tasks/send",
          "params": {
            "skill_id": "get_quote",
            "arguments": {
              "from_token": "string — token symbol (e.g. USDC, WETH, DAI)",
              "to_token": "string — token symbol",
              "amount": "number — amount of from_token to swap"
            }
          }
        }
      },
      "output": {
        "quote": {
          "from_token": "string",
          "to_token": "string",
          "from_amount": "number",
          "to_amount": "number",
          "rate": "number",
          "usd_value": "number",
          "protocol_fee_bps": 25,
          "escrow_contract": "address",
          "network": "Base Mainnet",
          "chain_id": 8453,
          "settlement": "atomic_on_chain",
          "valid_for_seconds": 60
        }
      },
      "examples": [
        "Get a quote for swapping 1000 USDC to WETH",
        "How much DAI can I get for 5000 USDC?",
        "Quote 10000 USDC to WETH"
      ]
    },
    {
      "id": "execute_trade",
      "name": "Execute OTC Trade",
      "description": "Create a trustless on-chain escrow for a token swap on Base. Both parties deposit, settlement is atomic.",
      "tags": ["trade", "escrow", "swap", "settlement"],
      "input": {
        "method": "JSON-RPC",
        "jsonrpc": {
          "method": "tasks/send",
          "params": {
            "skill_id": "execute_trade",
            "arguments": {
              "from_token": "string — token symbol",
              "to_token": "string — token symbol",
              "amount": "number — amount of from_token"
            }
          }
        }
      },
      "output": {
        "trade": {
          "trade_id": "bytes32",
          "status": "Created",
          "escrow_contract": "address",
          "create_tx": "tx hash",
          "basescan_url": "string",
          "next_steps": "Buyer and seller must approve + deposit tokens"
        },
        "quote": "same as get_quote output"
      },
      "examples": [
        "Swap 1000 USDC for DAI through escrow",
        "Execute trade: 5000 USDC to WETH"
      ]
    },
    {
      "id": "check_trade",
      "name": "Check Trade Status",
      "description": "Check the on-chain status of an existing escrow trade by its trade ID.",
      "tags": ["status", "trade", "escrow"],
      "input": {
        "method": "JSON-RPC",
        "jsonrpc": {
          "method": "tasks/send",
          "params": {
            "skill_id": "check_trade",
            "arguments": {
              "trade_id": "bytes32 — the escrow trade ID"
            }
          }
        }
      },
      "output": {
        "trade": {
          "trade_id": "bytes32",
          "status": "Created | BuyerDeposited | SellerDeposited | BothDeposited | Settled | Expired | Refunded",
          "buyer": "address",
          "seller": "address",
          "buy_token": "address",
          "sell_token": "address"
        }
      },
      "examples": [
        "Check trade status for 0x8cb14ec9..."
      ]
    },
    {
      "id": "get_prices",
      "name": "Get Live Prices",
      "description": "Get current token prices from CoinGecko for all supported tokens.",
      "tags": ["prices", "market", "rates"],
      "input": {
        "method": "REST GET or JSON-RPC",
        "rest": "GET /api/prices",
        "jsonrpc": {
          "method": "tasks/send",
          "params": {
            "skill_id": "get_prices",
            "arguments": {}
          }
        }
      },
      "output": {
        "prices": {
          "TOKEN": { "usd": "number", "change_24h": "number" }
        },
        "source": "coingecko",
        "updated_at": "ISO 8601"
      },
      "examples": [
        "What are the current token prices?",
        "Get live crypto prices"
      ]
    }
  ],
  "authentication": {
    "required": false,
    "note": "No API key needed. Quotes are free. Trade execution requires the A2A server to have PRIVATE_KEY configured."
  },
  "capabilities": {
    "streaming": false,
    "push_notifications": false,
    "protocols": ["google-a2a", "json-rpc-2.0", "rest"]
  }
}
