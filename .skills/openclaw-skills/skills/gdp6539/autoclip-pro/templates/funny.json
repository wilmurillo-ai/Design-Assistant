{
  "name": "搞笑段子",
  "description": "适合娱乐内容、短视频、段子合集",
  "version": "1.0",
  
  "intro": {
    "enabled": true,
    "duration": 2,
    "title": {
      "enabled": true,
      "template": "🤣 {{标题}}",
      "fontSize": 52,
      "fontColor": "#FFFFFF",
      "backgroundColor": "#FF4500"
    },
    "animation": "bounce-in",
    "backgroundMusic": "upbeat"
  },
  
  "content": {
    "sections": [
      {
        "name": "悬念开场",
        "duration": "3-5s",
        "style": "吸引注意力"
      },
      {
        "name": "搞笑桥段",
        "duration": "15-60s",
        "style": "密集笑点"
      },
      {
        "name": "反转/包袱",
        "duration": "3-5s",
        "style": "意想不到"
      }
    ],
    
    "subtitles": {
      "enabled": true,
      "style": "醒目活泼",
      "highlight": {
        "keywords": true,
        "keyPoints": true,
        "emoji": true
      },
      "animation": "pop"
    },
    
    "visuals": {
      "transitions": "wipe",
      "graphics": {
        "stickers": true,
        "emoji": true,
        "memes": true,
        "arrows": true
      },
      "effects": {
        "zoom": true,
        "shake": true,
        "flash": true
      },
      "filters": {
        "saturation": 1.2,
        "contrast": 1.1
      }
    }
  },
  
  "outro": {
    "enabled": true,
    "duration": 3,
    "elements": {
      "subscribe": true,
      "nextVideo": true,
      "blooper": false
    },
    "animation": "slide-out",
    "cta": {
      "enabled": true,
      "text": "点个赞再走呗~",
      "emoji": "👍"
    }
  },
  
  "audio": {
    "backgroundMusic": {
      "enabled": true,
      "volume": 0.25,
      "style": "欢快活泼"
    },
    "soundEffects": {
      "enabled": true,
      "volume": 0.8,
      "types": ["boing", "splat", "whoosh", "laugh"]
    },
    "voiceOver": {
      "enabled": false
    }
  },
  
  "colors": {
    "primary": "#FF4500",
    "secondary": "#FFD700",
    "accent": "#00CED1",
    "background": "#1a1a1a",
    "text": "#FFFFFF"
  },
  
  "fonts": {
    "title": "SimHei",
    "subtitle": "Microsoft YaHei",
    "body": "Microsoft YaHei"
  },
  
  "transitions": {
    "default": "wipe",
    "duration": 0.3,
    "betweenSections": "zoom",
    "fastPaced": true
  },
  
  "timing": {
    "cutsPerMinute": "8-15",
    "avgShotDuration": "4-8s",
    "peakMoments": true
  },
  
  "engagement": {
    "hooks": true,
    "cliffhangers": true,
    "callToAction": true
  }
}