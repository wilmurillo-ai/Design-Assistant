{
  "name": "情感故事",
  "description": "适合 Vlog、情感表达、个人故事分享",
  "version": "1.0",
  
  "intro": {
    "enabled": true,
    "duration": 4,
    "title": {
      "enabled": true,
      "template": "{{标题}}",
      "fontSize": 42,
      "fontColor": "#FFFFFF",
      "backgroundColor": "#2c1810"
    },
    "animation": "zoom-in",
    "backgroundMusic": "sentimental"
  },
  
  "content": {
    "sections": [
      {
        "name": "情感铺垫",
        "duration": "10-30s",
        "style": "营造氛围"
      },
      {
        "name": "故事讲述",
        "duration": "60-300s",
        "style": "娓娓道来"
      },
      {
        "name": "情感升华",
        "duration": "15-30s",
        "style": "触动人心"
      }
    ],
    
    "subtitles": {
      "enabled": true,
      "style": "温暖柔和",
      "highlight": {
        "keywords": false,
        "keyPoints": true
      }
    },
    
    "visuals": {
      "transitions": "dissolve",
      "graphics": {
        "photos": true,
        "clips": true,
        "overlay": true
      },
      "filters": {
        "warmth": 1.1,
        "contrast": 1.05,
        "saturation": 0.95
      }
    }
  },
  
  "outro": {
    "enabled": true,
    "duration": 6,
    "elements": {
      "message": true,
      "subscribe": true,
      "contact": false
    },
    "animation": "fade-out",
    "quote": {
      "enabled": true,
      "template": "感谢你的观看 ❤️"
    }
  },
  
  "audio": {
    "backgroundMusic": {
      "enabled": true,
      "volume": 0.3,
      "style": "温暖抒情"
    },
    "voiceOver": {
      "enabled": true,
      "style": "亲切自然"
    },
    "ambient": {
      "enabled": true,
      "volume": 0.1
    }
  },
  
  "colors": {
    "primary": "#D4A574",
    "secondary": "#8B4513",
    "accent": "#FFB6C1",
    "background": "#2c1810",
    "text": "#F5E6D3"
  },
  
  "fonts": {
    "title": "STKaiti",
    "subtitle": "Microsoft YaHei",
    "body": "Microsoft YaHei"
  },
  
  "transitions": {
    "default": "dissolve",
    "duration": 0.8,
    "betweenSections": "crossfade"
  },
  
  "mood": {
    "tone": "温暖",
    "pace": "舒缓",
    "emotion": "感动"
  }
}