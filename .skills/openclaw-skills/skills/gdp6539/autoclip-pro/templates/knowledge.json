{
  "name": "知识科普",
  "description": "适合教育视频、知识分享内容",
  "version": "1.0",
  
  "intro": {
    "enabled": true,
    "duration": 3,
    "title": {
      "enabled": true,
      "template": "{{主题}} | 知识科普",
      "fontSize": 48,
      "fontColor": "#FFFFFF",
      "backgroundColor": "#1a1a2e"
    },
    "animation": "fade-in",
    "backgroundMusic": "calm"
  },
  
  "content": {
    "sections": [
      {
        "name": "开场白",
        "duration": "5-10s",
        "style": "轻松引出话题"
      },
      {
        "name": "核心内容",
        "duration": "60-180s",
        "style": "清晰讲解知识点"
      },
      {
        "name": "总结",
        "duration": "10-20s",
        "style": "回顾要点"
      }
    ],
    
    "subtitles": {
      "enabled": true,
      "style": "简洁清晰",
      "highlight": {
        "keywords": true,
        "keyPoints": true
      }
    },
    
    "visuals": {
      "transitions": "fade",
      "graphics": {
        "charts": true,
        "diagrams": true,
        "icons": true
      }
    }
  },
  
  "outro": {
    "enabled": true,
    "duration": 5,
    "elements": {
      "subscribe": true,
      "nextTopic": true,
      "credits": true
    },
    "animation": "fade-out"
  },
  
  "audio": {
    "backgroundMusic": {
      "enabled": true,
      "volume": 0.2,
      "style": "轻柔背景音乐"
    },
    "voiceOver": {
      "enabled": true,
      "style": "清晰专业"
    }
  },
  
  "colors": {
    "primary": "#4A90E2",
    "secondary": "#50C878",
    "accent": "#FFD700",
    "background": "#1a1a2e",
    "text": "#FFFFFF"
  },
  
  "fonts": {
    "title": "Microsoft YaHei",
    "subtitle": "Microsoft YaHei",
    "body": "Microsoft YaHei"
  },
  
  "transitions": {
    "default": "fade",
    "duration": 0.5,
    "betweenSections": "dissolve"
  }
}