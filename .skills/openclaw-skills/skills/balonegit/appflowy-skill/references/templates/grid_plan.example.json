        "状态": { "name": "进行中" },
        "子任务": {
          "options": [
            { "id": "ck-3-1", "name": "后端完成", "color": "Pink" },
            { "id": "ck-3-2", "name": "前端完成", "color": "Orange" },
            { "id": "ck-3-3", "name": "接口联调", "color": "Green" }
          ],
          "selected_option_ids": ["ck-3-1"]
        }
