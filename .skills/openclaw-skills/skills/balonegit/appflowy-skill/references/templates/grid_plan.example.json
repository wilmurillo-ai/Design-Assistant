{
  "grid": {
    "name": "PlanGrid",
    "heading": "详细工作计划表格（Grid）"
  },
  "rules": {
    "clean_default_rows": true,
    "max_default_rows": 3
  },
  "fields": [
    { "name": "负责人", "field_type": 0 },
    { "name": "说明", "field_type": 0 },
    { "name": "工时(人天)", "field_type": 1 },
    { "name": "开始日期", "field_type": 2 },
    {
      "name": "阶段",
      "field_type": 3,
      "type_option_data": {
        "content": "{\"options\": [{\"id\": \"phase-plan\", \"name\": \"规划\", \"color\": \"Yellow\"}, {\"id\": \"phase-dev\", \"name\": \"开发\", \"color\": \"Blue\"}], \"disable_color\": false}"
      }
    },
    {
      "name": "状态",
      "field_type": 3,
      "type_option_data": {
        "content": "{\"options\": [{\"id\": \"status-todo\", \"name\": \"未开始\", \"color\": \"Purple\"}, {\"id\": \"status-doing\", \"name\": \"进行中\", \"color\": \"Blue\"}, {\"id\": \"status-done\", \"name\": \"已完成\", \"color\": \"Green\"}], \"disable_color\": false}"
      }
    },
    { "name": "子任务", "field_type": 7 },
    { "name": "依赖", "field_type": 10, "type_option_data": { "database_id": "<db_id_placeholder>" } },
    { "name": "子项", "field_type": 10, "type_option_data": { "database_id": "<db_id_placeholder>" } }
  ],
  "rows": [
    {
      "key": "req-clarify",
      "cells": {
        "Name": "需求澄清与范围定义",
        "负责人": "产品经理",
        "说明": "输出 PRD 与风险清单",
        "工时(人天)": 3,
        "开始日期": "2026-03-01T09:00:00Z",
        "阶段": { "name": "规划" },
        "状态": { "name": "已完成" },
        "子任务": {
          "options": [
            { "id": "ck-1-1", "name": "访谈干系人", "color": "Pink" },
            { "id": "ck-1-2", "name": "竞品分析", "color": "Orange" },
            { "id": "ck-1-3", "name": "范围确认", "color": "Green" }
          ],
          "selected_option_ids": ["ck-1-1"]
        }
      }
    },
    {
      "key": "auth-api",
      "cells": {
        "Name": "认证与登录接口",
        "负责人": "后端负责人",
        "说明": "实现登录、刷新、登出流程",
        "工时(人天)": 4,
        "开始日期": "2026-03-10T09:00:00Z",
        "阶段": { "name": "开发" },
        "状态": { "name": "进行中" },
        "子任务": {
          "options": [
            { "id": "ck-2-1", "name": "登录接口", "color": "Pink" },
            { "id": "ck-2-2", "name": "Token 刷新", "color": "Orange" },
            { "id": "ck-2-3", "name": "安全审计", "color": "Green" }
          ],
          "selected_option_ids": ["ck-2-1"]
        }
      },
      "depends_on": ["req-clarify"]
    },
    {
      "key": "milestone-dev",
      "cells": {
        "Name": "开发里程碑",
        "负责人": "项目负责人",
        "说明": "核心功能开发完成",
        "工时(人天)": 1,
        "开始日期": "2026-03-26T09:00:00Z",
