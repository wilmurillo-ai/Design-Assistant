{
  "name": "wechat-md-publisher",
  "displayName": "WeChat MD Publisher",
  "version": "0.8.30",
  "description": "全功能微信公众号 Markdown 发布工具 - 支持草稿、发布、删除和多主题。⚠️ 需要 WECHAT_APP_ID 和 WECHAT_APP_SECRET 环境变量",
  "requiredEnvVars": ["WECHAT_APP_ID", "WECHAT_APP_SECRET"],
  "envVars": {
    "required": ["WECHAT_APP_ID", "WECHAT_APP_SECRET"],
    "optional": []
  },
  "install": {
    "type": "npm",
    "command": "npm install -g wechat-md-publisher",
    "package": "wechat-md-publisher",
    "global": true,
    "autoInstall": false,
    "autoUpdate": false,
    "riskLevel": "moderate",
    "riskReason": "全局安装第三方 npm 包，会在主机上执行未经审计的代码。安装前请审计源码。",
    "requiresApproval": true,
    "source": {
      "type": "npm",
      "registry": "https://registry.npmjs.org",
      "package": "wechat-md-publisher",
      "repository": "https://github.com/sipingme/wechat-md-publisher",
      "license": "Apache-2.0"
    },
    "verification": {
      "command": "wechat-pub --version",
      "expectedBinary": "wechat-pub"
    }
  },
  "credentials": {
    "primary": "WECHAT_APP_SECRET",
    "required": ["WECHAT_APP_ID", "WECHAT_APP_SECRET"],
    "storage": {
      "location": "~/.config/wechat-md-publisher-nodejs/",
      "encryption": "AES-256",
      "handler": "wechat-md-publisher npm 包",
      "handlerRepo": "https://github.com/sipingme/wechat-md-publisher",
      "auditFile": "src/services/account.ts"
    },
    "securityNote": "凭证加密由上游 npm 包处理。使用前请审计 https://github.com/sipingme/wechat-md-publisher/blob/main/src/services/account.ts"
  },
  "skill": {
    "name": "wechat-md-publisher",
    "displayName": "WeChat MD Publisher",
    "version": "0.8.30",
    "description": "全功能微信公众号 Markdown 发布工具 - 支持草稿、发布、删除和多主题。⚠️ 需要 WECHAT_APP_ID 和 WECHAT_APP_SECRET 环境变量",
    "requiredEnvVars": ["WECHAT_APP_ID", "WECHAT_APP_SECRET"],
    "envVars": {
      "required": ["WECHAT_APP_ID", "WECHAT_APP_SECRET"],
      "optional": []
    },
    "author": {
      "name": "Ping Si",
      "email": "sipingme@gmail.com",
      "github": "sipingme"
    },
    "repository": {
      "type": "git",
      "url": "https://github.com/sipingme/wechat-md-publisher-skill"
    },
    "license": "Apache-2.0",
    "category": "publishing",
    "tags": [
      "wechat",
      "publishing",
      "markdown",
      "content-management",
      "social-media"
    ],
    "requirements": {
      "node": ">=18.0.0",
      "npm": ">=8.0.0",
      "os": ["darwin", "linux", "win32"],
      "env": {
        "required": [
          {
            "name": "WECHAT_APP_ID",
            "description": "微信公众号 AppID（必需）"
          },
          {
            "name": "WECHAT_APP_SECRET",
            "description": "微信公众号 AppSecret（必需）"
          }
        ]
      }
    },
    "credentials": {
      "primary": "WECHAT_APP_SECRET",
      "storage": {
        "location": "~/.config/wechat-md-publisher-nodejs/",
        "handler": "wechat-md-publisher npm 包",
        "handlerRepo": "https://github.com/sipingme/wechat-md-publisher",
        "note": "凭证加密由上游 npm 包处理，本 skill 不直接处理凭证存储"
      }
    },
    "features": [
      "完整的草稿和发布管理",
      "8 个精美内置主题",
      "智能图片处理和缓存",
      "多账号支持",
      "CLI 工具和编程 API"
    ],
    "documentation": {
      "readme": "https://github.com/sipingme/wechat-md-publisher-skill/blob/main/README.md",
      "skill": "https://github.com/sipingme/wechat-md-publisher-skill/blob/main/SKILL.md",
      "quickStart": "https://github.com/sipingme/wechat-md-publisher-skill/blob/main/references/quick-start.md"
    },
    "screenshots": [],
    "demo": {
      "video": "",
      "gif": ""
    },
    "rating": {
      "clarity": 5,
      "timeToSuccess": 5,
      "usefulness": 5,
      "security": 5
    }
  }
}
