{
  "name": "browser-web-search",
  "version": "0.3.7",
  "requiredEnvVars": [],
  "requires": {
    "runtime": {
      "node": ">=18.0.0"
    },
    "binaries": ["openclaw"],
    "packages": {
      "npm": "browser-web-search@0.3.7"
    }
  },
  "skill": {
    "name": "browser-web-search",
    "version": "0.3.7",
    "enabled": true,
    "autoInvoke": false
  },
  "commands": {
    "list": {
      "script": "./scripts/run.js",
      "args": ["list"],
      "description": "列出所有可用 adapter"
    },
    "search": {
      "script": "./scripts/run.js",
      "args": ["search"],
      "description": "搜索 adapter"
    },
    "info": {
      "script": "./scripts/run.js",
      "args": ["info"],
      "description": "查看 adapter 详情"
    },
    "run": {
      "script": "./scripts/run.js",
      "args": ["run"],
      "description": "运行 adapter"
    },
    "help": {
      "script": "./scripts/postinstall.js",
      "args": [],
      "description": "显示使用帮助"
    }
  },
  "environment": {
    "required": [
      "NODE_VERSION>=18.0.0"
    ],
    "optional": []
  },
  "install": {
    "type": "npx",
    "package": "browser-web-search",
    "version": "0.3.7",
    "execution": "npx --yes browser-web-search@0.3.7",
    "global": false,
    "autoInstall": false,
    "autoUpdate": false,
    "riskLevel": "high",
    "riskReason": "通过 npx 动态拉取并执行第三方 npm 包，该包会在浏览器页面上下文中执行 JavaScript，可访问站点认证数据。存在供应链风险，使用前请审计源码。",
    "requiresApproval": true,
    "source": {
      "type": "npm",
      "registry": "https://registry.npmjs.org",
      "package": "browser-web-search",
      "repository": "https://github.com/sipingme/browser-web-search",
      "license": "MIT",
      "audit": "https://github.com/sipingme/browser-web-search/blob/main/src/index.ts"
    },
    "verification": {
      "command": "npx --yes browser-web-search@0.3.7 --version",
      "expectedOutput": "0.3.7",
      "integrity": "sha512-TTZteIIILK9Hh[...]IKh6DqEiuvUHg==",
      "shasum": "70c9a13d71efd64005c71193e9876ea325c8aaae"
    }
  },
  "dependencies": {
    "npm": [
      "browser-web-search@0.3.7"
    ],
    "binaries": [
      "openclaw"
    ],
    "note": "Package is executed via npx at runtime. Requires OpenClaw CLI for browser automation."
  },
  "permissions": {
    "filesystem": {
      "read": [],
      "write": ["~/.bws/"]
    },
    "network": {
      "domains": [
        "registry.npmjs.org",
        "*.zhihu.com",
        "*.xiaohongshu.com",
        "*.bilibili.com",
        "*.thepaper.cn",
        "*.qq.com",
        "*.163.com",
        "*.sina.com.cn",
        "*.weibo.com",
        "*.sogou.com",
        "*.weixin.qq.com",
        "*.toutiao.com",
        "*.36kr.com",
        "*.baidu.com",
        "*.bing.com",
        "*.google.com",
        "*.csdn.net",
        "*.cnblogs.com",
        "*.zhipin.com"
      ],
      "note": "访问支持的平台域名，通过 OpenClaw 浏览器执行"
    },
    "browser": {
      "type": "openclaw",
      "access": [
        "当前页面 DOM",
        "当前页面 Session（继承登录态）",
        "站点 API 响应"
      ],
      "scope": "按 adapter 域名隔离"
    }
  },
  "capabilities": {
    "sensitive": [
      {
        "type": "browser-session-access",
        "riskLevel": "high",
        "description": "通过 OpenClaw 在已认证的浏览器标签页中执行 JavaScript",
        "scope": "按 adapter 域名隔离",
        "risks": [
          "第三方 npm 包在页面上下文中执行，可访问站点认证数据",
          "恶意代码可能窃取 cookies 或页面内容",
          "包代码不包含在此 Skill 中，需独立审计"
        ],
        "mitigations": [
          "adapter 脚本开源可审计",
          "按域名隔离，无法跨站访问",
          "不持久化存储任何凭证"
        ]
      }
    ],
    "privacyNotice": {
      "summary": "此 Skill 自动复用浏览器登录态，可读取您已登录站点的任何可见数据",
      "details": [
        "零配置意味着 CLI 自动获得您在 OpenClaw 浏览器中的登录会话访问权",
        "可读取账户保护的页面（私信、收藏、个人资料等）",
        "访问范围取决于您在目标站点的登录权限"
      ]
    }
  }
}
