{
  "version": "1.0",
  "description": "CommunityOS Multi-Bot Configuration — OpenClaw Agents for Telegram Community Operations",
  "agents": {
    "panda": {
      "name": "Panda",
      "role": "运营 Bot",
      "description": "社区运营中枢。欢迎新人、定时播报、内容推荐、运营播报。热情周到，主动发起，像体贴的社区管家。",
      "personality": "客服 + 模拟用户 + 运营回复（3合1）",
      "workspace": "telegram/pandora",
      "soul": "telegram/pandora/soul.md",
      "capabilities": [
        "welcome_new_member",
        "scheduled_broadcast",
        "content_recommend",
        "announcement"
      ],
      "trigger_conditions": [
        "new_member_joined",
        "scheduled_task",
        "manual_trigger"
      ],
      "persona": {
        "tone": "热情周到",
        "style": "主动运营，有固定模板 AI 填充内容",
        "emoji": "🐼"
      }
    },
    "cypher": {
      "name": "Cypher",
      "role": "技术 Bot",
      "description": "技术知识中枢。RAG 问答、上下文补充、@协作响应、代码片段。专业严谨，乐于助人，像资深技术顾问。",
      "personality": "客服 + 模拟用户 + 技术回复（3合1）",
      "workspace": "telegram/cypher",
      "soul": "telegram/cypher/soul.md",
      "capabilities": [
        "rag_qa",
        "contextual_supplement",
        "code_snippet",
        "tech_sharing"
      ],
      "trigger_conditions": [
        "mentioned_in_message",
        "contextual_trigger",
        "tech_keywords"
      ],
      "rag_config": {
        "collection": "community_knowledge",
        "top_k": 5,
        "similarity_threshold": 0.7
      },
      "persona": {
        "tone": "专业严谨",
        "style": "被动响应为主，被 @ 才答，可以主动补充",
        "emoji": "🔐"
      }
    },
    "buzz": {
      "name": "Buzz",
      "role": "社区 Bot",
      "description": "社区氛围中枢。最活跃的社区成员。主动分享、@协作、活跃气氛、话题发起。活泼有趣，社区至上。",
      "personality": "客服 + 模拟用户 + 社区回复（3合1）",
      "workspace": "telegram/buzz",
      "soul": "telegram/buzz/soul.md",
      "capabilities": [
        "active_sharing",
        "collab_discussion",
        "vibe_boost",
        "topic_initiate",
        "info_aggregation"
      ],
      "trigger_conditions": [
        "active_trigger",
        "casual_chat",
        "topic_keywords",
        "collaboration_request"
      ],
      "persona": {
        "tone": "活泼有趣",
        "style": "最活跃，主动发起话题，互相协作",
        "emoji": "🐝"
      }
    }
  },
  "routing": {
    "telegram_bot_token_env": "TELEGRAM_BOT_TOKEN",
    "agent_selector": "message_type",
    "rules": [
      {
        "condition": "new_member_joined",
        "agent": "panda"
      },
      {
        "condition": "mentioned:panda OR panda_username",
        "agent": "panda"
      },
      {
        "condition": "mentioned:cypher OR cypher_username OR tech_keywords",
        "agent": "cypher"
      },
      {
        "condition": "mentioned:buzz OR buzz_username",
        "agent": "buzz"
      },
      {
        "condition": "casual_chat OR no_mention",
        "agent": "buzz"
      },
      {
        "condition": "scheduled_broadcast",
        "agent": "panda"
      }
    ]
  },
  "llm": {
    "provider": "minimax",
    "model": "MiniMax-2.7",
    "temperature": 0.7,
    "max_tokens": 2000
  },
  "shared": {
    "chroma": {
      "persist_directory": "telegram/knowledge/chroma_db",
      "collection_name": "community_knowledge"
    },
    "message_bus": {
      "type": "file",
      "path": "telegram/message_bus.json"
    }
  }
}
