    "@getlatedev/node": "^0.1.35",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/yargs": "^17.0.32",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
