    { "name": "rb_health_scores", "description": "Relationship health metrics", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"contact_id","type":"UUID","references":"rb_contacts(id)"},{"name":"score","type":"INTEGER"},{"name":"level","type":"TEXT"},{"name":"calculated_at","type":"TIMESTAMPTZ"}], "indexes": [] }
