      { "name": "mp_stores", "description": "Preferred stores", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"household_id","type":"UUID"},{"name":"name","type":"TEXT"},{"name":"role","type":"TEXT"},{"name":"color","type":"TEXT"},{"name":"created_at","type":"TIMESTAMPTZ"}], "indexes": [] },
      { "name": "mp_freezer_items", "description": "Freezer inventory", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"household_id","type":"UUID"},{"name":"name","type":"TEXT"},{"name":"quantity","type":"TEXT"},{"name":"added_date","type":"DATE"},{"name":"expiry_date","type":"DATE"},{"name":"notes","type":"TEXT"},{"name":"created_at","type":"TIMESTAMPTZ"}], "indexes": [] },
      { "name": "mp_dietary_preferences", "description": "Household dietary preferences", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"household_id","type":"UUID"},{"name":"key","type":"TEXT"},{"name":"label","type":"TEXT"},{"name":"is_active","type":"BOOLEAN"},{"name":"created_at","type":"TIMESTAMPTZ"}], "indexes": [] },
      { "name": "mp_flagged_recipes", "description": "AI-flagged recipe suggestions", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"household_id","type":"UUID"},{"name":"recipe_id","type":"UUID"},{"name":"match_score","type":"NUMERIC(3,2)"},{"name":"source","type":"TEXT"},{"name":"created_at","type":"TIMESTAMPTZ"}], "indexes": [] },
