      { "name": "mp_meal_slots", "description": "Individual meal assignments", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"meal_plan_id","type":"UUID","references":"mp_meal_plans(id)"},{"name":"day","type":"INTEGER"},{"name":"meal_type","type":"TEXT"},{"name":"recipe_id","type":"UUID","references":"mp_recipes(id)"},{"name":"custom_meal","type":"TEXT"},{"name":"notes","type":"TEXT"}], "indexes": [{"name":"idx_mp_meal_slots_plan","columns":["meal_plan_id"]}] },
      { "name": "mp_meal_slot_members", "description": "Who eats which meals", "columns": [{"name":"meal_slot_id","type":"UUID","references":"mp_meal_slots(id)"},{"name":"member_id","type":"UUID","references":"mp_members(id)"}], "indexes": [] },
      { "name": "mp_ratings", "description": "Meal ratings from household members", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"meal_slot_id","type":"UUID"},{"name":"member_id","type":"UUID"},{"name":"recipe_id","type":"UUID"},{"name":"score","type":"INTEGER"},{"name":"comment","type":"TEXT"},{"name":"created_at","type":"TIMESTAMPTZ"}], "indexes": [] },
      { "name": "mp_grocery_lists", "description": "Generated grocery lists", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"meal_plan_id","type":"UUID","references":"mp_meal_plans(id)"},{"name":"estimated_total_cents","type":"INTEGER"},{"name":"status","type":"TEXT","default":"pending"},{"name":"created_at","type":"TIMESTAMPTZ"},{"name":"updated_at","type":"TIMESTAMPTZ"}], "indexes": [] },
