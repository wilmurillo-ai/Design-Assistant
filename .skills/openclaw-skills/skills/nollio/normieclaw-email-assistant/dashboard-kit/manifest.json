    { "name": "ea_vip_senders", "description": "VIP sender configuration", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"user_id","type":"UUID"},{"name":"email","type":"TEXT"},{"name":"domain","type":"TEXT"},{"name":"label","type":"TEXT","default":"VIP"},{"name":"escalation","type":"TEXT","default":"notify"},{"name":"created_at","type":"TIMESTAMPTZ"}], "indexes": [] },
