    { "name": "tb_exercises", "description": "Exercise library (shared)", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"name","type":"TEXT"},{"name":"muscle_group","type":"TEXT"},{"name":"movement_type","type":"TEXT"},{"name":"equipment","type":"TEXT"},{"name":"instructions","type":"TEXT"},{"name":"created_at","type":"TIMESTAMPTZ"}], "indexes": [] },
    { "name": "tb_workouts", "description": "Workout sessions", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"user_id","type":"UUID"},{"name":"date","type":"DATE"},{"name":"split_day","type":"TEXT"},{"name":"duration_minutes","type":"INTEGER"},{"name":"rating","type":"INTEGER"},{"name":"notes","type":"TEXT"},{"name":"created_at","type":"TIMESTAMPTZ"},{"name":"updated_at","type":"TIMESTAMPTZ"}], "indexes": [{"name":"idx_tb_workouts_user_date","columns":["user_id","date DESC"]}] },
    { "name": "tb_workout_sets", "description": "Individual exercise sets", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"workout_id","type":"UUID","references":"tb_workouts(id)"},{"name":"exercise_name","type":"TEXT"},{"name":"set_number","type":"INTEGER"},{"name":"weight_lbs","type":"NUMERIC(6,1)"},{"name":"reps","type":"INTEGER"},{"name":"rpe","type":"NUMERIC(3,1)"},{"name":"is_warmup","type":"BOOLEAN","default":false},{"name":"notes","type":"TEXT"}], "indexes": [{"name":"idx_tb_workout_sets_workout","columns":["workout_id"]}] },
    { "name": "tb_body_metrics", "description": "Body measurements over time", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"user_id","type":"UUID"},{"name":"date","type":"DATE"},{"name":"weight_lbs","type":"NUMERIC(5,1)"},{"name":"body_fat_pct","type":"NUMERIC(4,1)"},{"name":"notes","type":"TEXT"},{"name":"created_at","type":"TIMESTAMPTZ"}], "indexes": [{"name":"idx_tb_body_metrics_user","columns":["user_id","date DESC"]}] },
    { "name": "tb_personal_records", "description": "Personal bests", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"user_id","type":"UUID"},{"name":"exercise_name","type":"TEXT"},{"name":"weight_pr_lbs","type":"NUMERIC(6,1)"},{"name":"reps_at_pr","type":"INTEGER"},{"name":"estimated_1rm_lbs","type":"NUMERIC(6,1)"},{"name":"achieved_date","type":"DATE"},{"name":"created_at","type":"TIMESTAMPTZ"},{"name":"updated_at","type":"TIMESTAMPTZ"}], "indexes": [{"name":"idx_tb_personal_records_user","columns":["user_id","exercise_name"]}] }
  ] },
