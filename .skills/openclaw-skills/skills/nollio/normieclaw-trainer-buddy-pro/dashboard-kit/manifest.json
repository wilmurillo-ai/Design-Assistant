{
  "skill_id": "trainer-buddy",
  "display_name": "Trainer Buddy Pro",
  "description": "Personalized fitness tracking with workout logging, progress charts, and personal records.",
  "icon": "Dumbbell",
  "accent_color": "#00f0ff",
  "sidebar": { "route": "/training", "label": "Training", "icon": "Dumbbell", "children": [{"label":"Overview","route":"/training"},{"label":"Workout Log","route":"/training/log","icon":"ClipboardList"},{"label":"Progress","route":"/training/progress","icon":"TrendingUp"},{"label":"Exercises","route":"/training/exercises","icon":"Dumbbell"},{"label":"PRs","route":"/training/prs","icon":"Trophy"}] },
  "database": { "prefix": "tb", "tables": [
    { "name": "tb_profiles", "description": "Fitness profiles", "columns": [{"name":"id","type":"UUID","primary_key":true},{"name":"user_id","type":"UUID"},{"name":"name","type":"TEXT"},{"name":"weight_lbs","type":"NUMERIC(5,1)"},{"name":"height_inches","type":"INTEGER"},{"name":"experience_level","type":"TEXT","default":"intermediate"},{"name":"primary_goal","type":"TEXT"},{"name":"created_at","type":"TIMESTAMPTZ"},{"name":"updated_at","type":"TIMESTAMPTZ"}], "indexes": [] },
