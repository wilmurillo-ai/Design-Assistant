# Cloudflare R2 配置示例
# 复制此文件到 ~/.openclaw/config/cloudflare-r2.env 并填入你的信息

# Cloudflare 账户 ID
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id-here

# S3 访问密钥
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key-id-here
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key-here

# 存储桶名称
CLOUDFLARE_R2_BUCKET_NAME=your-bucket-name-here

# 自定义公开域名（可选）
# 如果不设置，使用 Cloudflare 默认的 https://pub-${bucket-name}.r2.dev
CLOUDFLARE_R2_PUBLIC_DOMAIN=

# 是否默认设为公开可读
CLOUDFLARE_R2_DEFAULT_PUBLIC=true
