{
  "id": "formal-methods",
  "name": "Formal Methods",
  "version": "1.0.0",
  "description": "Formal verification with Lean 4, Coq, and Z3 SMT solver. Type-check proofs, compile theories, and solve satisfiability problems.",
  "category": "general",
  "author": "Prismer Team",
  "repository": "https://github.com/Prismer-AI/Prismer",
  "tools": [
    {
      "name": "lean_check",
      "description": "Type-check Lean 4 code and return the output",
      "parameters": {
        "code": {
          "type": "string",
          "description": "Lean 4 source code to type-check",
          "required": true
        },
        "filename": {
          "type": "string",
          "description": "Filename for the source (default: 'check.lean')",
          "required": false,
          "default": "check.lean"
        }
      }
    },
    {
      "name": "coq_check",
      "description": "Check a Coq proof for correctness",
      "parameters": {
        "code": {
          "type": "string",
          "description": "Coq source code to check",
          "required": true
        },
        "filename": {
          "type": "string",
          "description": "Filename for the source (default: 'check.v')",
          "required": false,
          "default": "check.v"
        }
      }
    },
    {
      "name": "coq_compile",
      "description": "Compile a Coq file to a .vo object file",
      "parameters": {
        "code": {
          "type": "string",
          "description": "Coq source code to compile",
          "required": true
        },
        "filename": {
          "type": "string",
          "description": "Filename for the source (default: 'compile.v')",
          "required": false,
          "default": "compile.v"
        }
      }
    },
    {
      "name": "z3_solve",
      "description": "Solve a satisfiability problem using Z3 SMT solver",
      "parameters": {
        "formula": {
          "type": "string",
          "description": "SMT-LIB2 formula to solve",
          "required": true
        }
      }
    },
    {
      "name": "prover_status",
      "description": "Check which formal provers are available and their versions",
      "parameters": {}
    }
  ],
  "dependencies": [],
  "builtin": true
}
