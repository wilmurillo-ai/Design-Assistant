    "物业管理",
    "能耗分析",
    "设备监控"
  ],
  "author": "ClawHub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawhub/skills/ioc-patrol-report"
  },
  "main": "scripts/generate_report.py",
  "scripts": {
    "daily": "uv run scripts/generate_report.py --type daily",
    "weekly": "uv run scripts/generate_report.py --type weekly",
    "test": "pytest tests/"
  },
  "dependencies": {
    "python": ">=3.10",
    "psycopg2-binary": ">=2.9.0",
    "pyyaml": ">=6.0"
  },
