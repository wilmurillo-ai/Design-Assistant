{
  "name": "baidu-netdisk",
  "version": "1.0.0",
  "description": "百度网盘文件管理 - 列出、搜索、创建目录",
  "author": "EVA",
  "license": "MIT",
  "runtime": {
    "type": "process",
    "command": "python3",
    "args": [
      "{{skillDir}}/scripts/main.py"
    ],
    "env": {}
  },
  "commands": {
    "list": {
      "description": "列出百度网盘文件",
      "args": ["list", "{path}"]
    },
    "search": {
      "description": "搜索百度网盘文件",
      "args": ["search", "{keyword}"]
    },
    "mkdir": {
      "description": "在百度网盘创建目录",
      "args": ["mkdir", "{path}"]
    }
  },
  "keywords": ["百度网盘", "baidu", "netdisk", "文件管理"]
}
