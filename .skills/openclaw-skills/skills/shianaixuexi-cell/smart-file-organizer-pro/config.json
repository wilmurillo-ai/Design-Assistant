{
  "version": "2.0.0",
  "mode": "standard",
  "预设模式": {
    "simple": {
      "描述": "简洁模式 - 快速分类，不重命名",
      "分类": true,
      "重命名": false,
      "去重": false,
      "归档": false
    },
    "standard": {
      "描述": "标准模式 - 分类+可选重命名",
      "分类": true,
      "重命名": true,
      "去重": true,
      "归档": false
    },
    "deep": {
      "描述": "深度模式 - 完整整理",
      "分类": true,
      "重命名": true,
      "去重": true,
      "归档": true
    },
    "archive": {
      "描述": "归档模式 - 按日期归档",
      "分类": false,
      "重命名": false,
      "去重": false,
      "归档": true
    }
  },
  "分类设置": {
    "图片": {
      "文件夹": "Pictures",
      "扩展名": [".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp", ".svg", ".raw", ".heic", ".tiff"],
      "图标": "📷"
    },
    "文档": {
      "文件夹": "Documents",
      "扩展名": [".pdf", ".doc", ".docx", ".xls", ".xlsx", ".ppt", ".pptx", ".txt", ".md", ".rtf", ".odt"],
      "图标": "📄"
    },
    "视频": {
      "文件夹": "Videos",
      "扩展名": [".mp4", ".mov", ".avi", ".mkv", ".flv", ".wmv", ".m4v", ".webm", ".3gp"],
      "图标": "🎬"
    },
    "音频": {
      "文件夹": "Music",
      "扩展名": [".mp3", ".wav", ".flac", ".m4a", ".aac", ".ogg", ".wma", ".opus"],
      "图标": "🎵"
    },
    "压缩包": {
      "文件夹": "Archives",
      "扩展名": [".zip", ".rar", ".7z", ".tar", ".gz", ".bz2", ".xz", ".iso"],
      "图标": "📦"
    },
    "代码": {
      "文件夹": "Code",
      "扩展名": [".py", ".js", ".java", ".cpp", ".c", ".h", ".html", ".css", ".json", ".xml", ".php", ".rb", ".go", ".rs", ".ts", ".jsx", ".tsx", ".vue", ".swift", ".kt"],
      "图标": "💻"
    },
    "可执行": {
      "文件夹": "Executables",
      "扩展名": [".exe", ".msi", ".app", ".dmg", ".deb", ".rpm", ".apk", ".sh", ".bat", ".cmd"],
      "图标": "⚙️"
    },
    "电子书": {
      "文件夹": "Books",
      "扩展名": [".epub", ".mobi", ".azw", ".azw3", ".fb2"],
      "图标": "📚"
    },
    "其他": {
      "文件夹": "Others",
      "扩展名": [],
      "图标": "📁"
    }
  },
  "按应用来源分类": {
    "启用": false,
    "规则": {
      "浏览器下载": {
        "关键词": ["未确认", "crdownload", "download", "从"],
        "目标文件夹": "Downloads/Browser"
      },
      "微信文件": {
        "关键词": ["wxwork", "wechat", "weixin"],
        "目标文件夹": "Downloads/WeChat"
      },
      "QQ文件": {
        "关键词": ["qq", "tencent"],
        "目标文件夹": "Downloads/QQ"
      },
      "钉钉文件": {
        "关键词": ["dingtalk", "dingding"],
        "目标文件夹": "Downloads/DingTalk"
      }
    }
  },
  "重命名规则": {
    "启用": true,
    "保留原始名称": false,
    "日期格式": "YYYYMMDD",
    "时间格式": "HHMMSS",
    "图片模式": "IMG_{YYYYMMDD}_{序号}",
    "视频模式": "VID_{YYYYMMDD}_{序号}",
    "文档模式": "DOC_{标题}_{YYYYMMDD}",
    "通用模式": "FILE_{YYYYMMDD}_{序号}",
    "最大标题长度": 30
  },
  "归档设置": {
    "启用": false,
    "日期格式": "YYYY/MM/DD",
    "使用创建日期": true,
    "使用修改日期": false,
    "保持原始结构": false,
    "创建归档报告": true
  },
  "重复文件检测": {
    "启用": true,
    "检测方法": "hash",
    "处理方式": "move",
    "保留策略": "oldest",
    "重复文件夹": "Duplicates",
    "精确匹配": true,
    "相似匹配": false,
    "相似度阈值": 0.95
  },
  "安全设置": {
    "预览模式": false,
    "自动备份": true,
    "备份保留天数": 30,
    "备份位置": "Backup",
    "跳过系统文件": true,
    "跳过隐藏文件": true,
    "最大文件大小MB": 1024,
    "安全模式": false,
    "确认危险操作": true,
    "只读检查": true
  },
  "性能设置": {
    "最大工作线程": 4,
    "显示进度": true,
    "进度更新间隔": 100,
    "使用缓存": true,
    "缓存位置": ".cache",
    "批量处理大小": 100
  },
  "输出设置": {
    "详细程度": "normal",
    "彩色输出": true,
    "生成报告": true,
    "报告位置": "Reports",
    "日志级别": "INFO",
    "日志位置": "Logs",
    "显示图标": true,
    "显示统计": true
  },
  "历史记录": {
    "启用": true,
    "最大历史数": 100,
    "历史位置": ".history",
    "自动清理": true,
    "清理天数": 90
  }
}
