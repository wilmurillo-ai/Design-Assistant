    "DESIGNKIT_OPENCLAW_AK_URL": {
      "type": "string",
      "description": "Optional billing or key-management page shown in user-facing guidance. Default: https://www.designkit.cn/openclaw.",
      "required": false
    }
  },
  "skills": {
    "designkit-edit-tools": {
      "entry": "skills/designkit-edit-tools/SKILL.md",
