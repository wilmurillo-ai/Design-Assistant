  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vieiradiego/openclaw-aws-sre-report.git"
  },
  "homepage": "https://github.com/vieiradiego/openclaw-aws-sre-report#readme",
  "bugs": {
    "url": "https://github.com/vieiradiego/openclaw-aws-sre-report/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-cloudwatch": "^3.600.0",
