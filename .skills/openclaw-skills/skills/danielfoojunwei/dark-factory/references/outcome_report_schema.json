{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dark Factory Outcome Report",
  "description": "Formal schema for provable outcome reports produced by dark-factory",
  "type": "object",
  "required": ["report_id", "specification_id", "status", "generated_code", "test_results", "cryptographic_signature"],
  "properties": {
    "report_id": {
      "type": "string",
      "pattern": "^report-[a-zA-Z0-9]{8,}$",
      "description": "Unique identifier for this outcome report"
    },
    "specification_id": {
      "type": "string",
      "description": "ID of the specification this report was generated from"
    },
    "title": {
      "type": "string",
      "description": "Title of the specification"
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed"],
      "description": "Overall execution status"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp when this report was generated"
    },
    "performance_metrics": {
      "type": "object",
      "properties": {
        "overall_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "behavioral_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "unit_test_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "integration_test_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "total_duration_ms": { "type": "number", "minimum": 0 }
      }
    },
    "generated_code": {
      "type": "object",
      "description": "Code generated by the AI agent",
      "properties": {
        "language": { "type": "string" },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "content"],
            "properties": {
              "path": { "type": "string" },
              "content": { "type": "string" },
              "language": { "type": "string" }
            }
          }
        },
        "generation_metadata": { "type": "object" }
      }
    },
    "test_results": {
      "type": "object",
      "description": "Results from all test stages",
      "properties": {
        "behavioral": { "type": "object" },
        "unit": { "type": "object" },
        "integration": { "type": "object" }
      }
    },
    "security_evidence": {
      "type": "object",
      "description": "Security validation evidence",
      "properties": {
        "validation_passed": { "type": "boolean" },
        "behavioral_scenarios_verified": { "type": "integer" },
        "guard_blocks": { "type": "integer" },
        "note": { "type": "string" }
      }
    },
    "edge_cases": {
      "type": "array",
      "description": "Failed scenarios that represent edge cases for feedback-loop analysis",
      "items": { "type": "object" }
    },
    "failures": {
      "type": "array",
      "description": "Test failures for feedback-loop analysis",
      "items": { "type": "object" }
    },
    "cryptographic_signature": {
      "type": "object",
      "description": "Cryptographic proof of report integrity",
      "required": ["algorithm", "digest", "signed_at"],
      "properties": {
        "algorithm": { "type": "string", "description": "Hashing/signing algorithm used" },
        "digest": { "type": "string", "description": "Hex digest of the report content" },
        "signed_at": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
