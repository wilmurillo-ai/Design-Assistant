  "data_contracts": [
    {
      "id": "support_ticket",
      "file": "references/data_contracts_support_ticket.json",
      "version": "1.0.0",
      "producers": ["support-intake"],
      "consumers": ["support-triage", "sentiment-analysis"]
    },
    {
      "id": "sentiment_response",
      "file": "references/data_contracts_sentiment_response.json",
      "version": "1.0.0",
      "producers": ["sentiment-analysis"],
      "consumers": ["response-generator", "escalation-manager"]
    }
  ],
  "integration_patterns": [
    {
      "name": "Support Processing Pipeline",
      "description": "Sequential processing of support tickets through triage, sentiment analysis, and response generation",
      "pattern_type": "sequential",
      "steps": [
        {
          "step": 1,
          "skill": "support-intake",
          "description": "Ingest ticket"
        },
        {
          "step": 2,
          "skill": "support-triage",
          "description": "Classify and route",
          "depends_on": [1]
        },
        {
          "step": 3,
          "skill": "sentiment-analysis",
          "description": "Analyze sentiment",
          "depends_on": [1],
          "parallel_with": [2]
        },
        {
          "step": 4,
          "skill": "response-generator",
          "description": "Generate response",
          "depends_on": [2, 3],
          "condition": "triage_result.action == 'auto_respond'"
        },
        {
          "step": 5,
          "skill": "escalation-manager",
          "description": "Escalate if needed",
          "depends_on": [2, 3],
          "condition": "triage_result.action == 'escalate' OR sentiment_response.sentiment == 'negative'"
        }
      ]
    }
  ]
}
