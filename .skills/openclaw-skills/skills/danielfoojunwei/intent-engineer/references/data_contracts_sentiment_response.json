{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sentiment Analysis Response",
  "description": "Response from sentiment analysis skill containing sentiment classification and confidence",
  "type": "object",
  "properties": {
    "ticket_id": {
      "type": "string",
      "description": "Reference to the original ticket being analyzed",
      "pattern": "^TICKET-[0-9]{6}$"
    },
    "sentiment": {
      "type": "string",
      "enum": ["positive", "neutral", "negative"],
      "description": "Overall sentiment classification"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score for the sentiment classification (0-1)"
    },
    "emotion_scores": {
      "type": "object",
      "properties": {
        "anger": { "type": "number", "minimum": 0, "maximum": 1 },
        "frustration": { "type": "number", "minimum": 0, "maximum": 1 },
        "satisfaction": { "type": "number", "minimum": 0, "maximum": 1 },
        "urgency": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "description": "Detailed emotion scores"
    },
    "key_phrases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Important phrases extracted from the text"
    },
    "analyzed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the analysis was performed"
    },
    "analysis_model": {
      "type": "string",
      "description": "Name and version of the model used for analysis"
    }
  },
  "required": ["ticket_id", "sentiment", "confidence", "analyzed_at"],
  "additionalProperties": false,
  "x-data-lineage": {
    "sources": ["sentiment-analysis"],
    "consumers": ["response-generator", "escalation-manager"],
    "transformations": [
      {
        "from_skill": "sentiment-analysis",
        "to_skill": "response-generator",
        "transformation": "Use sentiment and emotion_scores to inform response tone"
      },
      {
        "from_skill": "sentiment-analysis",
        "to_skill": "escalation-manager",
        "transformation": "Use negative sentiment and urgency score to determine escalation priority"
      }
    ]
  }
}
