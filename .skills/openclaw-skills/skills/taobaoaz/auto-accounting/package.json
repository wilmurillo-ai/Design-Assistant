  },
  "devDependencies": {},
  "python": ">=3.7",
  "repository": {
    "type": "git",
    "url": "https://github.com/taobaoaz/auto-accounting.git"
  },
  "bugs": {
    "url": "https://github.com/taobaoaz/auto-accounting/issues"
  },
