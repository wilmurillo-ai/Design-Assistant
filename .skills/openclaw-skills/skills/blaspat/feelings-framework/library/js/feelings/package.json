  },
  "keywords": [
    "ai",
    "agent",
    "feelings",
    "emotion",
    "mood",
    "feelings-engine"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
