{
  "name": "feelings-framework",
  "version": "1.0.0",
  "description": "A general-purpose AI agent feelings engine",
  "type": "module",
  "main": "core.js",
  "exports": {
    ".": {
      "import": "./core.js",
      "types": "./core.d.ts"
    }
  },
  "types": "core.d.ts",
  "files": [
    "core.js",
    "core.d.ts"
  ],
  "scripts": {
