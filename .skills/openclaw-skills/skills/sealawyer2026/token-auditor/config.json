{
  "version": "1.0.0",
  "audit": {
    "retention_days": 90,
    "anomaly_threshold": 2.0,
    "waste_threshold": 0.3
  },
  "reports": {
    "output_dir": "./reports",
    "formats": ["markdown", "json"],
    "auto_save": true
  },
  "alerts": {
    "enable_email": false,
    "enable_webhook": false,
    "thresholds": {
      "daily_increase": 50,
      "weekly_increase": 100,
      "waste_ratio": 0.3
    }
  },
  "optimization": {
    "suggest_compression": true,
    "suggest_routing": true,
    "suggest_budget": true,
    "min_savings_to_report": 10
  }
}
