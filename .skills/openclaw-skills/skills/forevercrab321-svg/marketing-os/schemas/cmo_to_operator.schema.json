{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "marketing-os/schemas/cmo_to_operator.schema.json",
    "title": "CMO to Operator Mission Brief",
    "description": "Collaboration protocol schema — structured mission brief passed from Virtual CMO to Marketing Operator",
    "type": "object",
    "required": [
        "mission_id",
        "objective",
        "target_audience",
        "strategy",
        "priority",
        "recommended_channels",
        "actions",
        "success_criteria"
    ],
    "properties": {
        "mission_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique mission identifier generated by CMO"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "When the mission was created"
        },
        "objective": {
            "type": "string",
            "minLength": 20,
            "description": "Clear, measurable goal for this mission"
        },
        "target_audience": {
            "type": "object",
            "description": "Target audience specification",
            "required": [
                "segment_name",
                "description"
            ],
            "properties": {
                "segment_name": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "size_estimate": {
                    "type": "string"
                },
                "pain_points": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "channels": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "buying_triggers": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "strategy": {
            "type": "object",
            "description": "Strategic approach for this mission",
            "required": [
                "positioning",
                "approach"
            ],
            "properties": {
                "positioning": {
                    "type": "string",
                    "description": "Positioning statement"
                },
                "approach": {
                    "type": "string",
                    "description": "How to execute the strategy"
                },
                "key_messages": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "differentiation": {
                    "type": "string"
                }
            }
        },
        "priority": {
            "type": "string",
            "enum": [
                "critical",
                "high",
                "medium",
                "low"
            ],
            "description": "Mission priority level"
        },
        "recommended_channels": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "channel",
                    "priority_rank"
                ],
                "properties": {
                    "channel": {
                        "type": "string"
                    },
                    "rationale": {
                        "type": "string"
                    },
                    "estimated_reach": {
                        "type": "string"
                    },
                    "estimated_cost": {
                        "type": "string"
                    },
                    "priority_rank": {
                        "type": "integer",
                        "minimum": 1
                    }
                }
            },
            "description": "Ranked list of recommended marketing channels"
        },
        "actions": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "action",
                    "priority"
                ],
                "properties": {
                    "action": {
                        "type": "string",
                        "description": "Specific action to take"
                    },
                    "priority": {
                        "type": "string",
                        "enum": [
                            "critical",
                            "high",
                            "medium",
                            "low"
                        ]
                    },
                    "expected_impact": {
                        "type": "string"
                    },
                    "owner": {
                        "type": "string",
                        "enum": [
                            "operator",
                            "cmo"
                        ]
                    },
                    "estimated_timeline": {
                        "type": "string"
                    }
                }
            },
            "description": "Specific actions for the Operator to decompose into tasks"
        },
        "success_criteria": {
            "type": "object",
            "description": "How to measure mission success",
            "required": [
                "primary_kpi"
            ],
            "properties": {
                "primary_kpi": {
                    "type": "object",
                    "properties": {
                        "metric": {
                            "type": "string"
                        },
                        "target": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "metric",
                        "target"
                    ]
                },
                "secondary_kpis": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "metric": {
                                "type": "string"
                            },
                            "target": {
                                "type": "string"
                            }
                        }
                    }
                },
                "leading_indicators": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "constraints": {
            "type": "object",
            "description": "Constraints and limitations for execution",
            "properties": {
                "budget": {
                    "type": "number",
                    "minimum": 0
                },
                "timeline": {
                    "type": "string"
                },
                "brand_guidelines": {
                    "type": "string"
                },
                "prohibited_channels": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "required_approvals": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "geographic_restrictions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "context": {
            "type": "object",
            "description": "Additional context from CMO analysis",
            "properties": {
                "analysis_id": {
                    "type": "string",
                    "description": "Reference to the CMO analysis"
                },
                "market_conditions": {
                    "type": "string"
                },
                "competitive_landscape": {
                    "type": "string"
                },
                "known_risks": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "risk": {
                                "type": "string"
                            },
                            "severity": {
                                "type": "number"
                            },
                            "mitigation": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    }
}