{
  "name": "anomalib-detector",
  "display_name": "Anomalib 工业异常检测",
  "version": "1.1.0",
  "description": "基于 Intel anomalib 的工业视觉异常检测 Skill，支持 20+ 种检测模型，可用于产品缺陷检测、质量控制等场景",
  "author": {
    "name": "Coze AI Agent",
    "contact": ""
  },
  "category": "computer-vision",
  "tags": [
    "anomaly-detection",
    "defect-detection",
    "industrial-qc",
    "machine-vision",
    "deep-learning"
  ],
  "platform": "coze",
  "license": "MIT-0",
  "repository": "",
  "documentation": "./README.md",
  "readme": "./README.md",
  "requirements": {
    "python": ">=3.9",
    "packages": [
      "anomalib>=2.3.0",
      "torch>=2.0.0",
      "torchvision>=0.15.0",
      "opencv-python>=4.8.0",
      "pillow>=10.0.0",
      "numpy>=1.24.0"
    ]
  },
  "installation": {
    "method": "pip",
    "commands": [
      "pip install anomalib",
      "pip install \"anomalib[cpu]\"",
      "pip install \"anomalib[cu130]\""
    ],
    "options": [
      {
        "name": "CPU 模式",
        "command": "pip install \"anomalib[cpu]\"",
        "description": "无 GPU 环境使用"
      },
      {
        "name": "GPU CUDA 13.0",
        "command": "pip install \"anomalib[cu130]\"",
        "description": "NVIDIA GPU 加速"
      },
      {
        "name": "OpenVINO",
        "command": "pip install \"anomalib[openvino]\"",
        "description": "Intel 硬件加速"
      }
    ]
  },
  "capabilities": {
    "detection": {
      "supported": [
        "single-image-anomaly",
        "batch-anomaly",
        "heatmap-generation",
        "segmentation"
      ]
    },
    "models": [
      "Patchcore",
      "Padim",
      "EfficientAd",
      "DRAEM",
      "GANomaly",
      "DFKD",
      "CFA",
      "FastFlow"
    ],
    "datasets": [
      "MVTecAD",
      "Folder",
      "VisA",
      "KolektorSDD"
    ],
    "export_formats": [
      "PyTorch",
      "ONNX",
      "OpenVINO"
    ]
  },
  "usage_example": {
    "python": "from anomalib.data import MVTecAD; from anomalib.models import Patchcore; from anomalib.engine import Engine",
    "code": "model = Patchcore(); engine = Engine(); engine.fit(model=model, datamodule=MVTecAD(category='bottle'))"
  },
