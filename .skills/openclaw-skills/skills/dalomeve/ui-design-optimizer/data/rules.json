{
  "version": "1.0.0",
  "rules": [
    {
      "id": "saas-001",
      "industry": "Tech & SaaS",
      "product_types": ["SaaS", "Micro SaaS", "B2B Enterprise", "Developer Tools", "AI/Chatbot"],
      "recommended_pattern": "product-led",
      "style_priority": ["minimalism", "material", "bento"],
      "color_mood": "professional,trustworthy,modern",
      "typography_mood": "clean,readable,geometric",
      "key_effects": ["smooth transitions", "subtle hover states", "loading skeletons"],
      "anti_patterns": ["bright neon colors", "playful animations", "emoji icons", "cluttered layouts"],
      "accessibility": "WCAG AA minimum"
    },
    {
      "id": "fintech-001",
      "industry": "Finance",
      "product_types": ["Fintech", "Banking", "Crypto", "Insurance", "Trading Dashboard"],
      "recommended_pattern": "comparison",
      "style_priority": ["minimalism", "dark", "material"],
      "color_mood": "trustworthy,secure,professional",
      "typography_mood": "serious,readable,authoritative",
      "key_effects": ["data visualization", "real-time updates", "subtle animations"],
      "anti_patterns": ["AI purple/pink gradients", "playful fonts", "excessive animations", "gamification"],
      "accessibility": "WCAG AA minimum"
    },
    {
