      "color_mood": "calming,trustworthy,clean",
      "typography_mood": "readable,professional,warm",
      "key_effects": ["gentle transitions", "clear CTAs", "trust badges"],
      "anti_patterns": ["dark themes", "aggressive colors", "complex animations", "urgent language"],
      "accessibility": "WCAG AAA preferred"
    },
