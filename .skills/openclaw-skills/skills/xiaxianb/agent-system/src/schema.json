{
  "agent_system": {
    "description": "OpenClaw 核心 Agent 调度系统 - 智能任务规划、执行、审查与自愈",
    "actions": {
      "dispatch": {
        "description": "主调度函数 - 接收用户输入，返回结构化结果",
        "input": {
          "type": "object",
          "required": ["input"],
          "properties": {
            "input": {
              "type": "string",
              "description": "用户输入或任务描述"
            }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "content": { "type": "string" },
            "plan": {
              "type": "object",
              "properties": {
                "intent": { "type": "string" },
                "complexity": { "type": "number" },
                "tasks": { "type": "array" }
              }
            },
            "metrics": {
              "type": "object",
              "properties": {
                "tokens": { "type": "number" },
                "truncated": { "type": "boolean" },
                "quality_score": { "type": "number" }
              }
            }
          }
        }
      },
      "plan": {
        "description": "仅做任务规划，不执行",
        "input": {
          "type": "object",
          "required": ["input"],
          "properties": {
            "input": { "type": "string" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "intent": { "type": "string" },
            "complexity": { "type": "number" },
            "tasks": { "type": "array" }
          }
        }
      },
      "review": {
        "description": "质量审查",
        "input": {
          "type": "object",
          "required": ["content"],
          "properties": {
            "content": { "type": "string" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "score": { "type": "number" },
            "is_valid": { "type": "boolean" },
            "should_trigger_heal": { "type": "boolean" },
            "issues": { "type": "array" }
          }
        }
      }
    }
  }
}
