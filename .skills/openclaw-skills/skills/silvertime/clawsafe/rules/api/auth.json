{
  "name": "API Authentication Detection",
  "category": "auth",
  "description": "检测认证配置问题",
  "severity": "high",
  "patterns": [
    {
      "id": "no_auth_check",
      "pattern": "(?:auth(?:entication)?|auth[_-]?required)\\s*[:=]\\s*(?:0|false|null|disabled|no[_-]?auth)",
      "weight": 0.8,
      "severity": "critical",
      "description": "未启用认证"
    },
    {
      "id": "weak_auth",
      "pattern": "(?:auth[_-]?(?:method|type)\\s*[:=]\\s*(?:basic|none|anonymous))",
      "weight": 0.6,
      "severity": "medium",
      "description": "弱认证方式"
    },
    {
      "id": "bypass_auth",
      "pattern": "(?:skip[_-]?auth|bypass[_-]?auth|auth[_-]?bypass|auth[_-]?disabled)",
      "weight": 0.85,
      "severity": "critical",
      "description": "认证绕过标记"
    },
    {
      "id": "session_fixation",
      "pattern": "(?:session[_-]?id|jsessionid|session[_-]?token)\\s*[:=]",
      "weight": 0.5,
      "severity": "medium",
      "description": "会话固定风险"
    },
    {
      "id": "expired_token",
      "pattern": "(?:token[_-]?expire|expire[_-]?at|expiry)\\s*[:=]\\s*(?:0|-1|null)",
      "weight": 0.7,
      "severity": "high",
      "description": "Token 永不过期"
    }
  ]
}
