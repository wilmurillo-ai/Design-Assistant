      "delve",
      "tapestry",
      "unwavering",
      "pivotal",
      "comprehensive",
      "landscape",
      "testament",
      "in conclusion",
      "moreover",
      "furthermore"
    ],
    "tier_2_ai_signs": [
      "elevate",
      "unlock",
      "seamless",
      "empower",
      "harness",
      "dive into",
      "embark",
      "transformative",
      "innovative",
      "cutting-edge"
