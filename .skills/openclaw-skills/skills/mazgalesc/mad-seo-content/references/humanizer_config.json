{
  "framework": "Human-GEO Framework V1.0",
  "detection_patterns": [
    "repetitive_sentence_structure",
    "rule_of_three_lists",
    "lack_of_burstiness",
    "robotic_transitions",
    "sycophantic_intros",
    "significance_inflation",
    "promotional_fluff",
    "vague_attributions",
    "passive_voice_overuse",
    "cliché_metaphors"
  ],
