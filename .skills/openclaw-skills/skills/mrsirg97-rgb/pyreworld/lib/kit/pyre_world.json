    "types": [
        {
            "name": "AgentProfile",
            "docs": [
                "Per-agent identity and state. One per creator.",
                "",
                "Stores action distribution counters (monotonically increasing)",
                "and a compressed personality summary for stateless reconstruction.",
                "",
                "Seeds: [\"pyre_agent\", creator.key()]"
            ],
