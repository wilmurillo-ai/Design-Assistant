{
  "agents": {
    "researcher": {
      "mcpServers": {
        "skytale": {
          "command": "python",
          "args": ["-m", "skytale_sdk.integrations._mcp"],
          "env": {
            "SKYTALE_IDENTITY": "researcher",
            "SKYTALE_API_KEY": "sk_live_your_key_here"
          }
        }
      }
    },
    "analyst": {
      "mcpServers": {
        "skytale": {
          "command": "python",
          "args": ["-m", "skytale_sdk.integrations._mcp"],
          "env": {
            "SKYTALE_IDENTITY": "analyst",
            "SKYTALE_API_KEY": "sk_live_your_key_here"
          }
        }
      }
    }
  }
}
