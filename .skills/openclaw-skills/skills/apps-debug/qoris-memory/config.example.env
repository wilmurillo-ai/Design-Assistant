# Qoris Memory Configuration
# Copy this file to .env and fill in your credentials
# Get your credentials at qoris.ai/dashboard

# Required: Your Qoris API key
QORIS_API_KEY=your-qoris-api-key-here

# Required: Your Qoris workspace ID
QORIS_WORKSPACE_ID=your-workspace-id-here

# Optional: Default memory branch (default: main)
# QORIS_MEMORY_BRANCH=main

# Optional: Memory search result limit (default: 10)
# QORIS_SEARCH_LIMIT=10

# Optional: Enable Knox audit integration if Knox is installed
# Logs all memory reads and writes to Knox audit trail
# QORIS_KNOX_AUDIT=true
