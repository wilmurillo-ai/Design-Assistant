{
  "name": "qoris-memory",
  "version": "1.0.5",
  "description": "Legacy listing. See qoris-memory-mcp for the canonical version under @qoris-ai.",
  "author": "qorisai",
  "license": "MIT-0",
  "homepage": "https://qoris.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/QORIS-AI/qoris-memory-openclaw-skill"
