{
  "id": "hawk-bridge",
  "name": "hawk-bridge",
  "description": "AutoCapture + AutoRecall bridge to hawk Python memory system. Zero-config defaults: Jina AI free embedding (no GPU needed) + groq LLM (free tier).",
  "version": "1.1.0",
  "hooks": [
    {
      "name": "hawk-recall",
      "events": [
        "agent:bootstrap"
      ],
      "description": "Inject relevant hawk memories before agent starts"
    },
    {
      "name": "hawk-capture",
      "events": [
        "message:sent"
      ],
      "description": "Auto-extract and store memories after agent responds"
    }
  ],
  "config": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "embedding": {
        "type": "object",
        "description": "Embedding provider settings",
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "jina",
              "qianwen",
              "ollama",
              "openai",
              "cohere",
              "openclaw"
            ],
            "default": "jina",
            "description": "jina=Jina AI free tier (default, no GPU), qianwen=阿里云 DashScope, ollama=local GPU, openai=paid, cohere=free tier"
          },
          "apiKey": {
            "type": "string",
            "description": "API key — not needed for ollama"
          },
          "model": {
            "type": "string",
            "description": "Embedding model name",
            "default": "jina-embeddings-v5-small (jina) | text-embedding-v1 (qianwen) | nomic-embed-text (ollama)"
          },
          "baseURL": {
            "type": "string",
            "description": "Custom API base URL (e.g. http://localhost:11434 for ollama)"
          },
          "dimensions": {
            "type": "number",
            "default": 1024
          }
        }
      },
      "llm": {
        "type": "object",
        "description": "LLM provider for memory extraction (Python side)",
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "groq",
              "ollama",
              "openai",
              "openrouter"
            ],
            "default": "groq",
            "description": "groq=free Llama-3 (no key), ollama=local free, openai=paid"
          },
          "apiKey": {
            "type": "string"
          },
          "model": {
            "type": "string",
            "default": "llama-3.3-70b-versatile (groq) | llama3 (ollama)"
          }
        }
      },
      "recall": {
        "type": "object",
        "properties": {
          "topK": {
            "type": "number",
            "default": 5
          },
          "minScore": {
            "type": "number",
            "default": 0.6
          },
          "injectEmoji": {
            "type": "string",
            "default": "🦅"
          }
        }
      },
      "capture": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "maxChunks": {
            "type": "number",
            "default": 3
          },
          "importanceThreshold": {
            "type": "number",
            "default": 0.5
          },
          "ttlMs": {
            "type": "number",
            "default": 2592000000,
            "description": "Memory TTL in ms, 0=never expire, default 30 days"
          },
          "maxChunkSize": {
            "type": "number",
            "default": 2000,
            "description": "Max characters per memory chunk"
          },
          "minChunkSize": {
            "type": "number",
            "default": 20,
            "description": "Min characters for valid chunk"
          },
          "dedupSimilarity": {
            "type": "number",
            "default": 0.95,
            "description": "Similarity threshold 0~1 for dedup"
          }
        }
      },
      "audit": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Write audit log to ~/.hawk/audit.log"
          }
        }
      },
      "python": {
        "type": "object",
        "properties": {
          "pythonPath": {
            "type": "string",
            "description": "Python interpreter path, auto-detected if omitted"
          },
          "hawkDir": {
            "type": "string",
            "default": "~/.openclaw/hawk"
          }
        }
      }
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  }
}