{
  "plugins": {
    "entries": {
      "hawk-bridge": {
        "enabled": true,
        "config": {
          "embedding": {
            "provider": "minimax",
            "model": "embedding-2-normal",
            "baseURL": "https://api.minimaxi.com/v1",
            "dimensions": 1024
          },
          "llm": {
            "provider": "minimax",
            "model": "MiniMax-M2.7",
            "baseURL": "https://api.minimaxi.com/anthropic"
          },
          "recall": {
            "topK": 5,
            "minScore": 0.6,
            "injectEmoji": "🦅"
          },
          "capture": {
            "enabled": true,
            "maxChunks": 3,
            "importanceThreshold": 0.5
          },
          "python": {
            "pythonPath": "python3.12",
            "hawkDir": "~/.openclaw/hawk"
          }
        }
      }
    }
  }
}
