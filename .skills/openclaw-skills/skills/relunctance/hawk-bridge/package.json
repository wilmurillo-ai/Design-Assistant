{
  "name": "hawk-bridge",
  "version": "1.1.0",
  "description": "OpenClaw hook bridge to hawk Python memory system - autoCapture + autoRecall",
  "type": "module",
  "main": "src/index.ts",
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "openai": "^6.21.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2"
  },
  "openclaw": {
    "compat": {
      "pluginApi": "1.0"
    },
    "extensions": [
      "./dist/index.js"
    ],
    "hooks": [
      "./dist/hooks/hawk-recall",
      "./dist/hooks/hawk-capture"
    ]
  },
  "scripts": {
    "build": "node -e \"const e=require('esbuild');Promise.all([e.build({entryPoints:['src/index.ts'],bundle:true,outfile:'dist/index.js',platform:'node',format:'esm',external:['openclaw','lancedb','@lancedb/*','openai','rank_bm25','crypto']}),e.build({entryPoints:['src/hooks/hawk-recall/handler.ts'],bundle:true,outfile:'dist/hooks/hawk-recall/hawk-recall.js',platform:'node',format:'esm',external:['openclaw','lancedb','@lancedb/*','openai','rank_bm25','crypto']}),e.build({entryPoints:['src/hooks/hawk-capture/handler.ts'],bundle:true,outfile:'dist/hooks/hawk-capture/hawk-capture.js',platform:'node',format:'esm',external:['openclaw','lancedb','@lancedb/*','openai','rank_bm25','crypto']}),e.build({entryPoints:['src/seed.ts'],bundle:true,outfile:'dist/seed.js',platform:'node',format:'esm',external:['openclaw','lancedb','@lancedb/*','openai','rank_bm25','crypto']})]).then(()=>{require('fs').cpSync('src/hooks/hawk-recall/HOOK.md','dist/hooks/hawk-recall/HOOK.md');require('fs').cpSync('src/hooks/hawk-capture/HOOK.md','dist/hooks/hawk-capture/HOOK.md');console.log('Built successfully')}).catch(e=>{console.error(e.message);process.exit(1)})\"",
    "seed": "node dist/seed.js"
  }
}
