{
  "name": "fasterizy",
  "version": "1.0.2",
  "description": "Faster work with coding agents",
  "main": "cli.js",
  "bin": {
    "fasterizy": "./cli.js",
    "izy": "./cli.js"
  },
  "files": [
    "cli.js",
    "cli/",
    "hooks/",
    "scripts/",
    "SKILL.md",
    "skills/",
