{
  "name": "xhs-publisher-scripts",
  "version": "1.0.0",
  "description": "小红书通用自动发帖脚本（封面生成 + Puppeteer 发布）",
  "main": "xhs_publisher.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "postinstall": "node postinstall.js",
    "install:cn": "PUPPETEER_DOWNLOAD_HOST=https://npmmirror.com/mirrors npm install",
    "install:skip": "PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true npm install",
    "check": "node postinstall.js"
  },
  "dependencies": {
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
