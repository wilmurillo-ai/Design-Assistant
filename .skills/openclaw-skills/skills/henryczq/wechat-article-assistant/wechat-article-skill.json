{
  "name": "wechat-article-assistant",
  "displayName": "WeChat Article Assistant",
  "description": "Assistant for the local WeChat article sync service. Supports account search and management, article sync, recent article queries, single article detail lookup by aid or URL, login helpers, and sync log inspection.",
  "version": "1.4.1",
  "author": "OpenClaw",
  "tools": [
    {
      "name": "getRecentArticles",
      "displayName": "Get Recent Articles",
      "description": "Fetch recent articles published within the last N hours.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "hours": {
            "type": "integer",
            "description": "Time window in hours.",
            "default": 24,
            "minimum": 1
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of articles to return.",
            "default": 50,
            "minimum": 1
          }
        }
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "name": "listAccounts",
      "displayName": "List Accounts",
      "description": "Return the locally added official account list.",
      "inputSchema": {
        "type": "object",
        "properties": {}
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "name": "listSyncAccounts",
      "displayName": "List Sync Accounts",
      "description": "Return the current sync-config account list.",
      "inputSchema": {
        "type": "object",
        "properties": {}
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "name": "getArticleDetail",
      "displayName": "Get Article Detail",
      "description": "Fetch a single article by aid or mp.weixin.qq.com URL.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "aid": {
            "type": "string",
            "description": "Article aid, for example 2247493916_1."
          },
          "link": {
            "type": "string",
            "description": "Public WeChat article URL."
          },
          "download_images": {
            "type": "boolean",
            "description": "Whether to download article images when supported.",
            "default": false
          }
        },
        "anyOf": [
          { "required": ["aid"] },
          { "required": ["link"] }
        ]
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "name": "triggerSync",
      "displayName": "Trigger Sync",
      "description": "Trigger article sync for one official account.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "fakeid": {
            "type": "string",
            "description": "Official account fakeid."
          }
        },
        "required": ["fakeid"]
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "name": "triggerSyncAll",
      "displayName": "Trigger Sync All",
      "description": "Trigger article sync for all configured accounts.",
      "inputSchema": {
        "type": "object",
        "properties": {}
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "name": "searchAccount",
      "displayName": "Search Account",
      "description": "Search for an official account by keyword.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string",
            "description": "Search keyword."
          }
        },
        "required": ["keyword"]
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "name": "addAccount",
      "displayName": "Add Account",
      "description": "Add an official account to the local service and trigger the first sync.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "fakeid": {
            "type": "string",
            "description": "Official account fakeid."
          },
          "nickname": {
            "type": "string",
            "description": "Official account nickname."
          },
          "avatar": {
            "type": "string",
            "description": "Optional avatar URL.",
            "default": ""
          }
        },
        "required": ["fakeid", "nickname"]
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "name": "addAccountByKeyword",
      "displayName": "Add Account By Keyword",
      "description": "Search for an official account by keyword, automatically resolve a unique exact match, and add it to the local service.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string",
            "description": "Keyword or exact official account name."
          }
        },
        "required": ["keyword"]
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "name": "deleteAccount",
      "displayName": "Delete Account",
      "description": "Delete an official account by fakeid or nickname.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "fakeid": {
            "type": "string",
            "description": "Official account fakeid."
          },
          "nickname": {
            "type": "string",
            "description": "Official account nickname."
          }
        },
        "anyOf": [
          { "required": ["fakeid"] },
          { "required": ["nickname"] }
        ]
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "name": "getLoginQrcode",
      "displayName": "Get Login QR Code",
      "description": "Start the login flow and return the session information.",
      "inputSchema": {
        "type": "object",
        "properties": {}
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "name": "checkLoginStatus",
      "displayName": "Check Login Status",
      "description": "Check the login status for a session id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "sid": {
            "type": "string",
            "description": "Session id returned by the login command."
          }
        },
        "required": ["sid"]
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "name": "getLoginInfo",
      "displayName": "Get Login Info",
      "description": "Return the current login status information.",
      "inputSchema": {
        "type": "object",
        "properties": {}
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "name": "getSyncLogs",
      "displayName": "Get Sync Logs",
      "description": "Fetch sync task logs, optionally filtered by fakeid.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "fakeid": {
            "type": "string",
            "description": "Optional fakeid filter.",
            "default": ""
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of logs to return.",
            "default": 50,
            "minimum": 1
          }
        }
      },
      "returnSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" },
          "formatted_text": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    }
  ],
  "entryPoint": {
    "type": "python",
    "script": "scripts/wechat_article_skill.py"
  }
}
