{
  "name": "xiaohongshu-creator-finder",
  "version": "1.1.0",
  "description": "小红书AI创作者识别 - 自动搜索并识别AI原创动画创作者",
  "author": "OpenClaw",
  "entry": "skill.py",
  "triggers": [
    "/小红书创作者识别",
    "/找AI创作者",
    "/xhs-finder",
    "帮我找小红书上的AI动画创作者",
    "搜索小红书的AI短剧创作者",
    "识别小红书上做AI视频的博主"
  ],
  "keywords": [
    "小红书",
    "创作者",
    "AI动画",
    "AI短剧",
    "AI视频",
    "博主识别",
    "数据采集"
  ],
  "inputs": {
    "keywords": {
      "type": "array",
      "description": "搜索关键词列表",
      "default": ["AI动画", "AI短剧", "AI视频"],
      "required": false
    },
    "min_likes": {
      "type": "number",
      "description": "最小点赞数",
      "default": 50,
      "required": false
    },
    "min_comments": {
      "type": "number",
      "description": "最小评论数",
      "default": 20,
      "required": false
    },
    "max_days_ago": {
      "type": "number",
      "description": "最大发布时间（天前）",
      "default": 30,
      "required": false
    },
    "min_followers": {
      "type": "number",
      "description": "最小粉丝量",
      "default": 1000,
      "required": false
    },
    "max_results": {
      "type": "number",
      "description": "每个关键词最大采集数",
      "default": 15,
      "required": false
    },
    "output_format": {
      "type": "string",
      "description": "输出格式",
      "default": "excel",
      "enum": ["excel", "json"],
      "required": false
    },
    "headless": {
      "type": "boolean",
      "description": "是否使用无界面模式",
      "default": false,
      "required": false
    }
  },
  "dependencies": [
    "playwright>=1.40.0",
    "pandas>=2.0.0",
    "openpyxl>=3.1.0"
  ],
  "setup_commands": [
    "pip install playwright pandas openpyxl",
    "playwright install chromium"
  ]
}
