{
  "name": "semgrepll",
  "description": "Local semantic code search - 100% offline",
  "version": "1.3.1",
  "repository": "https://github.com/rizperdana/semgrepll",
  "pypi": "semgrepll",
  "install": {
    "type": "pip",
    "package": "semgrepll"
  },
  "env": {
    "EMBED_BACKEND": "auto",
    "SEMGREP_BACKEND": "sqlite"
  },
  "commands": {
    "index": "semgrep index <path>",
    "search": "semgrep search <query>",
    "list": "semgrep ls"
  }
}
