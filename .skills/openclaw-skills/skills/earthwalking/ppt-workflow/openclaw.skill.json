{
  "id": "ppt-workflow",
  "name": "PPT 工作流",
  "description": "基于标准化工作流制作学术 PPT，从内容搜索到美化优化的全流程自动化",
  "version": "1.0.0",
  "author": "academic-assistant",
  "license": "MIT",
  
  "trigger": {
    "keywords": [
      "做个 PPT",
      "制作 PPT",
      "做幻灯片",
      "PPT 主题",
      "presentation",
      "学术报告 PPT",
      "会议 PPT",
      "答辩 PPT"
    ],
    "files": [".pptx", ".ppt"],
    "mode": "keyword"
  },

  "workflow": {
    "stages": [
      {
        "name": "需求确认",
        "model": "qwen3.5",
        "duration": "1 分钟",
        "tasks": [
          "确认报告时长 (5/15/30/60 分钟)",
          "确认目标受众 (学术/商业/大众)",
          "确认核心信息 (3 个关键点)",
          "确认特殊要求 (模板、颜色等)"
        ]
      },
      {
        "name": "内容搜索",
        "model": "kimi-2.5",
        "duration": "30 分钟",
        "tasks": [
          "搜索最新文献 (10-20 篇)",
          "提取关键数据",
          "整理重要图表",
          "生成引用库"
        ]
      },
      {
        "name": "框架设计",
        "model": "qwen3.5",
        "duration": "20 分钟",
        "tasks": [
          "设计幻灯片结构",
          "规划每页内容",
          "设计故事线",
          "输出详细大纲"
        ]
      },
      {
        "name": "内容填充",
        "model": "qwen3.5",
        "duration": "50 分钟",
        "tasks": [
          "逐页撰写内容",
          "准备图表数据",
          "插入引用文献",
          "添加演讲备注"
        ]
      },
      {
        "name": "幻灯片制作",
        "model": "qwen3.5",
        "duration": "40 分钟",
        "tasks": [
          "创建 PPTX 文件",
          "应用模板",
          "逐页添加内容",
          "插入图表图片"
        ]
      },
      {
        "name": "美化优化",
        "model": "minimax-2.5",
        "duration": "20 分钟",
        "tasks": [
          "视觉优化 (颜色、排版)",
          "文案润色",
          "动画建议",
          "最终检查"
        ]
      },
      {
        "name": "输出交付",
        "model": "qwen3.5",
        "duration": "10 分钟",
        "tasks": [
          "导出 PPTX + PDF",
          "质量检查",
          "生成交付包",
          "提供使用说明"
        ]
      }
    ]
  },

  "models": {
    "primary": "qwen3.5",
    "secondary": ["kimi-2.5", "minimax-2.5"],
    "routing": {
      "content_search": "kimi-2.5",
      "framework_design": "qwen3.5",
      "content_creation": "qwen3.5",
      "ppt_creation": "qwen3.5",
      "beautification": "minimax-2.5",
      "delivery": "qwen3.5"
    }
  },

  "skills": {
    "required": [
      "pptx",
      "scientific-slides",
      "academic-writing",
      "citation-management",
      "web_search",
      "scientific-visualization"
    ],
    "optional": [
      "matplotlib",
      "paper-parse",
      "deep-research"
    ]
  },

  "templates": {
    "default": {
      "duration": "15 分钟",
      "slides": "15-20 页",
      "structure": [
        "标题页 (1)",
        "目录 (1)",
        "背景介绍 (2-3)",
        "研究方法 (2-3)",
        "研究结果 (4-6)",
        "讨论 (2)",
        "结论 (1)",
        "致谢/Q&A (1)"
      ]
    },
    "quick": {
      "duration": "5 分钟",
      "slides": "5-8 页",
      "structure": [
        "标题页 (1)",
        "问题 (1)",
        "方法 (1)",
        "结果 (2-3)",
        "结论 (1)",
        "Q&A (1)"
      ]
    },
    "standard": {
      "duration": "30 分钟",
      "slides": "20-30 页",
      "structure": [
        "标题页 (1)",
        "目录 (1)",
        "背景 (3-4)",
        "方法 (3-4)",
        "结果 1 (3-4)",
        "结果 2 (3-4)",
        "结果 3 (3-4)",
        "讨论 (3)",
        "结论 (2)",
        "致谢/Q&A (1)"
      ]
    },
    "defense": {
      "duration": "45-60 分钟",
      "slides": "30-50 页",
      "structure": [
        "标题页 (1)",
        "目录 (1)",
        "研究背景 (4-6)",
        "文献综述 (4-6)",
        "研究方法 (4-6)",
        "研究 1 (6-8)",
        "研究 2 (6-8)",
        "研究 3 (6-8)",
        "总讨论 (4)",
        "结论 (2)",
        "创新点 (2)",
        "致谢/Q&A (1)"
      ]
    }
  },

  "design": {
    "color_schemes": {
      "academic_blue": {
        "primary": "#1E3A8A",
        "secondary": "#3B82F6",
        "accent": "#EF4444",
        "background": "#FFFFFF",
        "text": "#374151"
      },
      "academic_green": {
        "primary": "#065F46",
        "secondary": "#10B981",
        "accent": "#F59E0B",
        "background": "#FFFFFF",
        "text": "#374151"
      },
      "minimalist": {
        "primary": "#000000",
        "secondary": "#6B7280",
        "accent": "#EF4444",
        "background": "#FFFFFF",
        "text": "#111827"
      }
    },
    "fonts": {
      "title": {"size": "32-40pt", "family": "思源黑体 Bold"},
      "body": {"size": "24-28pt", "family": "思源黑体 Regular"},
      "note": {"size": "18-20pt", "family": "思源黑体 Light"},
      "english": {"family": "Arial/Helvetica"}
    }
  },

  "output": {
    "formats": ["pptx", "pdf", "pdf_notes"],
    "delivery_package": [
      "presentation.pptx",
      "presentation.pdf",
      "presentation_notes.pdf",
      "figures/",
      "references.bib",
      "README.md"
    ],
    "quality_check": {
      "content": ["核心信息清晰", "逻辑连贯", "数据准确", "引用规范", "无错别字"],
      "visual": ["配色统一", "排版整齐", "图片清晰", "图表规范", "留白适当"],
      "technical": ["文件正常打开", "字体正常显示", "图片正常加载", "动画播放正常", "页码连续"],
      "timing": ["排练计时", "符合规定时长", "预留 Q&A 时间"]
    }
  },

  "examples": [
    {
      "input": "帮我做一个 PPT，主题是：AI 在心理学研究中的应用",
      "params": {
        "duration": "15 分钟",
        "audience": "学术会议",
        "key_findings": ["AI 提升研究效率", "LLM 作为研究工具", "人机协作新模式"]
      }
    },
    {
      "input": "帮我做一个 PPT，主题是：主观幸福感与社会支持的关系研究",
      "params": {
        "duration": "15 分钟",
        "audience": "心理学学术会议",
        "data": "N=48,845，中国全国样本",
        "key_finding": "社会支持显著预测主观幸福感"
      }
    },
    {
      "input": "帮我做一个 PPT，主题是：博士论文答辩",
      "params": {
        "duration": "30 分钟",
        "audience": "答辩委员会",
        "focus": ["研究贡献", "创新点", "发表成果"]
      }
    }
  ],

  "config": {
    "workspace": "ppt_projects",
    "auto_save": true,
    "version_control": true,
    "backup": true
  }
}
