{
  "name": "ppt-workflow",
  "version": "1.0.0",
  "description": "基于标准化工作流的 PPT 制作技能。从内容搜索到美化优化的全流程自动化，只需提供主题，自动完成文献搜索、框架设计、内容填充、幻灯片制作、美化优化和输出交付。",
  "author": "academic-assistant",
  "license": "MIT",
  "keywords": [
    "PPT",
    "presentation",
    "幻灯片",
    "学术报告",
    "工作流",
    "自动化"
  ],
  "category": "productivity",
  "min_version": "1.0.0",
  "models": [
    "qwen3.5",
    "kimi-2.5",
    "minimax-2.5"
  ],
  "dependencies": [
    "pptx",
    "scientific-slides",
    "academic-writing",
    "citation-management",
    "web_search",
    "scientific-visualization"
  ],
  "trigger": {
    "keywords": [
      "做个 PPT",
      "制作 PPT",
      "做幻灯片",
      "PPT 主题",
      "presentation",
      "学术报告 PPT",
      "会议 PPT",
      "答辩 PPT"
    ]
  },
  "features": [
    "7 阶段工作流自动化",
    "智能模型路由",
    "学术规范支持",
    "多种模板选择",
    "质量检查清单",
    "完整交付包"
  ],
  "use_cases": [
    "学术报告 PPT 制作",
    "论文答辩幻灯片",
    "会议演示文稿",
    "研讨会报告",
    "课程讲义制作"
  ],
  "workflow": {
    "stages": 7,
    "total_time": "2-4 小时",
    "models": {
      "content_search": "kimi-2.5",
      "framework_design": "qwen3.5",
      "content_creation": "qwen3.5",
      "ppt_creation": "qwen3.5",
      "beautification": "minimax-2.5",
      "delivery": "qwen3.5"
    }
  },
  "templates": [
    {
      "name": "quick",
      "duration": "5 分钟",
      "slides": "5-8 页"
    },
    {
      "name": "standard",
      "duration": "15 分钟",
      "slides": "15-20 页"
    },
    {
      "name": "academic",
      "duration": "30 分钟",
      "slides": "20-30 页"
    },
    {
      "name": "defense",
      "duration": "45-60 分钟",
      "slides": "30-50 页"
    }
  ],
  "design": {
    "color_schemes": [
      "academic_blue",
      "academic_green",
      "minimalist",
      "china_red"
    ],
    "fonts": [
      "思源黑体",
      "Arial",
      "Helvetica"
    ]
  },
  "output": {
    "formats": [
      "pptx",
      "pdf",
      "pdf_notes"
    ],
    "delivery_package": [
      "presentation.pptx",
      "presentation.pdf",
      "presentation_notes.pdf",
      "figures/",
      "references.bib",
      "README.md"
    ]
  },
  "examples": [
    {
      "title": "学术报告",
      "input": "帮我做一个 PPT，主题是：AI 在心理学研究中的应用",
      "params": {
        "duration": "15 分钟",
        "audience": "学术会议"
      }
    },
    {
      "title": "论文答辩",
      "input": "帮我做一个 PPT，主题是：博士论文答辩",
      "params": {
        "duration": "30 分钟",
        "audience": "答辩委员会"
      }
    },
    {
      "title": "产教融合报告",
      "input": "帮我做一个 PPT，主题是：产教融汇背景下，职业本科双创生态构建",
      "params": {
        "duration": "45 分钟",
        "audience": "高校管理者"
      }
    }
  ],
  "quality_check": {
    "content": [
      "核心信息清晰",
      "逻辑连贯",
      "数据准确",
      "引用规范"
    ],
    "visual": [
      "配色统一",
      "排版整齐",
      "图片清晰",
      "图表规范"
    ],
    "technical": [
      "文件正常打开",
      "字体正常显示",
      "图片正常加载"
    ]
  },
  "best_practices": [
    "提前规划，至少提前 1 天",
    "明确需求：时长、受众、核心信息",
    "提供相关资料：文献、数据、图片",
    "及时反馈，24 小时内给出修改意见",
    "多次排练，至少 3 次"
  ],
  "support": {
    "documentation": "https://clawhub.com/skills/ppt-workflow/docs",
    "issues": "https://clawhub.com/skills/ppt-workflow/issues",
    "discussion": "https://clawhub.com/skills/ppt-workflow/discussions"
  },
  "changelog": {
    "1.0.0": {
      "date": "2026-03-14",
      "changes": [
        "初始版本发布",
        "7 阶段工作流",
        "智能模型路由",
        "4 种模板支持",
        "质量检查清单"
      ]
    }
  }
}
