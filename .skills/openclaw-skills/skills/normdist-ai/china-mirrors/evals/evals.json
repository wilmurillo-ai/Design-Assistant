{
  "skill_name": "china-mirrors",
  "evals": [
    {
      "id": 1,
      "prompt": "我的 pip 安装依赖很慢，帮我配置国内镜像加速",
      "expected_output": "应该执行 pip 镜像配置脚本或提供配置命令，使用阿里云或清华大学等国内镜像源",
      "files": [],
      "assertions": [
        {
          "type": "contains",
          "value": "mirrors.aliyun.com"
        },
        {
          "type": "contains",
          "value": "pypi"
        }
      ]
    },
    {
      "id": 2,
      "prompt": "npm install 太慢了，怎么解决？",
      "expected_output": "应该配置 npm 使用国内镜像源，如 npmmirror.com",
      "files": [],
      "assertions": [
        {
          "type": "contains",
          "value": "registry.npmmirror.com"
        },
        {
          "type": "contains",
          "value": "npm config"
        }
      ]
    },
    {
      "id": 3,
      "prompt": "帮我一键配置所有包管理器的国内镜像",
      "expected_output": "应该运行 config_all.py 脚本或提供综合配置方案，支持多种包管理器",
      "files": [],
      "assertions": [
        {
          "type": "contains",
          "value": "config_all.py"
        },
        {
          "type": "contains",
          "value": "--all"
        }
      ]
    },
    {
      "id": 4,
      "prompt": "我想把 cargo 的源换成国内的",
      "expected_output": "应该配置 Rust cargo 使用清华或中科大镜像",
      "files": [],
      "assertions": [
        {
          "type": "contains",
          "value": "crates.io-index"
        },
        {
          "type": "contains",
          "value": ".cargo/config.toml"
        }
      ]
    },
    {
      "id": 5,
      "prompt": "go mod download 超时了，怎么办？",
      "expected_output": "应该配置 GOPROXY 环境变量为国内代理",
      "files": [],
      "assertions": [
        {
          "type": "contains",
          "value": "GOPROXY"
        },
        {
          "type": "contains",
          "value": "goproxy.cn"
        }
      ]
    }
  ]
}
