{
  "name": "youos",
  "version": "0.1.18",
  "displayName": "YouOS \u2014 Personal Email Copilot",
  "description": "Learns your email writing style from Gmail and drafts replies that sound like you. Local-first on Apple Silicon with manual Python install; review source before running pip install -e .",
  "author": "DrBaher",
  "homepage": "https://github.com/DrBaher/youos",
  "repository": "https://github.com/DrBaher/youos",
  "category": "productivity",
  "tags": [
    "email",
    "drafting",
    "personal-ai",
    "local-model",
    "self-improving",
    "privacy",
    "apple-silicon"
  ],
  "requires": {
    "bins": [
      "gog",
      "python3"
    ],
    "platform": "darwin",
    "arch": "arm64",
    "minRam": "8GB"
  },
  "runtime": {
    "packageType": "application",
    "execution": "local-python",
    "install": {
      "kind": "manual",
      "steps": [
        "python3 -m venv .venv",
        "source .venv/bin/activate",
        "pip install -e ."
      ]
    }
  },
  "credentials": {
    "required": [
      "gog authentication for Gmail/Docs ingestion"
    ],
    "optional": [
      "Claude/API credentials only if external fallback is enabled"
    ]
  },
  "emoji": "\u2709\ufe0f",
  "license": "MIT"
}
