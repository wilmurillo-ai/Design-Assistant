[
  {
    "id": "BASH-001",
    "name": "Bash 远程代码执行",
    "category": "remote_load",
    "severity": "CRITICAL",
    "patterns": [
      "curl.*\\|.*bash",
      "wget.*\\|.*bash",
      "curl.*\\|.*sh",
      "wget.*\\|.*sh",
      "bash.*<\\(.*curl",
      "sh.*<\\(.*wget"
    ],
    "description": "Bash 远程下载并执行",
    "mitre_atlas": ["T0009"],
    "risk_score": 95
  },
  {
    "id": "BASH-002",
    "name": "Bash 命令注入",
    "category": "command_injection",
    "severity": "CRITICAL",
    "patterns": [
      "eval\\s+\\$",
      "exec\\s+\\$",
      "\\$\\(.*\\).*\\|",
      "`.*`.*\\|",
      "xargs.*-I"
    ],
    "description": "Bash 命令注入",
    "mitre_atlas": ["T0027"],
    "risk_score": 90
  },
  {
    "id": "BASH-003",
    "name": "Bash 数据外传",
    "category": "data_exfiltration",
    "severity": "HIGH",
    "patterns": [
