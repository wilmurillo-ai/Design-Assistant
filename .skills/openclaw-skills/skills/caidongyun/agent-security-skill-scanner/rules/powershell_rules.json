    "description": "PowerShell 日志清除",
    "mitre_atlas": ["T0008"],
    "risk_score": 80
  },
  {
    "id": "PS-015",
    "name": "PowerShell 反分析",
    "category": "defense_evasion",
    "severity": "MEDIUM",
    "patterns": [
      "Get-Process.*vmware",
      "Get-Service.*vbox",
      "IsDebuggerPresent",
      "Debugger\\.IsAttached",
      "VirtualBox",
      "VMware"
    ],
    "description": "PowerShell 反虚拟机/调试器检测",
