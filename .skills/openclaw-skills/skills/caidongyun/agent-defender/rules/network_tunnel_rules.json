[
  {
    "id": "NT01",
    "name": "frp 检测",
    "patterns": [
      "\\bfrpc\\s+(start|reload)",
      "\\bfrps\\s+-c",
      "\\bfrpc\\.ini\\b",
      "\\bfrps\\.ini\\b",
      "server_addr\\s*="
    ],
    "risk": "HIGH",
    "description": "检测 frp 内网穿透工具",
    "action": "BLOCK",
    "enterprise_action": "BLOCK",
    "personal_action": "CONFIRM",
    "optimized": true
  },
  {
    "id": "NT02",
    "name": "ngrok 检测",
    "patterns": [
      "\\bngrok\\s+(http|tcp|tls)",
