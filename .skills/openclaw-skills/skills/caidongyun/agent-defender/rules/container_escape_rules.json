    "risk": "HIGH",
    "description": "检测通过 cgroup 逃逸",
    "action": "BLOCK",
    "optimized": true
  },
  {
    "id": "CE06",
    "name": "能力拆分检测",
    "patterns": [
      "--cap-add=SYS_ADMIN",
      "--cap-add=SYS_PTRACE",
      "--cap-add=NET_ADMIN"
