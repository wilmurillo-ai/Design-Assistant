# ============================================
# 小红书自动化技能 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填写你的配置

# --------------------------------------------
# 代理设置（可选）
# --------------------------------------------
# 格式: http://host:port 或 socks5://host:port
# 示例: PROXY=http://127.0.0.1:7890
PROXY=

# --------------------------------------------
# 浏览器模式
# --------------------------------------------
# 无头模式: true（后台运行，二维码保存到 tmp/ 目录）
# 有头模式: false（显示浏览器窗口，二维码显示在页面）
# 注意: 如果系统不支持图形界面（如 Linux 服务器），将强制使用 headless 模式
# 默认: 有显示器时显示窗口（false）
HEADLESS=

# --------------------------------------------
# 浏览器路径（可选）
# --------------------------------------------
# 默认使用 Playwright 内置的 Chromium
# 如需使用系统浏览器，填写浏览器可执行文件路径
# Windows 示例: C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS 示例: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
BROWSER_PATH=

# --------------------------------------------
# 浏览器类型（可选）
# --------------------------------------------
# 可选值: chrome, msedge, chromium
# 使用系统安装的 Chrome: chrome
# 使用系统安装的 Edge: msedge
# 使用 Playwright 内置 Chromium: chromium（默认）
BROWSER_CHANNEL=

# --------------------------------------------
# 调试模式
# --------------------------------------------
# 启用详细日志输出
DEBUG=false