{
  "_comment": "spec-engine v2.0 默认验证规则配置文件",
  "_说明": "可按需修改各检查项的 deduct（扣分）和条件",

  "required_sections": [
    {
      "name": "项目名称",
      "patterns": ["^#\\s+项目名称[：:]", "^#\\s+.+"],
      "deduct": 25,
      "_说明": "必须有项目名称（一级标题）"
    },
    {
      "name": "目标",
      "patterns": ["##\\s*\\d*[.、]?\\s*目标", "##\\s*目标"],
      "deduct": 20,
      "_说明": "必须有目标 section"
    },
    {
      "name": "验收标准",
      "patterns": ["##\\s*\\d*[.、]?\\s*验收标准", "##\\s*验收标准"],
      "deduct": 20,
      "_说明": "必须有验收标准"
    },
    {
      "name": "时间规划",
      "patterns": ["##\\s*\\d*[.、]?\\s*时间规划", "##\\s*时间规划", "##\\s*排期", "##\\s*计划"],
      "deduct": 15,
      "_说明": "必须有时间规划"
    }
  ],

  "recommended_sections": [
    {
      "name": "项目背景",
      "patterns": ["##\\s*\\d*[.、]?\\s*项目背景", "##\\s*背景"],
      "deduct": 5,
      "_说明": "推荐有项目背景"
    },
    {
      "name": "技术方案",
      "patterns": ["##\\s*\\d*[.、]?\\s*技术方案", "##\\s*技术栈"],
      "deduct": 5,
      "_说明": "推荐有技术方案"
    },
    {
      "name": "风险评估",
      "patterns": ["##\\s*\\d*[.、]?\\s*风险评估", "##\\s*风险"],
      "deduct": 5,
      "_说明": "推荐有风险评估"
    },
    {
      "name": "依赖项",
      "patterns": ["##\\s*\\d*[.、]?\\s*依赖项", "##\\s*依赖"],
      "deduct": 5,
      "_说明": "推荐有依赖项"
    }
  ],

  "min_content_length": {
    "目标": 20,
    "验收标准": 20,
    "时间规划": 15,
    "技术方案": 10,
    "_说明": "每个 section 去除空白后的最少字符数，防止写占位符"
  },

  "required_keywords": [
    {
      "keyword": "验收",
      "section_hint": "验收标准",
      "deduct": 5,
      "_说明": "验收标准 section 必须包含验收二字"
    },
    {
      "keyword": "测试",
      "section_hint": "",
      "deduct": 3,
      "_说明": "全文至少出现一次测试"
    }
  ],

  "custom_checks": [
    {
      "name": "时间规划含日期",
      "type": "date_format",
      "target": "时间规划",
      "value": "",
      "deduct": 5,
      "_说明": "时间规划必须包含具体日期（MM/DD 或 MM-DD 格式）"
    }
  ]
}
