    {
      "id": "tts_report",
      "service_id": "svc_cf_tts_report",
      "summary": "Synthesize a report-style speech clip from text.",
      "input_schema": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "maxLength": 4096
          },
          "speaker": {
            "type": "string",
            "maxLength": 64
          }
        }
      },
      "example_input": {
        "text": "hello from skill hub",
        "speaker": "alloy"
      }
    },
    {
      "id": "embeddings",
      "service_id": "svc_cf_embeddings",
      "summary": "Generate embeddings from text batches.",
      "input_schema": {
        "type": "object",
        "required": ["texts"],
        "properties": {
          "texts": {
            "type": "array",
            "minItems": 1,
            "maxItems": 128,
            "items": {
              "type": "string",
              "maxLength": 8192
            }
          },
          "truncate": {
            "type": "boolean"
          }
        }
      },
      "example_input": {
        "texts": ["hello world", "skill hub gateway"],
        "truncate": true
      }
    },
    {
      "id": "reranker",
      "service_id": "svc_cf_reranker",
      "summary": "Rerank document candidates for a query.",
      "input_schema": {
        "type": "object",
        "required": ["query", "documents"],
        "properties": {
          "query": {
            "type": "string",
            "maxLength": 4096
          },
          "documents": {
            "type": "array",
            "minItems": 1,
            "maxItems": 128,
            "items": {
              "type": "string",
              "maxLength": 8192
            }
          },
          "top_k": {
            "type": "integer",
            "minimum": 1,
            "maximum": 128
          }
        }
      },
      "example_input": {
        "query": "cloud cost optimization",
        "documents": ["doc1", "doc2"],
        "top_k": 2
      }
    },
    {
      "id": "asr",
      "service_id": "svc_cf_asr",
      "summary": "Transcribe uploaded audio.",
      "input_schema": {
        "type": "object",
        "required": ["audio_url"],
        "properties": {
          "audio_url": {
            "type": "string",
            "format": "uri",
            "description": "Upload an audio file/attachment through the host product flow. Do not require manual URL or raw JSON input in user-facing forms."
          },
          "language": {
            "type": "string",
            "minLength": 2,
            "maxLength": 8
          },
          "diarize": {
            "type": "boolean"
          }
        }
      },
      "example_input": {
        "audio_url": "https://raw.githubusercontent.com/anars/blank-audio/master/1-second-of-silence.wav",
        "language": "en",
        "diarize": false
      }
    },
