{
  "name": "base-config",
  "description": "Base exclusion configuration for all project types",
  "version": "1.0.0",
  
  "exclude": {
    "directories": [
      "node_modules",
      ".git",
      ".github",
      ".svn",
      ".hg",
      "__pycache__",
      ".venv",
      "venv",
      "env",
      ".env",
      "dist",
      "build",
      "out",
      "output",
      "target",
      "coverage",
      ".nyc_output",
      "logs",
      "log",
      "tmp",
      "temp",
      ".tmp",
      "cache",
      ".cache",
      "backup",
      ".backup",
      "bak",
      "vendor",
      "bower_components",
      "jspm_packages",
      ".idea",
      ".vscode",
      ".vs",
      ".settings",
      ".project",
      ".classpath",
      ".DS_Store",
      "Thumbs.db",
      "desktop.ini"
    ],
    "files": [
      "package-lock.json",
      "yarn.lock",
      "pnpm-lock.yaml",
      "poetry.lock",
      "Pipfile.lock",
      "composer.lock",
      "Gemfile.lock",
      "*.log",
      "*.tmp",
      "*.cache",
      "*.pid",
      "*.seed",
      "*.pid.lock",
      ".env.local",
      ".env.*.local",
      ".env.development",
      ".env.test",
      ".env.production",
      ".env.example",
      ".secret",
      ".secrets",
      ".npmrc",
      ".yarnrc",
      ".pypirc",
      ".gitignore",
      ".gitattributes",
      ".editorconfig",
      ".eslintcache",
      ".prettiercache",
      "*.min.js",
      "*.min.css",
      "*.min.map",
      "*.bundle.js",
      "*.chunk.js",
      "*.hot-update.js",
      "*.hot-update.json"
    ],
    "patterns": [
      "*~",
      "*.bak",
      "*.backup",
      "*.orig",
      "*.rej",
      "*.swp",
      "*.swo",
      "*.swn",
      "*._*",
      ".*~"
    ]
  },
  
  "file_filters": {
    "max_file_size": 1048576,
    "min_file_size": 10,
    "include_extensions": [
      ".md",
      ".mdx",
      ".txt",
      ".rst",
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".vue",
      ".py",
      ".java",
      ".go",
      ".rs",
      ".cpp",
      ".c",
      ".h",
      ".hpp",
      ".cs",
      ".php",
      ".rb",
      ".swift",
      ".kt",
      ".scala",
      ".json",
      ".yaml",
      ".yml",
      ".toml",
      ".xml",
      ".ini",
      ".conf",
      ".config",
      ".sql",
      ".graphql",
      ".gql",
      ".scss",
      ".sass",
      ".less",
      ".css",
      ".html",
      ".htm"
    ],
    "exclude_extensions": [
      ".png",
      ".jpg",
      ".jpeg",
      ".gif",
      ".bmp",
      ".svg",
      ".ico",
      ".webp",
      ".mp4",
      ".avi",
      ".mov",
      ".mkv",
      ".flv",
      ".wmv",
      ".mp3",
      ".wav",
      ".ogg",
      ".flac",
      ".aac",
      ".zip",
      ".tar",
      ".gz",
      ".bz2",
      ".7z",
      ".rar",
      ".pdf",
      ".doc",
      ".docx",
      ".xls",
      ".xlsx",
      ".ppt",
      ".pptx",
      ".exe",
      ".dll",
      ".so",
      ".dylib",
      ".bin",
      ".dat",
      ".db",
      ".sqlite",
      ".sqlite3"
    ]
  },
  
  "analysis_options": {
    "include_tests": false,
    "include_docs": true,
    "include_config": true,
    "max_files": 1000,
    "max_depth": 10
  }
}
