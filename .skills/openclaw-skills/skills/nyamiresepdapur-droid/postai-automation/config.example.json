{
  "postai": {
    "api_key": "YOUR_POST_AI_API_KEY",
    "account_id": "YOUR_ACCOUNT_ID",
    "endpoint": "https://api.postai.com/v1",
    "subscription": "lifetime"
  },
  "tiktok": {
    "account": "@your_tiktok_account",
    "cookie_file": "/path/to/tiktok_cookies.json",
    "session_id": "your_session_id_here",
    "enabled": true
  },
  "instagram": {
    "account": "@your_instagram_account",
    "cookie_file": "/path/to/instagram_cookies.json",
    "enabled": false
  },
  "threads": {
    "account": "@your_threads_account",
    "cookie_file": "/path/to/threads_cookies.json",
    "enabled": false
  },
  "defaults": {
    "language": "id",
    "videos_per_product": 10,
    "posting_schedule": ["08:00", "14:00", 20"],
    "caption_hashtags": ["#fyp", "#viral", "#affiliatemarketing", "#promotion"],
    "max_file_size_mb": 50
  },
  "analytics": {
    "tracking_enabled": true,
    "metrics_to_track": ["views", "likes", "comments", "shares", "saves", "sales"]
  }
}