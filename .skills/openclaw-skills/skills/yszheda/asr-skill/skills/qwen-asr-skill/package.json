{
  "name": "qwen-asr-skill",
  "version": "1.3.0",
  "description": "Qwen方言语音识别Skill - 极简版（仅0.6B模型，无强制对齐）",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "node test.js"
  },
  "keywords": [
    "openclaw",
    "skill",
    "asr",
    "speech-recognition",
    "qwen",
    "dialect",
    "minimal"
  ],
  "author": "OpenClaw Team",
  "license": "Apache-2.0",
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.0",
    "python-shell": "^5.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "openclaw": {
    "skillId": "qwen-asr-skill",
    "name": "Qwen ASR Skill (Minimal)",
    "description": "语音转文字服务，支持22种中文方言和多语言识别（极简版，仅0.6B模型）",
    "version": "1.3.0",
    "author": "OpenClaw Team",
    "icon": "🎤",
    "type": "audio",
    "capabilities": [
      "speech-to-text",
      "dialect-recognition",
      "language-detection"
    ],
    "endpoints": {
      "transcribe": {
        "path": "/transcribe",
        "method": "POST",
        "description": "音频转文字接口"
      }
    },
    "dependencies": {
      "python": ">=3.10",
      "qwen-asr": ">=0.0.6",
      "torch": ">=2.0.0"
    }
  }
}