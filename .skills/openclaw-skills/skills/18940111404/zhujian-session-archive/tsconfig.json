{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "paths": {
      "openclaw": ["/usr/lib/node_modules/openclaw"],
      "openclaw/*": ["/usr/lib/node_modules/openclaw/*"]
    }
  },
  "include": ["src/**/*"]
}
