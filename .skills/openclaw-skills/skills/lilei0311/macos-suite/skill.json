{
  "name": "macos-suite",
  "version": "0.2.3",
  "description": "macOS 系统应用自动化：打开/读取/创建（Mail/Maps/Calendar/Reminders/Notes/Freeform/Photos/Weather/Stocks/Clock）。支持未读/日程/笔记/行情读取与 Freeform 绘图排版（偏安全：修改类需 confirm=YES）。",
  "author": "OpenClaw Workspace",
  "license": "MIT",
  "keywords": [
    "macos",
    "mail",
    "maps",
    "calendar",
    "reminders",
    "notes",
    "freeform",
    "photos",
    "weather",
    "stocks",
    "本地应用",
    "自动化"
  ],
  "trigger": {
    "patterns": [
      "打开邮件",
      "未读邮件",
      "未读数量",
      "发邮件",
      "写邮件",
      "地图",
      "导航",
      "路线规划",
      "日历",
      "读取日程",
      "今日日程",
      "添加日程",
      "提醒事项",
      "查看提醒",
      "待办",
      "添加提醒",
      "备忘录",
      "搜索备忘录",
      "查看备忘录",
      "写笔记",
      "无边记",
      "Freeform",
      "无边记绘图",
      "无边记排版",
      "画板",
      "新建画板",
      "绘图",
      "画图",
      "插入文本框",
      "插入便笺",
      "画流程图",
      "照片",
      "相册",
      "最近照片",
      "天气",
      "今天天气",
      "股市",
      "股票",
      "报价",
      "时钟",
      "计时器"
    ]
  },
  "tools": ["exec"],
  "entry": "scripts/main.py",
  "dependencies": {
    "python": ">=3.9"
  },
  "platforms": ["darwin"]
}
