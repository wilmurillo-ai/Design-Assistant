  "question_patterns": {
    "_description": "자연어 질문 패턴을 키워드 그룹으로 매핑",
    "patterns": [
      {
        "regex": "(?i)(eVTOL|전기.*이착륙).*(인증|certification|감항|airworthiness)",
        "keyword_group": "evtol_certification"
      },
      {
        "regex": "(?i)(UAM|도심항공|AAM|선진항공).*(정책|규정|regulation|policy|법)",
        "keyword_group": "uam_policy"
      },
      {
        "regex": "(?i)(드론|UAS|무인).*(규정|법|regulation|rule|운용)",
        "keyword_group": "drone_uas"
      },
      {
        "regex": "(?i)(소음|noise).*(규정|기준|standard|regulation)",
        "keyword_group": "noise_regulation"
      },
      {
        "regex": "(?i)(원격.*식별|remote.*id)",
        "keyword_group": "remote_id"
      },
      {
        "regex": "(?i)(소프트웨어|DO-178|DO-254|항전).*(인증|certification|표준|standard)",
        "keyword_group": "software_avionics"
      },
      {
        "regex": "(?i)(안전관리|SMS|safety management)",
        "keyword_group": "safety_management"
      },
      {
        "regex": "(?i)(관제|airspace|공역|ATM|air traffic)",
        "keyword_group": "air_traffic_management"
      },
      {
        "regex": "(?i)(버티포트|vertiport|비행장|공항|aerodrome)",
        "keyword_group": "aerodrome"
      },
      {
        "regex": "(?i)(개발보증|ARP.*4754|시스템.*개발|development assurance)",
        "keyword_group": "development_assurance"
      },
      {
        "regex": "(?i)(시카고.*협약|Chicago.*Convention|국제항공법)",
        "keyword_group": "international_law"
      },
      {
        "regex": "(?i)(조종사|pilot).*(면허|license|자격)",
        "keyword_group": "pilot_licensing"
      }
    ]
  },

