    },
    "iata-stats": {
      "name": "IATA Industry Statistics",
      "base_url": "https://www.iata.org/en/iata-repository/publications/economic-reports/",
      "search_pattern": "site:iata.org statistics economic report {query}",
      "selectors": {
        "title": "h1",
        "items": ".content-list-item, .publication-item"
      },
      "tags": ["IATA", "statistics"],
      "category": "statistics"
    }
  }
}
