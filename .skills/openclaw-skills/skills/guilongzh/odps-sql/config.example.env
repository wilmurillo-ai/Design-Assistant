# ODPS Skill 配置文件
# 使用步骤：
#   1. 将此文件复制为 .env：  cp config.example.env .env
#   2. 填写下方的实际配置值
#   3. .env 文件仅供本地使用，请勿提交到代码仓库

# 阿里云 Access Key（在 RAM 控制台创建）
ALIYUN_ACCESS_ID=your_access_key_id_here
ALIYUN_ACCESS_SECRET=your_access_key_secret_here

# ODPS 项目名称
ALIYUN_PROJECT_NAME=your_project_name_here

# ODPS Endpoint（按所在区域修改，默认北京）
# 北京: http://service.cn-beijing.maxcompute.aliyun.com/api
# 上海: http://service.cn-shanghai.maxcompute.aliyun.com/api
# 杭州: http://service.cn-hangzhou.maxcompute.aliyun.com/api
# 深圳: http://service.cn-shenzhen.maxcompute.aliyun.com/api
# 香港: http://service.cn-hongkong.maxcompute.aliyun.com/api
# 新加坡: http://service.ap-southeast-1.maxcompute.aliyun.com/api
ALIYUN_END_POINT=http://service.cn-beijing.maxcompute.aliyun.com/api
