{
  "name": "@forceconstant/nano-gpt",
  "version": "0.1.3",
  "description": "NanoGPT provider plugin for OpenClaw — dynamic model catalog, auth, and usage tracking",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist/"
  ],
  "openclaw": {
    "plugin": "./openclaw.plugin.json",
    "extensions": [
      "./dist/index.js"
    ],
    "providers": [
      "nano-gpt"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "keywords": [
    "openclaw",
    "provider",
    "nano-gpt",
    "ai"
  ],
  "license": "MIT",
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vitest": "^3.1.4"
  },
  "dependencies": {
    "clawhub": "^0.9.0"
  }
}
