{
  "machine": {
    "name": "My Machine",
    "os": "macos",
    "description": "What this machine is for"
  },
  "proxy_chain": {
    "description": "Optional: special network proxy setup",
    "hops": [
      { "name": "http-proxy", "type": "http", "listen": ":8118", "target": "socks5://127.0.0.1:1080" },
      { "name": "ssh-tunnel", "type": "socks5", "listen": ":1080", "target": "VPS → external API" }
    ]
  },
  "tunnels": {
    "provider": "frp",
    "config_path": "~/.frp/frpc.toml",
    "vps": "1.2.3.4:7000",
    "domain": "*.tunnel.example.com",
    "entries": [
      { "subdomain": "app", "local_port": 3000, "service": "My App" },
      { "subdomain": "api", "local_port": 8000, "service": "My API" }
    ]
  },
  "services": [
    {
      "name": "My Gateway",
      "tier": 1,
      "type": "launchagent",
      "label": "com.example.gateway",
      "program": "/usr/local/bin/gateway",
      "args": ["--port", "8080"],
      "keep_alive": true,
      "log_prefix": "gateway",
      "description": "Main communication gateway"
    },
    {
      "name": "My Tunnel Client",
      "tier": 1,
      "type": "launchagent",
      "label": "com.example.frpc",
      "program": "/usr/local/bin/frpc",
      "args": ["-c", "/path/to/frpc.toml"],
      "keep_alive": true,
      "log_prefix": "frpc",
      "description": "All tunnels depend on this"
    },
    {
      "name": "My Dev Server",
      "tier": 2,
      "type": "tmux-bootstrap",
      "session": "dev-server",
      "socket": "openclaw",
      "port": 3000,
      "workdir": "/path/to/project",
      "command": "npm run dev",
      "description": "Frontend dev server"
    },
    {
      "name": "My Backend",
      "tier": 2,
      "type": "tmux-bootstrap",
      "session": "backend",
      "socket": "openclaw",
      "port": 8000,
      "workdir": "/path/to/backend",
      "command": ".venv/bin/uvicorn app.main:app --reload --port 8000",
      "description": "Python backend API"
    },
    {
      "name": "My Interactive Agent",
      "tier": 3,
      "type": "wrapper-daemon",
      "session": "My-Agent-Channel",
      "socket": "default",
      "workdir": "/path/to/agent-workspace",
      "command": "my-agent --channel telegram --bypass-permissions",
      "wrapper_label": "com.example.my-agent",
      "wrapper_script": "/path/to/scripts/restore-my-agent.sh",
      "check_interval": 30,
      "max_failures": 3,
      "cooldown_seconds": 3600,
      "startup_wait": 25,
      "description": "Persistent interactive agent on Telegram"
    }
  ]
}
