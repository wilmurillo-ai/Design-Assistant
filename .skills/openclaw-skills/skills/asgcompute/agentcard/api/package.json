{
  "name": "@asgcard/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preflight": "node scripts/preflight.js",
    "e2e:mainnet": "node scripts/e2e-mainnet.js",
    "e2e:mainnet:live": "node scripts/e2e-mainnet.js --live"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.5.0",
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "pg": "^8.19.0",
    "tweetnacl": "^1.0.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}