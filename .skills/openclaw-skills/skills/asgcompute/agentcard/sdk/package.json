{
  "name": "@asgcard/sdk",
  "version": "1.0.7",
  "description": "SDK for ASG Card — virtual MasterCard cards for AI agents, paid via x402 on Stellar",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
