{
  "mode": "full",
  "campaignMeta": {
    "id": "spring-benefit-relay-2026",
    "title": "Spring Benefit Relay",
    "subtitle": "Complete daily tasks and unlock checkpoint rewards",
    "dateRange": {
      "start": "2026-01-20",
      "end": "2026-02-05",
      "display": "01/20 - 02/05"
    }
  },
  "hero": {
    "headline": "Spring Benefit Relay",
    "subheadline": "Daily tasks unlock checkpoint rewards and final draw chances",
    "primaryCta": {
      "text": "Start Today",
      "action": "scrollToActivity"
    }
  },
  "activityFactory": {
    "autoCreateWhenOpenBrief": true,
    "selectionStrategy": "novelty-first-buildable",
    "activityFamily": "checkpoint-relay",
    "supportingMechanics": ["daily-checkin", "final-draw"],
    "whyChosen": "Turns task completion into visible route progress while keeping the page compact and reward-led."
  },
  "activityConfig": {
    "durationDays": 17,
    "checkpointCount": 4,
    "dailyTaskLimit": 3,
    "rewardCadence": "checkpoint-plus-final-draw",
    "visualPreset": "spring-premium-poster",
    "animationPreset": "route-chest-pop"
  },
  "tasks": [
    {
      "id": "daily-checkin",
      "title": "Daily check-in",
      "reward": "1 relay point",
      "state": "todo"
    },
    {
      "id": "share-guide",
      "title": "Share the spring guide",
      "reward": "1 speed-up token",
      "state": "done"
    }
  ],
  "rewards": [
    {
      "id": "coupon-10",
      "title": "$10 Coupon",
      "type": "coupon"
    },
    {
      "id": "vip-7d",
      "title": "VIP 7 Days",
      "type": "membership"
    }
  ],
  "lottery": {
    "enabled": true,
    "type": "final-draw",
    "cta": {
      "text": "Draw Now",
      "action": "startDraw"
    }
  },
  "modules": [
    { "id": "hero", "type": "hero-banner", "dataSource": "hero" },
    { "id": "activity-stage", "type": "checkpoint-relay-stage", "dataSource": "activityConfig" },
    { "id": "meta", "type": "campaign-meta", "dataSource": "campaignMeta" },
    { "id": "tasks", "type": "task-list", "dataSource": "tasks" },
    { "id": "draw", "type": "draw-panel", "dataSource": "lottery" },
    { "id": "rewards", "type": "reward-list", "dataSource": "rewards" }
  ],
  "popups": [
    {
      "id": "rulePopup",
      "trigger": "openRules"
    },
    {
      "id": "rewardResultPopup",
      "trigger": "drawSuccess"
    },
    {
      "id": "checkpointUnlockedPopup",
      "trigger": "checkpointReached"
    }
  ],
  "animationSystem": {
    "primarySequence": "checkpointUnlockBurst",
    "ambientLayers": ["sparkleDrift", "ribbonFloat"],
    "feedbackEffects": {
      "primaryCta": "ctaPulse",
      "taskClaim": "stampPop",
      "rewardReveal": "coinBurst"
    },
    "reducedMotionFallback": true
  },
  "visualPreset": {
    "heroStyle": "photorealistic-female-poster",
    "lighting": "warm rim light",
    "textureDirection": "realistic skin and fabric detail",
    "assetPath": "./image/bg.png"
  },
  "assetOutput": {
    "deliveryRoot": "./project",
    "deliverySlug": "spring-benefit-relay-2026",
    "bundleDir": "./project/spring-benefit-relay-2026",
    "rootDir": "./project/spring-benefit-relay-2026/image",
    "heroImage": "./project/spring-benefit-relay-2026/image/bg.png",
    "publicAssetPath": "./image/bg.png",
    "pythonMustCreateDirs": ["./project", "./project/spring-benefit-relay-2026", "./project/spring-benefit-relay-2026/image"],
    "savePolicy": "create-before-write",
    "mustWriteFiles": true
  },
  "stateMachine": {
    "states": [
      "init",
      "activityReady",
      "taskUpdated",
      "checkpointUnlocked",
      "chanceReady",
      "drawing",
      "resultShown"
    ]
  },
  "tracking": [
    { "event": "activity_generated", "trigger": "activity family selected" },
    { "event": "task_claim_click", "trigger": "click task claim button" },
    { "event": "draw_start_click", "trigger": "click draw CTA" }
  ]
}
