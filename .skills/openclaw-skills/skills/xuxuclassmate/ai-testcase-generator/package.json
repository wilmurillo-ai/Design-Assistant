{
  "name": "@classmatexuxu/testcase-generator",
  "version": "1.0.0",
  "description": "AI-powered test case generation for PRDs, specs, and multimodal QA inputs",
  "main": "./dist/index.js",
  "bin": {
    "testcase-generator": "./dist/index.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XuXuClassMate/testcase-generator.git"
  },
  "bugs": {
    "url": "https://github.com/XuXuClassMate/testcase-generator/issues"
  },
  "homepage": "https://github.com/XuXuClassMate/testcase-generator#readme",
  "keywords": [
    "openclaw",
    "testing",
    "testcase",
    "qa",
    "openai",
    "anthropic"
  ],
  "files": [
    "dist",
    "public",
    "README.md",
    "docs",
    "openclaw.plugin.json",
    "SKILL.md",
    ".env.example",
    "scripts/install.sh"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "ts-node src/index.ts",
    "dev:standalone": "ts-node src/index.ts --standalone",
    "start": "node dist/index.js --standalone",
    "standalone": "ts-node src/standalone.ts",
    "standalone:build": "tsc && node dist/standalone.js",
    "prepare:npm-package": "node scripts/prepare-npm-package.js",
    "prepack": "npm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.98.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "multer": "^2.0.2",
    "exceljs": "^4.4.0",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.6.0",
    "sharp": "^0.33.2",
    "cors": "^2.8.5",
    "archiver": "^6.0.1",
    "uuid": "^9.0.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.8",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "publishConfig": {
    "access": "public"
  }
}
