{
  "name": "sleep-rabbit-skill",
  "version": "1.0.6",
  "description": "眠小兔睡眠健康技能 - 专业的睡眠分析、压力评估和冥想指导系统",
  "author": "AISleepGen团队",
  "license": "MIT",
  "main": "skill.py",
  "dependencies": {
    "python": ">=3.8",
    "openclaw": ">=2026.3.0"
  },
  "no_external_dependencies": true,
  "python_stdlib_only": true,
  "permissions": ["filesystem"],
  "security": {
    "network_access": false,
    "local_only": true,
    "privacy_friendly": true,
    "no_external_dependencies": true,
    "python_stdlib_only": true
  },
  "features": {
    "sleep_analysis": {
      "description": "EDF睡眠数据分析",
      "commands": ["sleep-analyze"]
    },
    "stress_assessment": {
      "description": "心率变异性压力评估",
      "commands": ["stress-check"]
    },
    "meditation_guidance": {
      "description": "个性化冥想指导",
      "commands": ["meditation-guide"]
    },
    "health_reporting": {
      "description": "综合健康报告",
      "commands": ["health-report"]
    }
  },
  "commands": {
    "sleep-analyze": {
      "description": "分析EDF格式的睡眠数据",
      "usage": "/sleep-analyze <edf文件路径>",
      "example": "/sleep-analyze data/sample.edf"
    },
    "stress-check": {
      "description": "基于心率变异性评估压力水平",
      "usage": "/stress-check <心率数据>",
      "example": "/stress-check 70,72,75,68,80"
    },
    "meditation-guide": {
      "description": "提供个性化冥想指导",
      "usage": "/meditation-guide [--type <类型>] [--duration <分钟>]",
      "example": "/meditation-guide --type relaxation --duration 15"
    },
    "health-report": {
      "description": "生成综合健康报告",
      "usage": "/health-report [--sleep-data <文件>] [--stress-data <数据>]",
      "example": "/health-report --sleep-data data/sleep.edf --stress-data \"70,72,75\""
    },
    "skill-info": {
      "description": "显示技能信息",
      "usage": "/skill-info",
      "example": "/skill-info"
    },
    "health-check": {
      "description": "运行技能健康检查",
      "usage": "/health-check",
      "example": "/health-check"
    }
  },
  "compatibility": {
    "openclaw": ">=2026.3.0",
    "python": ">=3.8",
    "platforms": ["windows", "linux", "macos"]
  },
  "documentation": {
    "skill_guide": "SKILL.md",
    "user_manual": "PLUGIN_USAGE.md",
    "integration_guide": "INTEGRATION_GUIDE.md",
    "release_notes": "RELEASE.md",
    "changelog": "CHANGELOG.md"
  },
  "quality_assurance": {
    "network_code_check": "passed",
    "openclaw_structure_validation": "passed",
    "file_encoding_check": "passed",
    "documentation_consistency": "passed",
    "clawhub_standards": "passed"
  },
  "installation": {
    "method": "openclaw-standard",
    "instructions": "Add to OpenClaw config and restart gateway",
    "dependencies": "requirements.txt"
  },
  "notes": "此技能100%本地运行，无网络依赖，所有安全声明与代码实现一致。安全版本已移除所有child_process.exec调用，符合ClawHub安全规范。"
}