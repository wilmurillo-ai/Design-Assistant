  },
  "content": {
    "countStatus": true,
    "useIndent": false,
    "useJustify": false
  },
  "headingStyles": {
    "h1": "default",
    "h2": "default",
    "h3": "default",
    "h4": "default",
    "h5": "default",
    "h6": "default"
  },
  "customCSS": ""
}
