            "call_type": "fallback",
            "status": "={{ $json.wa_success ? 'whatsapp_sent' : 'sms_sent' }}",
            "timestamp": "={{ new Date().toISOString() }}"
          },
          "matchingColumns": [],
          "schema": []
        },
        "options": {}
      },
