      ],
      "id": "06e65aff-cdfb-47d8-bfaf-1cc5ee1e9e52",
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "YOUR_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ status: 'ok', order_id: $json.order_id, updated_to: $json.status }) }}",
        "options": {}
      },
      "name": "Respond",
