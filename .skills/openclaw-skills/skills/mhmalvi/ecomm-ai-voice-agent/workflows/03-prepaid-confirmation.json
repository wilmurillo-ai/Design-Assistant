      ],
      "id": "887dbb6a-6498-4b3d-a1e2-e31e24e52382"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.VAPI_API_URL}}/call/phone",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  assistantId: $env.VAPI_COD_ASSISTANT_ID,\n  customer: { number: $json.customer_phone, name: $json.customer_name },\n  assistantOverrides: {\n    firstMessage: 'Hello ' + $json.customer_name + ', thank you for your order #' + $json.order_number + '. We just wanted to personally confirm your purchase and let you know it is being processed. Is there anything you need help with?',\n    metadata: { order_id: $json.order_id, type: 'prepaid_highvalue' }\n  }\n}) }}",
        "options": {},
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env.VAPI_API_KEY}}"
            }
          ]
        }
      },
      "name": "Vapi High-Value Call",
      "type": "n8n-nodes-base.httpRequest",
