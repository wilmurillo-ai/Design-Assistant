    {
      "parameters": {
        "jsCode": "// Build confirmation SMS for prepaid orders\nconst order = $input.first().json;\n\nconst smsBody = `Hi ${order.customer_name}! Your order #${order.order_number} is confirmed. `\n  + `Items: ${order.items_summary}. Total: ${order.currency} ${order.total_amount}. `\n  + `Thank you for your purchase! Reply HELP for support.`;\n\nreturn [{ json: {\n  ...order,\n  sms_body: smsBody\n}}];"
      },
      "name": "Prepare SMS",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        400
      ],
      "id": "56a60460-9e02-4cbf-828e-11482902900f"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.TWILIO_API_URL}}/2010-04-01/Accounts/{{$env.TWILIO_ACCOUNT_SID}}/Messages.json",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ From: $env.TWILIO_PHONE_NUMBER, To: $json.customer_phone, Body: $json.sms_body }) }}",
        "options": {},
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Basic {{$env.TWILIO_AUTH_HEADER}}"
            }
          ]
        }
      },
      "name": "Send Confirmation SMS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        700,
        400
      ],
      "id": "3f1109f4-359a-4f93-b533-b2701f499227"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "c070c2f0-e8a3-4ac6-a0f7-02c106609c7e",
              "leftValue": "={{ $json.is_high_value }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ]
        }
      },
      "name": "High Value?",
