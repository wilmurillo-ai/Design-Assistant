      "webhookId": "ecomm-returns-faq",
      "id": "57bb83df-5cfc-40da-b3c0-d62548976a3f"
    },
    {
      "parameters": {
        "jsCode": "// Parse customer inquiry\nconst body = $input.first().json.body || $input.first().json;\n\nconst inquiry = {\n  order_id: body.order_id || '',\n  customer_phone: body.customer_phone || body.phone || '',\n  customer_name: body.customer_name || body.name || '',\n  customer_email: body.customer_email || body.email || '',\n  message: body.message || body.query || body.transcript || '',\n  intent: (body.intent || 'unknown').toLowerCase(),\n  source: body.source || 'voice',\n  timestamp: new Date().toISOString()\n};\n\n// Simple intent detection from message\nconst msg = inquiry.message.toLowerCase();\nif (!body.intent || body.intent === 'unknown') {\n  if (msg.includes('return') || msg.includes('send back') || msg.includes('exchange')) inquiry.intent = 'return';\n  else if (msg.includes('refund') || msg.includes('money back')) inquiry.intent = 'refund';\n  else if (msg.includes('where') || msg.includes('track') || msg.includes('shipping') || msg.includes('delivery')) inquiry.intent = 'order_status';\n  else inquiry.intent = 'faq';\n}\n\nreturn [{ json: inquiry }];"
      },
      "name": "Parse Intent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        400
      ],
      "id": "1ae28f95-77a1-4f19-830a-5123a1aac755"
