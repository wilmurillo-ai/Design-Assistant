    {
      "parameters": {
        "jsCode": "// Generate return policy response via template\nconst d = $input.first().json;\nconst response = {\n  ...d,\n  ai_response: `I understand you'd like to return an item from order #${d.order_id}. `\n    + `Our return policy allows returns within 30 days of delivery. `\n    + `The item must be unused and in original packaging. `\n    + `I'll initiate a return request for you. You'll receive a return shipping label via email shortly.`,\n  action: 'initiate_return',\n  sms_response: `Return request initiated for order #${d.order_id}. Check your email for the return label. Questions? Reply HELP.`\n};\nreturn [{ json: response }];"
      },
      "name": "Return Policy Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        160
      ],
      "id": "f58b738f-72ab-4293-b34f-7357b443ff4a"
    },
    {
      "parameters": {
        "jsCode": "// Look up refund status\nconst d = $input.first().json;\nconst response = {\n  ...d,\n  ai_response: `Let me check the refund status for order #${d.order_id}. `\n    + `Refunds typically take 5-10 business days to process after we receive the returned item. `\n    + `I'll send you an update via SMS with the current status.`,\n  action: 'check_refund',\n  sms_response: `Refund update for order #${d.order_id}: Your refund is being processed. Expected 5-10 business days. We'll notify you when complete.`\n};\nreturn [{ json: response }];"
      },
      "name": "Refund Status Lookup",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        340
      ],
      "id": "2128be4e-fc97-4ff7-aacc-59676c94fcad"
    },
    {
      "parameters": {
        "jsCode": "// Check order/shipping status\nconst d = $input.first().json;\nconst response = {\n  ...d,\n  ai_response: `I'll look up the status of order #${d.order_id} for you right away.`,\n  action: 'check_status',\n  sms_response: `Order #${d.order_id} status update will be sent shortly. Track at your store account.`\n};\nreturn [{ json: response }];"
      },
      "name": "Order Status Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
