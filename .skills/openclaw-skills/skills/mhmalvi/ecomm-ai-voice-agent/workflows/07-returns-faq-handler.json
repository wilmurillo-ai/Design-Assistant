    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: 'gpt-4o-mini',\n  messages: [\n    { role: 'system', content: 'You are an eCommerce customer support assistant. Answer the customer\\'s question helpfully and concisely. If you cannot answer, say you will connect them to a human agent.' },\n    { role: 'user', content: $json.message || 'General inquiry about order #' + $json.order_id }\n  ],\n  max_tokens: 300\n}) }}",
        "options": {},
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env.OPENAI_API_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "name": "OpenAI FAQ Answer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        960,
        700
      ],
      "id": "9473d4d5-8dc0-4cfa-b833-103f45ec2a92"
    },
    {
      "parameters": {
        "jsCode": "// Extract OpenAI response\nconst aiResp = $input.first().json;\nconst inquiry = $('Parse Intent').first().json;\nconst answer = aiResp.choices?.[0]?.message?.content || 'I apologize, let me connect you to a human agent.';\n\nreturn [{ json: {\n  ...inquiry,\n  ai_response: answer,\n  action: 'faq_answered',\n  sms_response: answer.substring(0, 160)\n}}];"
      },
      "name": "Format FAQ Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
