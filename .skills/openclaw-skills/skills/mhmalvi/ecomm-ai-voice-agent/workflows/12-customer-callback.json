      "name": "Get Recent Order",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        1140,
        400
      ],
      "id": "0b82d3c0-844a-40a2-aa4d-d500f52b1fb3",
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "YOUR_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Build context for AI response\nconst data = $('Find Customer Record').first().json;\nconst orders = $input.all();\nlet recentOrder = null;\n\n// Find most recent order for this customer\nfor (const o of orders) {\n  if (o.json.customer_phone === data.customer_phone || o.json.order_id === data.last_order_id) {\n    if (!recentOrder || (o.json.timestamp > recentOrder.timestamp)) {\n      recentOrder = o.json;\n    }\n  }\n}\n\nconst context = {\n  ...data,\n  order: recentOrder || {},\n  has_order: !!recentOrder,\n  context_summary: recentOrder\n    ? `Customer ${data.customer_name} calling about order #${recentOrder.order_number} (${recentOrder.status}, ${recentOrder.items_summary})`\n    : `New/unknown customer ${data.customer_name || data.customer_phone} calling`\n};\n\nreturn [{ json: context }];"
      },
