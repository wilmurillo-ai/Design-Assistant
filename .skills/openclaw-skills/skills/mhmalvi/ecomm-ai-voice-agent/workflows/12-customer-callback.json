      ],
      "id": "9ab4d672-0a91-485f-91b0-4b3536f391dc",
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "YOUR_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Match customer by phone\nconst call = $('Parse Inbound Call').first().json;\nconst customers = $input.all();\nlet customer = null;\n\nfor (const c of customers) {\n  if (c.json.customer_phone === call.customer_phone) {\n    customer = c.json;\n    break;\n  }\n}\n\nreturn [{ json: {\n  ...call,\n  is_existing: !!customer,\n  customer_record: customer || {},\n  last_order_id: customer?.last_order_id || '',\n  customer_email: customer?.customer_email || ''\n}}];"
      },
      "name": "Find Customer Record",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        920,
        400
      ],
      "id": "4831ff20-478a-44ac-bb9f-a3b3819031ab"
    },
    {
      "parameters": {
