    },
    {
      "parameters": {
        "jsCode": "// Parse inbound customer callback from Vapi\nconst body = $input.first().json.body || $input.first().json;\n\nconst call = {\n  call_id: body.call_id || body.id || '',\n  customer_phone: body.customer?.number || body.from || body.caller_number || '',\n  customer_name: body.customer?.name || body.caller_name || '',\n  transcript: body.transcript || '',\n  summary: body.summary || '',\n  intent: (body.intent || body.analysis?.intent || 'general').toLowerCase(),\n  duration: body.duration || 0,\n  timestamp: new Date().toISOString()\n};\n\nreturn [{ json: call }];"
      },
      "name": "Parse Inbound Call",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        400
      ],
      "id": "1cc8055c-8467-44b9-b31d-a63be4fd3aba"
    },
    {
      "parameters": {
