        "toEmail": "={{$env.DENTAL_STAFF_EMAIL}}",
        "subject": "=Cancellation: {{ $json.patient_name }} — {{ $json.service_type }} slot now open",
        "html": "=<h2>Appointment Cancelled</h2><p><strong>{{ $json.patient_name }}</strong> cancelled their <strong>{{ $json.service_type }}</strong> appointment on <strong>{{ $json.appointment_date }}</strong>.</p><p>Reason: {{ $json.cancellation_reason }}</p><p>Waitlist patients have been notified automatically.</p>",
        "options": {
