      "name": "Get Waitlist",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        940,
        560
      ],
      "id": "n5-read-waitlist",
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "YOUR_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst freedSlot = $('Parse Cancellation').first().json;\nconst slotDate = new Date(freedSlot.appointment_date);\nconst slotEnd = new Date(freedSlot.appointment_end || slotDate.getTime() + 3600000);\n\n// Find waitlist patients who want the same service or any slot near this date\nconst candidates = items.filter(item => {\n  const w = item.json;\n  if (w.status === 'filled' || w.status === 'declined') return false;\n  \n  // Check if preferred date matches (within 2 days)\n  if (w.preferred_date) {\n    const prefDate = new Date(w.preferred_date);\n    const daysDiff = Math.abs((slotDate - prefDate) / (1000 * 60 * 60 * 24));\n    if (daysDiff > 2) return false;\n  }\n  \n  // Check service compatibility\n  if (w.service_type && freedSlot.service_type) {\n    const wService = w.service_type.toLowerCase();\n    const fService = freedSlot.service_type.toLowerCase();\n    if (wService !== fService && wService !== 'any') return false;\n  }\n  \n  return true;\n}).sort((a, b) => {\n  // Priority: earlier waitlist entries first\n  return new Date(a.json.added_at || 0) - new Date(b.json.added_at || 0);\n});\n\nif (candidates.length === 0) {\n  return [{ json: { no_candidates: true, freed_slot: freedSlot } }];\n}\n\n// Return top 3 candidates to contact\nreturn candidates.slice(0, 3).map(c => ({\n  json: {\n    ...c.json,\n    freed_slot_date: freedSlot.appointment_date,\n    freed_slot_end: freedSlot.appointment_end,\n    freed_service: freedSlot.service_type,\n    freed_by: freedSlot.freed_by,\n    sms_message: `Hi ${c.json.patient_name}! Great news — a ${freedSlot.service_type} appointment slot just opened up on ${slotDate.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' })} at ${slotDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })}. Reply YES to book it or NO to pass. First come, first served!`\n  }\n}));"
      },
      "name": "Match Waitlist Candidates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        560
      ],
      "id": "n5-match"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-candidates",
              "leftValue": "={{ $json.no_candidates }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notEquals"
              }
            }
          ]
        }
      },
      "name": "Candidates Found?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1440,
        560
      ],
      "id": "n5-if-candidates"
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "from": "={{$env.TWILIO_PHONE_NUMBER}}",
        "to": "={{ $json.patient_phone }}",
        "body": "={{ $json.sms_message }}"
      },
