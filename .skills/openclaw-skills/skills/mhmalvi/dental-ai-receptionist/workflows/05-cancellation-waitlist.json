        "jsonBody": "={{ JSON.stringify({ assistantId: $env.VAPI_WAITLIST_ASSISTANT_ID, customer: { number: $json.patient_phone, name: $json.patient_name }, metadata: { freed_slot_date: $json.freed_slot_date, freed_service: $json.freed_service, action: 'waitlist_offer' } }) }}",
        "options": {}
      },
      "name": "Call Waitlist Patient (Vapi)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1700,
        640
      ],
      "id": "n5-vapi-waitlist"
    },
    {
