        240,
        400
      ],
      "webhookId": "dental-cancel-appt",
      "id": "n5-webhook"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst action = body.action || 'cancel';\nconst data = {\n  action: action,\n  appointment_id: body.appointment_id || '',\n  patient_name: body.patient_name || body.caller_name || '',\n  patient_phone: body.caller_phone || body.patient_phone || '',\n  appointment_date: body.appointment_date || '',\n  appointment_end: body.appointment_end || '',\n  service_type: body.service_type || body.appointment_type || '',\n  cancellation_reason: body.cancellation_reason || body.reason || 'Not specified',\n  call_id: body.call_id || '',\n  freed_by: body.freed_by || 'patient_cancellation',\n  original_patient: body.original_patient || body.patient_name || '',\n  timestamp: new Date().toISOString()\n};\n\nreturn [{ json: data }];"
      },
      "name": "Parse Cancellation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        400
      ],
      "id": "n5-parse"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "is-cancel",
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "cancel",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputLabel": "Cancel Appointment"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "is-waitlist",
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "fill_from_waitlist",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputLabel": "Fill from Waitlist"
            }
          ],
          "fallbackOutput": {
            "renameOutput": true,
            "outputLabel": "Unknown Action"
          }
        },
        "options": {}
      },
