            "patient_name": "={{ $json.patient_name }}",
            "patient_phone": "={{ $json.patient_phone }}",
            "reminder_type": "={{ $json.reminder_type }}",
            "channel": "sms",
            "sent_at": "={{ new Date().toISOString() }}",
            "status": "sent"
          },
          "matchingColumns": [],
          "schema": []
        },
        "options": {}
      },
      "name": "Log Reminder Sent",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
