            "appointment_id": "={{ $json.appointment_id }}",
            "reminder_48h_sent": "={{ $json.reminder_type === '48h' ? 'yes' : $json.reminder_48h_sent }}",
            "reminder_24h_sent": "={{ $json.reminder_type === '24h' ? 'yes' : $json.reminder_24h_sent }}",
            "reminder_2h_sent": "={{ $json.reminder_type === '2h' ? 'yes' : $json.reminder_2h_sent }}"
