            "index": 0
          }
        ]
      ]
    },
    "AI Generate Summary": {
      "main": [
        [
          {
            "node": "Prepare Summary",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Prepare Summary": {
      "main": [
        [
          {
            "node": "Email Staff with Summary",
            "type": "main",
            "index": 0
          },
          {
            "node": "High Priority?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Email Staff with Summary": {
      "main": [
        [
          {
            "node": "Log Escalation",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "High Priority?": {
      "main": [
        [
          {
            "node": "SMS Alert to Manager",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Log Escalation": {
      "main": [
        [
          {
