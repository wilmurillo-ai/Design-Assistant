# Tavily Search 配置示例
# 复制此文件为 .env 并填入你的配置

# ========== 必需配置 ==========

# Tavily API密钥 (必需)
# 从 https://tavily.com 获取
TAVILY_API_KEY=your_api_key_here

# ========== 可选配置 ==========

# 缓存目录 (默认: ~/.openclaw/cache/tavily)
# 脚本会读取此配置并创建相应目录
TAVILY_CACHE_DIR=~/.openclaw/cache/tavily

# 默认超时时间 (秒)
# 命令行参数 --timeout 的默认值
TAVILY_DEFAULT_TIMEOUT=30

# 默认缓存TTL (秒)
# 命令行参数 --cache-ttl 的默认值
TAVILY_CACHE_TTL=300

# 默认最大结果数
# 命令行参数 --max-results 的默认值
TAVILY_MAX_RESULTS=5

# 默认搜索深度 (basic/advanced)
# 命令行参数 --search-depth 的默认值
TAVILY_SEARCH_DEPTH=basic

# ========== 使用说明 ==========

# 方法1: 环境变量
# export TAVILY_API_KEY="your_key"
# export TAVILY_CACHE_DIR="/custom/cache/path"
# export TAVILY_DEFAULT_TIMEOUT=45

# 方法2: 配置文件
# 1. 将 TAVILY_API_KEY 替换为你的实际API密钥
# 2. 可选: 根据需要调整其他配置
# 3. 保存为 ~/.openclaw/.env
# 4. 运行技能: python3 scripts/tavily_search.py --query "测试"

# 注意: 环境变量的优先级高于配置文件
# 命令行参数的优先级最高