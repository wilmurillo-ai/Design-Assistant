{
    "name": "gsdata_search",
    "display_name": "GSData 项目数据搜索技能",
    "description": "访问GSData数据总线API，搜索社交媒体数据。支持自然语言解析，自动提取关键词、平台、情感属性、发文时间等参数。",
    "version": "1.0.0",
    "author": "Claude Code",
    "command": "python gsdata_search.py",
    "arguments": {
        "text": {
            "type": "string",
            "required": true,
            "description": "要解析的自然语言搜索请求文本",
            "examples": [
                "项目ID: 12345 签名: abc123 帮我获取10篇关于吉利汽车 微博或者抖音的最新负面新闻",
                "project_id: PROJ789 sign: xyz789 关键词: 安徽 平台: 微博 时间: 2024-03-12",
                "项目id：DEMO001，sign：123abc，帮我找5篇关于新能源汽车的微博正面新闻"
            ]
        }
    },
    "output": {
        "description": "API请求参数的JSON格式，或缺失参数的提示信息",
        "examples": [
            "{\"project_id\": \"12345\", \"sign\": \"abc123\", \"router\": \"/standard/search/get-data\", \"params\": {\"keywords_include\": \"吉利汽车\", \"media_name\": \"\", \"platform_name\": \"微博,抖音\", \"posttime_start\": \"2024-03-12 11:00:00\", \"posttime_end\": \"2024-03-12 11:59:59\", \"is_content\": 0, \"paging_type\": \"page\", \"page\": 1, \"limit\": 10, \"news_emotion\": \"负面\"}}",
            "请补充必填参数：project_id、sign"
        ]
    },
    "categories": [
        "数据分析",
        "API访问",
        "社交媒体搜索",
        "参数解析"
    ],
    "tags": [
        "GSData",
        "数据总线",
        "API",
        "社交媒体",
        "新闻搜索",
        "参数解析",
        "自然语言处理"
    ],
    "requirements": [
        "Python 3.6 或更高版本"
    ]
}