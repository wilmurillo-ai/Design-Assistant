{
  "examples": [
    {
      "description": "基础：只传 template_id + start（其余用默认值）",
      "request": {
        "draft_id": "YOUR_DRAFT_ID",
        "template_id": "7373303725881822491",
        "start": 1.3
      }
    },
    {
      "description": "带占位文本替换：texts 数组 + 位置偏移 + 时间范围",
      "request": {
        "draft_id": "YOUR_DRAFT_ID",
        "template_id": "7163508464772336909",
        "texts": ["victory", "胜利纪念"],
        "start": 1,
        "end": 3,
        "transform_x": 0.23,
        "transform_y": -0.7
      }
    },
    {
      "description": "变换参数：旋转 + 缩放 + 自定义 track_name",
      "request": {
        "draft_id": "YOUR_DRAFT_ID",
        "template_id": "7295896343376153868",
        "start": 7,
        "end": 9,
        "transform_x": 0.23,
        "transform_y": -0.7,
        "rotation": 10,
        "scale_x": 1.3,
        "scale_y": 2.5,
        "track_name": "233"
      }
    }
  ]
}
