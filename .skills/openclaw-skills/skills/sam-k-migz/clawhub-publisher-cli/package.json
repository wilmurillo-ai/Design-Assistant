{
  "name": "clawhub-publisher",
  "version": "0.1.1",
  "type": "module",
  "description": "CLI-first tool to validate, clean, package, and publish OpenClaw skills to ClawHub.",
  "bin": {
    "clawhub-publisher": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "openclaw",
    "clawhub",
    "skills",
    "publisher",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1",
    "chalk": "^5.4.1",
    "commander": "^14.0.1",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
