{
  "name": "@jingyu525/wechat-image-generator",
  "version": "1.0.2",
  "description": "Generate beautiful images for WeChat articles (covers, comparisons, charts) with zero token cost",
  "keywords": [
    "wechat",
    "image",
    "generator",
    "cover",
    "social-media",
    "openclaw",
    "skill"
  ],
  "author": {
    "name": "jingyu525",
    "url": "https://github.com/jingyu525"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jingyu525/wechat-image-generator"
  },
  "homepage": "https://github.com/jingyu525/wechat-image-generator",
  "bugs": {
    "url": "https://github.com/jingyu525/wechat-image-generator/issues"
  },
  "openclaw": {
    "type": "skill",
    "emoji": "🎨",
    "requires": {
      "bins": ["python3"]
    }
  },
  "scripts": {
    "serve": "cd output && python3 -m http.server 8765",
    "generate:cover": "python3 scripts/generate.py cover",
    "generate:compare": "python3 scripts/generate.py compare",
    "generate:chart": "python3 scripts/generate.py chart"
  }
}
