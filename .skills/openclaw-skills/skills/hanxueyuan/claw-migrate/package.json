{
  "name": "claw-migrate",
  "version": "2.2.1",
  "description": "OpenClaw GitHub Configuration Migration Tool - Supports bidirectional sync, scheduled backup, configuration management",
  "main": "src/index.js",
  "bin": {
    "claw-migrate": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "test": "node tests/run-all-tests.js",
    "test:merger": "node tests/merger.test.js",
    "test:setup": "node tests/setup.test.js",
    "test:backup": "node tests/backup.test.js",
    "test:restore": "node tests/restore.test.js",
    "test:config": "node tests/config-manager.test.js",
    "test:scheduler": "node tests/scheduler.test.js",
    "test:integration": "node tests/integration.test.js",
    "test:all": "npm test",
    "lint": "node -c src/*.js && node -c tests/*.js && echo '✓ JavaScript syntax OK'",
    "clean": "rm -rf node_modules/ *.log test-results/"
  },
  "keywords": [
    "openclaw",
    "migration",
    "github",
    "configuration",
    "sync",
    "backup",
    "restore",
    "schedule"
  ],
  "author": "OpenClaw Team",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hanxueyuan/claw-migrate.git"
  },
  "bugs": {
    "url": "https://github.com/hanxueyuan/claw-migrate/issues"
  },
  "homepage": "https://github.com/hanxueyuan/claw-migrate#readme"
}
