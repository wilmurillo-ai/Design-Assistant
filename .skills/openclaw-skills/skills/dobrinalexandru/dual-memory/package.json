	},
	"openclaw": {
		"extensions": ["./index.ts"],
		"compat": {
			"pluginApi": "1.0.0"
		},
		"build": {
			"openclawVersion": ">=2026.1.29"
		}
	},
	"devDependencies": {
		"typescript": "^5.9.3"
	}
