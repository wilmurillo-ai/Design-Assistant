# Mail Skill Configuration

# --- Account 1 ---
MAIL_ACCOUNT_1_EMAIL=your_email@example.com
MAIL_ACCOUNT_1_PASSWORD=your_app_password
MAIL_ACCOUNT_1_IMAP_SERVER=imap.example.com
MAIL_ACCOUNT_1_IMAP_PORT=993
MAIL_ACCOUNT_1_SMTP_SERVER=smtp.example.com
MAIL_ACCOUNT_1_SMTP_PORT=465
# MAIL_ACCOUNT_1_POP3_SERVER=pop.example.com
# MAIL_ACCOUNT_1_POP3_PORT=995
MAIL_ACCOUNT_1_USE_SSL=true

# --- Account 2 (Optional) ---
# MAIL_ACCOUNT_2_EMAIL=another_email@example.com
# MAIL_ACCOUNT_2_PASSWORD=another_app_password
# MAIL_ACCOUNT_2_IMAP_SERVER=imap.example.com
# ...

# --- Storage Configuration ---
MAIL_STORAGE_ROOT=./mail_data
MAIL_ATTACHMENT_PATH=./mail_data/attachments
MAIL_DB_PATH=./mail_data/mail_index.db

# --- Behavior Configuration ---
MAIL_DEFAULT_FETCH_DAYS=7
MAIL_RETRY_COUNT=3
MAIL_TIMEOUT=30
