{
  "_meta": {
    "description": "XPath + regex extraction rules for ride receipt emails. Each provider may have multiple template versions. Rules are ordered by priority (try first pattern, fall back to next). Note: HTML entities like &amp; should be decoded after extraction.",
    "validated": "2026-03-19",
    "stats": {
      "bolt": { "emails": 48, "templates": 2 },
      "uber": { "emails": 48, "templates": 2 },
      "yandex": { "emails": 146, "templates": 1 },
      "lyft": { "emails": 2, "templates": 1 }
    }
  },

  "bolt": {
    "_template_detection": {
      "v1": "HTML contains 'was your driver' (5 emails, older Taxify-era template, inline styles only)",
      "v2": "HTML contains class 'captionBold' (43 emails, modern Bolt template with CSS classes)"
    },

    "total_text": [
      {
        "template": "v2",
        "xpath": "//span[@class='captionBold color-contentPrimaryInverted']",
        "regex": "class=\"captionBold color-contentPrimaryInverted\">([^<]+)</span>",
        "description": "Green banner total amount with currency symbol"
      },
      {
        "template": "v1",
        "xpath": "//td[contains(@style, 'white-space:nowrap')]",
        "regex": "white-space:nowrap[^>]*>([^<]+)</td>",
        "description": "Right-aligned total next to payment card"
      }
    ],

    "pickup": [
      {
        "template": "v2",
        "xpath": "(//td[@class='color-contentPrimary']/span)[1]",
        "regex": "<td class=\"color-contentPrimary\">\\s*<span>([^<]+)</span>",
        "description": "First address in route section. Use first match."
      },
      {
        "template": "v1",
        "xpath": "(//a[@href='' and contains(@style, 'text-decoration:none')])[1]",
        "regex": "<a href=\"\" style=\"text-decoration:none; color:rgb\\(0, 0, 0\\);\">([^<]+)</a>",
        "description": "First address link. Use first match."
      }
    ],

    "dropoff": [
      {
        "template": "v2",
        "xpath": "(//td[@class='color-contentPrimary']/span)[2]",
        "regex": "<td class=\"color-contentPrimary\">\\s*<span>([^<]+)</span>",
        "description": "Second address in route section. Use second match."
      },
      {
        "template": "v1",
        "xpath": "(//a[@href='' and contains(@style, 'text-decoration:none')])[2]",
        "regex": "<a href=\"\" style=\"text-decoration:none; color:rgb\\(0, 0, 0\\);\">([^<]+)</a>",
        "description": "Second address link. Use second match."
      }
    ],

    "driver": [
      {
        "template": "v2",
        "xpath": "//span[@class='bodyLarge color-contentPrimary']",
        "regex": "class=\"bodyLarge color-contentPrimary\">([^<]+)</span>",
        "description": "Driver name in bold body text"
      },
      {
        "template": "v1",
        "xpath": "//td[contains(text(), 'was your driver')]",
        "regex": ">(\\w[^<]*) was your driver\\.",
        "description": "Driver name before 'was your driver.' text"
      }
    ],

    "distance_text": [
      {
        "template": "v2",
        "xpath": "//td[contains(@class, 'bodySmall spacing-bottom-40-sm')]/span[2]",
        "regex": "class=\"bodySmall spacing-bottom-40-sm color-contentSecondary\">\\s*<span>[^<]+</span>\\s*•\\s*<span>([^<]+)</span>",
        "description": "Distance after bullet separator (e.g. '5 km')"
      },
      {
        "template": "v1",
        "xpath": "//td[preceding-sibling::td[contains(text(), 'Ride distance')]]",
        "regex": "Ride distance</td>\\s*<td[^>]*>([^<]+)</td>",
        "description": "Value cell next to 'Ride distance' label"
      }
    ],

    "duration_text": [
      {
        "template": "v2",
        "xpath": "//td[contains(@class, 'bodySmall spacing-bottom-40-sm')]/span[1]",
        "regex": "class=\"bodySmall spacing-bottom-40-sm color-contentSecondary\">\\s*<span>([^<]+)</span>",
        "description": "Duration before bullet separator (e.g. '00:10:19')"
      },
      {
        "template": "v1",
        "xpath": "//td[preceding-sibling::td[contains(text(), 'Ride duration')]]",
        "regex": "Ride duration</td>\\s*<td[^>]*>([^<]+)</td>",
        "description": "Value cell next to 'Ride duration' label"
      }
    ],

    "start_time_text": [
      {
        "template": "v2",
        "xpath": "(//span[contains(@style, 'word-break: keep-all')])[1]",
        "regex": "word-break: keep-all;\">(\\d{2}:\\d{2})</span>\\s*</td>\\s*</tr>\\s*<tr>",
        "description": "First time with keep-all style, followed by another row. Use first match."
      },
      {
        "template": "v1",
        "xpath": "(//td[contains(@style, 'text-align:right') and contains(@style, 'color:rgb(153')])[1]",
        "regex": "<a href=\"\"[^>]*>[^<]+</a>\\s*</td>\\s*<td[^>]*>\\s*(\\d{2}:\\d{2})\\s*</td>",
        "description": "Time in right column next to pickup address"
      }
    ],

    "end_time_text": [
      {
        "template": "v2",
        "xpath": "(//span[contains(@style, 'word-break: keep-all')])[last()]",
        "regex": "word-break: keep-all;\">(\\d{2}:\\d{2})</span>\\s*</td>\\s*</tr>\\s*</table>",
        "description": "Last time with keep-all style, followed by table close."
      },
      {
        "template": "v1",
        "xpath": "(//td[contains(@style, 'border-top:1px solid rgb(216') and contains(@style, 'text-align:right')])[last()]",
        "regex": "border-top:1px solid rgb\\(216, 216, 216\\)[^>]*>\\s*(\\d{2}:\\d{2})\\s*</td>",
        "description": "Time in right column next to dropoff address"
      }
    ],

    "payment_method": [
      {
        "template": "v2",
        "xpath": "//td[@align='left' and contains(@class, 'bodyLarge')]/span",
        "regex": "<td align=\"left\" class=\"bodyLarge\\s*\">\\s*<span>([^<]+)</span>",
        "description": "Payment method text in bodyLarge cell"
      },
      {
        "template": "v1",
        "xpath": "//td[img[contains(@style, 'vertical-align:text-bottom')]]",
        "regex": "vertical-align:text-bottom[^>]*/>([^<]+)</td>",
        "description": "Text after card icon image"
      }
    ]
  },

  "uber": {
    "_template_detection": {
      "v1": "HTML contains class 'Uber18_text_p2' but no data-testid attributes (26 emails, older template ~2021-2025)",
      "v2": "HTML contains data-testid attributes (22 emails, newer receipt template ~2025+)"
    },

    "total_text": [
      {
        "template": "v2",
        "xpath": "//td[@data-testid='total_fare_amount']",
        "regex": "data-testid=\"total_fare_amount\"[^>]*>([^<]+)",
        "description": "Total fare in data-testid cell. Currency symbol may be prefix or suffix."
      },
      {
        "template": "v1",
        "xpath": "//span[@class='Uber18_text_p2'][ancestor::div[contains(text(),'Total')]]",
        "regex": "Total\\s*\\n?\\s*<span class=\"Uber18_text_p2\"[^>]*>([^<]+)",
        "description": "Total in span after 'Total' text. NOTE: may contain \\u00a0 (non-breaking space) between currency and amount."
      }
    ],

    "pickup": [
      {
        "template": "v2",
        "xpath": "//td[@data-testid='address_point_0_address']",
        "regex": "data-testid=\"address_point_0_address\"[^>]*>([^<]+)",
        "description": "Pickup address in first address point"
      },
      {
        "template": "v1",
        "xpath": "(//td[@class='Uber18_text_p1 black' and @align='left'])[1]",
        "regex": "class=\"Uber18_text_p2 black\"[^>]*align=\"left\"[^>]*>\\d+:\\d+\\s*[AP]M</td></tr><tr><td class=\"Uber18_text_p1 black\"[^>]*align=\"left\"[^>]*>([^<]+)",
        "description": "Address cell immediately after pickup time. Use first match."
      }
    ],

    "dropoff": [
      {
        "template": "v2",
        "xpath": "//td[@data-testid='address_point_1_address']",
        "regex": "data-testid=\"address_point_1_address\"[^>]*>([^<]+)",
        "description": "Dropoff address in second address point"
      },
      {
        "template": "v1",
        "xpath": "(//td[@class='Uber18_text_p1 black'])[2]",
        "regex": "class=\"Uber18_text_p2 black\"[^>]*>\\d+:\\d+\\s*[AP]M</td></tr><tr><td class=\"Uber18_text_p1 black\"[^>]*>([^<]+)",
        "description": "Address cell immediately after dropoff time. Use second match."
      }
    ],

    "driver": [
      {
        "template": "v2",
        "xpath": "//td[@data-testid='driverInfo_title']",
        "regex": "data-testid=\"driverInfo_title\"[^>]*>You rode with ([^<]+)",
        "description": "Driver name after 'You rode with' text"
      },
      {
        "template": "v1",
        "xpath": "//td[contains(text(), 'You rode with')]",
        "regex": ">You rode with ([^<]+)</td>",
        "description": "Driver name in 'You rode with X' cell"
      }
    ],

    "distance_text": [
      {
        "template": "v2",
        "xpath": "//td[@data-testid='distance_duration']",
        "regex": "data-testid=\"distance_duration\"[^>]*>([^,]+)",
        "description": "Distance before comma in 'X kilometers, Y minutes' format"
      },
      {
        "template": "v1",
        "xpath": "//td[contains(@style, 'white-space:nowrap')]",
        "regex": "white-space:nowrap[^>]*>([^|<]+)\\s*\\|",
        "description": "Distance before pipe in 'X kilometers | Y min' format"
      }
    ],

    "duration_text": [
      {
        "template": "v2",
        "xpath": "//td[@data-testid='distance_duration']",
        "regex": "data-testid=\"distance_duration\"[^>]*>[^,]+,\\s*(\\d+\\s*\\w+)",
        "description": "Duration after comma in 'X kilometers, Y minutes' format"
      },
      {
        "template": "v1",
        "xpath": "//td[contains(@style, 'white-space:nowrap')]",
        "regex": "white-space:nowrap[^>]*>[^|]+\\|\\s*(\\d+\\s*min)",
        "description": "Duration after pipe in 'X kilometers | Y min' format"
      }
    ],

    "start_time_text": [
      {
        "template": "v2",
        "xpath": "//td[@data-testid='address_point_0_time']",
        "regex": "data-testid=\"address_point_0_time\"[^>]*>([^<]+)",
        "description": "Pickup time in first address point"
      },
      {
        "template": "v1",
        "xpath": "(//td[@class='Uber18_text_p2 black' and @align='left'])[1]",
        "regex": "class=\"Uber18_text_p2 black\"[^>]*align=\"left\"[^>]*>(\\d+:\\d+\\s*[AP]M)",
        "description": "First time value with align=left. Use first match."
      }
    ],

    "end_time_text": [
      {
        "template": "v2",
        "xpath": "//td[@data-testid='address_point_1_time']",
        "regex": "data-testid=\"address_point_1_time\"[^>]*>([^<]+)",
        "description": "Dropoff time in second address point"
      },
      {
        "template": "v1",
        "xpath": "(//td[@class='Uber18_text_p2 black'])[last() in time context]",
        "regex": "class=\"Uber18_text_p2 black\"[^>]*>(\\d+:\\d+\\s*[AP]M)",
        "description": "Second time match from Uber18_text_p2 black cells. Use second match."
      }
    ],

    "payment_method": [
      {
        "template": "v2",
        "xpath": "//td[@data-testid='payments_0_Card.String']",
        "regex": "data-testid=\"payments_0_Card\\.String\"[^>]*>([^<]+)",
        "description": "Payment card string in data-testid cell"
      },
      {
        "template": "v1",
        "xpath": "//td[contains(@style, 'font-weight:bolder')]",
        "regex": "font-weight:bolder\">([^<]+)</td>",
        "description": "Bold payment text. NOTE: may only show first payment method; multi-payment (e.g. 'Uber Cash + Visa') may be split across cells."
      }
    ]
  },

  "yandex": {
    "_template_detection": {
      "v1": "Single consistent template across all 146 emails. Uses semantic CSS classes (report__, route__, details__, card__)."
    },

    "total_text": [
      {
        "template": "v1",
        "xpath": "//td[@class='report__value report__value_main']",
        "regex": "class=\"report__value report__value_main\"[^>]*>\\s*([^<\\s][^<]*?)\\s*</td>",
        "description": "Main total value cell. Currency may be prefix symbol (₽757) or prefix code (р.14.3)."
      }
    ],

    "pickup": [
      {
        "template": "v1",
        "xpath": "(//td[@class='route__point-details'][contains(@style, 'border-bottom: 1px')])/p[@class='route__point-name']",
        "regex": "border-bottom: 1px solid #E7E5E1;\">\\s*<p class=\"route__point-name\"[^>]*>([^<]+)",
        "description": "First route point name (with solid bottom border = not last point)"
      }
    ],

    "dropoff": [
      {
        "template": "v1",
        "xpath": "(//td[@class='route__point-details'][contains(@style, 'border-bottom: 0')])/p[@class='route__point-name']",
        "regex": "border-bottom: 0;\">\\s*<p class=\"route__point-name\"[^>]*>([^<]+)",
        "description": "Last route point name (border-bottom: 0 = final destination)"
      }
    ],

    "driver": [
      {
        "template": "v1",
        "xpath": "//p[@class='details__value'][preceding-sibling::p[contains(text(), 'Driver')]]",
        "regex": "Driver</p>\\s*<p class=\"details__value\"[^>]*>([^<]+)",
        "description": "Driver full name in details section after 'Driver' label"
      }
    ],

    "distance_text": [
      {
        "template": "v1",
        "xpath": "//td[@class='report__value']//p[@class='hint'][contains(text(), 'km')]",
        "regex": "class=\"hint\"[^>]*>(\\d+[\\d.]*\\s*km)</p>",
        "description": "Distance in hint text under ride duration (e.g. '9.2 km')"
      }
    ],

    "duration_text": [
      {
        "template": "v1",
        "xpath": "//td[@class='report__value']//p[@class='ride-time']",
        "regex": "<p class=\"ride-time\"[^>]*>([^<]+)</p>",
        "description": "Duration in ride-time paragraph (e.g. '30 min')"
      }
    ],

    "start_time_text": [
      {
        "template": "v1",
        "xpath": "(//td[@class='route__point-details'][contains(@style, 'border-bottom: 1px')])/p[@class='hint']",
        "regex": "border-bottom: 1px solid #E7E5E1;\">\\s*<p class=\"route__point-name\"[^>]*>[^<]+</p>\\s*<p class=\"hint\"[^>]*>(\\d{2}:\\d{2})",
        "description": "Time hint under pickup point name"
      }
    ],

    "end_time_text": [
      {
        "template": "v1",
        "xpath": "(//td[@class='route__point-details'][contains(@style, 'border-bottom: 0')])/p[@class='hint']",
        "regex": "border-bottom: 0;\">\\s*<p class=\"route__point-name\"[^>]*>[^<]+</p>\\s*<p class=\"hint\"[^>]*>\\s*(\\d{2}:\\d{2})",
        "description": "Time hint under dropoff point name"
      }
    ],

    "payment_method": [
      {
        "template": "v1",
        "xpath": "//td[@class='card__name']",
        "regex": "class=\"card__name\"[^>]*>\\s*([^<\\s][^<]*?)\\s*</td>",
        "description": "Payment method name in card section. NOTE: masked card numbers use &nbsp; instead of regular space (e.g. '••••&nbsp;6267'). Decode HTML entities after extraction."
      }
    ]
  },

  "lyft": {
    "_template_detection": {
      "v1": "Single template across both emails. Uses LyftProUI font family classes."
    },

    "total_text": [
      {
        "template": "v1",
        "xpath": "//td[@class='value charge-total mobileHeaderSmall']/strong",
        "regex": "class=\"value charge-total[^\"]*\"[^>]*>\\s*<strong>\\s*([^<]+?)\\s*</strong>",
        "description": "Bold total in charge-total cell (e.g. '$59.99')"
      }
    ],

    "pickup": [
      {
        "template": "v1",
        "xpath": "(//td[@class='mobileBodySmall']/a)[1]",
        "regex": "<td class=\"mobileBodySmall\"[^>]*>\\s*<a[^>]*>([^<]+)</a>",
        "description": "First address link in mobileBodySmall cell. Use first match."
      }
    ],

    "dropoff": [
      {
        "template": "v1",
        "xpath": "(//td[@class='mobileBodySmall']/a)[2]",
        "regex": "<td class=\"mobileBodySmall\"[^>]*>\\s*<a[^>]*>([^<]+)</a>",
        "description": "Second address link in mobileBodySmall cell. Use second match."
      }
    ],

    "driver": [
      {
        "template": "v1",
        "xpath": "//div[contains(@style, 'display:none')]//span[@class='break-on-desktop']",
        "regex": "Thanks for riding with\\s*<span[^>]*>([^<]+)!</span>",
        "description": "Driver name in preheader hidden div"
      }
    ],

    "distance_text": [
      {
        "template": "v1",
        "xpath": "//td[contains(text(), 'Lyft fare')]",
        "regex": "Lyft fare \\(([^,]+),",
        "description": "Distance in fare line parentheses (e.g. '54.08mi')"
      }
    ],

    "duration_text": [
      {
        "template": "v1",
        "xpath": "//td[contains(text(), 'Lyft fare')]",
        "regex": "Lyft fare \\([^,]+,\\s*([^)]+)\\)",
        "description": "Duration in fare line parentheses (e.g. '59m 18s')"
      }
    ],

    "start_time_text": [
      {
        "template": "v1",
        "xpath": "//td[contains(@style, 'LyftProUI-Bold')]//span",
        "regex": "AT\\s+(\\d+:\\d+\\s*[AP]M)",
        "description": "Time after 'AT' in bold date/time header (e.g. 'OCTOBER 1, 2023 AT 9:43 AM')"
      }
    ],

    "end_time_text": [
      {
        "template": "v1",
        "xpath": "//td[contains(text(), 'Drop-off')]//span",
        "regex": "Drop-off.*?(\\d+:\\d+\\s*[AP]M)</span>",
        "description": "Time in Drop-off section span"
      }
    ],

    "payment_method": [
      {
        "template": "v1",
        "xpath": "//span[contains(@style, 'padding-left')]",
        "regex": "<span[^>]*padding-left[^>]*>([^<]+)</span></td>",
        "description": "Payment text after credit card icon (e.g. 'Visa *5135')"
      }
    ]
  }
}
