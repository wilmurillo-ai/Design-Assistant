{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": [
      "node"
    ],
    "lib": [
      "ES2023"
    ],
    "noImplicitAny": false
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "test/**/*.ts",
    "types/**/*.d.ts"
  ]
}
