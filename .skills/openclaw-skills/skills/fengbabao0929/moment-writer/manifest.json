{
  "name": "moments-writer-lite",
  "version": "1.0.0",
  "description": "朋友圈文案生成器（精简版）- 基于私域变现核心方法论",
  "author": "Claude Code Assistant",
  "main": "main.js",
  "commands": [
    {
      "name": "moments",
      "description": "生成朋友圈文案 - 支持专业型、靠谱型、温暖型、利他型、反认知、圈用户、自我介绍",
      "parameters": [
        {
          "name": "type",
          "type": "string",
          "description": "文案类型",
          "required": true,
          "enum": ["professional", "reliable", "warm", "altruistic", "counter", "target", "intro_100"]
        },
        {
          "name": "topic",
          "type": "string",
          "description": "文案主题",
          "required": false
        }
      ],
      "examples": [
        {"usage": "/moments professional 户外咨询场景", "description": "专业型"},
        {"usage": "/moments reliable 逆袭故事", "description": "靠谱型"},
        {"usage": "/moments warm 亲子时光", "description": "温暖型"},
        {"usage": "/moments altruistic 干货分享", "description": "利他型"},
        {"usage": "/moments counter 补课谎言", "description": "反认知"},
        {"usage": "/moments target 筛选客户", "description": "圈用户"},
        {"usage": "/moments intro_100 我的价值", "description": "自我介绍"}
      ]
    }
  ],
  "keywords": ["wechat", "moments", "朋友圈", "私域", "文案", "营销"],
  "dependencies": []
}
