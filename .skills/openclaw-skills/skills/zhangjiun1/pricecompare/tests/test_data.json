{
  "search_tests": [
    {
      "input": "iPhone 16",
      "expected": "找到相关商品",
      "type": "search"
    },
    {
      "input": "在京东搜索手机",
      "expected": "找到京东商品",
      "type": "search_platform"
    },
    {
      "input": "淘宝搜索连衣裙",
      "expected": "找到淘宝商品",
      "type": "search_platform"
    }
  ],
  "convert_tests": [
    {
      "input": "https://item.jd.com/10021724657015.html",
      "expected": "优惠链接已生成",
      "platform": "jd",
      "type": "convert"
    },
    {
      "input": "https://item.taobao.com/item.htm?id=123456",
      "expected": "优惠链接已生成",
      "platform": "taobao",
      "type": "convert"
    },
    {
      "input": "https://mobile.yangkeduo.com/goods.html?goods_id=123456",
      "expected": "优惠链接已生成",
      "platform": "pinduoduo",
      "type": "convert"
    }
  ],
  "parse_tests": [
    {
      "input": "【淘宝】假一赔四 https://e.tb.cn/h.iVW7Wnbs5Woz1ZI",
      "expected": "商品信息已解析",
      "platform": "taobao",
      "type": "parse"
    },
    {
      "input": "【京东】10:/京鲜生 云南石林树熟人参果",
      "expected": "商品信息已解析",
      "platform": "jd",
      "type": "parse"
    }
  ],
  "compare_tests": [
    {
      "input": "对比 iPhone 16",
      "expected": "价格对比结果",
      "type": "compare"
    },
    {
      "input": "比价 华为手机",
      "expected": "价格对比结果",
      "type": "compare"
    }
  ],
  "error_tests": [
    {
      "input": "https://invalid-url.com",
      "expected": "无法识别的链接格式",
      "type": "error"
    },
    {
      "input": "xyzabc123nonexistent",
      "expected": "未找到相关商品",
      "type": "error"
    }
  ]
}
