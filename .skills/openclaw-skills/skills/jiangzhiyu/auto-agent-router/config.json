    {
      "type": "writing",
      "keywords": [
        "文章",
        "文档",
        "报告",
        "总结",
        "写作",
        "周报",
        "日报",
        "邮件",
        "文案"
      ],
      "agent": "writer",
      "model": "dashscope/qwen3.5-plus",
      "priority": "medium"
    },
    {
      "type": "analysis",
      "keywords": [
        "分析",
        "数据",
        "图表",
        "统计",
        "趋势",
        "对比",
        "可视化"
      ],
      "agent": "analyst",
      "model": "dashscope/qwen3.5-plus",
      "priority": "medium"
    },
    {
      "type": "research",
      "keywords": [
        "调研",
        "研究",
        "搜索",
        "查找",
        "资料",
