    },
    {
      "type": "devops",
      "keywords": [
        "部署",
        "服务器",
        "重启",
        "日志",
        "运维",
        "配置",
        "docker",
        "k8s"
      ],
      "agent": "devops",
      "model": "dashscope/qwen3.5-plus",
      "priority": "high"
