{
  "VAULT_PATH": "./prompt_vault.json",
  "DEFAULT_CATEGORIES": ["system", "task", "template", "snippet", "chain"],
  "TEAM_SETTINGS": {
    "default_author": "Team",
    "require_author": false,
    "require_category": true,
    "allow_duplicates": false
  },
  "RATING_SETTINGS": {
    "scale": 5,
    "require_notes": false
  },
  "SEARCH_SETTINGS": {
    "case_sensitive": false,
    "partial_match": true,
    "search_fields": ["name", "text", "notes"]
  },
  "BACKUP_SETTINGS": {
    "auto_backup": true,
    "max_backups": 5
  },
  "BROWSE_SETTINGS": {
    "default_output": "./prompt_vault_browse.html",
    "title": "Prompt Vault",
    "sort_by": "rating",
    "sort_order": "desc"
  },
  "VALIDATION": {
    "min_prompt_length": 10,
    "max_prompt_length": 10000,
    "max_name_length": 100
  }
}
