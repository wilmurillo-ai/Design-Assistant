{
  "agents": {
    "defaults": {
      "bootstrapMaxChars": 20000,
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "45m",
        "keepLastAssistants": 5,
        "softTrimRatio": 0.7,
        "hardClearRatio": 0.9,
        "minPrunableToolChars": 1000,
        "softTrim": {
          "maxChars": 12000,
          "headChars": 1000,
          "tailChars": 1000
        },
        "hardClear": {
          "enabled": true,
          "placeholder": "[tool result removed to save context]"
        }
      },
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 30000,
        "maxHistoryShare": 0.8,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 140000
        }
      },
      "timeoutSeconds": 900,
      "heartbeat": {
        "model": "anthropic/claude-haiku-4-5"
      },
      "subagents": {
        "archiveAfterMinutes": 60
      }
    }
  },
  "tools": {
    "web": {
      "fetch": {
        "maxChars": 50000
      }
    }
  },
  "session": {
    "maintenance": {
      "mode": "enforce",
      "pruneDays": 14,
      "maxEntries": 1000
    }
  },
  "plugins": {
    "entries": {
      "whatsapp": { "enabled": false },
      "discord": { "enabled": false },
      "slack": { "enabled": false },
      "nostr": { "enabled": false },
      "googlechat": { "enabled": false },
      "imessage": { "enabled": false },
      "signal": { "enabled": false }
    }
  }
}
