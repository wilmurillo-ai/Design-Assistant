{
  "agents": {
    "defaults": {
      "bootstrapMaxChars": 10000,
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "15m",
        "keepLastAssistants": 2,
        "softTrimRatio": 0.5,
        "hardClearRatio": 0.75,
        "minPrunableToolChars": 300,
        "softTrim": {
          "maxChars": 4000,
          "headChars": 300,
          "tailChars": 300
        },
        "hardClear": {
          "enabled": true,
          "placeholder": "[removed]"
        }
      },
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 50000,
        "maxHistoryShare": 0.5,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 80000
        }
      },
      "timeoutSeconds": 300,
      "heartbeat": {
        "model": "anthropic/claude-haiku-4-5"
      },
      "subagents": {
        "archiveAfterMinutes": 15
      }
    }
  },
  "tools": {
    "web": {
      "fetch": {
        "maxChars": 15000
      }
    }
  },
  "session": {
    "maintenance": {
      "mode": "enforce",
      "pruneDays": 3,
      "maxEntries": 200
    }
  },
  "plugins": {
    "entries": {
      "whatsapp": { "enabled": false },
      "discord": { "enabled": false },
      "slack": { "enabled": false },
      "nostr": { "enabled": false },
      "googlechat": { "enabled": false },
      "imessage": { "enabled": false },
      "signal": { "enabled": false }
    }
  }
}
