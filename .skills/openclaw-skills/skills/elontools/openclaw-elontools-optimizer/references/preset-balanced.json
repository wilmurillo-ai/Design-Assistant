{
  "agents": {
    "defaults": {
      "bootstrapMaxChars": 15000,
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "30m",
        "keepLastAssistants": 3,
        "softTrimRatio": 0.6,
        "hardClearRatio": 0.85,
        "minPrunableToolChars": 500,
        "softTrim": {
          "maxChars": 8000,
          "headChars": 500,
          "tailChars": 500
        },
        "hardClear": {
          "enabled": true,
          "placeholder": "[tool result removed to save context]"
        }
      },
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 40000,
        "maxHistoryShare": 0.7,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 120000
        }
      },
      "timeoutSeconds": 900,
      "heartbeat": {
        "model": "anthropic/claude-haiku-4-5"
      },
      "subagents": {
        "archiveAfterMinutes": 30
      }
    }
  },
  "tools": {
    "web": {
      "fetch": {
        "maxChars": 30000
      }
    }
  },
  "session": {
    "maintenance": {
      "mode": "enforce",
      "pruneDays": 7,
      "maxEntries": 500
    }
  },
  "plugins": {
    "entries": {
      "whatsapp": { "enabled": false },
      "discord": { "enabled": false },
      "slack": { "enabled": false },
      "nostr": { "enabled": false },
      "googlechat": { "enabled": false },
      "imessage": { "enabled": false },
      "signal": { "enabled": false }
    }
  }
}
