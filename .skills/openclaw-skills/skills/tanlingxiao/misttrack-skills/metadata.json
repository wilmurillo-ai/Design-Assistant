{
  "version": "1.0.0",
  "organization": "SlowMist",
  "date": "February 2026",
  "abstract": "MistTrack OpenAPI 技能包 - 基于 MistTrack 反洗钱追踪系统的 AI Agent 工具，支持加密货币地址风险评分（AML/KYT/KYA）、地址标签查询、地址概览、地址画像、交易调查、行为分析和交易对手分析。支持 BTC、ETH、TRX、BNB、SOL 等20+条链上的200+代币。",
  "supported_apis": [
    "v1/status",
    "v1/address_labels",
    "v1/address_overview",
    "v2/risk_score",
    "v2/risk_score_create_task",
    "v2/risk_score_query_task",
    "v1/transactions_investigation",
    "v1/address_action",
    "v1/address_trace",
    "v1/address_counterparty"
  ],
  "references": [
    "https://misttrack.io/",
    "https://docs.misttrack.io/",
    "https://docs.misttrack.io/openapi/overview",
    "https://dashboard.misttrack.io"
  ]
}