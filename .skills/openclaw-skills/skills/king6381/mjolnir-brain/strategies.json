  "pip_install_fail": {
    "description": "pip package installation failed",
    "match": ["pip install", "ModuleNotFoundError", "Could not find a version"],
    "solutions": [
      {"action": "Use mirror: pip install -i https://mirrors.example.com/pypi/simple/", "successRate": 0.90, "tries": 10, "env": "behind firewall"},
      {"action": "Upgrade setuptools: pip install --upgrade setuptools wheel", "successRate": 0.60, "tries": 5},
      {"action": "Try different Python version (3.11 has best compatibility)", "successRate": 0.40, "tries": 3, "env": "dependency incompatible"}
    ]
  },

  "npm_install_fail": {
    "description": "npm installation failed",
    "match": ["npm install", "npm ERR!", "EACCES"],
    "solutions": [
      {"action": "sudo npm install -g", "successRate": 0.80, "tries": 10, "requires_consent": true},
      {"action": "Use npx instead (no global install)", "successRate": 0.70, "tries": 5},
      {"action": "Fix npm prefix: npm config set prefix ~/.npm-global", "successRate": 0.60, "tries": 3}
    ]
  },

  "service_crash": {
    "description": "Service crash or won't start",
    "match": ["EADDRINUSE", "address already in use", "service crash", "restart failed"],
    "solutions": [
      {"action": "Check zombie processes: ps aux | grep <name> + lsof -i :<port>", "successRate": 0.75, "tries": 10},
      {"action": "Kill old PID + restart", "successRate": 0.70, "tries": 6},
      {"action": "Clean lock files + restart", "successRate": 0.55, "tries": 5},
      {"action": "Full reconfigure (keep data, rebuild config)", "successRate": 0.90, "tries": 3, "note": "last resort"}
    ]
  },

  "ssh_connect_fail": {
    "description": "SSH connection failed",
    "match": ["Connection refused", "Connection timed out", "Permission denied"],
