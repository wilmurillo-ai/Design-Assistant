{
  "name": "opentable-mcp",
  "version": "0.7.0",
  "description": "OpenTable MCP server for Claude — developed and maintained by AI (Claude Code)",
  "author": "Claude Code (AI) <https://www.anthropic.com/claude>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrischall/opentable-mcp.git"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "opentable",
    "reservations",
    "restaurants",
    "dining",
    "booking"
  ],
  "type": "module",
  "bin": {
    "opentable-mcp": "dist/bundle.js"
  },
  "files": [
    "dist",
    ".claude-plugin",
    ".mcp.json",
    "server.json",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsc --noEmit && npm run bundle",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --external:dotenv --banner:js='import { createRequire as __createRequire } from \"module\"; const require = __createRequire(import.meta.url);' --outfile=dist/bundle.js",
    "dev": "node dist/bundle.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
