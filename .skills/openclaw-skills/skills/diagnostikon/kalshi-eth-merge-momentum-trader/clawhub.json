{
  "emoji": "\u039e",
  "requires": {
    "env": [
      "SIMMER_API_KEY",
      "SOLANA_PRIVATE_KEY"
    ],
    "pip": [
      "simmer-sdk"
    ]
  },
  "cron": null,
  "autostart": false,
  "automaton": {
    "managed": true,
    "entrypoint": "trader.py"
  },
  "tunables": [
    {
      "env": "SIMMER_ETH_MERGE_ENTRY_EDGE",
      "type": "number",
      "default": 0.1,
      "range": [
        0.01,
        0.5
      ],
      "step": 0.01,
      "label": "Entry Edge"
    },
    {
      "env": "SIMMER_ETH_MERGE_EXIT_THRESHOLD",
      "type": "number",
      "default": 0.45,
      "range": [
        0.1,
        0.99
      ],
      "step": 0.01,
      "label": "Exit Threshold"
    },
    {
      "env": "SIMMER_ETH_MERGE_MAX_POSITION_USD",
      "type": "number",
      "default": 5.0,
      "range": [
        1,
        200
      ],
      "step": 1,
      "label": "Max Position Usd"
    },
    {
      "env": "SIMMER_ETH_MERGE_MAX_TRADES_PER_RUN",
      "type": "number",
      "default": 3,
      "range": [
        1,
        20
      ],
      "step": 1,
      "label": "Max Trades Per Run"
    },
    {
      "env": "SIMMER_ETH_MERGE_SLIPPAGE_MAX",
      "type": "number",
      "default": 0.15,
      "range": [
        0.05,
        1.0
      ],
      "step": 0.05,
      "label": "Slippage Max"
    },
    {
      "env": "SIMMER_ETH_MERGE_MIN_LIQUIDITY",
      "type": "number",
      "default": 0.0,
      "range": [
        0,
        10000
      ],
      "step": 100,
      "label": "Min Liquidity"
    },
    {
      "env": "SIMMER_ETH_MERGE_BURN_PCT",
      "type": "number",
      "default": 0.5,
      "range": [
        0.0,
        5.0
      ],
      "step": 0.01,
      "label": "Annual Burn Pct"
    },
    {
      "env": "SIMMER_ETH_MERGE_BASE_PRICE",
      "type": "number",
      "default": 3500.0,
      "range": [
        0,
        100000
      ],
      "step": 100,
      "label": "Base Eth Price"
    }
  ]
}
