{
  "emoji": "\ud83d\ude31\ud83d\udcca",
  "requires": {
    "env": [
      "SIMMER_API_KEY"
    ],
    "pip": [
      "simmer-sdk"
    ]
  },
  "cron": null,
  "autostart": false,
  "automaton": {
    "managed": true,
    "entrypoint": "trader.py"
  },
  "tunables": [
    {
      "env": "SIMMER_MAX_POSITION",
      "type": "number",
      "default": 40,
      "range": [
        1,
        200
      ],
      "step": 1,
      "label": "Max position size (USD)"
    },
    {
      "env": "SIMMER_MIN_TRADE",
      "type": "number",
      "default": 5,
      "range": [
        1,
        100
      ],
      "step": 1,
      "label": "Min trade size (USD)"
    },
    {
      "env": "SIMMER_MIN_VOLUME",
      "type": "number",
      "default": 3000,
      "range": [
        0,
        500000
      ],
      "step": 1000,
      "label": "Min market volume (USD)"
    },
    {
      "env": "SIMMER_MAX_SPREAD",
      "type": "number",
      "default": 0.1,
      "range": [
        0.01,
        0.5
      ],
      "step": 0.01,
      "label": "Max bid-ask spread"
    },
    {
      "env": "SIMMER_MIN_DAYS",
      "type": "number",
      "default": 7,
      "range": [
        0,
        180
      ],
      "step": 1,
      "label": "Min days until resolution"
    },
    {
      "env": "SIMMER_MAX_POSITIONS",
      "type": "number",
      "default": 10,
      "range": [
        1,
        20
      ],
      "step": 1,
      "label": "Max open positions"
    },
    {
      "env": "SIMMER_YES_THRESHOLD",
      "type": "number",
      "default": 0.38,
      "range": [
        0.01,
        0.49
      ],
      "step": 0.01,
      "label": "YES threshold"
    },
    {
      "env": "SIMMER_NO_THRESHOLD",
      "type": "number",
      "default": 0.62,
      "range": [
        0.51,
        0.99
      ],
      "step": 0.01,
      "label": "NO threshold"
    },
    {
      "env": "SIMMER_FEAR_THRESHOLD",
      "type": "number",
      "default": 0.65,
      "range": [
        0.4,
        0.9
      ],
      "step": 0.05,
      "label": "Fear index PANIC threshold"
    },
    {
      "env": "SIMMER_COMPLACENCY_THRESHOLD",
      "type": "number",
      "default": 0.3,
      "range": [
        0.1,
        0.5
      ],
      "step": 0.05,
      "label": "Fear index COMPLACENCY threshold"
    },
    {
      "env": "SIMMER_GEO_WEIGHT",
      "type": "number",
      "default": 0.35,
      "range": [
        0.0,
        1.0
      ],
      "step": 0.05,
      "label": "Geopolitical fear weight"
    },
    {
      "env": "SIMMER_CRYPTO_WEIGHT",
      "type": "number",
      "default": 0.3,
      "range": [
        0.0,
        1.0
      ],
      "step": 0.05,
      "label": "Crypto fear weight"
    },
    {
      "env": "SIMMER_HEALTH_WEIGHT",
      "type": "number",
      "default": 0.2,
      "range": [
        0.0,
        1.0
      ],
      "step": 0.05,
      "label": "Health fear weight"
    },
    {
      "env": "SIMMER_WEATHER_WEIGHT",
      "type": "number",
      "default": 0.15,
      "range": [
        0.0,
        1.0
      ],
      "step": 0.05,
      "label": "Weather fear weight"
    }
  ],
  "version": "0.0.2"
}