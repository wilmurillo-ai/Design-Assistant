{
  "emoji": "\ud83d\udea2",
  "requires": {
    "env": [
      "SIMMER_API_KEY"
    ],
    "pip": [
      "simmer-sdk"
    ]
  },
  "cron": null,
  "autostart": false,
  "automaton": {
    "managed": true,
    "entrypoint": "trader.py"
  },
  "tunables": [
    {
      "env": "SIMMER_MAX_POSITION",
      "default": 25,
      "range": [1, 200],
      "step": 1,
      "label": "Max position size (USD)",
      "type": "number"
    },
    {
      "env": "SIMMER_MIN_VOLUME",
      "default": 1000,
      "range": [0, 100000],
      "step": 500,
      "label": "Min market volume (USD)",
      "type": "number"
    },
    {
      "env": "SIMMER_MAX_SPREAD",
      "default": 0.12,
      "range": [0.01, 0.5],
      "step": 0.01,
      "label": "Max bid-ask spread",
      "type": "number"
    },
    {
      "env": "SIMMER_MIN_DAYS",
      "default": 0,
      "range": [0, 90],
      "step": 1,
      "label": "Min days until resolution",
      "type": "number"
    },
    {
      "env": "SIMMER_MAX_POSITIONS",
      "default": 8,
      "range": [1, 20],
      "step": 1,
      "label": "Max open positions",
      "type": "number"
    },
    {
      "env": "SIMMER_YES_THRESHOLD",
      "default": 0.42,
      "range": [0.01, 0.49],
      "step": 0.01,
      "label": "YES threshold",
      "type": "number"
    },
    {
      "env": "SIMMER_NO_THRESHOLD",
      "default": 0.58,
      "range": [0.51, 0.99],
      "step": 0.01,
      "label": "NO threshold",
      "type": "number"
    },
    {
      "env": "SIMMER_MIN_TRADE",
      "default": 5,
      "range": [1, 100],
      "step": 1,
      "label": "Min trade size (USD)",
      "type": "number"
    }
  ]
}
