{
  "emoji": "\u039e",
  "requires": {
    "env": [
      "SIMMER_API_KEY",
      "SOLANA_PRIVATE_KEY"
    ],
    "pip": [
      "simmer-sdk"
    ]
  },
  "cron": null,
  "autostart": false,
  "automaton": {
    "managed": true,
    "entrypoint": "trader.py"
  },
  "tunables": [
    {
      "env": "SIMMER_ETH_BTCBETA_ENTRY_EDGE",
      "type": "number",
      "default": 0.1,
      "range": [
        0.01,
        0.5
      ],
      "step": 0.01,
      "label": "Entry Edge"
    },
    {
      "env": "SIMMER_ETH_BTCBETA_EXIT_THRESHOLD",
      "type": "number",
      "default": 0.45,
      "range": [
        0.1,
        0.99
      ],
      "step": 0.01,
      "label": "Exit Threshold"
    },
    {
      "env": "SIMMER_ETH_BTCBETA_MAX_POSITION_USD",
      "type": "number",
      "default": 5.0,
      "range": [
        1,
        200
      ],
      "step": 1,
      "label": "Max Position Usd"
    },
    {
      "env": "SIMMER_ETH_BTCBETA_MAX_TRADES_PER_RUN",
      "type": "number",
      "default": 4,
      "range": [
        1,
        20
      ],
      "step": 1,
      "label": "Max Trades Per Run"
    },
    {
      "env": "SIMMER_ETH_BTCBETA_SLIPPAGE_MAX",
      "type": "number",
      "default": 0.15,
      "range": [
        0.05,
        1.0
      ],
      "step": 0.05,
      "label": "Slippage Max"
    },
    {
      "env": "SIMMER_ETH_BTCBETA_MIN_LIQUIDITY",
      "type": "number",
      "default": 0.0,
      "range": [
        0,
        10000
      ],
      "step": 100,
      "label": "Min Liquidity"
    },
    {
      "env": "SIMMER_ETH_BTCBETA_BETA",
      "type": "number",
      "default": 1.3,
      "range": [
        0,
        200
      ],
      "step": 1,
      "label": "Beta Factor"
    },
    {
      "env": "SIMMER_ETH_BTCBETA_LAG_HOURS",
      "type": "number",
      "default": 6.0,
      "range": [
        0,
        200
      ],
      "step": 1,
      "label": "Lag Window Hours"
    }
  ]
}
