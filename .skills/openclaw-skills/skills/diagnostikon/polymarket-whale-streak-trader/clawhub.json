{
  "emoji": "\ud83d\udc0b\ud83d\udd25",
  "requires": {"env": ["SIMMER_API_KEY"], "pip": ["simmer-sdk"]},
  "cron": null,
  "autostart": false,
  "automaton": {"managed": true, "entrypoint": "trader.py"},
  "tunables": [
    {"env": "SIMMER_MAX_POSITION", "type": "number", "default": 40, "range": [1, 200], "step": 1, "label": "Max position size (USD)"},
    {"env": "SIMMER_MIN_TRADE", "type": "number", "default": 5, "range": [1, 100], "step": 1, "label": "Min trade size (USD)"},
    {"env": "SIMMER_MIN_VOLUME", "type": "number", "default": 3000, "range": [0, 500000], "step": 1000, "label": "Min market volume (USD)"},
    {"env": "SIMMER_MAX_SPREAD", "type": "number", "default": 0.10, "range": [0.01, 0.5], "step": 0.01, "label": "Max bid-ask spread"},
    {"env": "SIMMER_MIN_DAYS", "type": "number", "default": 5, "range": [0, 180], "step": 1, "label": "Min days until resolution"},
    {"env": "SIMMER_MAX_POSITIONS", "type": "number", "default": 8, "range": [1, 20], "step": 1, "label": "Max open positions"},
    {"env": "SIMMER_YES_THRESHOLD", "type": "number", "default": 0.38, "range": [0.01, 0.49], "step": 0.01, "label": "YES threshold"},
    {"env": "SIMMER_NO_THRESHOLD", "type": "number", "default": 0.62, "range": [0.51, 0.99], "step": 0.01, "label": "NO threshold"},
    {"env": "SIMMER_HOT_WIN_RATE", "type": "number", "default": 0.65, "range": [0.5, 0.9], "step": 0.05, "label": "Hot streak win rate threshold"},
    {"env": "SIMMER_COLD_WIN_RATE", "type": "number", "default": 0.45, "range": [0.2, 0.6], "step": 0.05, "label": "Cold streak win rate threshold"},
    {"env": "SIMMER_STREAK_WINDOW", "type": "number", "default": 30, "range": [10, 100], "step": 5, "label": "Recent trades to evaluate"},
    {"env": "SIMMER_LEADERBOARD_LIMIT", "type": "number", "default": 20, "range": [5, 50], "step": 5, "label": "Top N wallets to scan"}
  ]
}
