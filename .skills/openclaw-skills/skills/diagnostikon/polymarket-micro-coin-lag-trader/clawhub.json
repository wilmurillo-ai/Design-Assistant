{
  "emoji": "\ud83d\udd17\u26a1",
  "requires": {
    "env": [
      "SIMMER_API_KEY"
    ],
    "pip": [
      "simmer-sdk"
    ]
  },
  "cron": null,
  "autostart": false,
  "automaton": {
    "managed": true,
    "entrypoint": "trader.py"
  },
  "tunables": [
    {
      "env": "SIMMER_MAX_POSITION",
      "type": "number",
      "default": 10,
      "range": [
        1,
        50
      ],
      "step": 1,
      "label": "Max position size USD"
    },
    {
      "env": "SIMMER_MIN_TRADE",
      "type": "number",
      "default": 2,
      "range": [
        1,
        20
      ],
      "step": 1,
      "label": "Min trade size USD"
    },
    {
      "env": "SIMMER_MAX_SPREAD",
      "type": "number",
      "default": 0.12,
      "range": [
        0.01,
        0.5
      ],
      "step": 0.01,
      "label": "Max bid-ask spread"
    },
    {
      "env": "SIMMER_MAX_POSITIONS",
      "type": "number",
      "default": 15,
      "range": [
        1,
        30
      ],
      "step": 1,
      "label": "Max open positions"
    },
    {
      "env": "SIMMER_LEAD_THRESHOLD",
      "type": "number",
      "default": 0.6,
      "range": [
        0.51,
        0.8
      ],
      "step": 0.01,
      "label": "BTC lead signal threshold"
    },
    {
      "env": "SIMMER_MIN_VOLUME",
      "type": "number",
      "default": 1000,
      "range": [
        0,
        100000
      ],
      "step": 500,
      "label": "Min market volume USD"
    },
    {
      "env": "SIMMER_YES_THRESHOLD",
      "type": "number",
      "default": 0.42,
      "range": [
        0.2,
        0.5
      ],
      "step": 0.01,
      "label": "YES threshold (buy below)"
    },
    {
      "env": "SIMMER_NO_THRESHOLD",
      "type": "number",
      "default": 0.58,
      "range": [
        0.5,
        0.8
      ],
      "step": 0.01,
      "label": "NO threshold (sell above)"
    },
    {
      "env": "SIMMER_MIN_DAYS",
      "type": "number",
      "default": 0,
      "range": [
        0,
        30
      ],
      "step": 1,
      "label": "Min days until resolution"
    }
  ],
  "version": "0.0.2"
}