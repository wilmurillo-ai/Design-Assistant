{
  "emoji": "\ud83d\udd04\ud83d\udc0b",
  "requires": {"env": ["SIMMER_API_KEY"], "pip": ["simmer-sdk"]},
  "cron": null,
  "autostart": false,
  "automaton": {"managed": true, "entrypoint": "trader.py"},
  "tunables": [
    {"env": "SIMMER_MAX_POSITION", "type": "number", "default": 50, "range": [1, 200], "step": 1, "label": "Max position size (USD)"},
    {"env": "SIMMER_MIN_TRADE", "type": "number", "default": 5, "range": [1, 100], "step": 1, "label": "Min trade size (USD)"},
    {"env": "SIMMER_MIN_VOLUME", "type": "number", "default": 3000, "range": [0, 500000], "step": 1000, "label": "Min market volume (USD)"},
    {"env": "SIMMER_MAX_SPREAD", "type": "number", "default": 0.10, "range": [0.01, 0.5], "step": 0.01, "label": "Max bid-ask spread"},
    {"env": "SIMMER_MIN_DAYS", "type": "number", "default": 3, "range": [0, 180], "step": 1, "label": "Min days until resolution"},
    {"env": "SIMMER_MAX_POSITIONS", "type": "number", "default": 10, "range": [1, 20], "step": 1, "label": "Max open positions"},
    {"env": "SIMMER_YES_THRESHOLD", "type": "number", "default": 0.38, "range": [0.01, 0.49], "step": 0.01, "label": "YES threshold"},
    {"env": "SIMMER_NO_THRESHOLD", "type": "number", "default": 0.62, "range": [0.51, 0.99], "step": 0.01, "label": "NO threshold"},
    {"env": "SIMMER_ROSTER_SIZE", "type": "number", "default": 5, "range": [2, 15], "step": 1, "label": "Max wallets in active roster"},
    {"env": "SIMMER_MIN_PNL", "type": "number", "default": 0, "range": [-1000, 10000], "step": 100, "label": "Min rolling PnL to qualify"},
    {"env": "SIMMER_COPY_MAX_USD", "type": "number", "default": 50, "range": [5, 500], "step": 5, "label": "Max USD per copied position"},
    {"env": "SIMMER_COPY_MAX_TRADES", "type": "number", "default": 10, "range": [1, 30], "step": 1, "label": "Max trades per run"}
  ]
}
