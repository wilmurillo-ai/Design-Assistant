      {"name": "notion_query_database", "description": "Query a Notion database", "parameters": {"type": "object", "properties": {"database_id": {"type": "string"}}, "required": ["database_id"]}},
      {"name": "notion_search", "description": "Search Notion pages", "parameters": {"type": "object", "properties": {"query": {"type": "string"}}}}
    ]
  },
  "env": [{"name": "NOTION_API_KEY", "description": "Notion API Key", "required": true}],
