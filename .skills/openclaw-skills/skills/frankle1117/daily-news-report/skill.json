{
  "name": "daily-news-brief",
  "version": "1.0.0",
  "description": "每日新闻摘要推送 - 定时抓取、去重、分类、改写新闻并推送到Telegram",
  "author": "OpenClaw Team",
  "license": "MIT",
  "main": "index.ts",
  "keywords": [
    "news",
    "daily-brief",
    "telegram",
    "robot",
    "real-estate",
    "ai"
  ],
  "permissions": [
    "internet",
    "file-system:read",
    "file-system:write",
    "env:read"
  ],
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "node-cron": "^3.0.3",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0"
  },
  "config": {
    "mode": {
      "type": "string",
      "enum": ["all", "focused"],
      "default": "all",
      "description": "监控模式：全量模式 或 重点领域模式"
    },
    "focus_topics": {
      "type": "array",
      "default": ["robot", "real_estate", "ai"],
      "description": "重点领域监控的话题"
    },
    "sources": {
      "primary": {
        "type": "array",
        "default": ["cls", "ithome", "36kr"],
        "description": "主要新闻源"
      },
      "backup": {
        "type": "array",
        "default": [],
        "description": "备用新闻源"
      }
    },
    "schedule": {
      "type": "array",
      "default": ["08:00", "17:30", "22:30"],
      "description": "定时执行时间"
    },
    "max_items": {
      "type": "number",
      "default": 15,
      "description": "最大新闻条数"
    },
    "include_links": {
      "type": "boolean",
      "default": true,
      "description": "是否包含链接"
    },
    "timezone": {
      "type": "string",
      "default": "Asia/Shanghai",
      "description": "时区"
    },
    "telegram_chat_id": {
      "type": "string",
      "default": "",
      "description": "Telegram Chat ID"
    },
    "telegram_bot_token": {
      "type": "string",
      "default": "",
      "description": "Telegram Bot Token"
    }
  },
  "commands": {
    "run": {
      "description": "执行一次新闻抓取和推送",
      "usage": "daily-news-brief run"
    },
    "test": {
      "description": "测试模式执行（不发送推送）",
      "usage": "daily-news-brief test"
    },
    "start": {
      "description": "启动定时任务",
      "usage": "daily-news-brief start"
    },
    "config": {
      "description": "查看当前配置",
      "usage": "daily-news-brief config"
    }
  }
}