{
  "region": "cn",
  "judge_model": "glm-5-judge",
  "max_models": 3,
  "depth": "simple",
  "max_tokens": 8192,
  "max_tokens_judge": 16384,

  "models": {
    "glm-5": {
      "provider": "openrouter",
      "model_id": "z-ai/glm-5:online",
      "api_base": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "timeout": 60,
      "roles": ["general", "retrieval", "analysis"]
    },
    "minimax-m2.5": {
      "provider": "openrouter",
      "model_id": "minimax/minimax-m2.5:online",
      "api_base": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "timeout": 60,
      "roles": ["reasoning", "creative", "synthesis", "analysis"]
    },
    "qwen3.5": {
      "provider": "openrouter",
      "model_id": "qwen/qwen3.5-35b-a3b:online",
      "api_base": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "timeout": 60,
      "roles": ["structured", "retrieval", "coding", "technical", "math"]
    },
    "kimi-k2.5": {
      "provider": "openrouter",
      "model_id": "moonshotai/kimi-k2.5:online",
      "api_base": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "timeout": 60,
      "roles": ["longcontext", "retrieval", "current_events", "research", "factual"]
    },
    "deepseek-v3.2": {
      "provider": "openrouter",
      "model_id": "deepseek/deepseek-v3.2:online",
      "api_base": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "timeout": 60,
      "roles": ["coding", "technical", "reasoning", "analysis"]
    },
    "glm-5-judge": {
      "provider": "openrouter",
      "model_id": "z-ai/glm-5",
      "api_base": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "timeout": 60,
      "roles": ["judge"]
    },
    "qwen3.5-judge": {
      "provider": "openrouter",
      "model_id": "qwen/qwen3.5-35b-a3b:online",
      "api_base": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "timeout": 60,
      "roles": ["judge"]
    }
  },

  "routing": {
    "financial": {
      "models": ["kimi-k2.5", "qwen3.5", "glm-5"],
      "judge_prompt": "judge_financial"
    },

    "technical": {
      "models": ["qwen3.5", "deepseek-v3.2", "kimi-k2.5"]
    },

    "social": {
      "models": ["kimi-k2.5", "minimax-m2.5"]
    },

    "current_events": {
      "models": ["kimi-k2.5", "glm-5", "qwen3.5"]
    },

    "scientific": {
      "models": ["qwen3.5", "deepseek-v3.2", "kimi-k2.5"]
    },

    "creative": {
      "models": ["minimax-m2.5", "kimi-k2.5", "glm-5"]
    },

    "general": {
      "models": ["kimi-k2.5", "glm-5", "minimax-m2.5"]
    }
  }
}
