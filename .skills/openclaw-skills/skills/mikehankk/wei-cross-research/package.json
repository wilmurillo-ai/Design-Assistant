{
  "name": "wei-research",
  "version": "1.1.0",
  "description": "Multi-Model Researcher - Query multiple LLMs in parallel and synthesize responses",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "bun:dev": "bun scripts/index.ts",
    "bun:start": "bun run scripts/index.ts",
    "bun:agent": "bun run scripts/agent.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "@types/bun": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
