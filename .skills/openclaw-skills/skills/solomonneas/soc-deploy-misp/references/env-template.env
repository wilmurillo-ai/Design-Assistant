# MISP .env template
# Copy to misp-docker/.env and customize

# MISP Core
MISP_BASEURL=http://CHANGE_ME
MISP_ADMIN_EMAIL=admin@misp.local
MISP_ADMIN_PASSPHRASE=CHANGE_ME

# MySQL/MariaDB
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=misp
MYSQL_USER=misp
MYSQL_PASSWORD=CHANGE_ME_RANDOM
MYSQL_ROOT_PASSWORD=CHANGE_ME_RANDOM

# CRITICAL: Scale based on host RAM
# 4GB host = 512M, 8GB = 2048M, 16GB = 4096M
INNODB_BUFFER_POOL_SIZE=512M

# Redis
REDIS_FQDN=redis

# MISP Modules
MISP_MODULES_URL=http://misp-modules
