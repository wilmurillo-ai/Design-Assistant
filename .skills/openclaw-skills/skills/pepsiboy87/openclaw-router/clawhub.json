{
  "name": "openclaw-router",
  "version": "1.0.0",
  "description": "Intelligent Model Routing - Save 60% on AI Costs / 智能路由系统 - 节省 60% 成本",
  "author": "pepsiboy87",
  "license": "MIT",
  "homepage": "https://github.com/pepsiboy87/openclaw-router",
  "repository": "https://github.com/pepsiboy87/openclaw-router",
  
  "category": "automation",
  "tags": [
    "routing",
    "model-selection",
    "cost-optimization",
    "llm",
    "ai",
    "i18n",
    "global",
    "automation",
    "openclaw"
  ],
  
  "languages": [
    "en",
    "zh"
  ],
  
  "regions": [
    "global",
    "china",
    "us",
    "eu",
    "asia"
  ],
  
  "cloud_providers": [
    "alibaba_cloud",
    "openai",
    "anthropic",
    "aws_bedrock",
    "azure_openai",
    "google_vertex"
  ],
  
  "currencies": [
    "USD",
    "CNY",
    "EUR"
  ],
  
  "pricing": {
    "type": "free",
    "license": "MIT",
    "note": "Free and open source (MIT License). All core features free forever.",
    "support": {
      "community": {
        "type": "free",
        "price": 0,
        "response_time": "Best effort",
        "channels": ["GitHub Issues", "Discord"]
      },
      "priority": {
        "type": "paid",
        "price": 29,
        "currency": "CNY",
        "billing_cycle": "monthly",
        "response_time": "24 hours",
        "channels": ["Email", "WeChat"],
        "features": [
          "优先支持",
          "远程协助",
          "定制配置",
          "定期更新"
        ]
      },
      "enterprise": {
        "type": "paid",
        "price": 199,
        "currency": "CNY",
        "billing_cycle": "monthly",
        "response_time": "4 hours",
        "channels": ["专属微信", "电话"],
        "features": [
          "多用户管理",
          "API 访问",
          "SLA 保障",
          "专属支持",
          "私有化部署",
          "定制开发"
        ]
      }
    }
  },
  
  "requirements": {
    "openclaw": ">=2026.2.24",
    "python": ">=3.8",
    "system": {
      "memory_min_gb": 2,
      "disk_min_gb": 1
    }
  },
  
  "dependencies": {
    "python_packages": [
      "requests>=2.28.0",
      "psutil>=5.9.0",
      "pyyaml>=6.0"
    ]
  },
  
  "entry_point": "src/__init__.py",
  "main_script": "router_config_wizard.py",
  "config_template": "config/default.yaml",
  
  "features": [
    "5 维度自评系统",
    "智能模型选择",
    "环境自动检测",
    "一键配置向导",
    "Token 用量追踪",
    "成本预算管理",
    "用户偏好学习",
    "全场景支持"
  ],
  
  "supported_models": {
    "local": [
      "qwen2.5:7b",
      "qwen2.5:14b",
      "qwen2.5:72b"
    ],
    "cloud": [
      "dashscope/qwen3.5-plus",
      "dashscope/qwen3-max",
      "dashscope/kimi-k2.5",
      "dashscope/qwen-vl-max",
      "dashscope/qwen-vl-plus",
      "openai/gpt-4",
      "openai/gpt-4o",
      "anthropic/claude-3",
      "anthropic/claude-3-opus",
      "anthropic/claude-3-sonnet",
      "anthropic/claude-3-haiku"
    ]
  },
  
  "optional_features": {
    "vision": {
      "name": "视觉识别",
      "description": "图像理解、OCR、截图分析",
      "required": false,
      "providers": [
        {
          "name": "Anthropic Claude-3",
          "env": "ANTHROPIC_API_KEY",
          "models": ["claude-3-opus", "claude-3-sonnet", "claude-3-haiku"],
          "cost": "$0.00025-0.015/次"
        },
        {
          "name": "OpenAI GPT-4o",
          "env": "OPENAI_API_KEY",
          "models": ["gpt-4o", "gpt-4-turbo"],
          "cost": "$0.005-0.03/次"
        },
        {
          "name": "阿里云 qwen-vl",
          "env": "DASHSCOPE_API_KEY",
          "models": ["qwen-vl-max", "qwen-vl-plus"],
          "cost": "¥0.01-0.03/次"
        }
      ]
    }
  },
  
  "documentation": {
    "readme": "README.md",
    "configuration": "docs/CONFIGURATION.md",
    "api": "docs/API.md",
    "examples": "docs/EXAMPLES.md",
    "faq": "docs/FAQ.md"
  },
  
  "changelog": {
    "3.0.0": {
      "date": "2026-03-02",
      "changes": [
        "全新架构，模块化设计",
        "环境自动检测",
        "智能配置推荐",
        "5 维度自评系统",
        "全场景支持",
        "Token 用量显示",
        "成本预算管理",
        "多语言支持（EN/ZH）",
        "全球化合规（GDPR/CCPA/PIPL）",
        "完全免费开源（MIT）"
      ]
    }
  }
}
