{
  "name": "e2e-test-recorder",
  "version": "1.0.0",
  "description": "Automated end-to-end test recorder with screen recording capabilities",
  "main": "scripts/record-browser.js",
  "bin": {
    "e2e-test": "./scripts/cli.js"
  },
  "scripts": {
    "start": "node scripts/cli.js",
    "record": "node scripts/cli.js record",
    "test": "node scripts/record-test.js",
    "demo": "node examples/basic-recording.js",
    "build": "echo 'No build step required'",
    "lint": "eslint scripts/ examples/",
    "format": "prettier --write scripts/ examples/ configs/"
  },
  "keywords": [
    "e2e-test",
    "screen-recording",
    "automation",
    "testing",
    "puppeteer",
    "video-recording",
    "workbuddy",
    "openclaw",
    "skill"
  ],
  "author": "Multi-Agent Flow Team",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.0.0",
    "commander": "^11.0.0",
    "ffmpeg-static": "^5.0.0",
    "fs-extra": "^11.0.0",
    "inquirer": "^8.0.0",
    "ora": "^5.0.0",
    "puppeteer": "^21.0.0",
    "puppeteer-screen-recorder": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/e2e-test-recorder.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/e2e-test-recorder/issues"
  },
  "homepage": "https://github.com/your-org/e2e-test-recorder#readme",
  "files": [
    "scripts/",
    "configs/",
    "templates/",
    "examples/",
    "SKILL.md",
    "README.md",
    "package.json"
  ]
}
