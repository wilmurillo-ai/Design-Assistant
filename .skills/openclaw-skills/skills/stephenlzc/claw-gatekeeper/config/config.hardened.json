{
  "_comment": "Hardened Security Configuration for Claw Gatekeeper v0.1.0",
  "_description": "Maximum safety mode: all operations require human approval, strict rules engine, no auto-allow",
  "_security_level": "maximum",
  
  "version": "1.0.0-hardened",
  "mode": "standard",
  "enabled": true,
  
  "_approval_policy": "ALL operations require human confirmation - human-in-the-loop mode",
  "critical_requires_approval": true,
  "high_requires_approval": true,
  "medium_requires_approval": true,
  "low_auto_allow": false,
  
  "_whitelist": "Safe operations that bypass detailed analysis but still require confirmation in strict mode",
  "whitelist_paths": [
    "~/Downloads",
    "~/Documents",
    "/tmp",
    "~/workspace",
    "~/projects"
  ],
  "whitelist_commands": [
    "ls",
    "pwd",
    "cat",
    "echo",
    "grep",
    "head",
    "tail",
    "less",
    "more",
    "git status",
    "git log",
    "git diff",
    "git branch",
    "git remote -v",
    "find . -name",
    "wc -l",
    "mkdir -p",
    "touch",
    "cp",
    "mv",
    "rm -i",
    "rmdir",
    "python3 --version",
    "node --version",
    "npm --version",
    "which",
    "type"
  ],
  "whitelist_domains": [
    "raw.githubusercontent.com",
    "pypi.org",
    "registry.npmjs.org",
    "api.github.com"
  ],
  "whitelist_skills": [],
  
  "_blacklist": "Dangerous operations - immediate rejection without LLM consultation",
  "blacklist_paths": [
    "/etc/passwd",
    "/etc/shadow",
    "/etc/sudoers",
    "/etc/ssh",
    "~/.ssh",
    "~/.gnupg",
    "~/.aws",
    "~/.kube",
    "~/.docker",
    "~/.npmrc",
    "~/.pypirc",
    "~/.openclaw",
    "~/.*_history",
    "~/.bash_history",
    "~/.zsh_history",
    "~/.zhistory",
    "/var/log",
    "/var/lib",
    "/proc",
    "/sys",
    "/dev/sd*"
  ],
  "blacklist_commands": [
    "rm -rf /",
    "rm -rf /*",
    "rm -rf ~",
    "rm -rf ~/",
    "rm -rf $HOME",
    "rm -rf /home",
    "mkfs",
    "mkfs.ext",
    "mkfs.ntfs",
    "mkfs.vfat",
    "dd if=",
    "dd of=",
    "format",
    "fdisk",
    "parted",
    "> /dev/sd",
    "> /dev/hd",
    "chmod -R 777 /",
    "chmod -R 777 /*",
    "chown -R root:root /",
    ":(){ :|:& };:",
    "fork bomb",
    "curl .* | sh",
    "curl .* | bash",
    "wget .* | sh",
    "wget .* | bash",
    "eval $(",
    "eval `",
    "python -c 'import os; os.system",
    "python3 -c 'import os; os.system",
    "perl -e 'system",
    "ruby -e 'exec",
    "nc -e",
    "netcat -e",
    "bash -i >& /dev/tcp",
    "sh -i >& /dev/tcp",
    "openssl s_client",
    "socat",
    "ncat -e"
  ],
  "blacklist_domains": [
    "localhost",
    "127.0.0.1",
    "0.0.0.0",
    "*.local",
    "169.254.",
    "10.",
    "192.168.",
    "172.16."
  ],
  "blacklist_skills": [],
  
  "_behavior_settings": "Strict mode with minimal automation",
  "batch_threshold": 3,
  "log_all_operations": true,
  "log_decisions": true,
  "alert_on_repeated_denial": true,
  "auto_learn": false,
  "emergency_stop": false,
  "check_hidden_files": true,
  "strict_mode": true,
  
  "_ui_settings": "User-friendly but secure",
  "use_colors": true,
  "compact_mode": false,
  "confirmation_timeout": 300,
  
  "_auto_decision": "DISABLED - all operations require human confirmation",
  "auto_allow_low": false,
  "auto_allow_medium": false,
  "auto_allow_high": false,
  
  "_security_notes": {
    "description": "Hardened configuration for maximum safety with human-in-the-loop",
    "approval_workflow": "Rules engine → Risk scoring → Human confirmation → Execution",
    "llm_usage": "Rules engine handles 90% of decisions; no conversation context sent to LLM",
    "data_minimization": "Decisions based on operation type and command patterns only",
    "fallback_mode": "If LLM unavailable, defaults to DENY (fail-secure)",
    "audit_policy": "All operations logged, 30-day retention via external cron",
    "session_management": "Session approvals available for MEDIUM/HIGH, CRITICAL always requires individual confirmation",
    "last_updated": "2026-03-12"
  }
}
