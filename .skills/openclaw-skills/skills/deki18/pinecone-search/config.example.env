# Pinecone API Key
# 从 Pinecone 控制台获取: https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here

# 向量嵌入 API Key
# 从你的向量服务提供商获取
EMBEDDING_API_KEY=your_embedding_api_key_here

# Embedding API base URL (OpenAI compatible)
EMBEDDING_BASE_URL=https://api.openai.com/v1

# 向量嵌入模型
# 示例: text-embedding-3-large, text-embedding-3-small, etc.
EMBEDDING_MODEL=text-embedding-3-large

# Pinecone index name
INDEX_NAME=your-index-name

# Pinecone namespace (optional)
# Used to isolate different types of data
# Leave empty if namespace isolation is not needed
NAMESPACE=default
