# ── Binance API ────────────────────────────────────────────────────────────────
# Read-only keys — no trade/withdraw permissions needed
BINANCE_API_KEY=your_read_only_api_key_here
BINANCE_API_SECRET=your_read_only_api_secret_here

# ── Anthropic (Claude AI) ──────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# AI model to use — run '/models' in Telegram or 'models' in CLI to see all options
# Fast & cheap:    claude-haiku-4-5-20251001   ← recommended for daily use
# Best quality:    claude-sonnet-4-6
# Most powerful:   claude-opus-4-6
AI_MODEL=claude-haiku-4-5-20251001

# ── Telegram Bot ───────────────────────────────────────────────────────────────
# Create a bot at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your Telegram user ID — only this user can interact with the bot
# Find yours: https://t.me/userinfobot
TELEGRAM_USER_ID=your_telegram_user_id_here

# ── Language ────────────────────────────────────────────────────────────────────
# en = English | nl = Nederlands
LANGUAGE=en

# ── User Preferences ────────────────────────────────────────────────────────────
RISK_PROFILE=moderate          # conservative / moderate / aggressive
BASE_CURRENCY=USDT
FIAT_CURRENCY=EUR
DCA_BUDGET_MONTHLY=500         # Monthly DCA budget in FIAT_CURRENCY
