      ]
    }
  ],

  "compatibility": {
    "openclaw_min": "2025.1",
    "gateway_min": "1.0",
    "breaking_changes": []
  },

  "permissions": {
    "file_system": {
      "read": [
        "csv_path (user configured)",
        "db_path (user configured)",
        "config.json (skill directory)"
      ],
      "write": [
        "config.json (skill directory)",
        "user specified export paths"
      ]
    },
    "subprocess": {
      "allowed": ["C:\\Program Files\\Quicker\\QuickerStarter.exe"],
      "restricted": true
    },
    "network": false,
    "system": {
      "platform": ["windows"]
    }
  },

  "metadata": {
    "optimized": true,
    "optimization_tool": "advanced-skill-creator",
    "optimization_date": "2026-03-28",
    "security_audit": {
      "status": "passed",
      "date": "2026-03-28",
      "tool": "skill-vetting",
      "findings": []
    },
    "publish_ready": true
  }
}
