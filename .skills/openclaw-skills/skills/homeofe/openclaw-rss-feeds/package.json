{
  "name": "@elvatis_com/openclaw-rss-feeds",
  "version": "0.2.0",
  "description": "OpenClaw plugin - RSS/Atom feed digest with CVE enrichment and Ghost CMS drafts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/__tests__",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": ["openclaw", "openclaw-plugin", "rss", "feeds", "cve", "security", "digest", "ghost"],
  "author": "Elvatis <hello@example.invalid>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elvatis/openclaw-rss-feeds.git"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.0",
    "node-cron": "^3.0.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
