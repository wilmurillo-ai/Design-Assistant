  "repository": {
    "type": "git",
    "url": "git+https://github.com/elvatis/openclaw-ispconfig.git"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "overrides": {
    "test-exclude": "^7.0.1"
  }
