{
  "id": "vibe-reading-skill",
  "name": "Vibe Reading Skill",
  "version": "0.1.0",
  "description": "Intelligent reading analysis Agent Skill that helps users quickly understand the core content of voluminous works. Through AI's deep reading and structured analysis, transforms entire books into digestible summary reports.",
  "author": "Your Name",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/vibe-reading-skill.git"
  },
  "entry_point": {
    "module": "vibe_reading_skill",
    "function": "process_book"
  },
  "parameters": {
    "input_path": {
      "type": "string",
      "required": true,
      "description": "Input file path (EPUB or TXT format)",
      "example": "book.epub"
    },
    "output_dir": {
      "type": "string",
      "required": false,
      "description": "Output directory (optional, default uses project directory structure)",
      "default": null
    },
    "api_key": {
      "type": "string",
      "required": false,
      "description": "Gemini API Key (optional, can also be set via environment variable GEMINI_API_KEY)",
      "default": null
    },
    "model": {
      "type": "string",
      "required": false,
      "description": "Gemini model to use (optional, default gemini-2.5-pro)",
      "default": "gemini-2.5-pro",
      "options": [
        "gemini-3-pro",
        "gemini-3",
        "gemini-2.5-pro",
        "gemini-2.5-flash",
        "gemini-1.5-pro",
        "gemini-1.5-flash"
      ]
    }
  },
  "returns": {
    "type": "object",
    "properties": {
      "status": {
        "type": "string",
        "description": "Processing status: 'success' or 'error'"
      },
      "message": {
        "type": "string",
        "description": "Processing result message"
      },
      "output_paths": {
        "type": "object",
        "description": "Output file paths",
        "properties": {
          "chapters": {
            "type": "string",
            "description": "Chapter file directory"
          },
          "summaries": {
            "type": "string",
            "description": "Summary file directory"
          },
          "pdf": {
            "type": "string",
            "description": "PDF file path (if generated)"
          },
          "html": {
            "type": "string",
            "description": "HTML file path (if generated)"
          }
        }
      },
      "metadata": {
        "type": "object",
        "description": "Processing metadata",
        "properties": {
          "book_title": {
            "type": "string",
            "description": "Book title"
          },
          "chapter_count": {
            "type": "integer",
            "description": "Chapter count"
          },
          "processing_time": {
            "type": "number",
            "description": "Processing time (seconds)"
          }
        }
      }
    }
  },
  "requirements": {
    "python": ">=3.8",
    "dependencies": [
      "google-generativeai",
      "ebooklib",
      "markdown",
      "playwright"
    ]
  },
  "features": [
    "Intelligent chapter identification",
    "AI-driven deep analysis",
    "Contextual coherent understanding",
    "Multiple format output (Markdown, PDF, HTML)",
    "Multi-language support",
    "Interactive Q&A interface"
  ],
  "tags": [
    "reading",
    "analysis",
    "ai",
    "book",
    "epub",
    "summarization",
    "gemini"
  ]
}
