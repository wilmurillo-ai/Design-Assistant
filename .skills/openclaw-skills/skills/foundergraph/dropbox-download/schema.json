{
  "name": "Download File",
  "description": "Download a file from Dropbox",
  "type": "tool",
  "tool": {
    "type": "http",
    "method": "POST",
    "url": "https://api.dropboxapi.com/2/files/download",
    "headers": {
      "Authorization": "Bearer dropbox.api_key",
      "Content-Type": "application/json"
    },
    "body": {
      "dynamic": "{{inputs}}"
    }
  },
  "properties": [
    {
      "name": "path",
      "type": "string",
      "description": "The path of the file to download.",
      "source": "input"
    },
    {
      "name": "rev",
      "type": "string",
      "description": "Please specify revision in path instead.",
      "source": "input"
    }
  ],
  "input_schema": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string",
        "description": "The path of the file to download."
      },
      "rev": {
        "type": "string",
        "description": "Optional revision identifier (deprecated, specify in path instead)."
      }
    },
    "required": [
      "path"
    ]
  }
}
