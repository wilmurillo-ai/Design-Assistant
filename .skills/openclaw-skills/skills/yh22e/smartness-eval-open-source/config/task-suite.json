    {
      "id": "robust_special_chars",
      "name": "特殊字符输入不崩溃",
      "tags": ["standard"],
      "type": "exit_code",
      "command": ["python3", "scripts/cognitive-kernel-v6.py", "--process", "{}[]<>\"'\\n\\t&&||;$()"],
      "expected": 0,
      "dimensions": {"robustness": 0.8}
    },
    {
      "id": "robust_unicode",
      "name": "Unicode输入正常处理",
      "tags": ["deep"],
      "type": "json_path_exists",
      "command": ["python3", "scripts/cognitive-kernel-v6.py", "--process", "🎬 帮我做个视频 📹"],
      "path": "intent.primary",
      "dimensions": {"robustness": 0.5}
