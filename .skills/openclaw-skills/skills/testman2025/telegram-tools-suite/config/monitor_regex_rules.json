    ["开卡", "(?<![不没])(?:开卡|开\\s*卡)"],
    ["绑定", "(?<!不)绑定"],
    ["bin", "\\bbin\\b", "i"],
    ["绑定/绑卡+广告平台", "(?is)(?=.*(?:绑定|绑\\s*卡))(?=.*{_PLATFORM_AD})"],
    ["开卡+广告平台", "(?is)(?=.*(?<![不没])(?:开卡|开\\s*卡))(?=.*{_PLATFORM_AD})"],
    ["vcc+广告平台", "(?is)(?=.*\\bvcc\\b)(?=.*{_PLATFORM_AD})"],
    ["虚拟卡+广告平台", "(?is)(?=.*(?:虚拟卡|虚拟\\s*信用卡))(?=.*{_PLATFORM_AD})"]
  ]
}
