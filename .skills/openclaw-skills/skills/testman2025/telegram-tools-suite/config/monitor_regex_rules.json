{
  "_PLATFORM_AD": "(?:\\b(?:facebook|google|tiktok|meta)\\s+ads\\b|\\badvertisement\\b|(?:谷歌|Google|脸书|Facebook|Meta|TikTok|抖音)\\s*广告)",
  "rules": [
