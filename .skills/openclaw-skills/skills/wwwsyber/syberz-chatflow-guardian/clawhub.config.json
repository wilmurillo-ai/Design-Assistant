  "tags": [
    "conversation",
    "monitoring",
    "ai-assistant",
    "predictive",
    "deep-learning",
    "multi-platform",
    "chat",
    "productivity"
  ],
  
  "categories": [
    "productivity",
    "communication",
    "ai-assistant"
  ],
  
  "platforms": [
    "qqbot",
    "wecom",
    "slack",
    "dingtalk",
    "wechat",
    "discord",
    "telegram",
    "whatsapp"
  ],
  
  "configuration": {
    "monitoring": {
      "check_interval": 180,
      "response_threshold": 180,
      "quiet_hours": ["23:00-07:00"]
    },
    "platforms": {
      "enabled": true,
      "supported": ["qqbot", "wecom", "slack", "dingtalk"]
    },
    "predictive": {
      "enabled": true,
      "prediction_threshold": 0.7
    },
    "deeplearning": {
      "enabled": true,
      "use_pretrained": true
    }
  },
  
  "requirements": {
    "openclaw": ">=2026.3.0",
    "node": ">=16.0.0",
    "memory": ">=512MB",
    "storage": ">=10MB"
  },
  
  "dependencies": {
    "node-cron": "^3.0.2",
    "winston": "^3.11.0",
    "lodash": "^4.17.21"
  },
  
  "main": "src/index.js",
  
  "scripts": {
    "start": "node src/index.js",
    "test": "node tests/run-tests.js",
    "demo": "node scripts/enhanced-demo.js"
  },
  
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0"
  },
  
  "repository": {
    "type": "git",
    "url": "https://github.com/syberZ/chatflow-guardian"
  },
  
  "homepage": "https://github.com/syberZ/chatflow-guardian",
  
  "bugs": {
    "url": "https://github.com/syberZ/chatflow-guardian/issues"
  },
  
