{
  "name": "openclaw-skill-turboquant-optimizer",
  "version": "2.0.0",
  "description": "Comprehensive token and memory optimization for OpenClaw, inspired by Google's TurboQuant research",
  "main": "lib/index.js",
  "bin": {
    "turboquant": "./bin/turboquant"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "benchmark": "node bin/turboquant benchmark",
    "analyze": "node bin/turboquant analyze",
    "lint": "eslint lib/ bin/ test/"
  },
  "keywords": [
    "openclaw",
    "skill",
    "turboquant",
    "optimization",
    "tokens",
    "compression",
    "memory",
    "performance",
    "google",
    "ai",
    "efficiency"
  ],
  "author": "MincoSoft Technologies <cynthia@mincosoft.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mincosoft/openclaw-skill-turboquant-optimizer.git"
  },
  "bugs": {
    "url": "https://github.com/mincosoft/openclaw-skill-turboquant-optimizer/issues"
  },
  "homepage": "https://github.com/mincosoft/openclaw-skill-turboquant-optimizer#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "eslint": "^8.57.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "!lib/index.js"
    ]
  },
  "openclaw": {
    "skillName": "turboquant-optimizer",
    "minVersion": "1.0.0",
    "categories": ["optimization", "performance", "tokens"],
    "hooks": [
      "pre-api-call",
      "post-session-load"
    ]
  }
}
