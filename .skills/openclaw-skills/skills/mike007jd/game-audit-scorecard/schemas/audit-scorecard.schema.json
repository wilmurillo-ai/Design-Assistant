{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Game Superpowers Audit Scorecard",
  "type": "object",
  "required": [
    "project_state",
    "audit_mode",
    "dimensions"
  ],
  "properties": {
    "project_state": {"type": "string"},
    "audit_mode": {
      "type": "string",
      "enum": ["audit-only", "audit-and-plan", "audit-and-patch"]
    },
    "dimensions": {
      "type": "object",
      "required": [
        "ux_flow",
        "hud_readability",
        "feedback_design",
        "audio_feedback",
        "game_feel",
        "mechanics_clarity",
        "scope_completeness",
        "production_readiness",
        "architecture_health",
        "live_risk"
      ],
      "properties": {
        "ux_flow": {"type": "number", "minimum": 0, "maximum": 10},
        "hud_readability": {"type": "number", "minimum": 0, "maximum": 10},
        "feedback_design": {"type": "number", "minimum": 0, "maximum": 10},
        "audio_feedback": {"type": "number", "minimum": 0, "maximum": 10},
        "game_feel": {"type": "number", "minimum": 0, "maximum": 10},
        "mechanics_clarity": {"type": "number", "minimum": 0, "maximum": 10},
        "scope_completeness": {"type": "number", "minimum": 0, "maximum": 10},
        "production_readiness": {"type": "number", "minimum": 0, "maximum": 10},
        "architecture_health": {"type": "number", "minimum": 0, "maximum": 10},
        "live_risk": {"type": "number", "minimum": 0, "maximum": 10}
      }
    },
    "top_issues": {"type": "array", "items": {"type": "string"}},
    "quick_wins": {"type": "array", "items": {"type": "string"}},
    "high_risk_areas": {"type": "array", "items": {"type": "string"}},
    "confidence_notes": {"type": "array", "items": {"type": "string"}},
    "evidence_summary": {
      "type": "object",
      "properties": {
        "confirmed_findings": {"type": "integer", "minimum": 0},
        "inferred_findings": {"type": "integer", "minimum": 0},
        "missing_runtime_evidence": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
