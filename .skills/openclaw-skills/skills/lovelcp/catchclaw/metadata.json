{
  "name": "agentar-cli",
  "version": "3.3.6",
  "description": "Standalone CLI for searching, listing, installing, and exporting agentars.",
  "api_base_url": "https://catchclaw.me",
  "required_binaries": [
    "node"
  ],
  "config_paths": [
    {
      "path": "~/.agentar",
      "access": "read_write"
    },
    {
      "path": "~/.openclaw/workspace",
      "access": "read_write"
    },
    {
      "path": "~/.openclaw/agentar-workspaces",
      "access": "read_write"
    }
  ],
  "credentials": {
    "optional": true,
    "description": "API key for agentars that require backend authentication",
    "path": "skills/.credentials",
    "written_by": "install command when user passes --api-key"
  }
}
