{
  "common_patterns": [
    "{company}{year}",
    "{company}@{year}",
    "{name}{birthday}",
    "{location}{year}"
  ],
  "mutations": {
    "capitalize": true,
    "add_numbers": ["", "1", "123", "1234", "2024"],
    "add_symbols": ["", "!", "@", "#"],
    "leet_speak": {
      "a": ["a", "@", "4"],
      "e": ["e", "3"],
      "i": ["i", "1"],
      "o": ["o", "0"],
      "s": ["s", "$", "5"]
    }
  }
}
