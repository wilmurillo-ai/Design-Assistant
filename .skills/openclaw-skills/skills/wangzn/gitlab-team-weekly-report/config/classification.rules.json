    },
    {
      "match": [
        "protos/kimi"
      ],
      "category": "KimiClaw 主营业务",
      "subcategory": "运营后台与管理工具",
      "notes": "协议仓默认偏管理/接口能力，标题规则可覆盖"
    },
    {
      "match": [
        "plugin",
        "mcp",
        "skill",
        "channel",
        "wecom",
        "feishu",
        "whatsapp"
      ],
      "category": "Agent 与渠道生态",
      "subcategory": "插件、工具与 Skill 框架"
    }
