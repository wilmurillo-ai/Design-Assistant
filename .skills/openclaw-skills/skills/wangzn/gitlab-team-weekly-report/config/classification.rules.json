{
  "priority": [
    "repo",
    "label",
    "title",
    "branch",
    "classification",
    "default"
  ],
  "default_category": {
    "category": "KimiClaw 主营业务",
    "subcategory": "资源供应商与实例编排"
  },
  "repo_rules": [
    {
      "match": [
        "zhanghuishi/cdn",
        "cdn"
      ],
      "category": "KimiClaw 主营业务",
      "subcategory": "CDN 与边缘网络",
      "notes": "CDN 项目单独归类"
    },
    {
      "match": [
        "engineering/secrets/kimi-secret-prod",
        "engineering/devops/kimi-secret"
      ],
      "category": "KimiClaw 主营业务",
      "subcategory": "资源供应商与实例编排"
    },
    {
      "match": [
        "user-center",
        "account",
        "passport",
        "auth"
      ],
      "category": "用户体系与商业化",
      "subcategory": "账号、身份与登录"
    },
    {
      "match": [
        "billing",
        "subscription",
        "payment"
      ],
      "category": "用户体系与商业化",
      "subcategory": "订阅、计费与配额"
