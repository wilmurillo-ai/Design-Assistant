{
  "test_cases": [
    {
      "name": "Phishing Detection - Obvious Typosquat",
      "toolName": "phishing_detect",
      "input": {
        "url": "https://paypa1-secure.com/login"
      },
      "expected_verdict": "PHISHING",
      "description": "PayPal typosquat with '1' instead of 'l', free SSL, no MX records"
    },
    {
      "name": "Phishing Detection - Homoglyph",
      "toolName": "phishing_detect",
      "input": {
        "domain": "st ripe.com"
      },
      "expected_verdict": "PHISHING",
      "description": "Stripe with homoglyph substitution (rn = m)"
    },
    {
      "name": "Phishing Detection - Suspicious Domain",
      "toolName": "phishing_detect",
      "input": {
        "domain": "stripe-verify.com"
      },
      "expected_verdict": "SUSPICIOUS",
      "description": "Stripe lookalike with keyword addition"
    },
    {
      "name": "Domain Trust - Legitimate Enterprise",
      "toolName": "domain_trust",
      "input": {
        "domain": "stripe.com"
      },
      "expected_trust_level": "HIGHLY_TRUSTED",
      "description": "Major payment processor with EV cert, SPF, DKIM, DMARC"
    },
    {
      "name": "Domain Trust - Suspicious New Domain",
      "toolName": "domain_trust",
      "input": {
        "domain": "sketchy-corp.xyz"
      },
      "expected_trust_level": "UNTRUSTED",
      "description": "New domain on suspicious TLD with minimal setup"
    },
    {
      "name": "Brand Monitor - PayPal Lookalikes",
      "toolName": "brand_monitor",
      "input": {
        "brand_domain": "paypal.com",
        "limit": 10
      },
      "expected_lookalikes": 3,
      "description": "Find typosquats and lookalikes targeting PayPal"
    },
    {
      "name": "Brand Monitor - Stripe Lookalikes",
      "toolName": "brand_monitor",
      "input": {
        "brand_domain": "stripe.com",
        "limit": 20
      },
      "expected_lookalikes": 5,
      "description": "Find typosquats and lookalikes targeting Stripe"
    },
    {
      "name": "Phishing Detection - Legitimate Domain",
      "toolName": "phishing_detect",
      "input": {
        "url": "https://www.google.com"
      },
      "expected_verdict": "SAFE",
      "description": "Well-known legitimate domain"
    }
  ]
}
