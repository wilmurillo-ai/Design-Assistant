{
  "id": "openclaw-tavern-plugin",
  "name": "OpenClaw SillyTavern Plugin",
  "description": "SillyTavern-compatible role-play command plugin for OpenClaw with long memory, multimodal output, and Generative-Agents-style companion.",
  "version": "0.1.0",
  "author": "garfeildma",
  "homepage": "https://github.com/garfeildma/openclaw-tavern",
  "license": "MIT",
  "tags": [
    "roleplay",
    "sillytavern",
    "companion",
    "tts",
    "image-generation",
    "long-memory"
  ],
  "clawhub": {
    "slug": "openclaw-tavern-plugin",
    "category": "roleplay"
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "agentImage": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "provider": {
            "type": "string",
            "enum": [
              "inherit",
              "openai",
              "gemini"
            ],
            "default": "inherit"
          },
          "imageModel": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}