{
  "name": "siyuan-skill",
  "version": "1.6.3",
  "description": "Siyuan Notes connector skill for AI Agents",
  "main": "siyuan.js",
  "bin": {
    "siyuan": "./siyuan.js"
  },
  "keywords": [
    "siyuan",
    "notes",
    "api",
    "connector",
    "skill",
    "ai",
    "agent"
  ],
  "author": "Siyuan Skills",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dazexcl/siyuan-skill.git"
  },
  "bugs": {
    "url": "https://github.com/dazexcl/siyuan-skill/issues"
  },
  "homepage": "https://github.com/dazexcl/siyuan-skill#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "config": {
    "requiredEnvVars": [
      "SIYUAN_BASE_URL",
      "SIYUAN_TOKEN",
      "SIYUAN_DEFAULT_NOTEBOOK"
    ],
    "optionalEnvVars": [
      "SIYUAN_PERMISSION_MODE",
      "SIYUAN_NOTEBOOK_LIST",
      "QDRANT_URL",
      "QDRANT_API_KEY",
      "OLLAMA_BASE_URL",
      "OLLAMA_EMBED_MODEL",
      "SIYUAN_TLS_ALLOW_SELF_SIGNED",
      "SIYUAN_TLS_ALLOWED_HOSTS"
    ]
  },
  "skill": {
    "skillType": "cli",
    "installType": "executable",
    "runtime": "node",
    "runtimeVersion": ">=14.0.0",
    "requiredEnvVars": [
      {
        "name": "SIYUAN_BASE_URL",
        "description": "思源笔记 API 地址（建议使用 localhost）",
        "required": true
      },
      {
        "name": "SIYUAN_TOKEN",
        "description": "API 认证令牌",
        "required": true
      },
      {
        "name": "SIYUAN_DEFAULT_NOTEBOOK",
        "description": "默认笔记本 ID",
        "required": true
      }
    ],
    "optionalEnvVars": [
      {
        "name": "SIYUAN_PERMISSION_MODE",
        "description": "权限模式",
        "default": "all"
      },
      {
        "name": "SIYUAN_NOTEBOOK_LIST",
        "description": "白名单/黑名单笔记本列表"
      },
      {
        "name": "QDRANT_URL",
        "description": "Qdrant 向量数据库地址（语义搜索需要）"
      },
      {
        "name": "OLLAMA_BASE_URL",
        "description": "Ollama 服务地址（语义搜索需要）"
      },
      {
        "name": "OLLAMA_EMBED_MODEL",
        "description": "Embedding 模型名称",
        "default": "nomic-embed-text"
      }
    ],
    "security": {
      "recommendedBaseUrl": "http://127.0.0.1:6806",
      "tlsValidation": "enabled",
      "sensitiveFields": ["token", "password", "apiKey"]
    }
  }
}
