{
  "id": "murf",
  "name": "Murf",
  "description": "High-quality text-to-speech via Murf (FALCON and GEN2 models)",
  "contracts": {
    "speechProviders": ["murf"]
  },
  "providerAuthEnvVars": {
    "murf": ["MURF_API_KEY"]
  },
  "uiHints": {
    "apiKey": {
      "label": "API key",
      "placeholder": "your Murf API key",
      "sensitive": true
    },
    "voiceId": {
      "label": "Voice ID",
      "placeholder": "en-US-natalie"
    },
    "model": {
      "label": "Model",
      "help": "FALCON (low latency) or GEN2 (studio quality)"
    },
    "region": {
      "label": "API region",
      "help": "Regional endpoint: global, us-east, us-west, eu-central, etc."
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "Murf API key (or set MURF_API_KEY env var)"
      },
      "voiceId": {
        "type": "string",
        "description": "Murf voice identifier (e.g. en-US-natalie)"
      },
      "model": {
        "type": "string",
        "enum": ["FALCON", "GEN2"],
        "description": "TTS model: FALCON (fast) or GEN2 (high fidelity)"
      },
      "locale": {
        "type": "string",
        "description": "BCP-47 locale code (e.g. en-US)"
      },
      "style": {
        "type": "string",
        "description": "Speaking style (e.g. Conversation, Newscast)"
      },
      "rate": {
        "type": "number",
        "minimum": -50,
        "maximum": 50,
        "description": "Speech rate adjustment (-50 to 50)"
      },
      "pitch": {
        "type": "number",
        "minimum": -50,
        "maximum": 50,
        "description": "Pitch adjustment (-50 to 50)"
      },
      "region": {
        "type": "string",
        "description": "Murf API regional endpoint (e.g. global, us-east, eu-central)"
      },
      "format": {
        "type": "string",
        "enum": ["MP3", "WAV", "OGG", "FLAC"],
        "description": "Audio output format"
      },
      "sampleRate": {
        "type": "number",
        "enum": [8000, 16000, 24000, 44100, 48000],
        "description": "Audio sample rate in Hz"
      }
    }
  }
}
