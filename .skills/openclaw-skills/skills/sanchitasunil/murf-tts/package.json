{
  "name": "openclaw-murf-tts",
  "version": "0.1.0",
  "description": "OpenClaw speech provider plugin for Murf Falcon TTS",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.mjs"
    ],
    "providers": [
      "murf"
    ],
    "compat": {
      "pluginApi": ">=2026.4.1",
      "minGatewayVersion": "2026.4.1"
    },
    "build": {
      "openclawVersion": "2026.4.1",
      "pluginSdkVersion": "2026.4.1"
    }
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsdown": "latest",
    "typescript": "^5",
    "vitest": "^2"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "tts",
    "speech",
    "murf",
    "falcon"
  ],
  "author": "Sanchita Sunil",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sanchitasunil/openclaw-murf-tts.git"
  },
  "dependencies": {
    "@buape/carbon": "^0.14.0"
  }
}
