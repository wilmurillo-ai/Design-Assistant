// Example OpenClaw config for the Murf TTS plugin.
// Copy the "messages" block into your openclaw config.json5.
// See README.md for full documentation.
{
  "messages": {
    "tts": {
      // Set to "always" to auto-generate speech for every reply,
      // or "on-demand" to use /tts commands only.
      "auto": "always",

      // Select murf as the TTS provider.
      "provider": "murf",

      "providers": {
        "murf": {
          // Required: your Murf API key (or set MURF_API_KEY env var instead).
          "apiKey": "your_murf_api_key_here",

          // Voice ID -- run `openclaw tts voices` to list available voices.
          "voiceId": "en-US-natalie",

          // Model: "FALCON" (fast, ~130ms) or "GEN2" (studio quality).
          "model": "FALCON",

          // BCP-47 locale code.
          "locale": "en-US",

          // Speaking style (e.g. "Conversation", "Newscast").
          "style": "Conversation",

          // Speech rate adjustment (-50 to 50, 0 = normal).
          "rate": 0,

          // Pitch adjustment (-50 to 50, 0 = normal).
          "pitch": 0,

          // API region -- use the closest to you for lower latency.
          // Options: global, us-east, us-west, eu-central, uk, in, au, ca, jp, kr, me, sa-east
          "region": "global",

          // Audio output format: MP3, WAV, OGG, FLAC
          "format": "MP3",

          // Sample rate in Hz: 8000, 16000, 24000, 44100, 48000
          // Default: 24000 for FALCON, 44100 for GEN2
          "sampleRate": 24000
        }
      }
    }
  },

  // Enable the murf plugin.
  "plugins": {
    "enabled": true,
    "entries": {
      "murf": {
        "enabled": true
      }
    }
  }
}
